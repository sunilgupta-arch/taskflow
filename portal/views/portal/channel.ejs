  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 14px rgba(0,0,0,0.4); cursor: pointer; z-index: 10;
  transition: transform 0.15s; font-size: 1rem;
}
.gc-scroll-btn:hover { transform: translateY(-2px); background: #1d4ed8; }
.gc-scroll-btn-badge {
