<div class="gc-fullpage">
  <div class="gc-fullpage-header">
    <div class="d-flex align-items-center gap-2">
      <i class="bi bi-broadcast" style="font-size:1.1rem"></i>
      <span class="fw-bold" style="font-size:1rem">Group Channel</span>
    </div>
  </div>
  <div class="gc-presence-strip" id="gcPresenceStrip"></div>
  <div class="gc-pinned-bar" id="gcPinnedBar" style="display:none">
    <div class="gc-pinned-bar-header" onclick="toggleGcPinnedList()">
      <i class="bi bi-pin-angle-fill"></i>
      <span id="gcPinnedBarTitle">0 pinned</span>
      <i class="bi bi-chevron-down gc-pinned-bar-chev" id="gcPinnedBarChev"></i>
    </div>
    <div class="gc-pinned-bar-list" id="gcPinnedBarList" style="display:none"></div>
  </div>
  <div class="gc-fullpage-messages" id="gcFullMessages">
    <div class="text-center text-muted py-4 small">Loading...</div>
  </div>
  <button class="gc-scroll-btn" id="gcScrollBtn" onclick="gcScrollToBottom()" style="display:none" title="Jump to latest"><i class="bi bi-chevron-double-down"></i><span class="gc-scroll-btn-badge" id="gcScrollBtnBadge" style="display:none">0</span></button>
  <div class="gc-typing-bar" id="gcFullTypingBar" style="display:none"></div>
  <div class="gc-reply-compose-bar" id="gcReplyBar" style="display:none">
    <i class="bi bi-reply-fill" style="color:#2563eb"></i>
    <div class="gc-reply-compose-text">
      <span class="gc-reply-compose-sender" id="gcReplyBarSender"></span>
      <span class="gc-reply-compose-content" id="gcReplyBarContent"></span>
    </div>
    <i class="bi bi-x-lg gc-reply-compose-close" onclick="cancelGcFullReply()" title="Cancel reply"></i>
  </div>
  <div class="gc-fullpage-input" style="position:relative">
    <div class="gc-mention-popup" id="gcMentionPopup" style="display:none"></div>
    <input type="file" id="gcFullFileInput" style="display:none" onchange="sendGcFullFile()">
    <div class="d-flex gap-2 align-items-stretch">
      <textarea class="form-control" id="gcFullInput" placeholder="Type a message..." rows="2" oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
      <div class="gc-input-btns">
        <button class="btn btn-outline-secondary gc-input-btn" onclick="document.getElementById('gcFullFileInput').click()" title="Attach"><i class="bi bi-paperclip"></i></button>
        <button class="btn btn-primary gc-input-btn" onclick="sendGcFullMessage()" title="Send"><i class="bi bi-send"></i></button>
      </div>
    </div>
  </div>
</div>

<style>
.gc-fullpage {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  position: relative;
}

.gc-scroll-btn {
  position: absolute; right: 28px; bottom: 110px;
  width: 42px; height: 42px; border-radius: 50%;
