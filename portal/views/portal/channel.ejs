}
.gc-reaction-chip:hover { background: rgba(255,255,255,0.15); }
.gc-reaction-chip.mine { background: rgba(37,99,235,0.3); border-color: rgba(37,99,235,0.6); }
.gc-fullpage-messages .msg-bubble.sent .gc-reaction-chip { background: rgba(0,0,0,0.25); border-color: rgba(255,255,255,0.25); }
.gc-fullpage-messages .msg-bubble.sent .gc-reaction-chip.mine { background: rgba(255,255,255,0.35); border-color: rgba(255,255,255,0.6); }

.gc-fullpage-header {
