}

.gc-unread-divider { text-align: center; padding: 10px 0; position: relative; }
.gc-unread-divider::before, .gc-unread-divider::after {
  content: ''; position: absolute; top: 50%; width: 38%; height: 1px;
  background: rgba(239,68,68,0.4);
}
.gc-unread-divider::before { left: 4%; }
.gc-unread-divider::after { right: 4%; }
.gc-unread-divider span {
  font-size: 0.7rem; color: #ef4444; background: rgba(239,68,68,0.12);
  padding: 4px 14px; border-radius: 12px; border: 1px solid rgba(239,68,68,0.35);
