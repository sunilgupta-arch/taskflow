  font-size: 0.9rem; line-height: 1; z-index: 2;
}
.gc-fullpage-messages .msg-bubble:hover .gc-msg-edit,
.gc-fullpage-messages .gc-msg-edit:hover { opacity: 1; visibility: visible; }
.gc-fullpage-messages .gc-msg-edit:hover { background: rgba(34,197,94,0.9); }
.gc-edited-label { font-size: 0.65rem; opacity: 0.55; margin-left: 6px; font-style: italic; }
.gc-editor textarea {
