    var list = _gcMentionCandidates();
    if (!list.length) return false;
    if (e.key === 'ArrowDown') { e.preventDefault(); _gcMentionIdx = (_gcMentionIdx + 1) % list.length; _gcRenderMentionPopup(); return true; }
    if (e.key === 'ArrowUp') { e.preventDefault(); _gcMentionIdx = (_gcMentionIdx - 1 + list.length) % list.length; _gcRenderMentionPopup(); return true; }
    if (e.key === 'Enter' || e.key === 'Tab') { e.preventDefault(); _gcSelectMention(_gcMentionIdx); return true; }
    if (e.key === 'Escape') { e.preventDefault(); _gcHideMention(); return true; }
    return false;
  }

