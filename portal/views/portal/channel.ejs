  window.editGcFullMsg = function(msgId) {
    var bubble = document.querySelector('[data-gcf-msg-id="' + msgId + '"]');
    if (!bubble) return;
    var contentEl = bubble.querySelector('.msg-content');
    if (!contentEl) return;
    if (contentEl.querySelector('.gc-editor')) return;
    var originalHtml = contentEl.innerHTML;
    var originalRaw = _gcMsgRaw[msgId] || contentEl.textContent || '';
    contentEl.innerHTML = '<div class="gc-editor">' +
      '<textarea class="form-control form-control-sm" rows="2">' + _esc(originalRaw) + '</textarea>' +
      '<div class="gc-editor-actions">' +
        '<button class="btn btn-sm btn-outline-light" data-action="cancel">Cancel</button>' +
        '<button class="btn btn-sm btn-primary" data-action="save">Save</button>' +
      '</div></div>';
    var ta = contentEl.querySelector('textarea');
    var cancelBtn = contentEl.querySelector('[data-action="cancel"]');
    var saveBtn = contentEl.querySelector('[data-action="save"]');
    ta.focus(); ta.setSelectionRange(ta.value.length, ta.value.length);
    function cancel() { contentEl.innerHTML = originalHtml; }
    function save() {
      var v = ta.value.trim();
      if (!v) return;
      if (v === originalRaw) { cancel(); return; }
      fetch(_baseUrl + '/messages/' + msgId, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: v })
      }).then(function(r) {
        if (!r.ok) return r.json().then(function(j) { alert(j.message || 'Edit failed'); cancel(); });
      });
    }
    cancelBtn.addEventListener('click', cancel);
    saveBtn.addEventListener('click', save);
    ta.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { e.preventDefault(); cancel(); }
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); save(); }
    });
  };

  // ── Reactions ───────────────────────────────────
