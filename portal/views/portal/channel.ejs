.gc-pinned-item-content { color: var(--tf-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.gc-fullpage-messages .gc-msg-edit {
  position: absolute; top: 6px; right: 78px; cursor: pointer;
  opacity: 0; visibility: hidden; color: #fff;
