}
.gc-fullpage-messages .gc-reply-quote:hover { background: rgba(255,255,255,0.12); }
.gc-fullpage-messages .msg-bubble.sent .gc-reply-quote { background: rgba(0,0,0,0.2); border-left-color: rgba(255,255,255,0.6); }
.gc-fullpage-messages .gc-reply-quote-sender { font-weight: 600; color: var(--tf-accent, #60a5fa); }
.gc-fullpage-messages .msg-bubble.sent .gc-reply-quote-sender { color: rgba(255,255,255,0.9); }
.gc-fullpage-messages .gc-reply-quote-content { color: var(--tf-text-muted, #94a3b8); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.gc-fullpage-messages .msg-bubble.sent .gc-reply-quote-content { color: rgba(255,255,255,0.75); }
.gc-reply-compose-bar {
  padding: 6px 16px; background: rgba(37,99,235,0.1);
  border-top: 1px solid rgba(37,99,235,0.3); border-left: 3px solid #2563eb;
