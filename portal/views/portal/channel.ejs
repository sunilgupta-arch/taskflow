  window.sendGcFullFile = function() {
    var fileInput = document.getElementById('gcFullFileInput');
    if (!fileInput.files.length) return;
    var file = fileInput.files[0];
    if (file.size > 5 * 1024 * 1024) {
      alert('File too large. Max 5 MB.');
      fileInput.value = '';
      return;
    }
    var placeholderId = showUploadPlaceholder(file.name);
    var fd = new FormData(); fd.append('file', file);
    if (_gcReplyingTo) fd.append('reply_to_id', _gcReplyingTo.id);
    fileInput.value = '';
    fetch(_baseUrl + '/file', { method: 'POST', body: fd })
      .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, body: j }; }); })
      .then(function(res) {
        if (res.ok) {
          var el = document.getElementById(placeholderId);
          if (el) el.remove();
          cancelGcFullReply();
        } else {
          markUploadFailed(placeholderId, res.body.message);
        }
      })
      .catch(function() { markUploadFailed(placeholderId, 'Upload failed'); });
  };

  window.deleteGcFullMsg = function(msgId) {
