      <div class="help-nav-section">Features</div>
      <a class="help-nav-item" href="#" onclick="showHelpSection('chat')">Chat</a>
      <a class="help-nav-item" href="#" onclick="showHelpSection('tasks')">Tasks</a>
      <a class="help-nav-item" href="#" onclick="showHelpSection('notes')">Notes & Dictation</a>
