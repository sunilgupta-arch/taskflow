      document.getElementById('urgentFab').style.display = 'none';

      // Update status
      if (chat.status === 'waiting') {
        document.getElementById('urgentWidgetStatus').textContent = 'Waiting for response...';
        document.getElementById('urgentWidgetStatus').className = 'urgent-widget-status waiting';
      } else if (chat.status === 'accepted') {
        document.getElementById('urgentWidgetStatus').textContent = 'Connected with ' + chat.accepted_by_name;
        document.getElementById('urgentWidgetStatus').className = 'urgent-widget-status connected';
      }
      // Client can always send messages
      document.getElementById('urgentWidgetInput').style.display = '';

      loadUrgentMessages();
