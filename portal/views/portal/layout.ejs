  // ── @mentions ───────────────────────────────────
  var _gcUserName = PORTAL_USER.name;
  function _gcEscMention(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
  function gcRenderWithMentions(text) {
    var html = _gcEscMention(text || '');
    html = html.replace(/(https?:\/\/[^\s<]+)/g, function(m) {
      var clean = m.replace(/[.,;:!?)]+$/, '');
      var trailing = m.substring(clean.length);
      return '<a href="' + clean + '" target="_blank" rel="noopener" class="gc-link">' + clean + '</a>' + trailing;
    });
    return html.replace(/@\[([^\]]+)\]/g, function(_, name) {
      var cls = (name === _gcUserName) ? 'gc-mention gc-mention-self' : 'gc-mention';
      return '<span class="' + cls + '">@' + _gcEscMention(name) + '</span>';
