        .then(() => window.location.href = '/auth/login');
    }

    // DB stores timestamps in server timezone (Eastern = UTC-4)

    function parseServerDate(dateStr) {
      if (!dateStr) return new Date();
      // If already has timezone info or is ISO format, parse directly
      if (dateStr.includes('T') || dateStr.includes('Z') || dateStr.includes('+')) return new Date(dateStr);
      // Append UTC offset for Eastern time (server stores in EDT/EST)
      // Create the date in the server's timezone context
      const d = new Date(dateStr.replace(' ', 'T') + '-04:00');
      return isNaN(d.getTime()) ? new Date(dateStr) : d;
    }

    function timeAgo(dateStr) {
      const now = new Date();
      const d = parseServerDate(dateStr);
      const diff = Math.floor((now - d) / 1000);
      if (diff < 0) return 'just now';
      if (diff < 60) return 'just now';
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      if (diff < 172800) return 'yesterday';
      return d.toLocaleDateString();
    }
  </script>

  <% if (user.role_name !== 'CLIENT_SALES' && section !== 'channel') { %>
  <script>
  // ── Group Channel ──────────────────────────────────────────
  var _gcUserId = PORTAL_USER.id;
  var _gcCollapsed = localStorage.getItem('gc-collapsed') === '1';
  var _gcUnread = 0;
  var _gcBaseUrl = '/portal/channel';

  // ── Chat audio — persistent context ────────────────────
  var _gcAudioCtx      = null;
  var _gcAudioUnlocked = false;
  var _gcAudioPending  = false;
  var _gcTitleInterval = null;
  var _gcOrigTitle     = document.title;

  function _gcUnlockAudio() {
    if (_gcAudioUnlocked) return;
    try {
      if (!_gcAudioCtx) _gcAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
      var p = _gcAudioCtx.resume();
      if (p && p.then) p.then(function() {
        var buf = _gcAudioCtx.createBuffer(1, 1, 22050);
        var src = _gcAudioCtx.createBufferSource();
        src.buffer = buf; src.connect(_gcAudioCtx.destination); src.start(0);
        _gcAudioUnlocked = true;
        if (_gcAudioPending) { _gcAudioPending = false; playGcAlert(); }
      }).catch(function(){});
    } catch(e) {}
  }
  document.addEventListener('click',   _gcUnlockAudio, { once: false });
  document.addEventListener('keydown', _gcUnlockAudio, { once: false });

  function _gcStartTitleBlink() {
    if (_gcTitleInterval) return;
    _gcOrigTitle = document.title;
    var show = true;
    _gcTitleInterval = setInterval(function() {
      document.title = show ? '(!) New Message' : _gcOrigTitle;
      show = !show;
    }, 1000);
  }
  function _gcStopTitleBlink() {
    if (_gcTitleInterval) { clearInterval(_gcTitleInterval); _gcTitleInterval = null; }
    document.title = _gcOrigTitle;
  }
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden && !_gcCollapsed) _gcStopTitleBlink();
  });
  // ───────────────────────────────────────────────────────

  // ── Unread tracking + scroll-to-bottom ──────────
  var _gcLastReadKey = 'gc-last-read-' + _gcUserId;
  function _gcGetLastRead() { return parseInt(localStorage.getItem(_gcLastReadKey) || '0', 10); }
  function _gcSetLastRead(id) {
    var cur = _gcGetLastRead();
    if (id > cur) localStorage.setItem(_gcLastReadKey, String(id));
  }
  function _gcIsAtBottom(c, threshold) {
    threshold = threshold || 60;
    return c.scrollHeight - (c.scrollTop + c.clientHeight) < threshold;
  }
  window.gcScrollToBottom = function() {
    var c = document.getElementById('gcMessages');
