    var m = (text || '').match(/(https?:\/\/[^\s<]+)/);
    if (!m) return null;
    return m[0].replace(/[.,;:!?)]+$/, '');
  }
  function _gcRenderLinkPreviewHtml(preview) {
    if (!preview) return '';
    var img = preview.image ? '<div class="gc-link-preview-image"><img src="' + escapeHtml(preview.image) + '" alt="" onerror="this.parentNode.style.display=\'none\'" /></div>' : '';
    var site = preview.site_name ? '<div class="gc-link-preview-site">' + escapeHtml(preview.site_name) + '</div>' : '';
    var title = preview.title ? '<div class="gc-link-preview-title">' + escapeHtml(preview.title) + '</div>' : '';
    var desc = preview.description ? '<div class="gc-link-preview-desc">' + escapeHtml(preview.description) + '</div>' : '';
    return '<a class="gc-link-preview" href="' + escapeHtml(preview.url) + '" target="_blank" rel="noopener">' + img + '<div class="gc-link-preview-body">' + site + title + desc + '</div></a>';
  }
  function _gcInsertPreview(bubble, preview) {
    if (!bubble || bubble.querySelector('.gc-link-preview')) return;
    var content = bubble.querySelector('.msg-content');
    if (!content) return;
    content.insertAdjacentHTML('afterend', _gcRenderLinkPreviewHtml(preview));
  }
  function _gcFetchAndRenderPreview(bubble, rawText) {
    if (!bubble || !rawText) return;
    var url = _gcExtractFirstUrl(rawText);
    if (!url) return;
    if (bubble.querySelector('.gc-link-preview')) return;
    if (_gcLinkPreviewCache[url] === null) return;
    if (_gcLinkPreviewCache[url]) { _gcInsertPreview(bubble, _gcLinkPreviewCache[url]); return; }
    fetch(_gcBaseUrl + '/unfurl?url=' + encodeURIComponent(url))
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (!res.success) return;
        var preview = res.data.preview;
        _gcLinkPreviewCache[url] = preview || null;
        if (preview) _gcInsertPreview(bubble, preview);
      })
      .catch(function() {});
  }

  // ── Search ──────────────────────────────────────
  var _gcSearchTimer = null;
