  }
  window._gcShowMsgMenu = function(evt, msgId) {
    var existing = document.getElementById('gcMsgMenu');
    if (existing) { existing.remove(); var ob = document.querySelector('.gc-msg-menu-btn.gc-menu-open'); if (ob) ob.classList.remove('gc-menu-open'); return; }
    var bubble = document.querySelector('[data-gc-msg-id="' + msgId + '"]');
    if (!bubble) return;
    var isSent = bubble.classList.contains('sent');
    var isDeleted = bubble.classList.contains('deleted');
    var isPinned = bubble.classList.contains('pinned');
    var meta = _gcMsgMeta[msgId] || {};
    var canEdit = isSent && !isDeleted && meta.type === 'text' &&
      (Date.now() - new Date(meta.created_at).getTime()) < GC_EDIT_WINDOW_MS;
    var items = [];
    if (!isDeleted) {
      items.push({ icon: 'bi-reply-fill', label: 'Reply', fn: function() { replyToGcMsg(msgId); } });
      items.push({ icon: 'bi-emoji-smile', label: 'React', fn: function(r) { showGcEmojiPicker({ currentTarget: { getBoundingClientRect: function() { return r; } } }, msgId); } });
      if (_gcIsAdmin) items.push({ icon: 'bi-pin-angle-fill', label: isPinned ? 'Unpin' : 'Pin', fn: function() { togglePinGcMsg(msgId); } });
      if (canEdit) items.push({ icon: 'bi-pencil', label: 'Edit', fn: function() { editGcMsg(msgId); } });
      if (isSent) items.push({ icon: 'bi-trash', label: 'Delete', danger: true, fn: function() { deleteGcMsg(msgId); } });
    }
    if (!items.length) return;
    var triggerBtn = evt.currentTarget;
    triggerBtn.classList.add('gc-menu-open');
    var menu = document.createElement('div');
    menu.id = 'gcMsgMenu';
    menu.className = 'gc-msg-menu';
    items.forEach(function(item) {
      var el = document.createElement('button');
      el.className = 'gc-msg-menu-item' + (item.danger ? ' gc-menu-danger' : '');
      el.innerHTML = '<i class="bi ' + item.icon + '"></i>' + item.label;
      el.addEventListener('click', function(e) {
        e.stopPropagation();
