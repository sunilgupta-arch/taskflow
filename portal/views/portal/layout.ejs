    while ((m = re.exec(text)) !== null) { if (m[1] === _gcUserName) return true; }
    return false;
  }
  var _gcMentionActive = false, _gcMentionQuery = '', _gcMentionStart = -1, _gcMentionIdx = 0;
  function _gcHideMention() {
    _gcMentionActive = false; _gcMentionStart = -1; _gcMentionQuery = '';
    var p = document.getElementById('gcMentionPopup'); if (p) p.style.display = 'none';
  }
  function _gcMentionCandidates() {
    var q = _gcMentionQuery.toLowerCase();
    return (typeof _gcAllUsers !== 'undefined' ? _gcAllUsers : []).filter(function(u) {
      return u.id !== _gcUserId && u.name.toLowerCase().indexOf(q) !== -1;
    }).slice(0, 8);
  }
  function _gcRenderMentionPopup() {
    var p = document.getElementById('gcMentionPopup');
    if (!p) return;
