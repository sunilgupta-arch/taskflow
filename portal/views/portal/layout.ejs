      try { Notification.requestPermission(); } catch (e) {}
    }
    _gcNotifAsked = true;
  }
  function _gcShowNotif(msg) {
    if (!('Notification' in window)) return;
    if (Notification.permission !== 'granted') return;
    if (msg.sender_id === _gcUserId) return;
    var mentionsMe = _gcMentionsMe(msg.content);
    if (!document.hidden && !_gcCollapsed && !mentionsMe) return;
    var body = '';
    if (msg.type === 'file' && msg.attachment) body = '📎 ' + (msg.attachment.file_name || 'Sent a file');
    else body = (msg.content || '').replace(/@\[([^\]]+)\]/g, '@$1');
    var title = mentionsMe ? ('@ ' + msg.sender_name + ' mentioned you') : ('Group Channel — ' + msg.sender_name);
    try {
      var n = new Notification(title, { body: body, tag: 'gc-channel', renotify: true, requireInteraction: mentionsMe });
      n.onclick = function() { window.focus(); n.close(); };
      setTimeout(function() { try { n.close(); } catch (e) {} }, mentionsMe ? 15000 : 8000);
    } catch (e) {}
  }
  document.addEventListener('click', function _gcAsk(e) {
    var t = e.target;
    if (t.closest && (t.closest('#gcPanel') || t.closest('#gcHandle'))) {
      _gcRequestNotifPerm();
      document.removeEventListener('click', _gcAsk);
    }
  });

  // Apply initial collapsed state on load
  (function() {
    if (_gcCollapsed) {
      var panel = document.getElementById('gcPanel');
      var handle = document.getElementById('gcHandle');
      var main = document.querySelector('.portal-main');
      if (panel) panel.style.display = 'none';
      if (handle) handle.style.display = '';
      if (main) main.classList.add('gc-collapsed');
    }
  })();

  function toggleGroupChannel() {
    _gcCollapsed = !_gcCollapsed;
    localStorage.setItem('gc-collapsed', _gcCollapsed ? '1' : '0');
    document.getElementById('gcPanel').style.display = _gcCollapsed ? 'none' : '';
    document.getElementById('gcHandle').style.display = _gcCollapsed ? '' : 'none';
    document.querySelector('.portal-main').classList.toggle('gc-collapsed', _gcCollapsed);
    if (!_gcCollapsed) {
      _gcUnread = 0;
      _gcStopTitleBlink();
      var badge = document.getElementById('gcHandleBadge');
      badge.style.display = 'none';
      loadGcMessages();
    }
  }

  var _gcLoadingMore = false;
  var _gcHasMore = true;
  function loadGcMessages(beforeId) {
    var url = _gcBaseUrl + '/messages' + (beforeId ? '?before=' + beforeId : '');
    fetch(url).then(function(r) { return r.json(); }).then(function(res) {
      if (!res.success) return;
      if (!beforeId) { _gcHasMore = true; }
      renderGcMessages(res.data.messages, !!beforeId);
    });
  }
  function _gcLoadMore() {
    if (_gcLoadingMore || !_gcHasMore) return;
    var container = document.getElementById('gcMessages');
    if (!container) return;
    var first = container.querySelector('[data-gc-msg-id]');
    if (!first) return;
    var oldestId = parseInt(first.getAttribute('data-gc-msg-id'), 10);
    if (!oldestId) return;
    _gcLoadingMore = true;
    var prevHeight = container.scrollHeight;
    var loader = document.createElement('div');
    loader.className = 'text-center text-muted py-2 small gc-loading-more';
    loader.innerHTML = '<span class="gc-upload-spinner"></span> Loading...';
    container.insertAdjacentElement('afterbegin', loader);
    fetch(_gcBaseUrl + '/messages?before=' + oldestId)
      .then(function(r) { return r.json(); })
      .then(function(res) {
        loader.remove();
        if (!res.success) { _gcLoadingMore = false; return; }
        var msgs = res.data.messages || [];
        if (!msgs.length) { _gcHasMore = false; _gcLoadingMore = false; return; }
        renderGcMessages(msgs, true);
        container.scrollTop = container.scrollHeight - prevHeight;
        _gcLoadingMore = false;
      })
      .catch(function() { loader.remove(); _gcLoadingMore = false; });
  }

  var GC_IMAGE_EXTS = ['jpg','jpeg','png','gif','webp','bmp','svg'];
  function gcFileIcon(ext) {
    var map = {
      pdf: { icon: 'bi-file-earmark-pdf-fill', color: '#ef4444' },
      doc: { icon: 'bi-file-earmark-word-fill', color: '#2b7bf0' },
      docx: { icon: 'bi-file-earmark-word-fill', color: '#2b7bf0' },
      xls: { icon: 'bi-file-earmark-excel-fill', color: '#16a34a' },
      xlsx: { icon: 'bi-file-earmark-excel-fill', color: '#16a34a' },
      csv: { icon: 'bi-file-earmark-spreadsheet-fill', color: '#16a34a' },
      ppt: { icon: 'bi-file-earmark-ppt-fill', color: '#f97316' },
      pptx: { icon: 'bi-file-earmark-ppt-fill', color: '#f97316' },
      zip: { icon: 'bi-file-earmark-zip-fill', color: '#eab308' },
      rar: { icon: 'bi-file-earmark-zip-fill', color: '#eab308' },
      '7z': { icon: 'bi-file-earmark-zip-fill', color: '#eab308' },
      txt: { icon: 'bi-file-earmark-text-fill', color: '#9ca3af' },
      mp3: { icon: 'bi-file-earmark-music-fill', color: '#a855f7' },
      wav: { icon: 'bi-file-earmark-music-fill', color: '#a855f7' },
      mp4: { icon: 'bi-file-earmark-play-fill', color: '#ec4899' },
      mov: { icon: 'bi-file-earmark-play-fill', color: '#ec4899' },
      webm: { icon: 'bi-file-earmark-play-fill', color: '#ec4899' },
      js: { icon: 'bi-file-earmark-code-fill', color: '#f0db4f' },
      json: { icon: 'bi-file-earmark-code-fill', color: '#f0db4f' },
      html: { icon: 'bi-file-earmark-code-fill', color: '#e34c26' },
      css: { icon: 'bi-file-earmark-code-fill', color: '#2965f1' }
    };
    return map[ext] || { icon: 'bi-file-earmark-fill', color: '#94a3b8' };
  }
  function gcRenderFile(attachment, msgId) {
    var fname = attachment.file_name;
    var ext = fname.split('.').pop().toLowerCase();
    var url = _gcBaseUrl + '/attachment/' + msgId;
    if (GC_IMAGE_EXTS.indexOf(ext) !== -1) {
      return '<a href="' + url + '" target="_blank" class="msg-image-link"><img src="' + url + '" class="msg-image-preview" alt="' + fname + '" loading="lazy" style="max-width:180px;border-radius:6px;"></a>';
    }
    var short = fname.length > 20 ? fname.substring(0, 17) + '...' : fname;
    var size = attachment.file_size ? (attachment.file_size < 1048576 ? (attachment.file_size/1024).toFixed(1)+' KB' : (attachment.file_size/1048576).toFixed(1)+' MB') : '';
    var meta = gcFileIcon(ext);
    return '<a class="msg-file" href="' + url + '" target="_blank"><i class="bi ' + meta.icon + '" style="color:' + meta.color + ';font-size:1.4rem;"></i><div><span class="msg-file-name">' + short + '</span>' + (size ? '<span class="msg-file-size">' + size + '</span>' : '') + '</div></a>';
  }

  function gcDateLabel(dateStr) {
    var d = new Date(dateStr);
    var today = new Date();
    var yesterday = new Date(today);
    yesterday.setDate(yesterday.getDate() - 1);
    if (d.toDateString() === today.toDateString()) return 'Today';
    if (d.toDateString() === yesterday.toDateString()) return 'Yesterday';
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function renderGcMessages(messages, prepend) {
    var container = document.getElementById('gcMessages');
    if (!messages.length && !prepend) {
      container.innerHTML = '<div class="text-center text-muted py-3 small">No messages yet. Start the conversation!</div>';
      return;
    }
    var lastDate = '';
    var lastReadId = _gcGetLastRead();
    var unreadInserted = false;
    var html = messages.map(function(m) {
      var msgDate = gcDateLabel(m.created_at);
      var dateDivider = '';
      if (msgDate !== lastDate) {
        dateDivider = '<div class="msg-date-divider"><span>' + msgDate + '</span></div>';
        lastDate = msgDate;
      }
      var isSent = m.sender_id === _gcUserId;
      var unreadDivider = '';
      if (!unreadInserted && !isSent && m.id > lastReadId && lastReadId > 0) {
        unreadDivider = _gcUnreadDividerHtml();
        unreadInserted = true;
      }
      var cls = isSent ? 'sent' : 'received';
      var time = new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      var content = '';
      if (m.is_deleted) {
        content = '<em class="text-muted" style="font-size:0.75rem"><i class="bi bi-ban me-1"></i>deleted</em>';
      } else if (m.type === 'file' && m.attachment) {
        content = gcRenderFile(m.attachment, m.id);
      } else {
        content = gcRenderWithMentions(m.content);
      }
      _gcMsgRaw[m.id] = m.content;
      _gcMsgMeta[m.id] = { type: m.type, created_at: m.created_at, sender_id: m.sender_id };
      var menuBtn = _gcMenuBtnHtml(m);
      var pinInd = _gcPinIndicatorHtml(m);
      var replyQuote = _gcReplyQuoteHtml(m);
      var reactions = _gcRenderReactions(m);
      var senderName = !isSent ? '<div class="gc-msg-sender">' + escapeHtml(m.sender_name) + '</div>' : '';
      var editedLabel = m.edited_at ? '<span class="gc-edited-label">(edited)</span>' : '';
      return dateDivider + unreadDivider + '<div class="msg-bubble ' + cls + (m.is_deleted ? ' deleted' : '') + (m.is_pinned ? ' pinned' : '') + '" data-gc-msg-id="' + m.id + '">' + pinInd + menuBtn + senderName + replyQuote + '<div class="msg-content">' + content + '</div>' + reactions + '<div class="msg-footer"><span class="msg-time">' + time + '</span>' + editedLabel + '</div></div>';
    }).join('');
    if (prepend) {
      container.insertAdjacentHTML('afterbegin', html);
    } else {
      container.innerHTML = html;
      var div = container.querySelector('[data-gc-unread-divider]');
      if (div) { div.scrollIntoView({ block: 'center' }); }
      else { container.scrollTop = container.scrollHeight; }
      _gcUpdateScrollBtn();
    }
    messages.forEach(function(m) {
      if (m.type === 'text' && m.content && !m.is_deleted) {
        var b = container.querySelector('[data-gc-msg-id="' + m.id + '"]');
        if (b) _gcFetchAndRenderPreview(b, m.content);
      }
    });
  }

  function sendGcMessage() {
    var input = document.getElementById('gcInput');
    var content = input.value.trim();
    if (!content) return;
    var payload = { content: content };
    if (_gcReplyingTo) payload.reply_to_id = _gcReplyingTo.id;
    fetch(_gcBaseUrl + '/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    }).then(function() { input.value = ''; input.style.height = 'auto'; cancelGcReply(); });
  }

  function showGcUploadPlaceholder(filename, containerId) {
    var container = document.getElementById(containerId || 'gcMessages');
    if (!container) return null;
    if (container.querySelector('.text-center')) container.innerHTML = '';
    var id = 'gc-upload-' + Date.now();
    var html = '<div class="msg-bubble sent gc-uploading" id="' + id + '">' +
      '<div class="msg-content"><span class="gc-upload-spinner"></span><i class="bi bi-paperclip me-1"></i><span class="gc-upload-name">' + escapeHtml(filename) + '</span></div>' +
      '<div class="msg-footer"><span class="msg-time">Uploading…</span></div>' +
      '</div>';
    container.insertAdjacentHTML('beforeend', html);
    container.scrollTop = container.scrollHeight;
    return id;
  }
  function markGcUploadFailed(id, reason) {
    var el = document.getElementById(id);
    if (!el) return;
    el.classList.add('gc-upload-failed');
    var footer = el.querySelector('.msg-time');
    if (footer) footer.innerHTML = '<i class="bi bi-exclamation-circle me-1"></i>' + escapeHtml(reason || 'Upload failed');
    var spinner = el.querySelector('.gc-upload-spinner');
    if (spinner) spinner.remove();
  }

  function sendGcFile() {
    var fileInput = document.getElementById('gcFileInput');
    if (!fileInput.files.length) return;
    var file = fileInput.files[0];
    if (file.size > 5 * 1024 * 1024) {
      alert('File too large. Max 5 MB.');
      fileInput.value = '';
      return;
    }
    var placeholderId = showGcUploadPlaceholder(file.name, 'gcMessages');
    var fd = new FormData();
    fd.append('file', file);
    if (_gcReplyingTo) fd.append('reply_to_id', _gcReplyingTo.id);
    fileInput.value = '';
    fetch(_gcBaseUrl + '/file', { method: 'POST', body: fd })
      .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, body: j }; }); })
      .then(function(res) {
        if (res.ok) {
          var el = document.getElementById(placeholderId);
          if (el) el.remove();
          cancelGcReply();
        } else {
          markGcUploadFailed(placeholderId, res.body.message);
        }
      })
      .catch(function() { markGcUploadFailed(placeholderId, 'Upload failed'); });
  }

  function deleteGcMsg(msgId) {
    if (!confirm('Delete this message?')) return;
    fetch(_gcBaseUrl + '/messages/' + msgId, { method: 'DELETE' });
  }

  // Enter to send (mention-navigation takes precedence)
  document.getElementById('gcInput')?.addEventListener('keydown', function(e) {
    if (_gcMentionKeyHandler(e)) return;
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendGcMessage(); }
  });
  document.getElementById('gcInput')?.addEventListener('input', _gcMentionInputHandler);
  document.getElementById('gcInput')?.addEventListener('blur', function() { setTimeout(_gcHideMention, 150); });

  // Paste screenshot/image directly into chat
  function uploadGcFileDirect(file) {
    if (file.size > 5 * 1024 * 1024) { alert('File too large. Max 5 MB.'); return; }
    var placeholderId = showGcUploadPlaceholder(file.name || 'pasted-image.png', 'gcMessages');
    var fd = new FormData();
    fd.append('file', file, file.name || ('pasted-' + Date.now() + '.png'));
    if (_gcReplyingTo) fd.append('reply_to_id', _gcReplyingTo.id);
    fetch(_gcBaseUrl + '/file', { method: 'POST', body: fd })
      .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, body: j }; }); })
      .then(function(res) {
        if (res.ok) {
          var el = document.getElementById(placeholderId);
          if (el) el.remove();
          cancelGcReply();
        } else {
          markGcUploadFailed(placeholderId, res.body.message);
        }
      })
      .catch(function() { markGcUploadFailed(placeholderId, 'Upload failed'); });
  }

  document.getElementById('gcInput')?.addEventListener('paste', function(e) {
    var items = (e.clipboardData || window.clipboardData)?.items;
    if (!items) return;
    for (var i = 0; i < items.length; i++) {
      if (items[i].kind === 'file') {
        var file = items[i].getAsFile();
        if (file) {
          e.preventDefault();
          uploadGcFileDirect(file);
          return;
        }
      }
    }
  });

  // Socket: real-time messages
  function playGcAlert() {
    if (!_gcAudioCtx || _gcAudioCtx.state !== 'running') { _gcAudioPending = true; return; }
    try {
      var now = _gcAudioCtx.currentTime;
      [784, 1046].forEach(function(freq, i) {
        var o = _gcAudioCtx.createOscillator(), g = _gcAudioCtx.createGain();
        o.type = 'sine'; o.frequency.value = freq;
        o.connect(g); g.connect(_gcAudioCtx.destination);
        var t = now + i * 0.08;
        g.gain.setValueAtTime(0, t);
        g.gain.linearRampToValueAtTime(0.12, t + 0.02);
        g.gain.exponentialRampToValueAtTime(0.001, t + 0.22);
        o.start(t); o.stop(t + 0.25);
      });
    } catch(e) {}
  }

  mainSocket.on('channel:message', function(msg) {
    var isFromOther = msg.sender_id !== _gcUserId;
    if (isFromOther) {
      playGcAlert();
      if (document.hidden || _gcCollapsed) _gcStartTitleBlink();
    }
    _gcShowNotif(msg);
    if (_gcCollapsed) {
      if (isFromOther) {
        _gcUnread++;
        var badge = document.getElementById('gcHandleBadge');
        badge.textContent = _gcUnread;
        badge.style.display = '';
      }
    } else {
      var container = document.getElementById('gcMessages');
      if (container.querySelector('.text-center')) container.innerHTML = '';
      var wasAtBottom = _gcIsAtBottom(container);
      var isSent = msg.sender_id === _gcUserId;
      var cls = isSent ? 'sent' : 'received';
      var time = new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      var content = '';
      if (msg.type === 'file' && msg.attachment) {
        content = gcRenderFile(msg.attachment, msg.id);
      } else {
        content = gcRenderWithMentions(msg.content);
      }
      _gcMsgRaw[msg.id] = msg.content;
      _gcMsgMeta[msg.id] = { type: msg.type, created_at: msg.created_at, sender_id: msg.sender_id };
      var menuBtn = _gcMenuBtnHtml(msg);
      var replyQuote = _gcReplyQuoteHtml(msg);
      var senderName = !isSent ? '<div class="gc-msg-sender">' + escapeHtml(msg.sender_name) + '</div>' : '';
      if (isFromOther && !wasAtBottom && !container.querySelector('[data-gc-unread-divider]')) {
        container.insertAdjacentHTML('beforeend', _gcUnreadDividerHtml());
      }
      container.insertAdjacentHTML('beforeend', '<div class="msg-bubble ' + cls + '" data-gc-msg-id="' + msg.id + '">' + menuBtn + senderName + replyQuote + '<div class="msg-content">' + content + '</div><div class="msg-footer"><span class="msg-time">' + time + '</span></div></div>');
      if (msg.type === 'text' && msg.content) {
        var newBubble = container.querySelector('[data-gc-msg-id="' + msg.id + '"]');
        if (newBubble) _gcFetchAndRenderPreview(newBubble, msg.content);
      }
      if (isFromOther && _gcMentionsMe(msg.content)) {
        var bubble = container.querySelector('[data-gc-msg-id="' + msg.id + '"]');
        if (bubble) bubble.classList.add('gc-msg-mention-me');
      }
      if (wasAtBottom && !document.hidden) {
        container.scrollTop = container.scrollHeight;
        _gcSetLastRead(msg.id);
      } else if (isFromOther) {
        _gcBumpScrollBadge();
      }
      _gcUpdateScrollBtn();
    }
  });

  mainSocket.on('channel:message:pin', function(data) {
    var bubble = document.querySelector('[data-gc-msg-id="' + data.message.id + '"]');
    if (bubble) {
      bubble.classList.toggle('pinned', !!data.pinned);
      var existingInd = bubble.querySelector('.gc-pin-indicator');
      if (data.pinned && !existingInd) {
        bubble.insertAdjacentHTML('afterbegin', '<span class="gc-pin-indicator" title="Pinned"><i class="bi bi-pin-angle-fill"></i></span>');
      } else if (!data.pinned && existingInd) {
        existingInd.remove();
      }
    }
    loadGcPinned();
  });

  mainSocket.on('channel:message:edit', function(msg) {
    var bubble = document.querySelector('[data-gc-msg-id="' + msg.id + '"]');
    if (!bubble) return;
    _gcMsgRaw[msg.id] = msg.content;
    var contentEl = bubble.querySelector('.msg-content');
    if (contentEl) contentEl.innerHTML = gcRenderWithMentions(msg.content);
    var footer = bubble.querySelector('.msg-footer');
    if (footer && !footer.querySelector('.gc-edited-label')) {
      footer.insertAdjacentHTML('beforeend', '<span class="gc-edited-label">(edited)</span>');
    }
  });

  mainSocket.on('channel:reaction', function(data) {
    var bubble = document.querySelector('[data-gc-msg-id="' + data.message_id + '"]');
    if (!bubble) return;
    var block = bubble.querySelector('.gc-reactions');
    if (block) block.remove();
    var fakeMsg = { id: data.message_id, reactions: data.reactions || [] };
    var newHtml = _gcRenderReactions(fakeMsg);
    if (newHtml) {
      var content = bubble.querySelector('.msg-content');
      if (content) content.insertAdjacentHTML('afterend', newHtml);
    }
  });

  mainSocket.on('channel:message:delete', function(data) {
    var bubble = document.querySelector('[data-gc-msg-id="' + data.id + '"]');
    if (bubble) {
      bubble.classList.add('deleted');
      var c = bubble.querySelector('.msg-content');
      if (c) c.innerHTML = '<em class="text-muted" style="font-size:0.75rem"><i class="bi bi-ban me-1"></i>deleted</em>';
      var d = bubble.querySelector('.gc-msg-menu-btn');
      if (d) d.remove();
    }
  });

  // Typing indicators
  var _gcTypingTimer = null;
  var _gcRemoteTypingTimer = null;
  document.getElementById('gcInput')?.addEventListener('input', function() {
    mainSocket.emit('channel:typing');
    clearTimeout(_gcTypingTimer);
    _gcTypingTimer = setTimeout(function() {
      mainSocket.emit('channel:typing:stop');
    }, 2000);
  });
  mainSocket.on('channel:typing', function(data) {
    if (data.user_id === _gcUserId) return;
    var bar = document.getElementById('gcTypingBar');
    if (bar) { bar.innerHTML = '<span class="bridge-typing"><span class="typing-dots"><span></span><span></span><span></span></span></span>'; bar.style.display = ''; }
    clearTimeout(_gcRemoteTypingTimer);
    _gcRemoteTypingTimer = setTimeout(function() {
      if (bar) { bar.style.display = 'none'; bar.innerHTML = ''; }
    }, 3000);
  });
  mainSocket.on('channel:typing:stop', function(data) {
    if (data.user_id === _gcUserId) return;
    clearTimeout(_gcRemoteTypingTimer);
    var bar = document.getElementById('gcTypingBar');
    if (bar) { bar.style.display = 'none'; bar.innerHTML = ''; }
  });

  // ── Presence strip ──────────────────────────────
  var _gcAllUsers = [];

  function loadGcUsers() {
    fetch(_gcBaseUrl + '/users').then(function(r) { return r.json(); }).then(function(res) {
      if (!res.success) return;
      _gcAllUsers = res.data.users;
      renderGcPresence();
    });
  }

  function renderGcPresence() {
    var strip = document.getElementById('gcPresenceStrip');
    if (!strip) return;
    var online = _gcAllUsers.filter(function(u) { return u.online; });
    if (!online.length) { strip.innerHTML = ''; return; }
    strip.innerHTML = online.map(function(u) {
      var initials = u.name.split(' ').map(function(p){ return p[0]; }).join('').substring(0, 2).toUpperCase();
      return '<div class="gc-presence-avatar online" title="' + escapeHtml(u.name) + '" data-gc-uid="' + u.id + '">'
        + initials + '<span class="gc-presence-dot"></span></div>';
    }).join('');
  }

  // Real-time presence updates
  mainSocket.on('channel:presence', function(data) {
    _gcAllUsers.forEach(function(u) { if (u.id === data.user_id) u.online = data.online; });
    renderGcPresence();
  });

  // Scroll listener for scroll-to-bottom button + auto-mark-read + load-more
  document.getElementById('gcMessages')?.addEventListener('scroll', function() {
    _gcUpdateScrollBtn();
    if (this.scrollTop < 60) _gcLoadMore();
  });
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden && !_gcCollapsed) _gcUpdateScrollBtn();
  });

  // Load on page load
  loadGcMessages();
  loadGcUsers();
  loadGcPinned();
  </script>
  <% } %>

  <script src="/portal/portal.js"></script>
  <%- script %>

  <!-- Requests badge (runs on every portal page) -->
  <script>
  (function() {
    function updateReqBadge() {
      fetch('/portal/requests/badge', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json()).then(data => {
          if (!data.success) return;
          const badge = document.querySelector('.req-nav-badge');
          if (!badge) return;
          badge.textContent = data.data.count || '';
          badge.style.display = data.data.count > 0 ? '' : 'none';
        }).catch(() => {});
    }
    updateReqBadge();
    // Also update badge when queue:updated fires globally
    if (typeof io !== 'undefined') {
      const _reqSocket = io('/portal');
      _reqSocket.on('queue:updated', updateReqBadge);
      _reqSocket.on('queue:new_request', updateReqBadge);
    }
  })();
  </script>
</body>
</html>
