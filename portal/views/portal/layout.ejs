              '<td><span class="' + statusCls + ' fw-bold" style="font-size:0.72rem;text-transform:uppercase">' + c.status + '</span>' +
                (duration ? ' <span class="text-muted" style="font-size:0.65rem">(' + duration + ')</span>' : '') + '</td>' +
              '<td class="text-center">' + (c.message_count || 0) + '</td>' +
