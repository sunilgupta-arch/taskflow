    function toggleUrgentWidget() {
      if (_urgentWidgetOpen) {
        document.getElementById('urgentWidget').style.display = 'none';
        document.getElementById('urgentFab').style.display = 'flex';
        _urgentWidgetOpen = false;
      } else {
        document.getElementById('urgentWidget').style.display = 'flex';
        document.getElementById('urgentFab').style.display = 'none';
        _urgentWidgetOpen = true;
        loadUrgentMessages();
      }
    }

    function loadUrgentMessages() {
      if (!_urgentChatId) return;
      fetch('/portal/urgent/' + _urgentChatId + '/messages').then(r => r.json()).then(res => {
        if (!res.success) return;
        renderUrgentMessages(res.data.messages);
      });
    }

    function renderUrgentMessages(messages) {
      var container = document.getElementById('urgentWidgetMessages');
      if (!messages.length) { container.innerHTML = '<div class="text-center text-muted py-3 small">Waiting for response...</div>'; return; }
      container.innerHTML = messages.map(function(m) {
        if (m.type === 'system') {
          return '<div class="urgent-msg-system">' + escapeHtml(m.content) + '</div>';
        }
        var isMine = m.sender_id === PORTAL_USER.id;
        var cls = isMine ? 'sent' : 'received';
        var time = new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        var content = '';
        if (m.type === 'file' && m.attachment) {
          var _uext = m.attachment.file_name.split('.').pop().toLowerCase();
          var _uImgExts = ['jpg','jpeg','png','gif','webp','bmp','svg'];
          var _uurl = '/portal/urgent/attachment/' + m.id;
          if (_uImgExts.indexOf(_uext) !== -1) {
            content = '<a href="' + _uurl + '" target="_blank" class="msg-image-link"><img src="' + _uurl + '" class="msg-image-preview" alt="' + escapeHtml(m.attachment.file_name) + '" loading="lazy" style="max-width:200px;border-radius:6px;"></a>';
          } else {
            var _uMap = {pdf:['bi-file-earmark-pdf-fill','#ef4444'],doc:['bi-file-earmark-word-fill','#2b7bf0'],docx:['bi-file-earmark-word-fill','#2b7bf0'],xls:['bi-file-earmark-excel-fill','#16a34a'],xlsx:['bi-file-earmark-excel-fill','#16a34a'],csv:['bi-file-earmark-spreadsheet-fill','#16a34a'],ppt:['bi-file-earmark-ppt-fill','#f97316'],pptx:['bi-file-earmark-ppt-fill','#f97316'],zip:['bi-file-earmark-zip-fill','#eab308'],rar:['bi-file-earmark-zip-fill','#eab308'],'7z':['bi-file-earmark-zip-fill','#eab308'],txt:['bi-file-earmark-text-fill','#9ca3af'],mp3:['bi-file-earmark-music-fill','#a855f7'],mp4:['bi-file-earmark-play-fill','#ec4899']};
            var _uInfo = _uMap[_uext] || ['bi-file-earmark-fill','#94a3b8'];
            content = '<a href="' + _uurl + '" target="_blank" class="urgent-file-link"><i class="bi ' + _uInfo[0] + '" style="color:' + _uInfo[1] + ';font-size:1.3rem;"></i> ' + escapeHtml(m.attachment.file_name) + '</a>';
          }
        } else {
          content = escapeHtml(m.content);
        }
        return '<div class="urgent-msg ' + cls + '">' +
          (!isMine ? '<div class="urgent-msg-sender">' + escapeHtml(m.sender_name) + '</div>' : '') +
          '<div class="urgent-msg-content">' + content + '</div>' +
          '<div class="urgent-msg-time">' + time + '</div></div>';
      }).join('');
      container.scrollTop = container.scrollHeight;
    }

    async function sendUrgentMessage() {
      if (!_urgentChatId) return;
      var input = document.getElementById('urgentChatInput');
      var content = input.value.trim();
      if (!content) return;
      input.value = '';
      await fetch('/portal/urgent/' + _urgentChatId + '/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: content })
      });
