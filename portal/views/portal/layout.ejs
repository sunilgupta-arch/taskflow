  window._gcSelectMention = function(idx) {
    var list = _gcMentionCandidates();
    if (!list[idx]) return;
    var input = document.getElementById('gcInput');
    if (!input) return;
    var v = input.value, caret = input.selectionStart;
    var before = v.substring(0, _gcMentionStart);
    var after = v.substring(caret);
    var insert = '@[' + list[idx].name + '] ';
    input.value = before + insert + after;
    var newCaret = before.length + insert.length;
    input.setSelectionRange(newCaret, newCaret);
    input.focus();
    _gcHideMention();
  };
  function _gcMentionInputHandler() {
    var input = document.getElementById('gcInput');
    if (!input) return;
    var val = input.value, caret = input.selectionStart;
    var at = -1;
    for (var i = caret - 1; i >= 0; i--) {
      var c = val.charAt(i);
      if (c === '@') { at = i; break; }
      if (/\s/.test(c) || c === '[' || c === ']') break;
    }
    if (at === -1 || (at > 0 && !/\s/.test(val.charAt(at - 1)))) { _gcHideMention(); return; }
    _gcMentionActive = true;
    _gcMentionStart = at;
    _gcMentionQuery = val.substring(at + 1, caret);
    _gcMentionIdx = 0;
    _gcRenderMentionPopup();
  }
  function _gcMentionKeyHandler(e) {
    if (!_gcMentionActive) return false;
    var list = _gcMentionCandidates();
    if (!list.length) return false;
    if (e.key === 'ArrowDown') { e.preventDefault(); _gcMentionIdx = (_gcMentionIdx + 1) % list.length; _gcRenderMentionPopup(); return true; }
    if (e.key === 'ArrowUp') { e.preventDefault(); _gcMentionIdx = (_gcMentionIdx - 1 + list.length) % list.length; _gcRenderMentionPopup(); return true; }
    if (e.key === 'Enter' || e.key === 'Tab') { e.preventDefault(); _gcSelectMention(_gcMentionIdx); return true; }
    if (e.key === 'Escape') { e.preventDefault(); _gcHideMention(); return true; }
    return false;
  }

  // ── Link preview ────────────────────────────────
  var _gcLinkPreviewCache = {};
