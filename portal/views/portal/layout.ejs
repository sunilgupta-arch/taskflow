      else if (data.conversation_id === delegateChatConvId) statusEl = document.getElementById('delegateSupportStatus');
      if (!statusEl) return;
      statusEl.innerHTML = '<span class="bridge-typing"><span class="typing-dots"><span></span><span></span><span></span></span></span>';
      clearTimeout(_bridgeTypingTimers[data.conversation_id]);
      _bridgeTypingTimers[data.conversation_id] = setTimeout(function() {
