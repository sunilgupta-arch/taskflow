    if (!list.length) { _gcHideMention(); return; }
    if (_gcMentionIdx >= list.length) _gcMentionIdx = 0;
    p.innerHTML = list.map(function(u, i) {
      return '<div class="gc-mention-item' + (i === _gcMentionIdx ? ' active' : '') + '" data-mention-idx="' + i + '" onmousedown="_gcSelectMention(' + i + ')">' +
        '<div class="gc-mention-avatar">' + _gcEscMention(u.name.charAt(0).toUpperCase()) + '</div>' +
        '<div class="gc-mention-name">' + _gcEscMention(u.name) + '</div>' +
        '<div class="gc-mention-role">' + _gcEscMention((u.role_name || '').replace(/^LOCAL_|^CLIENT_/, '')) + '</div>' +
      '</div>';
    }).join('');
