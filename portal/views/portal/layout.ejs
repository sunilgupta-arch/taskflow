<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<script>(function(){var t=localStorage.getItem('tf-theme')||'dark';document.documentElement.setAttribute('data-bs-theme',t);if(localStorage.getItem('portal-sidebar-expanded')==='1')document.documentElement.classList.add('sidebar-expanded');})()</script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Client Portal' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/portal/portal.css">
  <%- style %>
</head>
<body>
  <!-- Activity Bar (VS Code style, expand/collapse) -->
  <nav class="portal-activity-bar" id="portalActivityBar">
    <div class="activity-bar-top">
      <div class="activity-bar-brand-row">
        <a href="/portal" class="activity-bar-brand" title="CFC Portal Home">
          <span class="brand-icon">C</span>
          <span class="ab-brand-name">CFC Portal</span>
        </a>
        <button class="ab-toggle" onclick="toggleSidebarExpand()" title="Expand / Collapse">
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
      <a href="/portal/chat" class="activity-bar-item <%= section === 'chat' ? 'active' : '' %>">
        <i class="bi bi-chat-dots-fill"></i>
        <span class="ab-label">Chat</span>
        <span class="ab-tooltip">Chat</span>
        <span class="activity-bar-badge chat-unread-badge" style="display:none"></span>
      </a>
      <a href="/portal/tasks" class="activity-bar-item <%= section === 'tasks' ? 'active' : '' %>">
        <i class="bi bi-kanban-fill"></i>
        <span class="ab-label">Tasks</span>
        <span class="ab-tooltip">Tasks</span>
      </a>
      <a href="/portal/requests" class="activity-bar-item <%= section === 'requests' ? 'active' : '' %>" style="position:relative;">
        <i class="bi bi-inbox-fill"></i>
        <span class="ab-label">Allocate Task TI</span>
        <span class="ab-tooltip">Allocate Task TI</span>
        <span class="activity-bar-badge req-nav-badge" style="display:none"></span>
      </a>
      <a href="/portal/notes" class="activity-bar-item <%= section === 'notes' ? 'active' : '' %>">
        <i class="bi bi-journal-text"></i>
        <span class="ab-label">Notes</span>
        <span class="ab-tooltip">Notes</span>
      </a>
      <a href="/portal/calendar" class="activity-bar-item <%= section === 'calendar' ? 'active' : '' %>">
        <i class="bi bi-calendar3"></i>
        <span class="ab-label">Calendar</span>
        <span class="ab-tooltip">Calendar</span>
      </a>
      <a href="/portal/reports" class="activity-bar-item <%= section === 'reports' ? 'active' : '' %>">
        <i class="bi bi-link-45deg"></i>
        <span class="ab-label">Links</span>
        <span class="ab-tooltip">Links</span>
      </a>
      <% if (['CLIENT_ADMIN', 'CLIENT_TOP_MGMT'].includes(user.role_name)) { %>
        <a href="/portal/team-status" class="activity-bar-item <%= section === 'team-status' ? 'active' : '' %>">
          <i class="bi bi-flag-fill"></i>
          <span class="ab-label">Team India</span>
          <span class="ab-tooltip">Team India</span>
        </a>
      <% } %>
      <% if (user.role_name === 'CLIENT_ADMIN') { %>
        <a href="/portal/users" class="activity-bar-item <%= section === 'users' ? 'active' : '' %>">
          <i class="bi bi-people-fill"></i>
          <span class="ab-label">Users</span>
          <span class="ab-tooltip">Users Management</span>
        </a>
      <% } %>
      <a href="/portal/help" class="activity-bar-item <%= section === 'help' ? 'active' : '' %>">
        <i class="bi bi-question-circle"></i>
        <span class="ab-label">Help</span>
        <span class="ab-tooltip">Help</span>
      </a>
    </div>
    <div class="activity-bar-bottom">
      <% if ((localAdmin || delegateSupport) && user.role_name !== 'CLIENT_SALES') { %>
        <div class="activity-bar-separator"></div>
        <div class="ab-section-label">Support</div>
      <% } %>
      <% if (localAdmin && user.role_name !== 'CLIENT_SALES') { %>
        <button class="activity-bar-item" onclick="toggleSupportChat('admin')">
          <i class="bi bi-headset"></i>
          <span class="ab-label"><span class="ab-label-name"><%= localAdmin.name.split(' ')[0] %></span><span class="ab-label-role">Primary</span></span>
          <span class="ab-tooltip"><%= localAdmin.name %> (Primary Support)</span>
          <span class="activity-bar-badge" id="adminChatBadge" style="display:none"></span>
        </button>
      <% } %>
      <% if (delegateSupport && user.role_name !== 'CLIENT_SALES') { %>
        <button class="activity-bar-item" onclick="toggleSupportChat('delegate')">
          <i class="bi bi-person-badge"></i>
          <span class="ab-label"><span class="ab-label-name"><%= delegateSupport.name.split(' ')[0] %></span><span class="ab-label-role">Secondary</span></span>
          <span class="ab-tooltip"><%= delegateSupport.name %> (Secondary Support)</span>
          <span class="activity-bar-badge" id="delegateChatBadge" style="display:none"></span>
        </button>
      <% } %>
      <button class="activity-bar-item" onclick="toggleTheme()" id="themeToggleBtn">
        <i class="bi" id="themeIcon"></i>
        <span class="ab-label">Theme</span>
        <span class="ab-tooltip">Toggle Theme</span>
      </button>
      <div class="dropdown">
        <button class="activity-bar-item" data-bs-toggle="dropdown" data-bs-display="static">
          <span class="activity-bar-avatar"><%= user.name.charAt(0).toUpperCase() %></span>
          <span class="ab-label"><%= user.name.split(' ')[0] %></span>
          <span class="ab-tooltip"><%= user.name %></span>
        </button>
        <ul class="dropdown-menu">
          <li>
            <span class="dropdown-item-text">
              <strong><%= user.name %></strong>
              <div class="small text-muted"><%= user.email %></div>
            </span>
          </li>
          <li><hr class="dropdown-divider"></li>
          <li>
            <a class="dropdown-item" href="#" onclick="showChangePwModal()">
              <i class="bi bi-key me-2"></i>Change Password
            </a>
          </li>
          <li>
            <a class="dropdown-item text-danger" href="#" onclick="portalLogout()">
              <i class="bi bi-box-arrow-right me-2"></i>Logout
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="portal-main<%= section === 'channel' ? ' gc-collapsed' : (user.role_name === 'CLIENT_SALES' ? ' gc-no-panel' : '') %>">
    <%- body %>
  </div>

  <% if (user.role_name !== 'CLIENT_SALES' && section !== 'channel') { %>
  <!-- Group Channel — right-side persistent panel -->
  <div class="gc-panel" id="gcPanel">
    <div class="gc-panel-header">
      <div class="d-flex align-items-center gap-2">
        <i class="bi bi-broadcast" style="font-size:0.9rem"></i>
        <span class="fw-bold" style="font-size:0.8rem">Group Channel</span>
      </div>
      <div class="d-flex align-items-center gc-header-actions">
        <button class="gc-header-btn" onclick="toggleGcSearch()" title="Search"><i class="bi bi-search"></i></button>
        <button class="gc-header-btn" onclick="openGcHelp()" title="Help"><i class="bi bi-question-circle"></i></button>
        <a href="/portal/channel" class="gc-header-btn" title="Maximize"><i class="bi bi-arrows-fullscreen"></i></a>
        <button class="gc-header-btn" onclick="toggleGroupChannel()" title="Collapse"><i class="bi bi-chevron-right" id="gcCollapseIcon"></i></button>
      </div>
    </div>
    <div class="gc-panel-body" id="gcPanelBody">
      <div class="gc-search-bar" id="gcSearchBar" style="display:none">
        <input type="text" class="form-control form-control-sm" id="gcSearchInput" placeholder="Search messages...">
        <i class="bi bi-x-lg gc-search-close" onclick="toggleGcSearch()" title="Close"></i>
        <div class="gc-search-results" id="gcSearchResults"></div>
      </div>
      <div class="gc-presence-strip" id="gcPresenceStrip"></div>
      <div class="gc-pinned-bar" id="gcPinnedBar" style="display:none">
        <div class="gc-pinned-bar-header" onclick="toggleGcPinnedList()">
          <i class="bi bi-pin-angle-fill"></i>
          <span id="gcPinnedBarTitle">0 pinned</span>
          <i class="bi bi-chevron-down gc-pinned-bar-chev" id="gcPinnedBarChev"></i>
        </div>
        <div class="gc-pinned-bar-list" id="gcPinnedBarList" style="display:none"></div>
      </div>
      <div class="gc-messages" id="gcMessages">
        <div class="text-center text-muted py-3 small">Loading...</div>
      </div>
      <button class="gc-scroll-btn" id="gcScrollBtn" onclick="gcScrollToBottom()" style="display:none" title="Jump to latest"><i class="bi bi-chevron-double-down"></i><span class="gc-scroll-btn-badge" id="gcScrollBtnBadge" style="display:none">0</span></button>
      <div class="gc-typing-bar" id="gcTypingBar" style="display:none"></div>
      <div class="gc-reply-compose-bar" id="gcReplyBar" style="display:none">
        <i class="bi bi-reply-fill" style="color:#2563eb;font-size:0.75rem"></i>
        <div class="gc-reply-compose-text">
          <span class="gc-reply-compose-sender" id="gcReplyBarSender"></span>
          <span class="gc-reply-compose-content" id="gcReplyBarContent"></span>
        </div>
        <i class="bi bi-x-lg gc-reply-compose-close" onclick="cancelGcReply()" title="Cancel reply"></i>
      </div>
      <div class="gc-input" style="position:relative">
        <div class="gc-mention-popup" id="gcMentionPopup" style="display:none"></div>
        <input type="file" id="gcFileInput" style="display:none" onchange="sendGcFile()">
        <div class="d-flex gap-1 align-items-stretch">
          <textarea class="form-control" id="gcInput" placeholder="Message..." rows="2" oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,100)+'px'"></textarea>
          <div class="gc-input-btns">
            <button class="btn btn-outline-secondary btn-sm gc-input-btn" onclick="document.getElementById('gcFileInput').click()" title="Attach"><i class="bi bi-paperclip"></i></button>
            <button class="btn btn-primary btn-sm gc-input-btn" onclick="sendGcMessage()" title="Send"><i class="bi bi-send"></i></button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Group Channel collapsed handle -->
  <div class="gc-handle" id="gcHandle" style="display:none" onclick="toggleGroupChannel()" title="Open Group Channel">
    <i class="bi bi-broadcast"></i>
    <span class="gc-handle-badge" id="gcHandleBadge" style="display:none"></span>
  </div>
  <% } %>

  <% if (user.role_name !== 'CLIENT_SALES') { %>
  <!-- Group Channel Help Modal -->
  <div class="gc-help-backdrop" id="gcHelpBackdrop" style="display:none" onclick="if(event.target===this) closeGcHelp()">
    <div class="gc-help-modal" role="dialog" aria-label="Group Channel help">
      <div class="gc-help-header">
        <div class="gc-help-title"><i class="bi bi-broadcast"></i>Group Channel — Guide</div>
        <button class="gc-help-close" onclick="closeGcHelp()" title="Close"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="gc-help-body">
        <div class="gc-help-intro">The Group Channel is a shared chat between your team and the local team. Here's everything you can do.</div>

        <div class="gc-help-section-title">Sending</div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-chat-dots-fill"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Send messages & files</div>
            <div class="gc-help-desc">Type and press <code>Enter</code>. <code>Shift+Enter</code> adds a new line. Click the paperclip for attachments (up to 5 MB). You can also <b>paste screenshots</b> directly into the compose box.</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-at"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Mention someone with @</div>
            <div class="gc-help-desc">Type <code>@</code> and start typing a name — a list pops up. Use <code>↑/↓</code> to move, <code>Enter</code> to pick. The mentioned person gets a red highlight on the message and a louder desktop notification (even if their chat is open).</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-reply-fill"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Reply to a specific message</div>
            <div class="gc-help-desc">Hover any message and click the <i class="bi bi-reply-fill"></i> icon. Your reply shows a quote of the original — click the quote later to jump to it.</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-emoji-smile-fill"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">React with emoji</div>
            <div class="gc-help-desc">Hover a message and click the smile icon to pick from 48 emojis. Click existing reaction chips to toggle yours on/off. Hover a chip to see who reacted.</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-pencil-fill"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Edit your own message</div>
            <div class="gc-help-desc">Within <b>15 minutes</b> of sending, hover your text message and click the pencil to edit inline. <code>Enter</code> saves, <code>Esc</code> cancels. Edited messages show <i>"(edited)"</i> in the footer.</div>
          </div>
        </div>

        <div class="gc-help-section-title">Reading</div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-chevron-double-down"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Stay caught up</div>
            <div class="gc-help-desc">When messages arrive while you're scrolled up, a blue jump-button appears with a red unread count. A <b>"New messages"</b> divider marks where you last left off. Scroll to the top to auto-load older history.</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-bell-fill"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Browser notifications</div>
            <div class="gc-help-desc">If the panel is collapsed or the tab is in the background, a desktop notification fires for new messages. Grant notification permission the first time you open the chat. Mentions always notify.</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-search"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Search older messages</div>
            <div class="gc-help-desc">Click the search icon, type 2+ characters. Matches are highlighted. Click a result to jump to it (scroll up first if it's not loaded yet).</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-link-45deg"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Automatic link previews</div>
            <div class="gc-help-desc">Any URL you paste becomes clickable and gets a preview card showing site title, description, and image.</div>
          </div>
        </div>

        <div class="gc-help-section-title">Organizing (admin)</div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-pin-angle-fill"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Pin important messages</div>
            <div class="gc-help-desc">Admins (<code>LOCAL_ADMIN</code>, <code>CLIENT_ADMIN</code>) can pin any message via the yellow pin icon on hover. A "N pinned" bar shows at the top — click to expand the list, click any pin to jump to it.</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-trash-fill"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">Delete your own message</div>
            <div class="gc-help-desc">Hover your message and click the red trash icon. Deleted messages show as "deleted" with the original replaced.</div>
          </div>
        </div>
        <div class="gc-help-item">
          <div class="gc-help-icon"><i class="bi bi-people-fill"></i></div>
          <div class="gc-help-content">
            <div class="gc-help-feature">See who's online</div>
            <div class="gc-help-desc">The top strip shows online users with a green dot.</div>
          </div>
        </div>

        <div class="gc-help-section-title">Tips</div>
        <ul class="gc-help-tips">
          <li>The chat panel stays collapsed/expanded across pages — your choice persists.</li>
          <li>Click <i class="bi bi-arrows-fullscreen"></i> Maximize to open a full-page channel view with more space.</li>
          <li>Messages with deleted reply-targets still work — the quote just shows "deleted message".</li>
          <li>Hover any reaction chip to see the full list of users who reacted.</li>
        </ul>
      </div>
    </div>
  </div>
  <script>
    (function() {
      window.openGcHelp = function() {
        var bd = document.getElementById('gcHelpBackdrop');
        if (bd) bd.style.display = 'flex';
      };
      window.closeGcHelp = function() {
        var bd = document.getElementById('gcHelpBackdrop');
        if (bd) bd.style.display = 'none';
      };
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          var bd = document.getElementById('gcHelpBackdrop');
          if (bd && bd.style.display !== 'none') closeGcHelp();
        }
      });
    })();
  </script>
  <% } %>

  <!-- Admin Chat Floating Panel (Primary Support) -->
  <% if (localAdmin && user.role_name !== 'CLIENT_SALES') { %>
  <div class="admin-chat-panel" id="adminChatPanel" style="display:none">
    <div class="admin-chat-header">
      <div class="d-flex align-items-center gap-2">
        <div class="admin-chat-avatar"><i class="bi bi-headset"></i></div>
        <div>
          <div class="fw-bold" style="font-size:0.85rem"><%= localAdmin.name %></div>
          <div class="small text-muted" id="adminSupportStatus">Primary Support</div>
        </div>
      </div>
      <button class="btn btn-sm btn-link p-0" onclick="toggleSupportChat('admin')"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="admin-chat-messages" id="adminChatMessages">
      <div class="text-center text-muted py-4 small">Start a conversation...</div>
    </div>
    <div class="admin-chat-input">
      <input type="file" id="adminChatFile" style="display:none" onchange="sendAdminChatFile()">
      <div class="d-flex gap-1">
        <textarea class="form-control" id="adminChatInput" placeholder="Type a message..." rows="2"></textarea>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:3px;">
          <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('adminChatFile').click()" style="width:34px;height:34px;padding:0" title="Attach"><i class="bi bi-paperclip"></i></button>
          <button class="btn btn-outline-secondary btn-sm" onclick="toggleFieldDictation('adminChatInput', this)" style="width:34px;height:34px;padding:0" title="Dictate"><i class="bi bi-mic"></i></button>
          <button class="btn btn-primary btn-sm" onclick="sendAdminChatMessage()" style="width:34px;height:34px;padding:0;grid-column:span 2" title="Send"><i class="bi bi-send"></i></button>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Delegate Chat Floating Panel (Secondary Support) -->
  <% if (delegateSupport && user.role_name !== 'CLIENT_SALES') { %>
  <div class="admin-chat-panel" id="delegateChatPanel" style="display:none">
    <div class="admin-chat-header">
      <div class="d-flex align-items-center gap-2">
        <div class="admin-chat-avatar" style="background:linear-gradient(135deg, var(--tf-success), #16a34a)"><i class="bi bi-person-badge"></i></div>
        <div>
          <div class="fw-bold" style="font-size:0.85rem"><%= delegateSupport.name %></div>
          <div class="small text-muted" id="delegateSupportStatus">Secondary Support</div>
        </div>
      </div>
      <button class="btn btn-sm btn-link p-0" onclick="toggleSupportChat('delegate')"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="admin-chat-messages" id="delegateChatMessages">
      <div class="text-center text-muted py-4 small">Start a conversation...</div>
    </div>
    <div class="admin-chat-input">
      <input type="file" id="delegateChatFile" style="display:none" onchange="sendDelegateChatFile()">
      <div class="d-flex gap-1">
        <textarea class="form-control" id="delegateChatInput" placeholder="Type a message..." rows="2"></textarea>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:3px;">
          <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('delegateChatFile').click()" style="width:34px;height:34px;padding:0" title="Attach"><i class="bi bi-paperclip"></i></button>
          <button class="btn btn-outline-secondary btn-sm" onclick="toggleFieldDictation('delegateChatInput', this)" style="width:34px;height:34px;padding:0" title="Dictate"><i class="bi bi-mic"></i></button>
          <button class="btn btn-primary btn-sm" onclick="sendDelegateChatMessage()" style="width:34px;height:34px;padding:0;grid-column:span 2" title="Send"><i class="bi bi-send"></i></button>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Urgent Chat Compose Modal -->
  <% if (['CLIENT_ADMIN', 'CLIENT_TOP_MGMT', 'CLIENT_MGMT', 'CLIENT_MANAGER'].includes(user.role_name)) { %>
  <div class="modal fade" id="urgentComposeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content urgent-modal-content">
        <div class="modal-header urgent-modal-header">
          <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Urgent Line</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted small mb-3">This sends an alert to the entire local team. Someone will pick up and respond.</p>
          <div class="mb-3">
            <textarea class="form-control" id="urgentComposeMsg" rows="3" placeholder="What do you need? Be specific..." maxlength="2000"></textarea>
          </div>
          <div class="mb-2">
            <input type="file" id="urgentComposeFile" style="display:none">
            <button class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('urgentComposeFile').click()"><i class="bi bi-paperclip me-1"></i>Attach file</button>
            <span class="small text-muted ms-2" id="urgentComposeFileName"></span>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger" onclick="sendUrgent()"><i class="bi bi-send me-1"></i>Send Urgent</button>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Urgent Chat Floating Widget (visible when active) -->
  <div class="urgent-widget" id="urgentWidget" style="display:none">
    <div class="urgent-widget-header" id="urgentWidgetHeader">
      <div class="d-flex align-items-center gap-2">
        <div class="urgent-widget-pulse"></div>
        <span class="fw-bold" style="font-size:0.85rem">Urgent Line</span>
        <span class="urgent-widget-status" id="urgentWidgetStatus">Waiting...</span>
      </div>
      <div class="d-flex align-items-center gap-1">
        <button class="btn btn-sm btn-link p-0 text-white" onclick="toggleUrgentWidget()" title="Minimize"><i class="bi bi-dash-lg"></i></button>
        <button class="btn btn-sm btn-outline-light urgent-resolve-btn" onclick="resolveUrgent()" title="Resolve"><i class="bi bi-check-lg"></i></button>
      </div>
    </div>
    <div class="urgent-widget-messages" id="urgentWidgetMessages"></div>
    <div class="urgent-typing-bar" id="urgentTypingBar" style="display:none;padding:2px 12px;font-size:0.75rem;color:#bbf7d0;"></div>
    <div class="urgent-widget-input" id="urgentWidgetInput">
      <input type="file" id="urgentChatFile" style="display:none" onchange="sendUrgentFile()">
      <div class="d-flex gap-1">
        <textarea class="form-control" id="urgentChatInput" placeholder="Type a message..." rows="2"></textarea>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:3px;">
          <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('urgentChatFile').click()" style="width:34px;height:34px;padding:0" title="Attach"><i class="bi bi-paperclip"></i></button>
          <button class="btn btn-warning btn-sm urgent-buzzer-btn" onclick="sendBuzzer()" style="width:34px;height:34px;padding:0" title="Buzz! Get attention"><i class="bi bi-bell-fill"></i></button>
          <button class="btn btn-danger btn-sm" onclick="sendUrgentMessage()" style="width:34px;height:34px;padding:0;grid-column:span 2" title="Send"><i class="bi bi-send"></i></button>
        </div>
      </div>
    </div>
  </div>

  <!-- Urgent History Modal -->
  <div class="modal fade" id="urgentHistoryModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Urgent Line History</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-0" id="urgentHistoryBody">
          <div class="text-center text-muted py-4">Loading...</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Urgent History Detail Modal (messages for a specific chat) -->
  <div class="modal fade" id="urgentHistoryDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="urgentHistoryDetailTitle">Messages</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" id="urgentHistoryDetailBody" style="max-height:400px;overflow-y:auto;display:flex;flex-direction:column;gap:6px;">
        </div>
      </div>
    </div>
  </div>

  <!-- Urgent Widget Minimized Fab -->
  <button class="urgent-fab" id="urgentFab" style="display:none" onclick="toggleUrgentWidget()">
    <i class="bi bi-exclamation-triangle-fill"></i>
  </button>

  <!-- Toast Container -->
  <div id="portalToastContainer" class="portal-toast-container"></div>

  <!-- Change Password Modal -->
  <div class="modal fade" id="changePwModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
      <div class="modal-content">
        <div class="modal-header">
          <h6 class="modal-title">Change Password</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label small">New Password *</label>
            <input type="password" class="form-control" id="changePwNew" placeholder="Min 6 characters">
          </div>
          <div class="mb-3">
            <label class="form-label small">Confirm Password *</label>
            <input type="password" class="form-control" id="changePwConfirm" placeholder="Confirm password">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary btn-sm" onclick="changePassword()">Update</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const PORTAL_USER = { id: <%= user.id %>, name: '<%= user.name %>', role: '<%= user.role_name %>' };
    const portalSocket = io('/portal', { withCredentials: true });
    const mainSocket = io('/', { withCredentials: true });

    portalSocket.on('connect', () => {
      portalSocket.emit('portal:join');
    });

    // Bridge chat messages come via main namespace
    mainSocket.on('bridge:message', (msg) => {
      if (msg.conversation_id === bridgeConvId) {
        renderBridgeMessages([msg], false);
        if (document.getElementById('panelChat')?.style.display !== 'none') {
          fetch(`/portal/bridge/conversations/${bridgeConvId}/read`, { method: 'POST' });
        }
      }
      if (msg.sender_id !== PORTAL_USER.id) {
        playNotificationSound();
      }
    });

    // Bridge message delete (Team India panel)
    mainSocket.on('bridge:message:delete', (data) => {
      if (data.conversation_id === bridgeConvId) {
        var bubble = document.querySelector('[data-bridge-msg-id="' + data.id + '"]');
        if (bubble) {
          bubble.classList.add('deleted');
          var contentEl = bubble.querySelector('.msg-content');
          if (contentEl) contentEl.innerHTML = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
          var delBtn = bubble.querySelector('.bridge-msg-delete');
          if (delBtn) delBtn.remove();
        }
      }
    });

    function updateThemeIcon() {
      const icon = document.getElementById('themeIcon');
      const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
      icon.className = isDark ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
    }

    function toggleTheme() {
      const html = document.documentElement;
      const current = html.getAttribute('data-bs-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-bs-theme', next);
      localStorage.setItem('tf-theme', next);
      updateThemeIcon();
    }

    updateThemeIcon();

    // ── Sidebar Expand / Collapse ────────────────────────────
    function toggleSidebarExpand() {
      var bar = document.getElementById('portalActivityBar');
      var expanded = bar.classList.toggle('expanded');
      document.documentElement.classList.toggle('sidebar-expanded', expanded);
      localStorage.setItem('portal-sidebar-expanded', expanded ? '1' : '0');
    }

    // Sync nav class with html class (already applied before render)
    (function() {
      if (document.documentElement.classList.contains('sidebar-expanded')) {
        document.getElementById('portalActivityBar').classList.add('expanded');
      }
      // Enable transitions now that initial state is set
      requestAnimationFrame(function() {
        document.documentElement.classList.add('sidebar-ready');
      });
    })();

    function showChangePwModal() {
      document.getElementById('changePwNew').value = '';
      document.getElementById('changePwConfirm').value = '';
      new bootstrap.Modal(document.getElementById('changePwModal')).show();
    }

    function changePassword() {
      const pw = document.getElementById('changePwNew').value;
      const confirm = document.getElementById('changePwConfirm').value;
      if (!pw || pw.length < 6) return alert('Password must be at least 6 characters');
      if (pw !== confirm) return alert('Passwords do not match');

      fetch('/portal/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ new_password: pw, confirm_password: confirm })
      })
        .then(r => r.json())
        .then(res => {
          if (res.success) {
            bootstrap.Modal.getInstance(document.getElementById('changePwModal')).hide();
            alert('Password changed successfully');
          } else {
            alert(res.message);
          }
        });
    }

    // ── Support Chat (Primary + Delegate) ──────────────────
    var adminChatConvId = null;
    var delegateChatConvId = null;
    <% if (localAdmin) { %>var LOCAL_ADMIN_ID = <%= localAdmin.id %>;<% } %>
    <% if (delegateSupport) { %>var DELEGATE_ID = <%= delegateSupport.id %>;<% } %>

    function toggleSupportChat(type) {
      var panelId = type === 'admin' ? 'adminChatPanel' : 'delegateChatPanel';
      var panel = document.getElementById(panelId);
      if (!panel) return;
      // Close the other panel if open
      var otherId = type === 'admin' ? 'delegateChatPanel' : 'adminChatPanel';
      var other = document.getElementById(otherId);
      if (other && other.style.display !== 'none') other.style.display = 'none';

      if (panel.style.display === 'none') {
        panel.style.display = 'flex';
        if (type === 'admin') initAdminChat();
        else initDelegateChat();
      } else {
        panel.style.display = 'none';
      }
    }

    // Keep old function name for backward compat (home page tile)
    function toggleAdminChat() { toggleSupportChat('admin'); }

    <% if (localAdmin) { %>
    function initAdminChat() {
      fetch('/portal/bridge/conversations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ local_user_id: LOCAL_ADMIN_ID })
      })
        .then(r => r.json())
        .then(res => {
          if (res.success) {
            adminChatConvId = res.data.conversation.id;
            loadSupportMessages('admin');
            fetch('/portal/bridge/conversations/' + adminChatConvId + '/read', { method: 'POST' });
            updateSupportBadges();
          }
        });
    }
    <% } %>

    <% if (delegateSupport) { %>
    function initDelegateChat() {
      fetch('/portal/bridge/conversations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ local_user_id: DELEGATE_ID })
      })
        .then(r => r.json())
        .then(res => {
          if (res.success) {
            delegateChatConvId = res.data.conversation.id;
            loadSupportMessages('delegate');
            fetch('/portal/bridge/conversations/' + delegateChatConvId + '/read', { method: 'POST' });
            updateSupportBadges();
          }
        });
    }
    <% } %>

    function loadSupportMessages(type) {
      var convId = type === 'admin' ? adminChatConvId : delegateChatConvId;
      if (!convId) return;
      fetch('/portal/bridge/conversations/' + convId + '/messages')
        .then(r => r.json())
        .then(res => {
          if (!res.success) return;
          renderSupportMessages(type, res.data.messages);
        });
    }

    function renderSupportMessages(type, messages) {
      var containerId = type === 'admin' ? 'adminChatMessages' : 'delegateChatMessages';
      var container = document.getElementById(containerId);
      if (!container) return;
      if (!messages.length) {
        container.innerHTML = '<div class="text-center text-muted py-4 small">Start a conversation...</div>';
        return;
      }
      var lastDate = '';
      container.innerHTML = messages.map(function(m) {
        var msgDate = formatDateLabel(m.created_at);
        var dateDivider = '';
        if (msgDate !== lastDate) {
          dateDivider = '<div class="msg-date-divider"><span>' + msgDate + '</span></div>';
          lastDate = msgDate;
        }
        var isSent = m.sender_id === PORTAL_USER.id;
        var cls = isSent ? 'sent' : 'received';
        var time = parseServerDate(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        var content = '';
        if (m.is_deleted) {
          content = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
        } else if (m.type === 'file' && m.attachment) {
          content = renderFileContent(m.attachment, m.id, '/portal/bridge/attachment');
        } else {
          content = linkify(escapeHtml(m.content));
        }
        var ticks = '';
        if (isSent && !m.is_deleted) {
          ticks = m.is_read
            ? '<span class="msg-ticks read"><i class="bi bi-check-all"></i></span>'
            : '<span class="msg-ticks"><i class="bi bi-check-all"></i></span>';
        }
        var deleteBtn = isSent && !m.is_deleted ? '<span class="bridge-msg-delete" onclick="event.stopPropagation(); deleteSupportMsg(\'' + type + '\', ' + m.id + ')" title="Delete"><i class="bi bi-trash"></i></span>' : '';
        return dateDivider + '<div class="msg-bubble ' + cls + (m.is_deleted ? ' deleted' : '') + '" data-bridge-msg-id="' + m.id + '">' + deleteBtn + '<div class="msg-content">' + content + '</div><div class="msg-footer"><span class="msg-time">' + time + '</span>' + ticks + '</div></div>';
      }).join('');
      container.scrollTop = container.scrollHeight;
    }

    function deleteSupportMsg(type, msgId) {
      if (!confirm('Delete this message?')) return;
      fetch('/portal/bridge/messages/' + msgId, { method: 'DELETE' })
        .then(r => r.json())
        .then(res => { if (!res.success) alert(res.message); });
    }

    function sendAdminChatMessage() {
      if (!adminChatConvId) return;
      var input = document.getElementById('adminChatInput');
      var content = input.value.trim();
      if (!content) return;
      fetch('/portal/bridge/conversations/' + adminChatConvId + '/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: content })
      }).then(function() { input.value = ''; });
    }

    // Shared upload helper for admin + delegate bridge panels
    function showBridgeUploadPlaceholder(containerId, filename) {
      var container = document.getElementById(containerId);
      if (!container) return null;
      var id = 'bridge-upload-' + Date.now();
      var html = '<div class="msg-bubble sent chat-uploading" id="' + id + '">' +
        '<div class="msg-content"><span class="gc-upload-spinner"></span><i class="bi bi-paperclip me-1"></i>' + escapeHtml(filename) + '</div>' +
        '<div class="msg-footer"><span class="msg-time">Uploading…</span></div>' +
        '</div>';
      container.insertAdjacentHTML('beforeend', html);
      container.scrollTop = container.scrollHeight;
      return id;
    }
    function markBridgeUploadFailed(id, reason) {
      var el = document.getElementById(id);
      if (!el) return;
      el.classList.add('chat-upload-failed');
      var footer = el.querySelector('.msg-time');
      if (footer) footer.innerHTML = '<i class="bi bi-exclamation-circle me-1"></i>' + escapeHtml(reason || 'Upload failed');
      var spinner = el.querySelector('.gc-upload-spinner');
      if (spinner) spinner.remove();
    }
    function uploadBridgeFileDirect(convId, containerId, file) {
      if (!convId) return;
      if (file.size > 10 * 1024 * 1024) { alert('File too large. Max 10 MB.'); return; }
      var placeholderId = showBridgeUploadPlaceholder(containerId, file.name || 'pasted-image.png');
      var fd = new FormData();
      fd.append('file', file, file.name || ('pasted-' + Date.now() + '.png'));
      fetch('/portal/bridge/conversations/' + convId + '/file', { method: 'POST', body: fd })
        .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, body: j }; }); })
        .then(function(res) {
          if (res.ok && res.body.success) {
            var el = document.getElementById(placeholderId);
            if (el) el.remove();
          } else {
            markBridgeUploadFailed(placeholderId, (res.body && res.body.message) || 'Upload failed');
          }
        })
        .catch(function() { markBridgeUploadFailed(placeholderId, 'Upload failed'); });
    }

    function sendAdminChatFile() {
      if (!adminChatConvId) return;
      var fileInput = document.getElementById('adminChatFile');
      if (!fileInput.files.length) return;
      var file = fileInput.files[0];
      fileInput.value = '';
      uploadBridgeFileDirect(adminChatConvId, 'adminChatMessages', file);
    }

    function sendDelegateChatMessage() {
      if (!delegateChatConvId) return;
      var input = document.getElementById('delegateChatInput');
      var content = input.value.trim();
      if (!content) return;
      fetch('/portal/bridge/conversations/' + delegateChatConvId + '/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: content })
      }).then(function() { input.value = ''; });
    }

    function sendDelegateChatFile() {
      if (!delegateChatConvId) return;
      var fileInput = document.getElementById('delegateChatFile');
      if (!fileInput.files.length) return;
      var file = fileInput.files[0];
      fileInput.value = '';
      uploadBridgeFileDirect(delegateChatConvId, 'delegateChatMessages', file);
    }

    // Paste screenshot handlers for admin + delegate chat inputs
    document.getElementById('adminChatInput')?.addEventListener('paste', function(e) {
      var items = (e.clipboardData || window.clipboardData)?.items;
      if (!items || !adminChatConvId) return;
      for (var i = 0; i < items.length; i++) {
        if (items[i].kind === 'file') {
          var f = items[i].getAsFile();
          if (f) { e.preventDefault(); uploadBridgeFileDirect(adminChatConvId, 'adminChatMessages', f); return; }
        }
      }
    });
    document.getElementById('delegateChatInput')?.addEventListener('paste', function(e) {
      var items = (e.clipboardData || window.clipboardData)?.items;
      if (!items || !delegateChatConvId) return;
      for (var i = 0; i < items.length; i++) {
        if (items[i].kind === 'file') {
          var f = items[i].getAsFile();
          if (f) { e.preventDefault(); uploadBridgeFileDirect(delegateChatConvId, 'delegateChatMessages', f); return; }
        }
      }
    });

    function updateSupportBadges() {
      fetch('/portal/bridge/unread-count')
        .then(r => r.json())
        .then(res => {
          if (!res.success) return;
          // Admin badge
          var adminBadge = document.getElementById('adminChatBadge');
          if (adminBadge) {
            var adminCount = res.data.by_user && res.data.by_user[LOCAL_ADMIN_ID] || 0;
            if (adminCount > 0) { adminBadge.textContent = adminCount; adminBadge.style.display = ''; }
            else { adminBadge.style.display = 'none'; }
          }
          // Delegate badge
          var delBadge = document.getElementById('delegateChatBadge');
          if (delBadge && typeof DELEGATE_ID !== 'undefined') {
            var delCount = res.data.by_user && res.data.by_user[DELEGATE_ID] || 0;
            if (delCount > 0) { delBadge.textContent = delCount; delBadge.style.display = ''; }
            else { delBadge.style.display = 'none'; }
          }
        });
    }

    // Enter to send
    document.getElementById('adminChatInput')?.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAdminChatMessage(); }
    });
    document.getElementById('delegateChatInput')?.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendDelegateChatMessage(); }
    });

    // Listen for bridge messages (both admin + delegate)
    mainSocket.on('bridge:message', function(msg) {
      // If the chat window is already showing this bridge conv inline, let portal.js handle it
      if (typeof currentConvIsBridge !== 'undefined' && currentConvIsBridge && currentConversationId === msg.conversation_id) return;

      // Admin chat
      if (adminChatConvId && msg.conversation_id === adminChatConvId) {
        var container = document.getElementById('adminChatMessages');
        if (container && container.querySelector('.text-center')) container.innerHTML = '';
        if (container) appendSupportMsg(container, msg);
        if (document.getElementById('adminChatPanel').style.display !== 'none') {
          fetch('/portal/bridge/conversations/' + adminChatConvId + '/read', { method: 'POST' });
        }
      }
      // Delegate chat
      if (delegateChatConvId && msg.conversation_id === delegateChatConvId) {
        var container2 = document.getElementById('delegateChatMessages');
        if (container2 && container2.querySelector('.text-center')) container2.innerHTML = '';
        if (container2) appendSupportMsg(container2, msg);
        if (document.getElementById('delegateChatPanel')?.style.display !== 'none') {
          fetch('/portal/bridge/conversations/' + delegateChatConvId + '/read', { method: 'POST' });
        }
      }
      if (msg.sender_id !== PORTAL_USER.id) {
        playNotificationSound();
        updateSupportBadges();
      }
    });

    function appendSupportMsg(container, msg) {
      var isSent = msg.sender_id === PORTAL_USER.id;
      var cls = isSent ? 'sent' : 'received';
      var time = parseServerDate(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      var content = '';
      if (msg.type === 'file' && msg.attachment) {
        content = renderFileContent(msg.attachment, msg.id, '/portal/bridge/attachment');
      } else {
        content = linkify(escapeHtml(msg.content));
      }
      var ticks = isSent ? '<span class="msg-ticks"><i class="bi bi-check-all"></i></span>' : '';
      container.insertAdjacentHTML('beforeend', '<div class="msg-bubble ' + cls + '" data-bridge-msg-id="' + (msg.id || '') + '"><div class="msg-content">' + content + '</div><div class="msg-footer"><span class="msg-time">' + time + '</span>' + ticks + '</div></div>');
      container.scrollTop = container.scrollHeight;
    }

    // Read receipt — turn ticks blue
    mainSocket.on('bridge:read', function(data) {
      var convId = data.conversation_id;
      var containerId = null;
      if (convId === adminChatConvId) containerId = 'adminChatMessages';
      else if (convId === delegateChatConvId) containerId = 'delegateChatMessages';
      if (!containerId) return;
      var container = document.getElementById(containerId);
      if (!container) return;
      container.querySelectorAll('.msg-bubble.sent .msg-ticks:not(.read)').forEach(function(el) {
        el.classList.add('read');
      });
    });

    // Typing indicator
    var _bridgeTypingTimers = {};

    mainSocket.on('bridge:typing', function(data) {
      var statusEl = null;
      if (data.conversation_id === adminChatConvId) statusEl = document.getElementById('adminSupportStatus');
      else if (data.conversation_id === delegateChatConvId) statusEl = document.getElementById('delegateSupportStatus');
      if (!statusEl) return;
      statusEl.innerHTML = '<span class="bridge-typing"><span class="typing-dots"><span></span><span></span><span></span></span></span>';
      clearTimeout(_bridgeTypingTimers[data.conversation_id]);
      _bridgeTypingTimers[data.conversation_id] = setTimeout(function() {
        if (data.conversation_id === adminChatConvId && statusEl) statusEl.textContent = 'Primary Support';
        else if (statusEl) statusEl.textContent = 'Secondary Support';
      }, 3000);
    });

    mainSocket.on('bridge:typing:stop', function(data) {
      var statusEl = null;
      if (data.conversation_id === adminChatConvId) statusEl = document.getElementById('adminSupportStatus');
      else if (data.conversation_id === delegateChatConvId) statusEl = document.getElementById('delegateSupportStatus');
      if (!statusEl) return;
      clearTimeout(_bridgeTypingTimers[data.conversation_id]);
      if (data.conversation_id === adminChatConvId) statusEl.textContent = 'Primary Support';
      else statusEl.textContent = 'Secondary Support';
    });

    // Emit typing when user types in the input
    function setupBridgeTyping(inputId, getConvId) {
      var el = document.getElementById(inputId);
      if (!el) return;
      var typingTimeout = null;
      el.addEventListener('keydown', function() {
        var convId = getConvId();
        if (!convId) return;
        mainSocket.emit('bridge:typing', { conversation_id: convId });
        clearTimeout(typingTimeout);
        typingTimeout = setTimeout(function() {
          mainSocket.emit('bridge:typing:stop', { conversation_id: convId });
        }, 2000);
      });
    }

    setupBridgeTyping('adminChatInput', function() { return adminChatConvId; });
    setupBridgeTyping('delegateChatInput', function() { return delegateChatConvId; });

    // Handle bridge message delete (both panels)
    mainSocket.on('bridge:message:delete', function(data) {
      var bubble = document.querySelector('[data-bridge-msg-id="' + data.id + '"]');
      if (bubble) {
        bubble.classList.add('deleted');
        var contentEl = bubble.querySelector('.msg-content');
        if (contentEl) contentEl.innerHTML = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
        var delBtn = bubble.querySelector('.bridge-msg-delete');
        if (delBtn) delBtn.remove();
      }
    });

    // Initial badge check + periodic refresh
    updateSupportBadges();
    setInterval(updateSupportBadges, 30000);

    // ── Urgent Line ──────────────────────────────────────────
    var _urgentChatId = null;
    var _urgentWidgetOpen = false;
    var _urgentComposeModalInst = null;

    function openUrgentLine() {
      // Check if there's an active urgent chat first
      fetch('/portal/urgent/active').then(r => r.json()).then(res => {
        if (res.success && res.data.chat) {
          // Already active — open the widget
          _urgentChatId = res.data.chat.id;
          showUrgentWidget(res.data.chat);
        } else {
          // No active — show compose modal
          if (!_urgentComposeModalInst) _urgentComposeModalInst = new bootstrap.Modal(document.getElementById('urgentComposeModal'));
          document.getElementById('urgentComposeMsg').value = '';
