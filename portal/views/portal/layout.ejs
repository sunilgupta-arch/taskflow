          '<thead><tr><th>Date</th><th>Raised By</th><th>Message</th><th>Accepted By</th><th>Status</th><th>Messages</th><th></th></tr></thead>' +
          '<tbody>' + res.data.chats.map(function(c) {
            var dt = new Date(c.created_at);
            var dateStr = dt.toLocaleDateString([], { month: 'short', day: 'numeric' }) + ' ' + dt.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            var statusCls = c.status === 'resolved' ? 'text-success' : c.status === 'accepted' ? 'text-info' : 'text-warning';
            var msg = c.message.length > 50 ? c.message.substring(0, 50) + '...' : c.message;
            var duration = '';
            if (c.resolved_at && c.created_at) {
              var mins = Math.round((new Date(c.resolved_at) - new Date(c.created_at)) / 60000);
              duration = mins < 1 ? '<1m' : mins + 'm';
            }
            return '<tr>' +
              '<td class="text-nowrap">' + dateStr + '</td>' +
              '<td>' + escapeHtml(c.created_by_name) + '</td>' +
              '<td title="' + escapeHtml(c.message) + '">' + escapeHtml(msg) + '</td>' +
              '<td>' + (c.accepted_by_name || '<span class="text-muted">—</span>') + '</td>' +
              '<td><span class="' + statusCls + ' fw-bold" style="font-size:0.72rem;text-transform:uppercase">' + c.status + '</span>' +
                (duration ? ' <span class="text-muted" style="font-size:0.65rem">(' + duration + ')</span>' : '') + '</td>' +
              '<td class="text-center">' + (c.message_count || 0) + '</td>' +
              '<td><button class="btn btn-sm btn-outline-primary" style="font-size:0.65rem;padding:1px 6px" onclick="viewUrgentHistoryDetail(' + c.id + ', \'' + escapeHtml(c.created_by_name) + '\')">View</button></td>' +
            '</tr>';
          }).join('') + '</tbody></table>';
