            var statusCls = c.status === 'resolved' ? 'text-success' : c.status === 'accepted' ? 'text-info' : 'text-warning';
            var msg = c.message.length > 50 ? c.message.substring(0, 50) + '...' : c.message;
            var duration = '';
            if (c.resolved_at && c.created_at) {
              var mins = Math.round((new Date(c.resolved_at) - new Date(c.created_at)) / 60000);
              duration = mins < 1 ? '<1m' : mins + 'm';
            }
            return '<tr>' +
              '<td class="text-nowrap">' + dateStr + '</td>' +
