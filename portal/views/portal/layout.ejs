      // Visual feedback immediately
      var btn = document.querySelector('.urgent-buzzer-btn');
      if (btn) { btn.classList.add('buzzing'); setTimeout(function() { btn.classList.remove('buzzing'); }, 1000); }
      // Hit API endpoint which will emit to all local users
