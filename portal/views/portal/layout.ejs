      _playReqCommentSound();
      var preview = data.body.length > 60 ? data.body.substring(0, 60) + '…' : data.body;
      var date = data.instance_date ? String(data.instance_date).split('T')[0] : '';
      var href = '/portal/requests' + (date ? '?date=' + date : '') + '#open=' + data.instance_id;
      showPortalToast({
