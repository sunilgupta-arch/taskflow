    async function sendUrgent() {
      var msg = document.getElementById('urgentComposeMsg').value.trim();
      if (!msg) return alert('Please write a message');

      try {
        var res = await fetch('/portal/urgent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg })
        });
        var data = await res.json();
        if (!data.success) return alert(data.message || 'Failed');

        _urgentChatId = data.data.chat.id;
        if (_urgentComposeModalInst) _urgentComposeModalInst.hide();

        // Send file attachment if any
        var fileInput = document.getElementById('urgentComposeFile');
        if (fileInput.files.length) {
          var fd = new FormData();
          fd.append('file', fileInput.files[0]);
          await fetch('/portal/urgent/' + _urgentChatId + '/file', { method: 'POST', body: fd });
        }

        showUrgentWidget(data.data.chat);
      } catch (err) {
        alert('Failed to send urgent message');
      }
    }

    function showUrgentWidget(chat) {
      _urgentChatId = chat.id;
      _urgentWidgetOpen = true;
      document.getElementById('urgentWidget').style.display = 'flex';
      document.getElementById('urgentFab').style.display = 'none';

      // Update status
      if (chat.status === 'waiting') {
        document.getElementById('urgentWidgetStatus').textContent = 'Waiting for response...';
        document.getElementById('urgentWidgetStatus').className = 'urgent-widget-status waiting';
      } else if (chat.status === 'accepted') {
        document.getElementById('urgentWidgetStatus').textContent = 'Connected with ' + chat.accepted_by_name;
        document.getElementById('urgentWidgetStatus').className = 'urgent-widget-status connected';
      }
      // Client can always send messages
      document.getElementById('urgentWidgetInput').style.display = '';

      loadUrgentMessages();
