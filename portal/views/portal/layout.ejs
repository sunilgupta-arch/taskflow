          if (!res.success) return;
          // Admin badge
          var adminBadge = document.getElementById('adminChatBadge');
          if (adminBadge) {
            var adminCount = res.data.by_user && res.data.by_user[LOCAL_ADMIN_ID] || 0;
            if (adminCount > 0) { adminBadge.textContent = adminCount; adminBadge.style.display = ''; }
            else { adminBadge.style.display = 'none'; }
          }
          // Delegate badge
          var delBadge = document.getElementById('delegateChatBadge');
          if (delBadge && typeof DELEGATE_ID !== 'undefined') {
            var delCount = res.data.by_user && res.data.by_user[DELEGATE_ID] || 0;
