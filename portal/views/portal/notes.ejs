<div class="notes-container">
  <div class="notes-sidebar" id="notesSidebar">
    <div class="notes-sidebar-header">
      <h6 class="mb-0">My Notes</h6>
      <button class="btn btn-sm btn-primary" onclick="createNewNote()" style="border-radius:8px;">
        <i class="bi bi-plus-lg"></i>
      </button>
    </div>
    <div class="notes-search">
      <input type="text" class="form-control form-control-sm" id="noteSearch" placeholder="Search notes..." oninput="searchNotes()">
    </div>
    <div class="notes-list" id="notesList">
      <div class="text-center text-muted py-4 small">Loading...</div>
    </div>
  </div>

  <div class="notes-editor" id="notesEditor">
    <div class="notes-editor-placeholder" id="notesPlaceholder">
      <i class="bi bi-journal-text" style="font-size:2.5rem;opacity:0.15"></i>
      <p style="color:var(--tf-text-muted);font-size:0.85rem;margin-top:12px;">Select a note or create a new one</p>
    </div>
    <div class="notes-editor-active" id="notesActive" style="display:none">
      <div class="notes-editor-header">
        <input type="text" class="notes-title-input" id="noteTitle" placeholder="Note title..." maxlength="255">
        <div class="notes-editor-actions">
          <button class="topnav-action" id="dictateBtn" onclick="toggleDictation()" title="Dictate">
            <i class="bi bi-mic" id="dictateIcon"></i>
          </button>
          <button class="topnav-action" onclick="saveNote()" title="Save">
            <i class="bi bi-check-lg"></i>
          </button>
          <button class="topnav-action" onclick="deleteNote()" title="Delete" style="color:var(--tf-danger)">
            <i class="bi bi-trash"></i>
          </button>
        </div>
      </div>
      <div class="notes-editor-body">
        <textarea class="notes-content-input" id="noteContent" placeholder="Start typing your note... or click the mic to dictate"></textarea>
      </div>
      <div class="notes-editor-footer">
        <span class="small text-muted" id="noteStatus"></span>
        <span class="small text-muted" id="dictateStatus" style="display:none">
          <span class="dictate-pulse"></span> Listening...
        </span>
      </div>
    </div>
  </div>
</div>
