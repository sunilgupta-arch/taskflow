<div class="reports-page">
  <div class="reports-header">
    <h5 class="mb-0">Links <a href="/portal/help?section=overview" class="portal-help-link" title="Help"><i class="bi bi-question-circle-fill"></i></a></h5>
    <button class="btn btn-sm btn-primary" onclick="showReportModal()"><i class="bi bi-plus-lg me-1"></i>Add Link</button>
  </div>

  <div class="reports-grid" id="reportsGrid">
    <div class="text-center text-muted py-5 small">Loading...</div>
  </div>
</div>

<!-- Add/Edit Link Modal -->
<div class="modal fade" id="reportModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title" id="reportModalTitle">Add Link</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="reportEditId">
        <div class="mb-3">
          <label class="form-label small">Name</label>
          <input type="text" class="form-control form-control-sm" id="reportName" maxlength="255" placeholder="e.g. Sales Dashboard, P&L Report...">
        </div>
        <div class="mb-3">
          <label class="form-label small">URL</label>
          <input type="url" class="form-control form-control-sm" id="reportUrl" placeholder="https://...">
        </div>
        <div class="mb-3">
          <label class="form-label small">Color</label>
          <div class="cal-color-picker">
            <button type="button" class="cal-color-opt selected" data-color="blue" style="background:#3b82f6" onclick="pickReportColor(this)"></button>
            <button type="button" class="cal-color-opt" data-color="green" style="background:#22c55e" onclick="pickReportColor(this)"></button>
            <button type="button" class="cal-color-opt" data-color="red" style="background:#ef4444" onclick="pickReportColor(this)"></button>
            <button type="button" class="cal-color-opt" data-color="amber" style="background:#f59e0b" onclick="pickReportColor(this)"></button>
            <button type="button" class="cal-color-opt" data-color="purple" style="background:#8b5cf6" onclick="pickReportColor(this)"></button>
            <button type="button" class="cal-color-opt" data-color="pink" style="background:#ec4899" onclick="pickReportColor(this)"></button>
            <button type="button" class="cal-color-opt" data-color="cyan" style="background:#06b6d4" onclick="pickReportColor(this)"></button>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-sm btn-primary" onclick="saveReport()">Save</button>
      </div>
    </div>
  </div>
</div>

<script>
const REPORT_COLORS = { blue: '#3b82f6', green: '#22c55e', red: '#ef4444', amber: '#f59e0b', purple: '#8b5cf6', pink: '#ec4899', cyan: '#06b6d4' };

// Icon guessing based on name keywords
function guessIcon(name) {
  const n = name.toLowerCase();
  if (/sales|revenue|income/i.test(n)) return 'bi-graph-up-arrow';
  if (/finance|financial|p&l|profit|loss|accounting/i.test(n)) return 'bi-currency-dollar';
  if (/budget/i.test(n)) return 'bi-wallet2';
  if (/inventory|stock/i.test(n)) return 'bi-box-seam';
  if (/hr|human|employee|staff|payroll/i.test(n)) return 'bi-people';
  if (/marketing|campaign|ads/i.test(n)) return 'bi-megaphone';
  if (/analytics|data|insight/i.test(n)) return 'bi-bar-chart-line';
  if (/dashboard/i.test(n)) return 'bi-speedometer2';
  if (/report/i.test(n)) return 'bi-file-earmark-bar-graph';
  if (/sheet|excel|spreadsheet|csv/i.test(n)) return 'bi-file-earmark-spreadsheet';
  if (/doc|document|word/i.test(n)) return 'bi-file-earmark-text';
  if (/pdf/i.test(n)) return 'bi-file-earmark-pdf';
  if (/presentation|slide|ppt/i.test(n)) return 'bi-easel';
  if (/calendar|schedule/i.test(n)) return 'bi-calendar3';
  if (/task|project|kanban/i.test(n)) return 'bi-kanban';
  if (/customer|client|crm/i.test(n)) return 'bi-person-lines-fill';
  if (/order|purchase/i.test(n)) return 'bi-cart3';
  if (/shipping|delivery|logistics/i.test(n)) return 'bi-truck';
  if (/support|ticket|help/i.test(n)) return 'bi-headset';
  if (/email|mail/i.test(n)) return 'bi-envelope';
  if (/chat|message/i.test(n)) return 'bi-chat-dots';
  if (/map|location|geo/i.test(n)) return 'bi-geo-alt';
  if (/video|youtube|stream/i.test(n)) return 'bi-camera-video';
  if (/drive|cloud|storage/i.test(n)) return 'bi-cloud';
  if (/link|url|web/i.test(n)) return 'bi-link-45deg';
  if (/form|survey/i.test(n)) return 'bi-ui-checks';
  if (/tax/i.test(n)) return 'bi-receipt';
  if (/bank/i.test(n)) return 'bi-bank';
  if (/meeting|zoom|teams/i.test(n)) return 'bi-camera-video';
  return 'bi-file-earmark-bar-graph';
}

let reportModalInstance = null;

function loadReports() {
  fetch('/portal/reports/list')
    .then(r => r.json())
    .then(res => {
      if (!res.success) return;
      renderReports(res.data.reports);
    })
    .catch(() => {});
}

function renderReports(reports) {
  const grid = document.getElementById('reportsGrid');
  if (!reports.length) {
    grid.innerHTML = '<div class="reports-empty"><i class="bi bi-file-earmark-bar-graph" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:10px"></i>No links yet<div class="small text-muted mt-1">Click "Add Link" to add your first link</div></div>';
    return;
  }

  grid.innerHTML = reports.map(r => {
    const c = REPORT_COLORS[r.color] || '#3b82f6';
    const icon = guessIcon(r.name);
    return '<div class="report-card" data-id="' + r.id + '">' +
      '<div class="report-card-actions">' +
        '<button class="report-action-btn" onclick="event.stopPropagation(); event.preventDefault(); editReport(' + r.id + ')" title="Edit"><i class="bi bi-pencil"></i></button>' +
        '<button class="report-action-btn report-action-delete" onclick="event.stopPropagation(); event.preventDefault(); deleteReport(' + r.id + ')" title="Delete"><i class="bi bi-trash"></i></button>' +
      '</div>' +
      '<a href="' + escHtml(r.url) + '" target="_blank" rel="noopener" class="report-card-link">' +
        '<div class="report-card-icon" style="--rc-color:' + c + '"><i class="bi ' + icon + '"></i></div>' +
        '<div class="report-card-name">' + escHtml(r.name) + '</div>' +
        '<div class="report-card-url">' + escHtml(shortenUrl(r.url)) + '</div>' +
      '</a>' +
    '</div>';
  }).join('');
}

function shortenUrl(url) {
  try {
    const u = new URL(url);
    return u.hostname.replace('www.', '');
  } catch (_) {
    return url.length > 30 ? url.substring(0, 30) + '...' : url;
  }
}

function escHtml(s) {
  if (!s) return '';
  var d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

function showReportModal(editData) {
  document.getElementById('reportEditId').value = editData ? editData.id : '';
  document.getElementById('reportName').value = editData ? editData.name : '';
  document.getElementById('reportUrl').value = editData ? editData.url : '';
  document.getElementById('reportModalTitle').textContent = editData ? 'Edit Link' : 'Add Link';

  // Reset color
  document.querySelectorAll('#reportModal .cal-color-opt').forEach(b => b.classList.remove('selected'));
  const activeColor = editData ? editData.color : 'blue';
  const btn = document.querySelector('#reportModal .cal-color-opt[data-color="' + activeColor + '"]');
  if (btn) btn.classList.add('selected');

  if (!reportModalInstance) reportModalInstance = new bootstrap.Modal(document.getElementById('reportModal'));
  reportModalInstance.show();
}

function pickReportColor(btn) {
  document.querySelectorAll('#reportModal .cal-color-opt').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
}

async function saveReport() {
  const id = document.getElementById('reportEditId').value;
  const name = document.getElementById('reportName').value.trim();
  const url = document.getElementById('reportUrl').value.trim();
  const color = document.querySelector('#reportModal .cal-color-opt.selected')?.dataset.color || 'blue';

  if (!name) return alert('Name is required');
  if (!url) return alert('URL is required');

  const endpoint = id ? '/portal/reports/' + id : '/portal/reports';
  const method = id ? 'PUT' : 'POST';

  try {
    const res = await fetch(endpoint, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, url, color })
    });
    const data = await res.json();
    if (data.success) {
      reportModalInstance.hide();
      loadReports();
    } else {
      alert(data.message || 'Failed');
    }
  } catch (_) {
    alert('Network error');
  }
}

async function editReport(id) {
  try {
    const res = await fetch('/portal/reports/list');
    const data = await res.json();
    if (data.success) {
      const r = data.data.reports.find(x => x.id === id);
      if (r) showReportModal(r);
    }
  } catch (_) {}
}

async function deleteReport(id) {
  if (!confirm('Delete this link?')) return;
  try {
    const res = await fetch('/portal/reports/' + id, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) loadReports();
  } catch (_) {}
}

loadReports();
</script>
