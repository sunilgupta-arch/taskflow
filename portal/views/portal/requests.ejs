<%
const isToday = selectedDate === today;
const isPast = selectedDate < today;

function fmtDate(d) {
  if (!d) return '';
  const dt = new Date(d + 'T00:00:00');
  return dt.toLocaleDateString('en-GB', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric' });
}

function prevDate(d) {
  const dt = new Date(d + 'T00:00:00');
  dt.setDate(dt.getDate() - 1);
  return dt.toISOString().split('T')[0];
}

function nextDate(d) {
  const dt = new Date(d + 'T00:00:00');
  dt.setDate(dt.getDate() + 1);
  return dt.toISOString().split('T')[0];
}

function statusBadge(s) {
  if (s === 'done')   return '<span class="badge bg-success">Done</span>';
  if (s === 'picked') return '<span class="badge bg-primary">In Progress</span>';
  if (s === 'missed') return '<span class="badge bg-danger">Missed</span>';
  return '<span class="badge bg-secondary">Pending</span>';
}

function priorityBadge(p) {
  if (p === 'urgent') return '<span class="badge bg-danger">Urgent</span>';
  if (p === 'high')   return '<span class="badge bg-warning text-dark">High</span>';
  return '<span class="badge bg-secondary">Normal</span>';
}

const canCreate = ['CLIENT_ADMIN', 'CLIENT_TOP_MGMT', 'CLIENT_MGMT', 'CLIENT_MANAGER', 'CLIENT_SALES'].includes(user.role_name);
const canDeactivate = ['CLIENT_ADMIN', 'CLIENT_TOP_MGMT'].includes(user.role_name);
const isSalesUser = user.role_name === 'CLIENT_SALES';
%>

<div class="portal-requests-wrap">
<div class="portal-page-header">
  <h5>Allocate Task TI</h5>
  <% if (canCreate) { %>
  <div class="d-flex gap-2">
    <% if (!isSalesUser) { %>
    <button class="btn btn-sm btn-outline-primary" onclick="showCreateRequestModal()">
      <i class="bi bi-plus-lg me-1"></i>New Request
    </button>
    <% } %>
    <button class="btn btn-sm btn-primary" onclick="showQuickRequestModal()">
      <i class="bi bi-lightning-fill me-1"></i>Quick Request
    </button>
  </div>
  <% } %>
</div>

<!-- Date Navigation -->
<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
  <a href="/portal/requests?date=<%= prevDate(selectedDate) %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-left"></i></a>
  <input type="date" value="<%= selectedDate %>" onchange="window.location='/portal/requests?date='+this.value"
         class="form-control form-control-sm" style="width:160px;cursor:pointer;">
  <% if (!isToday) { %>
  <a href="/portal/requests?date=<%= nextDate(selectedDate) %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-right"></i></a>
  <% } %>
  <a href="/portal/requests" class="btn btn-sm btn-outline-primary <%= isToday ? 'disabled' : '' %>"><i class="bi bi-calendar-today me-1"></i>Today</a>
  <span class="ms-auto small text-muted"><strong><%= fmtDate(selectedDate) %></strong></span>
</div>

<!-- Stats (rendered by JS) -->
<div class="d-flex flex-wrap gap-2 mb-3" id="reqStatsBar"></div>

<!-- Instances for this date — rendered by JS (live-updatable) -->
<div id="reqInstancesArea"></div>

<!-- Recurring Requests List (management) -->
<% if (canCreate && requests.length > 0) { %>
<div class="mt-4">
  <div class="d-flex align-items-center justify-content-between mb-2">
    <span class="fw-semibold small text-muted">RECURRING REQUESTS</span>
    <button class="btn btn-xs btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#recurringList">
      <i class="bi bi-chevron-down"></i>
    </button>
  </div>
  <div class="collapse" id="recurringList">
    <table class="portal-table portal-table-sm">
      <thead><tr><th>Title</th><th>Type</th><th>Recurrence</th><th>Start</th><th>Ends</th><th></th></tr></thead>
      <tbody>
        <% requests.filter(r => r.recurrence !== 'none').forEach(function(r) { %>
        <tr>
          <td><%= r.title %></td>
          <td><span class="badge bg-info text-dark small"><%= r.task_type %></span></td>
          <td><%= r.recurrence %></td>
          <td><%= r.start_date %></td>
          <td><%= r.recurrence_end_date || 'Ongoing' %></td>
          <td class="text-end" style="white-space:nowrap">
            <% if (canCreate) { %>
            <button class="btn btn-xs btn-outline-secondary req-edit-btn me-1"
              data-id="<%= r.id %>"
              data-title="<%= r.title %>"
              data-type="<%= r.task_type %>"
              data-priority="<%= r.priority %>"
              data-desc="<%= (r.description||'').replace(/"/g,'&quot;') %>"
              data-duetime="<%= r.due_time||'' %>"
              data-enddate="<%= r.recurrence_end_date||'' %>"
              data-assignto="<%= r.assigned_to||'' %>"
              data-recurrence="<%= r.recurrence %>"
              data-recurrencedays="<%= r.recurrence_days||'' %>"
              title="Edit">
              <i class="bi bi-pencil"></i>
            </button>
            <% } %>
            <% if (canDeactivate) { %>
            <button class="btn btn-xs btn-outline-danger req-deactivate-btn" data-id="<%= r.id %>" title="Stop recurring">Stop</button>
            <% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

</div><!-- /portal-requests-wrap -->

<!-- Detail Modal -->
<div class="modal fade" id="reqDetailModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="reqDetailTitle">Request Detail</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="reqDetailBody">
        <div class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></div>
      </div>
    </div>
  </div>
</div>

<!-- Create Request Modal -->
<% if (canCreate) { %>
<div class="modal fade" id="createRequestModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>New Work Request</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label small fw-semibold">Title <span class="text-danger">*</span></label>
            <input type="text" class="form-control form-control-sm" id="crTitle" placeholder="Brief description of the task">
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Task Type</label>
            <input type="text" class="form-control form-control-sm" id="crTaskType" list="crTaskTypeList" placeholder="e.g. Data Entry, PO Ordering..." value="General">
            <datalist id="crTaskTypeList">
              <% taskTypes.forEach(t => { %><option value="<%= t %>"><% }); %>
            </datalist>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Priority</label>
            <select class="form-select form-select-sm" id="crPriority">
              <option value="normal">Normal</option>
              <option value="high">High</option>
              <option value="urgent">Urgent</option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Description</label>
            <textarea class="form-control form-control-sm" id="crDescription" rows="3" placeholder="Full details, instructions, attachments context..."></textarea>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Start Date</label>
            <input type="date" class="form-control form-control-sm" id="crStartDate" value="<%= today %>">
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Due Time <span class="text-muted fw-normal">(optional)</span></label>
            <input type="time" class="form-control form-control-sm" id="crDueTime">
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Recurrence</label>
            <select class="form-select form-select-sm" id="crRecurrence" onchange="toggleRecurrenceFields()">
              <option value="none">One-time</option>
              <option value="daily">Daily</option>
              <option value="weekly">Weekly</option>
              <option value="monthly">Monthly (same date each month)</option>
            </select>
          </div>
          <div class="col-md-6" id="crEndDateRow" style="display:none">
            <label class="form-label small fw-semibold">End Date <span class="text-muted fw-normal">(optional)</span></label>
            <input type="date" class="form-control form-control-sm" id="crEndDate">
          </div>
          <div class="col-12" id="crWeekDaysRow" style="display:none">
            <label class="form-label small fw-semibold">Repeat on Days</label>
            <div class="d-flex gap-2 flex-wrap">
              <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(function(day, i) { %>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="crDay<%= i %>" value="<%= i %>">
                <label class="form-check-label small" for="crDay<%= i %>"><%= day %></label>
              </div>
              <% }); %>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Assign To <span class="text-muted fw-normal">(leave blank = open queue)</span></label>
            <select class="form-select form-select-sm" id="crAssignTo">
              <option value="">Open Queue (anyone can pick)</option>
              <% localUsers.forEach(function(u) { %>
              <option value="<%= u.id %>"><%= u.name %> (<%= u.role_name %>)</option>
              <% }); %>
            </select>
          </div>
          <div class="col-12" id="crAttachRow">
            <label class="form-label small fw-semibold">Attachment <span class="text-muted fw-normal">(optional, one-time only)</span></label>
            <input type="file" class="form-control form-control-sm" id="crAttachFile">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary btn-sm" onclick="submitCreateRequest()">
          <i class="bi bi-send me-1"></i>Submit Request
        </button>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Quick Request Modal (all canCreate roles) -->
<% if (canCreate) { %>
<div class="modal fade" id="quickRequestModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-lightning-fill me-2"></i>Quick Request</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label small fw-semibold">Title <span class="text-danger">*</span></label>
            <input type="text" class="form-control form-control-sm" id="qrTitle" placeholder="Brief description of the task">
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Task Type</label>
            <input type="text" class="form-control form-control-sm" id="qrTaskType" list="qrTaskTypeList" placeholder="e.g. Data Entry, PO Ordering..." value="General">
            <datalist id="qrTaskTypeList">
              <% taskTypes.forEach(t => { %><option value="<%= t %>"><% }); %>
            </datalist>
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Description</label>
            <textarea class="form-control form-control-sm" id="qrDescription" rows="3" placeholder="Any details or instructions..."></textarea>
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Attachment <span class="text-muted fw-normal">(optional)</span></label>
            <input type="file" class="form-control form-control-sm" id="qrAttachFile">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary btn-sm" onclick="submitQuickRequest()">
          <i class="bi bi-send me-1"></i>Submit
        </button>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Edit Request Modal -->
<% if (canCreate) { %>
<div class="modal fade" id="editRequestModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Request</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="erRequestId">
        <div class="row g-3">
          <!-- Left column: core fields -->
          <div class="col-md-6">
            <div class="row g-2">
              <div class="col-12">
                <label class="form-label small fw-semibold">Title <span class="text-danger">*</span></label>
                <input type="text" class="form-control form-control-sm" id="erTitle">
              </div>
              <div class="col-12" id="erLockNotice" style="display:none">
                <div class="alert alert-warning py-2 px-3 mb-0 small">
                  <i class="bi bi-lock-fill me-1"></i>Task is in progress — schedule fields are locked.
                </div>
              </div>
              <div class="col-6" id="erTaskTypeCol">
                <label class="form-label small fw-semibold">Task Type</label>
                <input type="text" class="form-control form-control-sm" id="erTaskType" list="crTaskTypeList">
              </div>
              <div class="col-6">
                <label class="form-label small fw-semibold">Priority</label>
                <select class="form-select form-select-sm" id="erPriority">
                  <option value="normal">Normal</option>
                  <option value="high">High</option>
                  <option value="urgent">Urgent</option>
                </select>
              </div>
              <div class="col-6" id="erDueTimeCol">
                <label class="form-label small fw-semibold">Due Time <span class="text-muted fw-normal">(opt.)</span></label>
                <input type="time" class="form-control form-control-sm" id="erDueTime">
              </div>
              <div class="col-6" id="erEndDateCol">
                <label class="form-label small fw-semibold">End Date <span class="text-muted fw-normal">(opt.)</span></label>
                <input type="date" class="form-control form-control-sm" id="erEndDate">
              </div>
              <div class="col-12">
                <label class="form-label small fw-semibold">Assign To</label>
                <select class="form-select form-select-sm" id="erAssignTo">
                  <option value="">Open Queue (anyone can pick)</option>
                  <% localUsers.forEach(function(u) { %>
                  <option value="<%= u.id %>"><%= u.name %> (<%= u.role_name %>)</option>
                  <% }); %>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label small fw-semibold">Description</label>
                <textarea class="form-control form-control-sm" id="erDescription" rows="3" style="resize:vertical"></textarea>
              </div>
              <div class="col-12" id="erAttachRow" style="display:none">
                <label class="form-label small fw-semibold">Add Attachment <span class="text-muted fw-normal">(optional)</span></label>
                <input type="file" class="form-control form-control-sm" id="erAttachFile">
              </div>
            </div>
          </div>
          <!-- Right column: schedule -->
          <div class="col-md-6 d-flex flex-column gap-2">
            <div id="erRecurrenceInfoRow" style="display:none">
              <div class="alert alert-info py-2 px-3 mb-0 small">
                <i class="bi bi-info-circle me-1"></i>Schedule changes apply from tomorrow. Past history is preserved.
              </div>
            </div>
            <div id="erRecurrenceTypeRow" style="display:none">
              <label class="form-label small fw-semibold">Recurrence</label>
              <select class="form-select form-select-sm" id="erRecurrence" onchange="toggleErRecurrenceFields()">
                <option value="daily">Daily</option>
                <option value="weekly">Weekly</option>
                <option value="monthly">Monthly (same date each month)</option>
              </select>
            </div>
            <div id="erWeekDaysRow" style="display:none">
              <label class="form-label small fw-semibold">Repeat on Days</label>
              <div class="d-flex gap-2 flex-wrap mt-1">
                <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(function(day, i) { %>
                <div class="form-check form-check-inline me-0">
                  <input class="form-check-input er-day-check" type="checkbox" id="erDay<%= i %>" value="<%= i %>">
                  <label class="form-check-label small" for="erDay<%= i %>"><%= day %></label>
                </div>
                <% }); %>
              </div>
            </div>
            <div id="erSeriesEndRow" style="display:none">
              <label class="form-label small fw-semibold">Series End Date <span class="text-muted fw-normal">(optional — leave blank to run indefinitely)</span></label>
              <input type="date" class="form-control form-control-sm" id="erSeriesEndDate">
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary btn-sm" onclick="submitEditRequest()">
          <i class="bi bi-check-lg me-1"></i>Save Changes
        </button>
      </div>
    </div>
  </div>
</div>
<% } %>

<style>
.portal-requests-wrap { padding: 20px 24px; height:100%; overflow-y:auto; box-sizing:border-box; }
.portal-page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem; }
.portal-page-header h5 { font-size:1rem; font-weight:500; color:var(--tf-text); margin:0; }
.portal-empty-state { text-align:center; padding:3rem 1rem; }
.portal-requests-table-wrap { overflow-x:auto; }
.portal-table { width:100%; border-collapse:collapse; }
.portal-table th { padding:7px 12px; border-bottom:1px solid var(--tf-border); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:.06em; color:var(--tf-muted); }
.portal-table td { padding:9px 12px; border-bottom:1px solid var(--tf-border); font-size:0.875rem; font-weight:400; }
.portal-table-sm th, .portal-table-sm td { padding:5px 10px; font-size:0.8rem; }
.req-row:hover td { background:var(--tf-surface-2); cursor:pointer; }
.req-row-overdue td { background:rgba(220,53,69,0.08); }
.req-row-cancelled td { opacity:0.5; text-decoration:line-through; }
.req-cancelled-toggle { padding:8px 12px; font-size:0.8rem; }
.req-cancelled-toggle a { color:var(--tf-muted); text-decoration:none; }
.req-cancelled-toggle a:hover { color:var(--tf-text); text-decoration:underline; }
.portal-req-detail-link { color:var(--tf-text); }
.portal-req-detail-link:hover { text-decoration:underline !important; }
.btn-xs { padding:2px 8px; font-size:0.72rem; }
.fs-sm { font-size:0.8rem; }
</style>

<script>
(function() {
  const PAGE_DATE  = '<%= selectedDate %>';
  const IS_PAST    = '<%= isPast %>' === 'true';
  const CAN_CREATE = '<%= canCreate %>' === 'true';
  const IS_SALES   = <%- isSalesUser %>;
  const _hashOpen  = (function() { var m = window.location.hash.match(/^#open=(\d+)$/); return m ? parseInt(m[1]) : null; })();
  let _openDetailId = null;

  function escHtml(s) {
    if (!s) return '';
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function statusBadge(s) {
    if (s === 'done')      return '<span class="badge bg-success">Done</span>';
    if (s === 'picked')    return '<span class="badge bg-primary">In Progress</span>';
    if (s === 'missed')    return '<span class="badge bg-danger">Missed</span>';
    if (s === 'cancelled') return '<span class="badge bg-secondary">Cancelled</span>';
    return '<span class="badge bg-secondary">Pending</span>';
  }
  function priorityBadge(p) {
    if (p === 'urgent') return '<span class="badge bg-danger">Urgent</span>';
    if (p === 'high')   return '<span class="badge bg-warning text-dark">High</span>';
    return '<span class="badge bg-secondary">Normal</span>';
  }

  const recLabels = { none: 'One-time', daily: 'Daily', weekly: 'Weekly', monthly: 'Monthly' };

  // ── Render instances table ──────────────────────────────
  function renderInstances(instances) {
    const area = document.getElementById('reqInstancesArea');
    const active    = (instances || []).filter(i => i.status !== 'cancelled');
    const cancelled = (instances || []).filter(i => i.status === 'cancelled');
    if (active.length === 0 && cancelled.length === 0) {
      area.innerHTML = `<div class="portal-empty-state">
        <i class="bi bi-inbox" style="font-size:2rem;color:var(--tf-muted)"></i>
        <p class="mt-2 text-muted">No requests for this date</p>
        ${CAN_CREATE && !IS_PAST ? '<button class="btn btn-sm btn-primary mt-1" onclick="showQuickRequestModal()"><i class="bi bi-lightning-fill me-1"></i>Quick Request</button>' + (IS_SALES ? '' : ' <button class="btn btn-sm btn-outline-primary mt-1" onclick="showCreateRequestModal()"><i class="bi bi-plus-lg me-1"></i>New Request</button>') : ''}
      </div>`;
      return;
    }
    let rows = '';
    const allVisible = [...active, ...cancelled];
    allVisible.forEach((inst, idx) => {
      const isOverdue = IS_PAST && ['open','picked'].includes(inst.status);
      const recLabel = inst.recurrence !== 'none' ? 'recurring' : 'one-time';
      const canEdit = CAN_CREATE && ['open', 'picked'].includes(inst.status);
      const editBtn = canEdit
        ? `<button class="btn btn-xs btn-link p-0 ms-2 req-edit-btn" style="opacity:0.5;vertical-align:baseline"
             data-id="${inst.request_id}"
             data-title="${escHtml(inst.title)}"
             data-type="${escHtml(inst.task_type)}"
             data-priority="${inst.priority}"
             data-desc="${escHtml(inst.description||'')}"
             data-duetime="${inst.due_time||''}"
             data-enddate=""
             data-assignto="${inst.default_assigned_to||''}"
             data-recurrence="${inst.recurrence||'none'}"
             data-status="${inst.status}"
             title="Edit request"><i class="bi bi-pencil" style="font-size:0.7rem"></i></button>`
        : '';
      const deleteBtn = CAN_CREATE && inst.status === 'open'
        ? `<button class="btn btn-xs btn-link p-0 ms-1 req-deactivate-btn" style="opacity:0.5;color:var(--bs-danger);vertical-align:baseline"
             data-id="${inst.request_id}"
             data-recurrence="${inst.recurrence}"
             title="${inst.recurrence !== 'none' ? 'Stop recurring request' : 'Delete request'}"><i class="bi bi-trash" style="font-size:0.7rem"></i></button>`
        : '';
      const cancelBtn = CAN_CREATE && !IS_PAST && inst.status === 'open'
        ? `<button class="btn btn-xs btn-outline-danger req-cancel-btn ms-1" data-id="${inst.id}" title="Cancel this request">✕</button>`
        : '';
      const isCancelled = inst.status === 'cancelled';
      rows += `<tr class="${isOverdue ? 'req-row-overdue' : ''} req-row${isCancelled ? ' req-row-cancelled' : ''}" data-id="${inst.id}" ${isCancelled ? 'style="display:none"' : ''}>
        <td class="text-muted small">${idx + 1}</td>
        <td>
          <a href="#" class="portal-req-detail-link" data-id="${inst.id}">${escHtml(inst.title)}</a>
          ${editBtn}${deleteBtn}
          ${isOverdue ? '<span class="badge bg-danger ms-1 small">Overdue</span>' : ''}
          ${cancelBtn}
        </td>
        <td><span class="badge" style="background:var(--bs-info-bg-subtle);color:var(--bs-info-text-emphasis)">${escHtml(inst.task_type)}</span></td>
        <td class="small text-muted">${recLabels[inst.recurrence] || inst.recurrence}</td>
        <td>${priorityBadge(inst.priority)}</td>
        <td class="small text-muted">${inst.due_time ? inst.due_time.substring(0,5) : '—'}</td>
        <td class="small" title="${escHtml(inst.created_by_name || '—')}">${escHtml((inst.created_by_name || '—').split(' ')[0])}</td>
        <td>${statusBadge(inst.status)}</td>
        <td class="small" title="${escHtml(inst.picked_by_name || inst.completed_by_name || '—')}">${escHtml(((inst.picked_by_name || inst.completed_by_name || '—').split(' ')[0]))}</td>
      </tr>`;
    });
    const cancelledFooter = cancelled.length > 0
      ? `<div class="req-cancelled-toggle" id="reqCancelledToggle">
           <a href="#" onclick="toggleCancelledRows(event)">
             Show ${cancelled.length} cancelled request${cancelled.length > 1 ? 's' : ''}
           </a>
         </div>`
      : '';
    area.innerHTML = `<div class="portal-requests-table-wrap">
      <table class="portal-table" id="requestsTable">
        <thead><tr><th>#</th><th>Title</th><th>Type</th><th>Frequency</th><th>Priority</th><th>Due Time</th><th>Creator</th><th>Status</th><th>Handled By</th></tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>${cancelledFooter}`;
  }

  var _cancelledVisible = false;
  window.toggleCancelledRows = function(e) {
    e.preventDefault();
    _cancelledVisible = !_cancelledVisible;
    document.querySelectorAll('.req-row-cancelled').forEach(function(tr) {
      tr.style.display = _cancelledVisible ? '' : 'none';
    });
    const link = document.querySelector('#reqCancelledToggle a');
    if (link) {
      const n = document.querySelectorAll('.req-row-cancelled').length;
      link.textContent = _cancelledVisible
        ? 'Hide cancelled requests'
        : 'Show ' + n + ' cancelled request' + (n > 1 ? 's' : '');
    }
  };

  // ── Update stats bar ────────────────────────────────────
  function renderStats(stats) {
    const bar = document.getElementById('reqStatsBar');
    if (!bar) return;
    bar.innerHTML = `
      <span class="badge bg-secondary" style="font-size:0.75rem;font-weight:400">${stats.total} Total</span>
      <span class="badge bg-secondary" style="font-size:0.75rem;font-weight:400">${stats.open} Pending</span>
      <span class="badge bg-primary"   style="font-size:0.75rem;font-weight:400">${stats.picked} In Progress</span>
      <span class="badge bg-success"   style="font-size:0.75rem;font-weight:400">${stats.done} Done</span>
      ${stats.missed > 0 ? `<span class="badge bg-danger" style="font-size:0.75rem;font-weight:400">${stats.missed} Missed</span>` : ''}
      ${IS_PAST ? '<span class="badge bg-warning text-dark ms-auto" style="font-size:0.75rem;font-weight:400">Past — read only</span>' : ''}`;
  }

  // ── Load instances from API (live update) ───────────────
  async function loadInstances(date, autoOpenId) {
    try {
      const r = await fetch('/portal/requests/instances?date=' + date, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      const data = await r.json();
      if (data.success) {
        renderInstances(data.data.instances);
        renderStats(data.data.stats);
        updateBadge();
        if (autoOpenId) openReqDetail(autoOpenId);
      }
    } catch (err) { console.error('loadInstances error', err); }
  }

  // ── Badge count update ──────────────────────────────────
  async function updateBadge() {
    try {
      const r = await fetch('/portal/requests/badge', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      const data = await r.json();
      if (data.success) {
        const badge = document.querySelector('.req-nav-badge');
        if (badge) {
          badge.textContent = data.data.count || '';
          badge.style.display = data.data.count > 0 ? '' : 'none';
        }
      }
    } catch {}
  }

  // Initial render from server-side data
  const _initInstances = <%- JSON.stringify(instances) %>;
  const _initStats     = <%- JSON.stringify(stats) %>;
  renderInstances(_initInstances);
  if (_hashOpen) openReqDetail(_hashOpen);

  // ── Create request ──────────────────────────────────────
  window.showCreateRequestModal = function() {
    new bootstrap.Modal(document.getElementById('createRequestModal')).show();
  };

  window.showQuickRequestModal = function() {
    document.getElementById('qrTitle').value = '';
    document.getElementById('qrTaskType').value = 'General';
    document.getElementById('qrDescription').value = '';
    if (document.getElementById('qrAttachFile')) document.getElementById('qrAttachFile').value = '';
    new bootstrap.Modal(document.getElementById('quickRequestModal')).show();
  };

  window.toggleRecurrenceFields = function() {
    const val = document.getElementById('crRecurrence').value;
    document.getElementById('crEndDateRow').style.display = val !== 'none' ? '' : 'none';
    document.getElementById('crWeekDaysRow').style.display = val === 'weekly' ? '' : 'none';
    document.getElementById('crAttachRow').style.display = val === 'none' ? '' : 'none';
  };

  window.submitCreateRequest = async function() {
    const title = document.getElementById('crTitle').value.trim();
    const task_type = document.getElementById('crTaskType').value.trim() || 'General';
    const start_date = document.getElementById('crStartDate').value;
    if (!title) { alert('Title is required'); return; }
    const recurrence = document.getElementById('crRecurrence').value;
    let recurrence_days = null;
    if (recurrence === 'weekly') {
      const checked = [...document.querySelectorAll('[id^="crDay"]:checked')].map(c => c.value);
      if (checked.length === 0) { alert('Select at least one day for weekly recurrence'); return; }
      recurrence_days = checked.join(',');
    }
    const payload = {
      title, task_type, start_date, recurrence, recurrence_days,
      description: document.getElementById('crDescription').value.trim() || null,
      priority: document.getElementById('crPriority').value,
      due_time: document.getElementById('crDueTime').value || null,
      recurrence_end_date: document.getElementById('crEndDate').value || null,
      assigned_to: document.getElementById('crAssignTo').value || null
    };
    try {
      const r = await fetch('/portal/requests', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(payload)
      });
      const data = await r.json();
      if (data.success) {
        const fileInput = document.getElementById('crAttachFile');
        if (fileInput && fileInput.files[0]) {
          const fd = new FormData();
          fd.append('file', fileInput.files[0]);
          await fetch('/portal/requests/' + data.data.id + '/attachments', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd
          }).catch(() => {});
          fileInput.value = '';
        }
        bootstrap.Modal.getInstance(document.getElementById('createRequestModal')).hide();
        loadInstances(PAGE_DATE);
      } else alert(data.message || 'Failed to create request');
    } catch (err) { alert('Error: ' + err.message); }
  };

  // ── Quick Request ───────────────────────────────────────
  window.submitQuickRequest = async function() {
    const title = document.getElementById('qrTitle').value.trim();
    if (!title) { alert('Title is required'); return; }
    const payload = {
      title,
      task_type: document.getElementById('qrTaskType').value.trim() || 'General',
      description: document.getElementById('qrDescription').value.trim() || null,
      priority: 'normal',
      recurrence: 'none',
      start_date: PAGE_DATE,
      due_time: null,
      assigned_to: null
    };
    try {
      const r = await fetch('/portal/requests', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(payload)
      });
      const data = await r.json();
      if (data.success) {
        const fileInput = document.getElementById('qrAttachFile');
        if (fileInput && fileInput.files[0]) {
          const fd = new FormData();
          fd.append('file', fileInput.files[0]);
          await fetch('/portal/requests/' + data.data.id + '/attachments', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd
          }).catch(() => {});
          fileInput.value = '';
        }
        bootstrap.Modal.getInstance(document.getElementById('quickRequestModal')).hide();
        loadInstances(PAGE_DATE);
      } else alert(data.message || 'Failed to create request');
    } catch (err) { alert('Error: ' + err.message); }
  };

  // ── Edit request ────────────────────────────────────────
  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.req-edit-btn');
    if (!btn) return;
    e.stopPropagation();
    document.getElementById('erRequestId').value   = btn.dataset.id;
    document.getElementById('erTitle').value        = btn.dataset.title || '';
    document.getElementById('erTaskType').value     = btn.dataset.type || 'General';
    document.getElementById('erPriority').value     = btn.dataset.priority || 'normal';
    document.getElementById('erDescription').value  = btn.dataset.desc || '';
    document.getElementById('erDueTime').value      = btn.dataset.duetime || '';
    document.getElementById('erEndDate').value      = btn.dataset.enddate || '';
    document.getElementById('erAssignTo').value     = btn.dataset.assignto || '';
    const isPicked = btn.dataset.status === 'picked';
    document.getElementById('erLockNotice').style.display   = isPicked ? '' : 'none';
    document.getElementById('erTaskTypeCol').style.display  = isPicked ? 'none' : '';
    document.getElementById('erDueTimeCol').style.display   = isPicked ? 'none' : '';
    document.getElementById('erEndDateCol').style.display   = isPicked ? 'none' : '';

    const isOneTime = (btn.dataset.recurrence || 'none') === 'none';
    document.getElementById('erAttachRow').style.display = (!isPicked && isOneTime) ? '' : 'none';
    if (document.getElementById('erAttachFile')) document.getElementById('erAttachFile').value = '';

    // Show recurrence fields only when opened from the Recurring Requests list
    // (those buttons carry data-recurrencedays; instance-table buttons do not)
    const hasRecurrenceData = btn.dataset.recurrencedays !== undefined;
    document.getElementById('erRecurrenceInfoRow').style.display = hasRecurrenceData ? '' : 'none';
    document.getElementById('erRecurrenceTypeRow').style.display = hasRecurrenceData ? '' : 'none';
    // Template edit: hide Due Time + left-col End Date; show Series End Date in right column
    document.getElementById('erDueTimeCol').style.display  = hasRecurrenceData ? 'none' : (isPicked ? 'none' : '');
    document.getElementById('erEndDateCol').style.display  = hasRecurrenceData ? 'none' : (isPicked ? 'none' : '');
    document.getElementById('erSeriesEndRow').style.display = hasRecurrenceData ? '' : 'none';
    if (hasRecurrenceData) {
      document.getElementById('erSeriesEndDate').value = btn.dataset.enddate || '';
      const rec = btn.dataset.recurrence || 'daily';
      document.getElementById('erRecurrence').value = rec;
      const activeDays = (btn.dataset.recurrencedays || '').split(',').map(Number).filter(n => n >= 0 && n <= 6);
      document.querySelectorAll('.er-day-check').forEach(cb => {
        cb.checked = activeDays.includes(parseInt(cb.value));
      });
      toggleErRecurrenceFields();
    }

    new bootstrap.Modal(document.getElementById('editRequestModal')).show();
  });

  window.toggleErRecurrenceFields = function() {
    const val = document.getElementById('erRecurrence').value;
    document.getElementById('erWeekDaysRow').style.display = val === 'weekly' ? '' : 'none';
  };

  window.submitEditRequest = async function() {
    const id = document.getElementById('erRequestId').value;
    const title = document.getElementById('erTitle').value.trim();
    if (!title) { alert('Title cannot be empty'); return; }
    const isTemplateEdit = document.getElementById('erRecurrenceTypeRow').style.display !== 'none';
    const payload = {
      title,
      priority:            document.getElementById('erPriority').value,
      description:         document.getElementById('erDescription').value.trim() || '',
      assigned_to:         document.getElementById('erAssignTo').value || ''
    };
    if (!isTemplateEdit) {
      payload.task_type           = document.getElementById('erTaskType').value.trim() || 'General';
      payload.due_time            = document.getElementById('erDueTime').value || '';
      payload.recurrence_end_date = document.getElementById('erEndDate').value || '';
    } else {
      payload.recurrence_end_date = document.getElementById('erSeriesEndDate').value || '';
    }
    if (isTemplateEdit) {
      payload.recurrence = document.getElementById('erRecurrence').value;
      if (payload.recurrence === 'weekly') {
        const checked = [...document.querySelectorAll('.er-day-check:checked')].map(c => c.value);
        if (checked.length === 0) { alert('Select at least one day for weekly recurrence'); return; }
        payload.recurrence_days = checked.join(',');
      } else {
        payload.recurrence_days = null;
      }
    }
    try {
      const r = await fetch('/portal/requests/' + id, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(payload)
      });
      const data = await r.json();
      if (data.success) {
        const fileInput = document.getElementById('erAttachFile');
        if (fileInput && fileInput.files[0]) {
          const fd = new FormData();
          fd.append('file', fileInput.files[0]);
          await fetch('/portal/requests/' + id + '/attachments', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd
          }).catch(() => {});
          fileInput.value = '';
        }
        bootstrap.Modal.getInstance(document.getElementById('editRequestModal')).hide();
        loadInstances(PAGE_DATE);
      } else alert(data.message || 'Failed to update');
    } catch (err) { alert('Error: ' + err.message); }
  };

  // ── Cancel instance ─────────────────────────────────────
  document.addEventListener('click', async function(e) {
    const btn = e.target.closest('.req-cancel-btn');
    if (!btn) return;
    e.stopPropagation();
    if (!confirm('Cancel this request? The local team will no longer see it.')) return;
    const id = btn.dataset.id;
    try {
      const r = await fetch('/portal/requests/instances/' + id + '/cancel', {
        method: 'PATCH', headers: { 'X-Requested-With': 'XMLHttpRequest' }
      });
      const data = await r.json();
      if (data.success) loadInstances(PAGE_DATE);
      else alert(data.message || 'Failed to cancel');
    } catch {}
  });

  // ── Detail modal ────────────────────────────────────────
  const _detailModalEl = document.getElementById('reqDetailModal');
  _detailModalEl.addEventListener('hidden.bs.modal', function() { _openDetailId = null; });

  async function openReqDetail(id) {
    _openDetailId = parseInt(id);
    document.getElementById('reqDetailTitle').textContent = 'Loading...';
    document.getElementById('reqDetailBody').innerHTML = '<div class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></div>';
    bootstrap.Modal.getOrCreateInstance(_detailModalEl).show();
    try {
      const r = await fetch('/portal/requests/instances/' + id, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      const data = await r.json();
      if (!data.success) { document.getElementById('reqDetailBody').innerHTML = '<p class="text-danger">Failed to load</p>'; return; }
      renderReqDetail(data.data);
    } catch { document.getElementById('reqDetailBody').innerHTML = '<p class="text-danger">Error</p>'; }
  }

  document.addEventListener('click', function(e) {
    const link = e.target.closest('.portal-req-detail-link');
    if (!link) return;
    e.preventDefault();
    openReqDetail(link.dataset.id);
  });

  // Row click → detail (but not if clicking a button or the detail link itself)
  document.addEventListener('click', async function(e) {
    const row = e.target.closest('.req-row');
    if (!row) return;
    if (e.target.closest('button,.portal-req-detail-link')) return;
    const id = row.dataset.id;
    document.getElementById('reqDetailTitle').textContent = 'Loading...';
    document.getElementById('reqDetailBody').innerHTML = '<div class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></div>';
    new bootstrap.Modal(document.getElementById('reqDetailModal')).show();
    try {
      const r = await fetch('/portal/requests/instances/' + id, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      const data = await r.json();
      if (data.success) renderReqDetail(data.data);
    } catch {}
  });

  function renderReqDetail(d) {
    const { instance: inst, history, comments, attachments } = d;
    document.getElementById('reqDetailTitle').textContent = inst.title;
    let html = `<div class="row g-3 mb-3">
      <div class="col-6"><div class="small text-muted mb-1">Task Type</div><span class="badge bg-info text-dark">${escHtml(inst.task_type)}</span></div>
      <div class="col-6"><div class="small text-muted mb-1">Priority</div>${priorityBadge(inst.priority)}</div>
      <div class="col-6"><div class="small text-muted mb-1">Recurrence</div>${recLabels[inst.recurrence] || inst.recurrence}</div>
      <div class="col-6"><div class="small text-muted mb-1">Due Time</div>${inst.due_time ? inst.due_time.substring(0,5) : '—'}</div>
      <div class="col-6"><div class="small text-muted mb-1">Status</div>${statusBadge(inst.status)}</div>
      <div class="col-6"><div class="small text-muted mb-1">Handled By</div>${escHtml(inst.picked_by_name || inst.completed_by_name || '—')}</div>
    </div>`;
    if (inst.description) html += `<div class="mb-3"><div class="small text-muted mb-1">Description</div><div class="p-2 rounded" style="background:var(--tf-surface-2);white-space:pre-wrap">${escHtml(inst.description)}</div></div>`;
    if (attachments && attachments.length > 0) {
      html += `<div class="mb-3"><div class="small text-muted mb-1 fw-semibold">Attachments</div>`;
      attachments.forEach(a => {
        html += `<div class="d-flex align-items-center gap-2 mb-1 small">
          <i class="bi bi-paperclip text-muted"></i>
          <a href="${escHtml(a.drive_view_link || '#')}" target="_blank" rel="noopener">${escHtml(a.file_name)}</a>
          <span class="text-muted">(${escHtml(a.uploaded_by_name)})</span>
        </div>`;
      });
      html += `</div>`;
    }
    if (history.length > 0) {
      html += `<div class="mb-3"><div class="small text-muted mb-2 fw-semibold">Timeline</div><ul class="list-group list-group-flush">`;
      history.forEach(h => { html += `<li class="list-group-item px-0 py-1 small"><span class="text-muted">${new Date(h.released_at).toLocaleString()}</span> — returned by <strong>${escHtml(h.released_by_name)}</strong>${h.reason ? ': ' + escHtml(h.reason) : ''}</li>`; });
      html += `</ul></div>`;
    }
    html += `<hr><div class="mb-2 small fw-semibold">Comments</div><div id="reqCommentsList">`;
    if (comments.length === 0) html += `<p class="text-muted small" id="reqNoComments">No comments yet.</p>`;
    comments.forEach(c => {
      const isClient = c.role_name && c.role_name.startsWith('CLIENT');
      html += `<div class="d-flex gap-2 mb-2">
        <div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center text-white small fw-bold" style="width:32px;height:32px;background:${isClient?'#0d6efd':'#198754'}">${c.user_name[0]}</div>
        <div><div class="small fw-semibold">${escHtml(c.user_name)} <span class="text-muted fw-normal">${new Date(c.created_at).toLocaleString()}</span></div>
        <div class="small" style="white-space:pre-wrap">${escHtml(c.body)}</div></div>
      </div>`;
    });
    html += `</div><div class="mt-2 d-flex gap-2">
      <textarea class="form-control form-control-sm flex-grow-1" id="reqCommentInput" rows="2" placeholder="Add a comment..."></textarea>
      <button class="btn btn-sm btn-primary align-self-end" onclick="submitReqComment(${inst.id})">Send</button>
    </div>`;
    document.getElementById('reqDetailBody').innerHTML = html;
  }

  window.submitReqComment = async function(instanceId) {
    const input = document.getElementById('reqCommentInput');
    const body = input.value.trim();
    if (!body) return;
    input.disabled = true;
    try {
      const r = await fetch('/portal/requests/instances/' + instanceId + '/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ body })
      });
      const data = await r.json();
      if (data.success) {
        input.value = '';
        const r2 = await fetch('/portal/requests/instances/' + instanceId, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        const d2 = await r2.json();
        if (d2.success) renderReqDetail(d2.data);
      } else alert(data.message || 'Failed');
    } catch { } finally { input.disabled = false; }
  };

  // ── Deactivate / delete request ─────────────────────────
  document.addEventListener('click', async function(e) {
    const btn = e.target.closest('.req-deactivate-btn');
    if (!btn) return;
    e.stopPropagation();
    const isRecurring = btn.dataset.recurrence && btn.dataset.recurrence !== 'none';
    const msg = isRecurring
      ? 'Stop this recurring request? No new instances will be created after today.'
      : 'Delete this request? It will be removed from the queue.';
    if (!confirm(msg)) return;
    const id = btn.dataset.id;
    try {
      const r = await fetch('/portal/requests/' + id + '/deactivate', { method: 'PATCH', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      const data = await r.json();
      if (data.success) loadInstances(PAGE_DATE);
      else alert(data.message || 'Failed');
    } catch {}
  });

  // ── Live comment callback (called by layout socket handler) ────────
  window.portalReqOnComment = function(data) {
    if (_openDetailId !== data.instance_id) return false;
    const list = document.getElementById('reqCommentsList');
    if (!list) return false;
    const noMsg = document.getElementById('reqNoComments');
    if (noMsg) noMsg.remove();
    const isClient = data.commenter_role && data.commenter_role.startsWith('CLIENT');
    const node = document.createElement('div');
    node.className = 'd-flex gap-2 mb-2';
    node.innerHTML = `<div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center text-white small fw-bold" style="width:32px;height:32px;background:${isClient?'#0d6efd':'#198754'}">${escHtml(data.commenter_name[0])}</div>
      <div><div class="small fw-semibold">${escHtml(data.commenter_name)} <span class="text-muted fw-normal">just now</span></div>
      <div class="small" style="white-space:pre-wrap">${escHtml(data.body)}</div></div>`;
    list.appendChild(node);
    list.scrollIntoView({ behavior: 'smooth', block: 'end' });
    return true;
  };

  // ── Socket.IO: live update without full reload ──────────
  if (typeof io !== 'undefined') {
    const socket = io('/portal');
    socket.on('queue:updated', function() { loadInstances(PAGE_DATE); });
    socket.on('queue:new_request', function() { loadInstances(PAGE_DATE); });
  }

  // Fetch initial badge count
  updateBadge();
})();
</script>
