  </a>

  <a href="/admin/notes" class="adm-card" style="--card-accent:#10b981;--card-rgb:16,185,129">
    <div class="adm-card-icon"><i class="bi bi-journal-text"></i></div>
    <div class="adm-card-body">
      <div class="adm-card-title">Notes</div>
      <div class="adm-card-desc">Shared team notes for SOPs, reference material, and internal documentation</div>
    </div>
    <div class="adm-card-footer"><span>Open Notes</span><i class="bi bi-arrow-right"></i></div>
  </a>

</div>
