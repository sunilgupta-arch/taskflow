<div class="adm-hub-header">
  <div class="adm-section-pill" style="background:rgba(16,185,129,0.1);color:#10b981;border:1px solid rgba(16,185,129,0.2)">
    <i class="bi bi-chat-dots-fill"></i> Communications
  </div>
  <h1 class="adm-hub-title">Communications</h1>
  <p class="adm-hub-sub">Stay connected with your team through chat, announcements, and shared notes</p>
</div>

<div class="adm-cards">

  <a href="/chat" class="adm-card" style="--card-accent:#00d4ff;--card-rgb:0,212,255">
    <div class="adm-card-icon"><i class="bi bi-chat-left-dots-fill"></i></div>
    <div class="adm-card-body">
      <div class="adm-card-title">Local Chat</div>
      <div class="adm-card-desc">Private direct messages and group chats between local team members</div>
    </div>
    <div class="adm-card-footer"><span>Open Chat</span><i class="bi bi-arrow-right"></i></div>
  </a>

  <a href="/channel" class="adm-card" style="--card-accent:#3b82f6;--card-rgb:59,130,246">
    <div class="adm-card-icon"><i class="bi bi-broadcast"></i></div>
    <div class="adm-card-body">
      <div class="adm-card-title">Group Channel</div>
      <div class="adm-card-desc">Team-wide real-time chat with mentions, replies, reactions, pinned messages and file sharing</div>
    </div>
    <div class="adm-card-footer"><span>Open Channel</span><i class="bi bi-arrow-right"></i></div>
  </a>

  <a href="/announcements" class="adm-card" style="--card-accent:#a855f7;--card-rgb:168,85,247">
    <div class="adm-card-icon"><i class="bi bi-megaphone"></i></div>
    <div class="adm-card-body">
      <div class="adm-card-title">Info Board</div>
      <div class="adm-card-desc">Post and manage announcements for your local team or client users — pin important updates</div>
