  <!-- Full docs banner -->
  <div class="hc-banner">
    <i class="bi bi-book hc-banner-icon"></i>
    <div class="hc-banner-body">
      <div class="hc-banner-title">Full Documentation</div>
      <div class="hc-banner-desc">Open the complete Help Center with step-by-step guides, tips, and role-specific walkthroughs</div>
    </div>
    <a href="/help" target="_blank" class="hc-banner-btn">
      <i class="bi bi-box-arrow-up-right"></i> Open Full Docs
    </a>
  </div>

</div><!-- .hc-wrap -->

<script>
function hcFilter(q) {
  var s = q.trim().toLowerCase();
  document.querySelectorAll('.hc-card').forEach(function(c) {
    var title = (c.dataset.title || '').toLowerCase();
    var desc  = (c.querySelector('.hc-card-desc')?.textContent || '').toLowerCase();
    c.dataset.hidden = (!s || title.includes(s) || desc.includes(s)) ? 'false' : 'true';
  });
}
</script>
