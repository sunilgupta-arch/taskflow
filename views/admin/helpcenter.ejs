<style>
@keyframes hcFadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }

/* ── Page ───────────────────────────────────────────────── */
.hc-wrap { animation:hcFadeIn 0.25s ease; }

/* ── Top bar ─────────────────────────────────────────────── */
.hc-topbar { display:flex; align-items:center; gap:12px; margin-bottom:20px; flex-wrap:wrap; }
.hc-topbar-left { flex:1; min-width:0; }
.hc-section-pill {
  display:inline-flex; align-items:center; gap:5px;
  background:rgba(100,116,139,0.12); border:1px solid rgba(100,116,139,0.25);
  color:#94a3b8; border-radius:20px; padding:3px 10px;
  font-family:var(--adm-mono); font-size:0.68rem; font-weight:700; letter-spacing:0.3px; margin-bottom:6px;
}
.hc-page-title { font-family:var(--adm-mono); font-size:1rem; font-weight:700; color:var(--adm-text); }
.hc-page-sub { font-size:0.78rem; color:var(--adm-muted); margin-top:2px; }
.hc-back-btn {
  display:inline-flex; align-items:center; gap:6px;
  background:var(--adm-surface); border:1px solid var(--adm-border);
  color:var(--adm-text-2); border-radius:8px; padding:0 12px; height:34px;
  font-size:0.8rem; text-decoration:none; flex-shrink:0; transition:border-color 0.15s;
}
.hc-back-btn:hover { border-color:var(--adm-border-2); color:var(--adm-text); }

/* ── Search ──────────────────────────────────────────────── */
.hc-search-wrap { position:relative; max-width:420px; margin-bottom:24px; }
.hc-search {
  width:100%; background:var(--adm-surface); border:1px solid var(--adm-border);
  color:var(--adm-text); border-radius:10px; padding:10px 14px 10px 38px;
  font-family:var(--adm-font); font-size:0.84rem; outline:none;
  transition:border-color 0.15s; box-sizing:border-box;
}
.hc-search:focus { border-color:rgba(100,116,139,0.5); }
.hc-search::placeholder { color:var(--adm-muted); }
.hc-search-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--adm-muted); font-size:0.82rem; pointer-events:none; }

/* ── Section label ───────────────────────────────────────── */
.hc-section-lbl {
  font-family:var(--adm-mono); font-size:0.65rem; font-weight:700; letter-spacing:1px;
  text-transform:uppercase; color:var(--adm-muted); margin-bottom:10px;
}

/* ── Topic grid ──────────────────────────────────────────── */
.hc-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px; margin-bottom:28px; }

/* ── Topic card ──────────────────────────────────────────── */
.hc-card {
  background:var(--adm-surface); border:1px solid var(--adm-border);
  border-radius:12px; padding:16px; display:flex; gap:12px; align-items:flex-start;
  text-decoration:none; transition:all 0.18s; cursor:pointer;
  position:relative; overflow:hidden;
}
.hc-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; background:var(--hc-accent,#94a3b8); opacity:0; transition:opacity 0.18s; }
.hc-card:hover { border-color:var(--hc-accent,var(--adm-border-2)); box-shadow:0 4px 18px rgba(0,0,0,0.22); transform:translateY(-1px); }
.hc-card:hover::before { opacity:1; }
.hc-card-icon {
  width:38px; height:38px; border-radius:9px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center; font-size:1.1rem;
  background:rgba(var(--hc-rgb,100,116,139),0.12); color:var(--hc-accent,#94a3b8);
}
.hc-card-body { flex:1; min-width:0; }
.hc-card-title { font-size:0.86rem; font-weight:600; color:var(--adm-text); margin-bottom:3px; line-height:1.3; }
.hc-card-desc { font-size:0.74rem; color:var(--adm-muted); line-height:1.45; }
.hc-card-arrow { font-size:0.7rem; color:var(--adm-muted); flex-shrink:0; margin-top:2px; }
.hc-card:hover .hc-card-arrow { color:var(--hc-accent,#94a3b8); }
.hc-card[data-hidden="true"] { display:none; }

/* ── Full docs banner ────────────────────────────────────── */
.hc-banner {
  background:linear-gradient(135deg,rgba(100,116,139,0.12),rgba(71,85,105,0.08));
  border:1px solid rgba(100,116,139,0.25); border-radius:12px;
  padding:18px 20px; display:flex; align-items:center; gap:16px; flex-wrap:wrap;
}
.hc-banner-icon { font-size:1.8rem; color:#94a3b8; flex-shrink:0; }
.hc-banner-body { flex:1; min-width:0; }
.hc-banner-title { font-size:0.9rem; font-weight:700; font-family:var(--adm-mono); color:var(--adm-text); margin-bottom:3px; }
.hc-banner-desc { font-size:0.78rem; color:var(--adm-muted); }
.hc-banner-btn {
  display:inline-flex; align-items:center; gap:6px; flex-shrink:0;
  background:var(--adm-surface-2); border:1px solid var(--adm-border);
  color:var(--adm-text-2); border-radius:8px; padding:8px 16px;
  font-size:0.8rem; font-family:var(--adm-font); text-decoration:none; transition:all 0.15s;
}
.hc-banner-btn:hover { border-color:var(--adm-border-2); color:var(--adm-text); }
</style>

<div class="hc-wrap">

  <!-- Top bar -->
  <div class="hc-topbar">
    <div class="hc-topbar-left">
      <div class="hc-section-pill"><i class="bi bi-tools"></i> Tools</div>
      <div class="hc-page-title">Help Center</div>
      <div class="hc-page-sub">Guides and documentation to help you use TaskFlow effectively</div>
    </div>
    <% if (user.role_name === 'LOCAL_USER') { %>
    <a href="/admin" class="hc-back-btn"><i class="bi bi-arrow-left"></i> Dashboard</a>
