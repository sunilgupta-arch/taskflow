    </a>
    <a href="/help?topic=backups" target="_blank" class="hc-card" style="--hc-accent:#f97316;--hc-rgb:249,115,22" data-title="Backups">
      <div class="hc-card-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
      <div class="hc-card-body">
        <div class="hc-card-title">Backups</div>
        <div class="hc-card-desc">Creating manual backups, scheduling automatic backups, and restoring</div>
      </div>
      <i class="bi bi-arrow-up-right hc-card-arrow"></i>
    </a>
    <a href="/help?topic=rewards" target="_blank" class="hc-card" style="--hc-accent:#fbbf24;--hc-rgb:251,191,36" data-title="Rewards">
      <div class="hc-card-icon"><i class="bi bi-trophy-fill"></i></div>
