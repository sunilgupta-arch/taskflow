<script>
(function() {
  // Show a toast when the cron fires a task reminder into the system chat
  function attachChatSystemListener() {
    if (typeof admBdrSock === 'undefined') {
      setTimeout(attachChatSystemListener, 500);
      return;
    }
    admBdrSock.on('chat:system', function(data) {
      if (data && data.type === 'task_reminder' && typeof showToast === 'function') {
        showToast('You have a task reminder — check your Messages!', 'info', 9000);
      }
    });
  }
  attachChatSystemListener();
})();
</script>
