    </nav>

    <div class="adm-sidebar-footer">
      <div class="adm-user-row">
        <div class="adm-user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <div style="min-width:0">
          <span class="adm-user-name"><%= user.name %></span>
          <span class="adm-user-role"><%= user.role_name.replace('LOCAL_','') %></span>
        </div>
      </div>
      <div class="adm-footer-btns">
        <a href="/" class="adm-footer-btn" title="Back to classic UI">
          <i class="bi bi-grid"></i> Classic
        </a>
        <a href="/auth/logout" class="adm-footer-btn" title="Sign out">
          <i class="bi bi-box-arrow-right"></i> Sign out
        </a>
      </div>
    </div>
  </aside>

  <!-- ── Main ─────────────────────────────────────────── -->
  <main class="adm-main">
    <div class="adm-topbar">
      <div class="adm-topbar-title"><%= typeof title !== 'undefined' ? title : 'Admin' %></div>
      <span class="adm-clock" id="admClock"></span>
      <a href="/admin/queue" class="adm-queue-btn" id="admQueueBtn" title="Client Queue — unpicked requests" style="display:none">
        <i class="bi bi-inbox-fill"></i>
        <span>Queue</span>
        <span class="adm-queue-count" id="admQueueCount"></span>
      </a>
      <button class="adm-gc-btn" id="admGcBtn" onclick="toggleAdmGc()" title="Group Channel">
        <i class="bi bi-people-fill"></i>
        <span class="adm-gc-badge" id="admGcBadge" style="display:none"></span>
      </button>
      <button class="adm-bridge-btn" id="admBridgeBtn" onclick="toggleAdmBridge()" title="Client Messages">
        <i class="bi bi-chat-dots-fill"></i>
        <span class="adm-bridge-badge" id="admBridgeBadge" style="display:none"></span>
      </button>
      <button class="adm-theme-btn" id="admThemeBtn" onclick="toggleAdmTheme()" title="Toggle theme"></button>
    </div>
    <div class="adm-content">
      <%- body %>
    </div>
