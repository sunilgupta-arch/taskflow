<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<script>(function(){var t=localStorage.getItem('tf-theme')||'dark';document.documentElement.setAttribute('data-bs-theme',t);})()</script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — TaskFlow' : 'TaskFlow Admin' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <%- style %>
  <style>
    /* ── Reset & base ─────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    * { scrollbar-width: thin; scrollbar-color: rgba(100,116,139,0.35) transparent; }
    *::-webkit-scrollbar { width: 4px; height: 4px; }
    *::-webkit-scrollbar-track { background: transparent; }
    *::-webkit-scrollbar-thumb { background: rgba(100,116,139,0.35); border-radius: 10px; }
    *::-webkit-scrollbar-thumb:hover { background: rgba(100,116,139,0.6); }

    /* ── Theme tokens ─────────────────────────────────── */
    :root {
      --adm-font: 'DM Sans', sans-serif;
      --adm-mono: 'Space Mono', monospace;
      --adm-sidebar-w: 240px;
    }

    @keyframes fadeIn  { from { opacity:0; } to { opacity:1; } }
    @keyframes scaleIn { from { opacity:0; transform:scale(0.92); } to { opacity:1; transform:none; } }

    [data-bs-theme="dark"] {
      --adm-bg:          #1a1a1a;
      --adm-sidebar:     #222222;
      --adm-sidebar-2:   #2a2a2a;
      --adm-surface:     #242424;
      --adm-surface-2:   #2e2e2e;
      --adm-border:      #383838;
      --adm-border-2:    #484848;
      --adm-accent:      #00d4ff;
      --adm-text:        #e2e2e2;
      --adm-text-2:      #a0a0a0;
      --adm-muted:       #666666;
      --adm-topbar:      rgba(26,26,26,0.88);
      /* motivation.js compat aliases */
      --tf-surface:      #242424;
      --tf-border:       #383838;
      --tf-text:         #e2e2e2;
      --tf-text-muted:   #a0a0a0;
      --tf-accent:       #00d4ff;
      --tf-success:      #22c55e;
    }

    [data-bs-theme="light"] {
      --adm-bg:          #f0f4f9;
      --adm-sidebar:     #ffffff;
      --adm-sidebar-2:   #f5f8fc;
      --adm-surface:     #ffffff;
      --adm-surface-2:   #f5f8fc;
      --adm-border:      #dde5ef;
      --adm-border-2:    #c8d6e8;
      --adm-accent:      #0284c7;
      --adm-text:        #1a2c3d;
      --adm-text-2:      #3d5568;
      --adm-muted:       #8ca8c0;
      --adm-topbar:      rgba(240,244,249,0.9);
      /* motivation.js compat aliases */
      --tf-surface:      #ffffff;
      --tf-border:       #dde5ef;
      --tf-text:         #1a2c3d;
      --tf-text-muted:   #3d5568;
      --tf-accent:       #0284c7;
      --tf-success:      #16a34a;
    }

    body {
      font-family: var(--adm-font);
      background: var(--adm-bg);
      color: var(--adm-text);
      height: 100vh;
      overflow: hidden;
    }

    /* ── Shell ────────────────────────────────────────── */
    .adm-shell {
      display: flex;
      height: 100vh;
    }

    /* ── Sidebar ──────────────────────────────────────── */
    .adm-sidebar {
      width: var(--adm-sidebar-w);
      height: 100vh;
      background: var(--adm-sidebar);
      border-right: 1px solid var(--adm-border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      position: relative;
      z-index: 10;
    }

    /* Brand */
    .adm-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 20px 20px 18px;
      border-bottom: 1px solid var(--adm-border);
      flex-shrink: 0;
    }
    .adm-brand-mark {
      width: 38px; height: 38px;
      border-radius: 10px;
      background: linear-gradient(135deg, #0284c7, #00d4ff);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--adm-mono);
      font-size: 0.8rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -1px;
      flex-shrink: 0;
    }
    .adm-brand-text { min-width: 0; }
    .adm-brand-name {
      display: block;
      font-family: var(--adm-mono);
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--adm-accent);
      letter-spacing: 0.5px;
      white-space: nowrap;
    }
    .adm-brand-org {
      display: block;
      font-size: 0.7rem;
      color: var(--adm-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Nav */
    .adm-nav {
      flex: 1;
      overflow-y: auto;
      padding: 12px 0;
    }
    .adm-nav-label {
      font-size: 0.6rem;
      font-family: var(--adm-mono);
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: var(--adm-muted);
      padding: 10px 20px 4px;
    }
    .adm-nav-link {
      display: flex;
      align-items: center;
      gap: 11px;
      padding: 9px 14px;
      margin: 1px 8px;
      border-radius: 10px;
      border-left: 2px solid transparent;
      color: var(--adm-text-2);
      font-size: 0.875rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.15s ease;
      cursor: pointer;
    }
    .adm-nav-link:hover {
      background: var(--adm-sidebar-2);
      color: var(--adm-text);
      border-left-color: var(--adm-border-2);
    }
    .adm-nav-link.active {
      background: rgba(0,212,255,0.07);
      color: var(--adm-text);
      border-left-color: var(--adm-accent);
    }
    .adm-nav-icon {
      width: 32px; height: 32px;
      border-radius: 8px;
      background: rgba(255,255,255,0.04);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.95rem;
      flex-shrink: 0;
      transition: background 0.15s, color 0.15s;
      color: var(--adm-muted);
    }
    .adm-nav-link:hover .adm-nav-icon { background: rgba(255,255,255,0.07); color: var(--adm-text-2); }
    .adm-nav-link.active .adm-nav-icon { background: rgba(0,212,255,0.12); color: var(--adm-accent); }

    /* Per-section active colours */
    .adm-nav-link[data-s="work"].active    { background: rgba(59,130,246,0.07);  border-left-color: #3b82f6; }
    .adm-nav-link[data-s="work"].active .adm-nav-icon    { background: rgba(59,130,246,0.14);  color: #3b82f6; }
    .adm-nav-link[data-s="team"].active    { background: rgba(139,92,246,0.07);  border-left-color: #8b5cf6; }
    .adm-nav-link[data-s="team"].active .adm-nav-icon    { background: rgba(139,92,246,0.14);  color: #8b5cf6; }
    .adm-nav-link[data-s="reports"].active { background: rgba(249,115,22,0.07);  border-left-color: #f97316; }
    .adm-nav-link[data-s="reports"].active .adm-nav-icon { background: rgba(249,115,22,0.14);  color: #f97316; }
    .adm-nav-link[data-s="comms"].active   { background: rgba(16,185,129,0.07);  border-left-color: #10b981; }
    .adm-nav-link[data-s="comms"].active .adm-nav-icon   { background: rgba(16,185,129,0.14);  color: #10b981; }
    .adm-nav-link[data-s="tools"].active   { background: rgba(100,116,139,0.07); border-left-color: #64748b; }
    .adm-nav-link[data-s="tools"].active .adm-nav-icon   { background: rgba(100,116,139,0.14); color: #94a3b8; }

    .adm-nav-divider {
      height: 1px;
      background: var(--adm-border);
      margin: 8px 16px;
    }

    /* Sidebar footer */
    .adm-sidebar-footer {
      border-top: 1px solid var(--adm-border);
      padding: 14px 16px;
      flex-shrink: 0;
    }
    .adm-user-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .adm-user-avatar {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: linear-gradient(135deg, #0284c7, #7c3aed);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--adm-mono);
      font-size: 0.75rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }
    .adm-user-name {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--adm-text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .adm-user-role {
      display: block;
      font-size: 0.65rem;
      color: var(--adm-muted);
      font-family: var(--adm-mono);
    }
    .adm-footer-btns {
      display: flex;
      gap: 6px;
    }
    .adm-footer-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 8px;
      border: 1px solid var(--adm-border);
      background: transparent;
      color: var(--adm-muted);
      font-size: 0.75rem;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.15s;
    }
    .adm-footer-btn:hover { border-color: var(--adm-border-2); color: var(--adm-text); background: var(--adm-sidebar-2); }
    .adm-footer-btn i { font-size: 0.85rem; }

    /* ── Change-password modal ────────────────────────────── */
    .adm-cpwd-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.55);
      z-index: 2000; display: none; align-items: center; justify-content: center;
    }
    .adm-cpwd-overlay.open { display: flex; }
    .adm-cpwd-dialog {
      background: var(--adm-surface); border: 1px solid var(--adm-border);
      border-radius: 16px; width: 100%; max-width: 360px; padding: 24px;
      display: flex; flex-direction: column; gap: 16px;
    }
    .adm-cpwd-title {
      font-size: 0.9rem; font-weight: 700; color: var(--adm-text);
      display: flex; align-items: center; gap: 8px; margin: 0;
    }
    .adm-cpwd-title i { color: var(--adm-accent); }
    .adm-cpwd-field { display: flex; flex-direction: column; gap: 5px; }
    .adm-cpwd-label { font-size: 0.7rem; font-family: var(--adm-mono); font-weight: 700; color: var(--adm-muted); text-transform: uppercase; letter-spacing: 0.4px; }
    .adm-cpwd-input {
      height: 38px; padding: 0 12px; border-radius: 9px;
      border: 1px solid var(--adm-border); background: var(--adm-surface-2);
      color: var(--adm-text); font-size: 0.85rem; font-family: var(--adm-font); width: 100%;
    }
    .adm-cpwd-input:focus { outline: none; border-color: var(--adm-accent); }
    .adm-cpwd-msg { font-size: 0.78rem; text-align: center; min-height: 1em; }
    .adm-cpwd-msg.ok  { color: #10b981; }
    .adm-cpwd-msg.err { color: #ef4444; }
    .adm-cpwd-actions { display: flex; gap: 8px; }
    .adm-cpwd-cancel {
      flex: 1; height: 36px; border-radius: 9px; border: 1px solid var(--adm-border);
      background: transparent; color: var(--adm-muted); font-size: 0.8rem;
      cursor: pointer; font-family: var(--adm-font);
    }
    .adm-cpwd-cancel:hover { color: var(--adm-text); border-color: var(--adm-border-2); }
    .adm-cpwd-submit {
      flex: 2; height: 36px; border-radius: 9px; border: none;
      background: var(--adm-accent); color: #000; font-size: 0.8rem;
      font-weight: 700; cursor: pointer; font-family: var(--adm-font);
    }
    .adm-cpwd-submit:hover { opacity: 0.88; }
    .adm-cpwd-submit:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── Main ─────────────────────────────────────────── */
    .adm-main {
      flex: 1;
      min-width: 0;
      height: 100vh;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    /* Topbar */
    .adm-topbar {
      position: sticky;
      top: 0;
      z-index: 5;
      height: 52px;
      background: var(--adm-topbar);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--adm-border);
      display: flex;
      align-items: center;
      padding: 0 24px;
      gap: 16px;
      flex-shrink: 0;
    }
    .adm-topbar-title {
      font-family: var(--adm-mono);
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--adm-text-2);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      flex: 1;
    }
    .adm-clock {
      font-family: var(--adm-mono);
      font-size: 0.72rem;
      color: var(--adm-muted);
    }
    .adm-theme-btn {
      width: 30px; height: 30px;
      border-radius: 8px;
      background: transparent;
      border: 1px solid var(--adm-border);
      color: var(--adm-muted);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem;
      transition: all 0.15s;
    }
    .adm-theme-btn:hover { border-color: var(--adm-accent); color: var(--adm-accent); }

    /* Content */
    .adm-content {
      flex: 1;
      padding: 20px 28px;
    }

    /* ── Hub page shared ──────────────────────────────── */
    .adm-hub-header {
      margin-bottom: 28px;
    }
    .adm-section-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
      font-family: var(--adm-mono);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }
    .adm-hub-title {
      font-family: var(--adm-mono);
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--adm-text);
      line-height: 1.2;
      margin-bottom: 6px;
    }
    .adm-hub-sub {
      font-size: 0.875rem;
      color: var(--adm-muted);
      line-height: 1.5;
    }

    /* ── Back button (shared across sub-pages) ────────── */
    .adm-back-btn {
      display: inline-flex; align-items: center; gap: 5px;
      height: 32px; padding: 0 12px; border-radius: 8px;
      background: var(--adm-surface); border: 1px solid var(--adm-border);
      color: var(--adm-muted); font-size: 0.75rem; font-weight: 600;
      font-family: var(--adm-mono); text-decoration: none; cursor: pointer;
      transition: all 0.15s; white-space: nowrap; flex-shrink: 0;
    }
    .adm-back-btn:hover { border-color: var(--adm-border-2); color: var(--adm-text); }

    /* ── Toasts ───────────────────────────────────────── */
    #_admToastContainer { position:fixed; top:24px; left:50%; transform:translateX(-50%); z-index:9999; display:flex; flex-direction:column; align-items:center; gap:10px; pointer-events:none; }
    .adm-toast { display:flex; align-items:flex-start; gap:10px; min-width:300px; max-width:420px; background:var(--adm-surface-2); border:1px solid var(--adm-border-2); border-top:3px solid var(--adm-accent); border-radius:10px; padding:12px 14px; box-shadow:0 6px 24px rgba(0,0,0,.5); pointer-events:all; animation:admToastIn .2s ease; }
    @keyframes admToastIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }
    .adm-toast-icon { font-size:1rem; color:var(--adm-accent); flex-shrink:0; margin-top:1px; }
    .adm-toast-body { flex:1; min-width:0; }
    .adm-toast-title { font-size:0.78rem; font-weight:600; color:var(--adm-text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .adm-toast-text  { font-size:0.72rem; color:var(--adm-muted); margin-top:2px; line-height:1.4; }
    .adm-toast-close { background:none; border:none; color:var(--adm-muted); font-size:1rem; line-height:1; cursor:pointer; padding:0; flex-shrink:0; }
    .adm-toast-close:hover { color:var(--adm-text); }

    /* ── Cards ────────────────────────────────────────── */
    .adm-cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 16px;
    }
    .adm-card {
      background: var(--adm-surface);
      border: 1px solid var(--adm-border);
      border-radius: 14px;
      padding: 22px;
      text-decoration: none;
      color: var(--adm-text);
      display: flex;
      flex-direction: column;
      gap: 14px;
      transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
      position: relative;
      overflow: hidden;
    }
    .adm-card::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 14px;
      border: 1px solid transparent;
      transition: border-color 0.18s;
      pointer-events: none;
    }
    .adm-card:hover {
      transform: translateY(-3px);
      border-color: var(--card-accent, var(--adm-accent));
      box-shadow: 0 12px 36px rgba(0,0,0,0.35), 0 0 0 1px color-mix(in srgb, var(--card-accent, #00d4ff) 30%, transparent);
      color: var(--adm-text);
      text-decoration: none;
    }
    .adm-card-icon {
      width: 50px; height: 50px;
      border-radius: 13px;
      background: rgba(var(--card-rgb, 0,212,255), 0.1);
      color: var(--card-accent, var(--adm-accent));
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }
    .adm-card-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--adm-text);
      margin-bottom: 5px;
    }
    .adm-card-desc {
      font-size: 0.78rem;
      color: var(--adm-muted);
      line-height: 1.55;
    }
    .adm-card-body { flex: 1; }
    .adm-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 12px;
      border-top: 1px solid var(--adm-border);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--card-accent, var(--adm-accent));
    }

    /* ── Dashboard section cards (larger) ─────────────── */
    .adm-section-cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 16px;
    }
    .adm-section-card {
      background: var(--adm-surface);
      border: 1px solid var(--adm-border);
      border-radius: 16px;
      padding: 28px;
      text-decoration: none;
      color: var(--adm-text);
      display: flex;
      align-items: flex-start;
      gap: 18px;
      transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    }
    .adm-section-card:hover {
      transform: translateY(-3px);
      border-color: var(--card-accent, var(--adm-accent));
      box-shadow: 0 12px 36px rgba(0,0,0,0.35);
      color: var(--adm-text);
      text-decoration: none;
    }
    .adm-section-card-icon {
      width: 54px; height: 54px;
      border-radius: 14px;
      background: rgba(var(--card-rgb, 0,212,255), 0.1);
      color: var(--card-accent, var(--adm-accent));
      display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem;
      flex-shrink: 0;
    }
    .adm-section-card-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--adm-text);
      margin-bottom: 5px;
    }
    .adm-section-card-desc {
      font-size: 0.78rem;
      color: var(--adm-muted);
      line-height: 1.5;
    }
    .adm-section-card-arrow {
      margin-left: auto;
      color: var(--adm-muted);
      font-size: 1rem;
      align-self: center;
      flex-shrink: 0;
      transition: color 0.15s, transform 0.15s;
    }
    .adm-section-card:hover .adm-section-card-arrow {
      color: var(--card-accent, var(--adm-accent));
      transform: translateX(4px);
    }

    /* ── Welcome strip (dashboard) ────────────────────── */
    .adm-welcome {
      background: linear-gradient(135deg, var(--adm-surface) 0%, var(--adm-surface-2) 100%);
      border: 1px solid var(--adm-border-2);
      border-radius: 16px;
      padding: 28px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 32px;
      position: relative;
      overflow: hidden;
    }
    .adm-welcome::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 180px; height: 180px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0,212,255,0.06) 0%, transparent 70%);
    }
    .adm-welcome-greeting {
      font-size: 0.8rem;
      color: var(--adm-muted);
      margin-bottom: 4px;
      font-family: var(--adm-mono);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .adm-welcome-name {
      font-family: var(--adm-mono);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--adm-text);
    }
    .adm-welcome-role {
      font-size: 0.75rem;
      color: var(--adm-accent);
      font-family: var(--adm-mono);
      margin-top: 4px;
    }
    .adm-welcome-date {
      text-align: right;
    }
    .adm-welcome-day {
      font-size: 2rem;
      font-weight: 700;
      font-family: var(--adm-mono);
      color: var(--adm-text);
      line-height: 1;
    }
    .adm-welcome-date-label {
      font-size: 0.72rem;
      color: var(--adm-muted);
      margin-top: 4px;
    }

    /* ── Responsive ───────────────────────────────────── */
    @media (max-width: 768px) {
      .adm-content { padding: 20px 16px; }
      .adm-cards { grid-template-columns: 1fr; }
      .adm-section-cards { grid-template-columns: 1fr; }
    }

    /* ── Notification bell ───────────────────────────── */
    .adm-notif-btn {
      position: relative; width: 34px; height: 34px; border-radius: 9px;
      background: transparent; border: 1px solid var(--adm-border);
      color: var(--adm-muted); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem; transition: all 0.15s; flex-shrink: 0;
    }
    .adm-notif-btn:hover { border-color: var(--adm-accent); color: var(--adm-accent); }
    .adm-notif-btn.has-unread { border-color: #f59e0b; color: #f59e0b; }
    .adm-notif-badge {
      position: absolute; top: -5px; right: -5px;
      background: #ef4444; color: #fff;
      font-size: 0.58rem; font-weight: 700; font-family: var(--adm-mono);
      min-width: 16px; height: 16px; padding: 0 4px;
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
    }
    .adm-notif-dropdown {
      position: fixed; top: 56px; right: 12px;
      width: 340px; max-width: calc(100vw - 24px);
      background: var(--adm-surface); border: 1px solid var(--adm-border);
      border-radius: 14px; box-shadow: 0 8px 32px rgba(0,0,0,0.35);
      z-index: 900; display: none; flex-direction: column;
      max-height: 420px; overflow: hidden;
    }
    .adm-notif-dropdown.open { display: flex; }
    .adm-notif-dd-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 14px; border-bottom: 1px solid var(--adm-border); flex-shrink: 0;
    }
    .adm-notif-dd-title {
      font-size: 0.75rem; font-weight: 700; font-family: var(--adm-mono);
      color: var(--adm-text); text-transform: uppercase; letter-spacing: 0.4px;
    }
    .adm-notif-read-all {
      font-size: 0.68rem; font-family: var(--adm-mono); color: var(--adm-accent);
      background: none; border: none; cursor: pointer; padding: 0;
    }
    .adm-notif-read-all:hover { opacity: 0.75; }
    .adm-notif-list { flex: 1; overflow-y: auto; }
    .adm-notif-item {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 11px 14px; border-bottom: 1px solid var(--adm-border);
      cursor: pointer; transition: background 0.1s; text-decoration: none;
    }
    .adm-notif-item:last-child { border-bottom: none; }
    .adm-notif-item:hover { background: var(--adm-surface-2); }
    .adm-notif-item.unread { background: rgba(0,212,255,0.04); }
    .adm-notif-icon {
      width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center; font-size: 0.82rem;
    }
    .adm-notif-icon.i-task     { background: rgba(59,130,246,0.12);  color: #3b82f6; }
    .adm-notif-icon.i-leave    { background: rgba(16,185,129,0.12);  color: #10b981; }
    .adm-notif-icon.i-default  { background: rgba(100,116,139,0.12); color: #94a3b8; }
    .adm-notif-content { flex: 1; min-width: 0; }
    .adm-notif-item-title {
      font-size: 0.78rem; font-weight: 600; color: var(--adm-text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .adm-notif-item-body {
      font-size: 0.7rem; color: var(--adm-muted); margin-top: 1px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .adm-notif-item-time {
      font-size: 0.62rem; font-family: var(--adm-mono); color: var(--adm-muted);
      margin-top: 3px;
    }
    .adm-notif-unread-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--adm-accent); flex-shrink: 0; margin-top: 4px;
    }
    .adm-notif-empty {
      text-align: center; color: var(--adm-muted);
      font-size: 0.78rem; padding: 30px 16px;
    }

    /* ── Bridge Chat Slide-over ──────────────────────── */
    /* ── Queue notification button ───────────────────── */
    .adm-queue-btn {
      position: relative;
      height: 34px;
      padding: 0 10px;
      border-radius: 9px;
      background: transparent;
      border: 1px solid var(--adm-border);
      color: var(--adm-muted);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      font-size: 0.78rem; font-weight: 600;
      text-decoration: none;
      transition: all 0.15s;
      flex-shrink: 0;
      white-space: nowrap;
    }
    .adm-queue-btn:hover { border-color: #f97316; color: #f97316; text-decoration: none; }
    .adm-queue-btn.has-open {
      border-color: #f97316;
      color: #f97316;
      background: rgba(249,115,22,0.08);
    }
    @keyframes admQueuePulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(249,115,22,0.5); }
      50%       { box-shadow: 0 0 0 5px rgba(249,115,22,0); }
    }
    .adm-queue-btn.has-open { animation: admQueuePulse 2.5s ease-in-out infinite; }
    .adm-queue-count {
      background: #f97316;
      color: #fff;
      font-size: 0.65rem; font-weight: 700;
      padding: 1px 6px; border-radius: 8px;
      min-width: 18px; text-align: center;
    }

    .adm-bridge-btn {
      position: relative;
      width: 34px; height: 34px;
      border-radius: 9px;
      background: transparent;
      border: 1px solid var(--adm-border);
      color: var(--adm-muted);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem;
      transition: all 0.15s;
      flex-shrink: 0;
    }
    .adm-bridge-btn:hover, .adm-bridge-btn.has-unread { border-color: #f59e0b; color: #f59e0b; }
    .adm-bridge-badge {
      position: absolute; top: -4px; right: -4px;
      background: #ef4444; color: #fff;
      font-size: 0.55rem; font-weight: 700;
      padding: 1px 5px; border-radius: 8px;
      min-width: 16px; text-align: center; pointer-events: none;
    }
    .adm-bridge-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 99;
      backdrop-filter: blur(2px);
    }
    .adm-bridge-drawer {
      position: fixed; top: 0; right: 0;
      width: 380px; height: 100vh;
      background: var(--adm-surface);
      border-left: 1px solid var(--adm-border);
      box-shadow: -8px 0 30px rgba(0,0,0,0.3);
      z-index: 100;
      display: flex; flex-direction: column;
      transform: translateX(100%);
      transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
    }
    .adm-bridge-drawer.open { transform: translateX(0); }
    .adm-bridge-drawer-header {
      padding: 14px 16px;
      border-bottom: 1px solid var(--adm-border);
      display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0;
    }
    .adm-bridge-drawer-title {
      font-weight: 600; font-size: 0.9rem; color: var(--adm-text);
      display: flex; align-items: center; gap: 8px;
    }
    /* Bridge conv list inside drawer */
    .adm-bridge-drawer .bdr-conv-list { flex: 1; overflow-y: auto; }
    .adm-bridge-drawer .bdr-conv-item {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px; cursor: pointer;
      transition: background 0.15s;
      border-bottom: 1px solid var(--adm-border);
    }
    .adm-bridge-drawer .bdr-conv-item:hover { background: var(--adm-surface-2); }
    .adm-bridge-drawer .bdr-conv-avatar {
      width: 36px; height: 36px; border-radius: 8px;
      background: linear-gradient(135deg, #0284c7, #7c3aed);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.8rem; color: #fff; flex-shrink: 0;
    }
    .adm-bridge-drawer .bdr-conv-info { flex: 1; min-width: 0; }
    .adm-bridge-drawer .bdr-conv-name { font-size: 0.82rem; font-weight: 600; display: block; color: var(--adm-text); }
    .adm-bridge-drawer .bdr-conv-last { font-size: 0.7rem; color: var(--adm-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .adm-bridge-drawer .bdr-conv-unread {
      background: var(--adm-accent); color: #fff;
      font-size: 0.55rem; font-weight: 700;
      padding: 2px 6px; border-radius: 10px; flex-shrink: 0;
    }
    /* Bridge chat view inside drawer */
    .adm-bridge-drawer .bdr-chat-view { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .adm-bridge-drawer .bdr-chat-header {
      padding: 10px 12px; border-bottom: 1px solid var(--adm-border);
      display: flex; align-items: center; gap: 8px; flex-shrink: 0;
    }
    .adm-bridge-drawer .bdr-back-btn {
      background: none; border: none; color: var(--adm-text-2);
      cursor: pointer; padding: 0 4px 0 0; font-size: 0.9rem; line-height: 1;
    }
    .adm-bridge-drawer .bdr-messages {
      flex: 1; overflow-y: auto; padding: 10px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .adm-bridge-drawer .bdr-messages .bdr-bubble {
      max-width: 80%; padding: 8px 12px;
      font-size: 0.8rem; border-radius: 14px;
      line-height: 1.4; word-wrap: break-word; position: relative;
    }
    .adm-bridge-drawer .bdr-messages .bdr-bubble.sent {
      align-self: flex-end; background: #2563eb; color: #fff; border-bottom-right-radius: 4px;
    }
    .adm-bridge-drawer .bdr-messages .bdr-bubble.received {
      align-self: flex-start; background: var(--adm-surface-2);
      border: 1px solid var(--adm-border); color: var(--adm-text); border-bottom-left-radius: 4px;
    }
    .adm-bridge-drawer .bdr-messages .bdr-bubble.deleted {
      opacity: 0.85; background: var(--adm-surface-2) !important;
      border: 1px dashed var(--adm-border) !important; color: var(--adm-muted) !important;
    }
    .adm-bridge-drawer .bdr-sender-name { font-size: 0.65rem; font-weight: 600; color: #a78bfa; margin-bottom: 2px; }
    .adm-bridge-drawer .bdr-bubble.sent .bdr-footer { color: rgba(255,255,255,0.6); }
    .adm-bridge-drawer .bdr-bubble.received .bdr-footer { color: var(--adm-muted); }
    .adm-bridge-drawer .bdr-time { font-size: 0.55rem; }
    .adm-bridge-drawer .bdr-ticks { font-size: 0.75rem; opacity: 0.5; line-height: 1; }
    .adm-bridge-drawer .bdr-ticks.read { color: #34b7f1; opacity: 1; }
    .adm-bridge-drawer .bdr-delete-btn {
      position: absolute; top: 3px; right: 5px;
      font-size: 0.6rem; opacity: 0; cursor: pointer;
      color: #ef4444; padding: 2px; transition: opacity 0.15s;
      background: none; border: none;
    }
    .adm-bridge-drawer .bdr-bubble:hover .bdr-delete-btn { opacity: 0.6; }
    .adm-bridge-drawer .bdr-delete-btn:hover { opacity: 1 !important; }
    .adm-bridge-drawer .bdr-date-div {
      text-align: center; margin: 8px 0;
      font-size: 0.55rem; color: var(--adm-muted); position: relative;
    }
    .adm-bridge-drawer .bdr-date-div span {
      background: var(--adm-surface); padding: 2px 10px;
      border: 1px solid var(--adm-border); border-radius: 20px; position: relative; z-index: 1;
    }
    .adm-bridge-drawer .bdr-date-div::before {
      content: ''; position: absolute; top: 50%; left: 0; right: 0;
      height: 1px; background: var(--adm-border);
    }
    .adm-bridge-drawer .bdr-img { max-width: 100%; max-height: 160px; border-radius: 8px; display: block; cursor: pointer; }
    .adm-bridge-drawer .bdr-file { display: flex; align-items: center; gap: 6px; color: inherit; text-decoration: none; font-size: 0.75rem; }
    .adm-bridge-drawer .bdr-input-area {
      padding: 10px 12px; border-top: 1px solid var(--adm-border); flex-shrink: 0;
    }
    .adm-bridge-drawer .bdr-input-row { display: flex; gap: 8px; align-items: stretch; }
    .adm-bridge-drawer .bdr-textarea {
      flex: 1; resize: none; min-height: 68px; max-height: 90px;
      font-size: 0.85rem; padding: 8px 10px; border-radius: 10px;
      background: var(--adm-surface-2); border: 1px solid var(--adm-border);
      color: var(--adm-text); font-family: var(--adm-font);
    }
    .adm-bridge-drawer .bdr-textarea:focus { outline: none; border-color: var(--adm-accent); }
    .adm-bridge-drawer .bdr-input-btns { display: flex; flex-direction: column; gap: 4px; }
    .adm-bridge-drawer .bdr-icon-btn {
      width: 36px; height: 32px; border-radius: 8px; flex-shrink: 0;
      border: 1px solid var(--adm-border); background: transparent;
      color: var(--adm-text-2); cursor: pointer;
      display: flex; align-items: center; justify-content: center; font-size: 0.85rem;
    }
    .adm-bridge-drawer .bdr-send-btn {
      width: 36px; flex: 1; border-radius: 8px; flex-shrink: 0;
      border: none; background: #2563eb; color: #fff; cursor: pointer;
      display: flex; align-items: center; justify-content: center; font-size: 0.85rem;
    }

    /* ── Group Channel Drawer ─────────────────────────── */
    .adm-gc-btn {
      position: relative; width: 34px; height: 34px; border-radius: 9px;
      background: transparent; border: 1px solid var(--adm-border);
      color: var(--adm-muted); cursor: pointer;
      display: flex; align-items: center; justify-content: center; font-size: 0.9rem;
      transition: border-color 0.15s, color 0.15s;
    }
    .adm-gc-btn:hover, .adm-gc-btn.active { border-color: #a78bfa; color: #a78bfa; }
    /* Badge */
    .adm-gc-badge {
      position: absolute; top: -5px; right: -5px;
      font-size: 0.58rem; font-weight: 800;
      padding: 0 5px; border-radius: 8px; min-width: 17px; height: 17px;
      display: flex; align-items: center; justify-content: center; pointer-events: none;
    }
    [data-bs-theme="dark"]  .adm-gc-badge { background: #eab308; color: #000; }
    [data-bs-theme="light"] .adm-gc-badge { background: #f97316; color: #fff; }

    /* Bell-shake + glow for dark */
    @keyframes admGcRingD {
      0%, 52%, 100% { transform: rotate(0deg); box-shadow: none; }
      18% { box-shadow: 0 0 0 4px rgba(234,179,8,0.35), 0 0 14px rgba(234,179,8,0.25); }
      56% { transform: rotate(-15deg); } 61% { transform: rotate(15deg); }
      66% { transform: rotate(-11deg); } 71% { transform: rotate(11deg); }
      76% { transform: rotate(-7deg);  } 81% { transform: rotate(7deg);  }
      88% { transform: rotate(0deg); }
    }
    /* Bell-shake + glow for light */
    @keyframes admGcRingL {
      0%, 52%, 100% { transform: rotate(0deg); box-shadow: none; }
      18% { box-shadow: 0 0 0 4px rgba(249,115,22,0.4), 0 0 14px rgba(249,115,22,0.3); }
      56% { transform: rotate(-15deg); } 61% { transform: rotate(15deg); }
      66% { transform: rotate(-11deg); } 71% { transform: rotate(11deg); }
      76% { transform: rotate(-7deg);  } 81% { transform: rotate(7deg);  }
      88% { transform: rotate(0deg); }
    }
    /* Expanding ping ring */
    @keyframes admGcPing {
      0%   { transform: scale(1);   opacity: 0.75; }
      100% { transform: scale(1.9); opacity: 0; }
    }

    [data-bs-theme="dark"]  .adm-gc-btn.has-unread { border-color: #eab308; color: #eab308; animation: admGcRingD 2.8s ease-in-out infinite; }
    [data-bs-theme="light"] .adm-gc-btn.has-unread { border-color: #f97316; color: #f97316; animation: admGcRingL 2.8s ease-in-out infinite; }

    /* Ping ring pseudo-element */
    .adm-gc-btn.has-unread::after {
      content: ''; position: absolute; inset: -2px; border-radius: 11px;
      animation: admGcPing 1.7s ease-out infinite; pointer-events: none;
    }
    [data-bs-theme="dark"]  .adm-gc-btn.has-unread::after { border: 2px solid #eab308; }
    [data-bs-theme="light"] .adm-gc-btn.has-unread::after { border: 2px solid #f97316; }
    .adm-gc-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.4);
      z-index: 1044; backdrop-filter: blur(2px);
    }
    .adm-gc-drawer {
      position: fixed; top: 0; right: 0; height: 100vh; width: 380px;
      background: var(--adm-bg); border-left: 1px solid var(--adm-border);
      box-shadow: -8px 0 30px rgba(0,0,0,0.4); z-index: 1045;
      display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
    }
    .adm-gc-drawer.open { transform: translateX(0); }
    .adm-gc-drawer-header {
      padding: 12px 14px; border-bottom: 1px solid var(--adm-border);
      display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
      background: var(--adm-surface);
    }
    .adm-gc-drawer-title {
      font-weight: 600; font-size: 0.88rem; color: var(--adm-text);
      display: flex; align-items: center; gap: 8px;
    }
    .adm-gc-messages {
      flex: 1; overflow-y: auto; padding: 12px 14px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .adm-gc-bubble {
      max-width: 82%; display: flex; flex-direction: column; gap: 1px;
    }
    .adm-gc-bubble.sent   { align-self: flex-end; align-items: flex-end; }
    .adm-gc-bubble.received { align-self: flex-start; align-items: flex-start; }
    .adm-gc-sender { font-size: 0.62rem; font-weight: 600; color: #a78bfa; margin-bottom: 2px; padding-left: 2px; }
    .adm-gc-content {
      padding: 7px 10px; border-radius: 12px; font-size: 0.82rem; line-height: 1.45;
      word-break: break-word; white-space: pre-wrap;
    }
    .adm-gc-bubble.sent   .adm-gc-content { background: #2563eb; color: #fff; border-bottom-right-radius: 4px; }
    .adm-gc-bubble.received .adm-gc-content { background: var(--adm-surface-2); color: var(--adm-text); border-bottom-left-radius: 4px; }
    .adm-gc-bubble.deleted .adm-gc-content { opacity: 0.5; font-style: italic; }
    .adm-gc-footer { display: flex; align-items: center; gap: 4px; margin-top: 1px; padding: 0 2px; }
    .adm-gc-time { font-size: 0.55rem; color: var(--adm-muted); }
    .adm-gc-date-div {
      display: flex; align-items: center; gap: 8px;
      margin: 8px 0; color: var(--adm-muted); font-size: 0.62rem;
    }
    .adm-gc-date-div::before, .adm-gc-date-div::after {
      content: ''; flex: 1; height: 1px; background: var(--adm-border);
    }
    .adm-gc-img { max-width: 100%; max-height: 160px; border-radius: 8px; display: block; cursor: pointer; }
    .adm-gc-file { display: flex; align-items: center; gap: 6px; color: inherit; text-decoration: none; font-size: 0.75rem; }
    .adm-gc-input-area {
      padding: 10px 12px; border-top: 1px solid var(--adm-border); flex-shrink: 0;
      background: var(--adm-surface);
    }
    .adm-gc-input-row { display: flex; gap: 8px; align-items: stretch; }
    .adm-gc-textarea {
      flex: 1; resize: none; border-radius: 9px; padding: 8px 10px; min-height: 58px;
      background: var(--adm-surface-2); border: 1px solid var(--adm-border);
      color: var(--adm-text); font-family: var(--adm-font); font-size: 0.82rem;
    }
    .adm-gc-textarea:focus { outline: none; border-color: #a78bfa; }
    .adm-gc-input-btns { display: flex; flex-direction: column; gap: 4px; }
    .adm-gc-icon-btn {
      width: 36px; height: 27px; border-radius: 7px; flex-shrink: 0;
      border: 1px solid var(--adm-border); background: var(--adm-surface-2);
      color: var(--adm-muted); cursor: pointer;
      display: flex; align-items: center; justify-content: center; font-size: 0.85rem;
    }
    .adm-gc-send-btn {
      width: 36px; flex: 1; border-radius: 8px; flex-shrink: 0;
      border: none; background: #a78bfa; color: #fff; cursor: pointer;
      display: flex; align-items: center; justify-content: center; font-size: 0.85rem;
    }
  </style>
</head>
<body>
<div id="_admToastContainer"></div>
<div class="adm-shell">

  <!-- ── Sidebar ──────────────────────────────────────── -->
  <aside class="adm-sidebar">
    <div class="adm-brand">
      <div class="adm-brand-mark">TF</div>
      <div class="adm-brand-text">
        <span class="adm-brand-name">TASKFLOW</span>
        <span class="adm-brand-org"><%= user.org_name %></span>
      </div>
    </div>

    <nav class="adm-nav">
      <a href="/admin" data-s="dashboard"
         class="adm-nav-link <%= section === 'dashboard' ? 'active' : '' %>">
        <div class="adm-nav-icon"><i class="bi bi-grid-1x2-fill"></i></div>
        <span>Dashboard</span>
      </a>

      <div class="adm-nav-divider"></div>

      <% if (user.role_name === 'LOCAL_USER') { %>
        <div class="adm-nav-label">My Work</div>

        <a href="/admin/my-tasks" data-s="my-tasks"
           class="adm-nav-link <%= section === 'my-tasks' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-person-check-fill"></i></div>
          <span>My Tasks</span>
        </a>

        <a href="/admin/queue" data-s="queue"
           class="adm-nav-link <%= section === 'queue' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-list-task"></i></div>
          <span>Client Queue</span>
        </a>

        <a href="/admin/leaves" data-s="leaves"
           class="adm-nav-link <%= section === 'leaves' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-calendar-check-fill"></i></div>
          <span>Leaves</span>
        </a>

        <a href="/admin/my-attendance" data-s="my-attendance"
           class="adm-nav-link <%= section === 'my-attendance' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-clock-history"></i></div>
          <span>My Attendance</span>
        </a>

        <a href="/admin/my-progress" data-s="my-progress"
           class="adm-nav-link <%= section === 'my-progress' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-graph-up-arrow"></i></div>
          <span>My Progress</span>
        </a>

        <div class="adm-nav-divider"></div>
        <div class="adm-nav-label">Communicate</div>

        <a href="/admin/comms" data-s="comms"
           class="adm-nav-link <%= section === 'comms' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-chat-dots-fill"></i></div>
          <span>Communications</span>
        </a>

        <a href="/admin/infoboard" data-s="infoboard"
           class="adm-nav-link <%= section === 'infoboard' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-pin-angle-fill"></i></div>
          <span>Info Board</span>
        </a>

        <a href="/admin/notes" data-s="notes"
           class="adm-nav-link <%= section === 'notes' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-journal-text"></i></div>
          <span>Notes</span>
        </a>

        <a href="/admin/helpcenter" data-s="helpcenter"
           class="adm-nav-link <%= section === 'helpcenter' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-question-circle-fill"></i></div>
          <span>Help</span>
        </a>

      <% } else { %>
        <div class="adm-nav-label">Sections</div>

        <a href="/admin/work" data-s="work"
           class="adm-nav-link <%= section === 'work' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-kanban"></i></div>
          <span>Work</span>
        </a>

        <a href="/admin/team" data-s="team"
           class="adm-nav-link <%= section === 'team' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-people-fill"></i></div>
          <span>Team</span>
        </a>

        <a href="/admin/reports" data-s="reports"
           class="adm-nav-link <%= section === 'reports' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-bar-chart-fill"></i></div>
          <span>Reports</span>
        </a>

        <a href="/admin/comms" data-s="comms"
           class="adm-nav-link <%= section === 'comms' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-chat-dots-fill"></i></div>
          <span>Communications</span>
        </a>

        <a href="/admin/tools" data-s="tools"
           class="adm-nav-link <%= section === 'tools' ? 'active' : '' %>">
          <div class="adm-nav-icon"><i class="bi bi-tools"></i></div>
          <span>Tools</span>
        </a>
      <% } %>
    </nav>

    <div class="adm-sidebar-footer">
      <div class="adm-user-row">
        <div class="adm-user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <div style="min-width:0;flex:1">
          <span class="adm-user-name" data-user-name="<%= user.name %>"><%= user.name %></span>
          <span class="adm-user-role" data-user-role="<%= user.role_name %>"><%= user.role_name.replace('LOCAL_','') %></span>
        </div>
        <button onclick="openAdmCpwd()" title="Change password" style="background:none;border:1px solid var(--adm-border);border-radius:7px;color:var(--adm-muted);cursor:pointer;padding:5px 7px;line-height:1;flex-shrink:0;transition:all 0.15s;" onmouseenter="this.style.borderColor='var(--adm-accent)';this.style.color='var(--adm-accent)'" onmouseleave="this.style.borderColor='var(--adm-border)';this.style.color='var(--adm-muted)'">
          <i class="bi bi-key" style="font-size:0.85rem"></i>
        </button>
      </div>
      <div class="adm-footer-btns">
        <a href="<%= user.role_name === 'LOCAL_USER' ? '/tasks' : '/tasks/board' %>" class="adm-footer-btn" title="Back to classic UI">
          <i class="bi bi-grid"></i> Classic
        </a>
        <a href="#" onclick="handleLogout();return false;" class="adm-footer-btn" title="Sign out">
          <i class="bi bi-box-arrow-right"></i> Sign out
        </a>
      </div>
    </div>
  </aside>

  <!-- ── Main ─────────────────────────────────────────── -->
  <main class="adm-main">
    <div class="adm-topbar">
      <div class="adm-topbar-title"><%= typeof title !== 'undefined' ? title : 'Admin' %></div>
      <span class="adm-clock" id="admClock"></span>
      <a href="/admin/queue" class="adm-queue-btn" id="admQueueBtn" title="Client Queue — unpicked requests" style="display:none">
        <i class="bi bi-inbox-fill"></i>
        <span>Queue</span>
        <span class="adm-queue-count" id="admQueueCount"></span>
      </a>
      <button class="adm-notif-btn" id="admNotifBtn" onclick="toggleAdmNotif()" title="Notifications">
        <i class="bi bi-bell-fill"></i>
        <span class="adm-notif-badge" id="admNotifBadge" style="display:none"></span>
      </button>
      <button class="adm-gc-btn" id="admGcBtn" onclick="toggleAdmGc()" title="Group Channel">
        <i class="bi bi-people-fill"></i>
        <span class="adm-gc-badge" id="admGcBadge" style="display:none"></span>
      </button>
      <button class="adm-bridge-btn" id="admBridgeBtn" onclick="toggleAdmBridge()" title="Client Messages">
        <i class="bi bi-chat-dots-fill"></i>
        <span class="adm-bridge-badge" id="admBridgeBadge" style="display:none"></span>
      </button>
      <button class="adm-theme-btn" id="admThemeBtn" onclick="toggleAdmTheme()" title="Toggle theme"></button>
    </div>
    <div class="adm-content">
      <%- body %>
    </div>
  </main>

</div>
<!-- Notification dropdown -->
<div class="adm-notif-dropdown" id="admNotifDropdown">
  <div class="adm-notif-dd-header">
    <span class="adm-notif-dd-title"><i class="bi bi-bell" style="margin-right:6px"></i>Notifications</span>
    <button class="adm-notif-read-all" onclick="admNotifReadAll()">Mark all read</button>
  </div>
  <div class="adm-notif-list" id="admNotifList">
    <div class="adm-notif-empty">Loading…</div>
  </div>
</div>

<!-- Bridge Chat Slide-over Drawer -->
<div class="adm-bridge-overlay" id="admBridgeOverlay" onclick="closeAdmBridge()" style="display:none"></div>
<div class="adm-bridge-drawer" id="admBridgeDrawer">
  <div class="adm-bridge-drawer-header">
    <div class="adm-bridge-drawer-title">
      <i class="bi bi-chat-dots-fill" style="color:#f59e0b"></i> Client Messages
    </div>
    <button class="adm-theme-btn" onclick="closeAdmBridge()" title="Close"><i class="bi bi-x-lg"></i></button>
  </div>
  <!-- Conversation list -->
  <div class="bdr-conv-list" id="admBdrConvList">
    <div class="text-center py-4 small" style="color:var(--adm-muted)">Loading…</div>
  </div>
  <!-- Chat view (hidden initially) -->
  <div class="bdr-chat-view" id="admBdrChatView" style="display:none">
    <div class="bdr-chat-header">
      <button class="bdr-back-btn" onclick="admBdrBackToList()"><i class="bi bi-arrow-left"></i></button>
      <div>
        <div style="font-weight:600;font-size:0.875rem;color:var(--adm-text)" id="admBdrChatName"></div>
        <div style="font-size:0.65rem;color:var(--adm-muted);min-height:14px" id="admBdrTyping"></div>
      </div>
    </div>
    <div class="bdr-messages" id="admBdrMessages"></div>
    <div class="bdr-input-area">
      <input type="file" id="admBdrFile" style="display:none" onchange="admBdrSendFile()">
      <div class="bdr-input-row">
        <textarea class="bdr-textarea" id="admBdrInput" placeholder="Type a message…" rows="2"></textarea>
        <div class="bdr-input-btns">
          <button class="bdr-icon-btn" onclick="document.getElementById('admBdrFile').click()" title="Attach"><i class="bi bi-paperclip"></i></button>
          <button class="bdr-send-btn" onclick="admBdrSend()"><i class="bi bi-send"></i></button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Group Channel Drawer -->
<div class="adm-gc-overlay" id="admGcOverlay" onclick="closeAdmGc()" style="display:none"></div>
<div class="adm-gc-drawer" id="admGcDrawer">
  <div class="adm-gc-drawer-header">
    <div class="adm-gc-drawer-title">
      <i class="bi bi-people-fill" style="color:#a78bfa"></i> Group Channel
    </div>
    <button class="adm-theme-btn" onclick="closeAdmGc()" title="Close"><i class="bi bi-x-lg"></i></button>
  </div>
  <div class="adm-gc-messages" id="admGcMessages">
    <div style="text-align:center;color:var(--adm-muted);padding:24px;font-size:0.82rem">Loading…</div>
  </div>
  <div class="adm-gc-input-area">
    <input type="file" id="admGcFile" style="display:none" onchange="admGcSendFile()">
    <div class="adm-gc-input-row">
      <textarea class="adm-gc-textarea" id="admGcInput" placeholder="Message the team…" rows="2"></textarea>
      <div class="adm-gc-input-btns">
        <button class="adm-gc-icon-btn" onclick="document.getElementById('admGcFile').click()" title="Attach"><i class="bi bi-paperclip"></i></button>
        <button class="adm-gc-send-btn" onclick="admGcSend()"><i class="bi bi-send"></i></button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.2/axios.min.js"></script>
<script src="https://cdn.socket.io/4.7.4/socket.io.min.js"></script>
<script>
  var USER_TIMEZONE = '<%= typeof user !== "undefined" && user.org_timezone ? user.org_timezone : "UTC" %>';

  function autoLogoutWithReason(reason) {
    fetch('/auth/logout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ logout_reason: reason })
    }).finally(function() { window.location.href = '/auth/login'; });
  }

  // Clock
  (function() {
    var el = document.getElementById('admClock');
    function tick() {
      if (!el) return;
      el.textContent = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
    }
    tick(); setInterval(tick, 1000);
  })();

  // Theme
  var _admTheme = localStorage.getItem('tf-theme') || 'dark';
  function applyAdmTheme(t) {
    document.documentElement.setAttribute('data-bs-theme', t);
    var btn = document.getElementById('admThemeBtn');
    if (btn) btn.innerHTML = t === 'dark'
      ? '<i class="bi bi-sun-fill"></i>'
      : '<i class="bi bi-moon-stars-fill"></i>';
  }
  function toggleAdmTheme() {
    _admTheme = _admTheme === 'dark' ? 'light' : 'dark';
    localStorage.setItem('tf-theme', _admTheme);
    applyAdmTheme(_admTheme);
  }
  applyAdmTheme(_admTheme);

  // ── Bridge Chat Slide-over ────────────────────────────────
  var admBdrConvId  = null;
  var admBdrUserId  = <%= user.id %>;
  var admBdrIsOpen  = false;

  function toggleAdmBridge() { admBdrIsOpen ? closeAdmBridge() : openAdmBridge(); }

  function openAdmBridge() {
    admBdrIsOpen = true;
    document.getElementById('admBridgeOverlay').style.display = '';
    document.getElementById('admBridgeDrawer').classList.add('open');
    admBdrLoadConvList();
  }

  function closeAdmBridge() {
    admBdrIsOpen = false;
    document.getElementById('admBridgeOverlay').style.display = 'none';
    document.getElementById('admBridgeDrawer').classList.remove('open');
  }

  function admBdrLoadConvList() {
    document.getElementById('admBdrConvList').style.display = '';
    document.getElementById('admBdrChatView').style.display  = 'none';
    fetch('/bridge/conversations').then(function(r){ return r.json(); }).then(function(res) {
      var convs = (res.data && res.data.conversations) ? res.data.conversations : (res.data || []);
      var list = document.getElementById('admBdrConvList');
      if (!convs.length) {
        list.innerHTML = '<div class="text-center py-4 small" style="color:var(--adm-muted)">No messages yet</div>';
        return;
      }
      list.innerHTML = convs.map(function(c) {
        var name   = c.client_user_name || c.other_user_name || 'Client';
        var unread = c.unread_count > 0 ? '<span class="bdr-conv-unread">'+c.unread_count+'</span>' : '';
        return '<div class="bdr-conv-item" onclick="admBdrOpenChat('+c.id+',\''+name.replace(/'/g,"\\'")+'\')">'+
          '<div class="bdr-conv-avatar">'+name.charAt(0).toUpperCase()+'</div>'+
          '<div class="bdr-conv-info"><span class="bdr-conv-name">'+admEsc(name)+'</span>'+
          '<span class="bdr-conv-last">'+(c.last_message ? admEsc(c.last_message) : '')+'</span></div>'+unread+'</div>';
      }).join('');
    }).catch(function(){});
  }

  function admBdrOpenChat(convId, name) {
    admBdrConvId = convId;
    document.getElementById('admBdrConvList').style.display = 'none';
    document.getElementById('admBdrChatView').style.display  = 'flex';
    document.getElementById('admBdrChatName').textContent    = name;
    document.getElementById('admBdrTyping').textContent      = '';
    admBdrLoadMessages(convId);
    fetch('/bridge/conversations/'+convId+'/read', {method:'POST'}).catch(function(){});
    admBdrUpdateBadge();
  }

  function admBdrBackToList() { admBdrConvId = null; admBdrLoadConvList(); }

  function admBdrLoadMessages(convId) {
    fetch('/bridge/conversations/'+convId+'/messages').then(function(r){ return r.json(); }).then(function(res) {
      admBdrRenderMessages((res.data && res.data.messages) ? res.data.messages : []);
    }).catch(function(){});
  }

  var ADM_IMG_EXTS = ['jpg','jpeg','png','gif','webp','bmp','svg'];
  function admBdrFileIcon(ext) {
    var m = {pdf:{i:'bi-file-earmark-pdf-fill',c:'#ef4444'},doc:{i:'bi-file-earmark-word-fill',c:'#2b7bf0'},docx:{i:'bi-file-earmark-word-fill',c:'#2b7bf0'},xls:{i:'bi-file-earmark-excel-fill',c:'#16a34a'},xlsx:{i:'bi-file-earmark-excel-fill',c:'#16a34a'},zip:{i:'bi-file-earmark-zip-fill',c:'#eab308'},rar:{i:'bi-file-earmark-zip-fill',c:'#eab308'},txt:{i:'bi-file-earmark-text-fill',c:'#9ca3af'}};
    return m[ext] || {i:'bi-file-earmark-fill',c:'#94a3b8'};
  }
  function admBdrRenderFile(att, msgId) {
    var fn = att.file_name, ext = fn.split('.').pop().toLowerCase(), url = '/bridge/attachment/'+msgId;
    if (ADM_IMG_EXTS.indexOf(ext) !== -1) return '<a href="'+url+'" target="_blank"><img src="'+url+'" class="bdr-img" alt="'+admEsc(fn)+'"></a>';
    var short = fn.length>28?fn.substring(0,25)+'…':fn;
    var sz = att.file_size ? (att.file_size<1048576?(att.file_size/1024).toFixed(1)+' KB':(att.file_size/1048576).toFixed(1)+' MB') : '';
    var ic = admBdrFileIcon(ext);
    return '<a class="bdr-file" href="'+url+'" target="_blank"><i class="bi '+ic.i+'" style="color:'+ic.c+';font-size:1.4rem"></i><div><span style="display:block;font-size:0.75rem">'+admEsc(short)+'</span>'+(sz?'<span style="display:block;font-size:0.6rem;opacity:0.6">'+sz+'</span>':'')+'</div></a>';
  }
  function admBdrDateLabel(ts) {
    var d = new Date(ts), now = new Date(), yest = new Date(now);
    yest.setDate(yest.getDate()-1);
    if (d.toDateString()===now.toDateString())  return 'Today';
    if (d.toDateString()===yest.toDateString()) return 'Yesterday';
    return d.toLocaleDateString('en-US',{weekday:'long',month:'short',day:'numeric'});
  }
  function admBdrRenderMessages(msgs) {
    var box = document.getElementById('admBdrMessages');
    if (!msgs.length) { box.innerHTML = '<div class="text-center py-4 small" style="color:var(--adm-muted)">No messages yet</div>'; return; }
    var lastDate = '', html = '';
    msgs.forEach(function(m) {
      var dl = admBdrDateLabel(m.created_at);
      if (dl !== lastDate) { html += '<div class="bdr-date-div"><span>'+dl+'</span></div>'; lastDate = dl; }
      var sent = m.sender_id === admBdrUserId, cls = sent ? 'sent' : 'received';
      var t = new Date(m.created_at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
      var content = '';
      if (m.is_deleted) { content = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>'; }
      else if (m.type==='file' && m.attachment) { content = admBdrRenderFile(m.attachment, m.id); }
      else { var tmp = document.createElement('div'); tmp.textContent = m.content||''; content = tmp.innerHTML; }
      var delBtn  = (sent && !m.is_deleted) ? '<button class="bdr-delete-btn" onclick="event.stopPropagation();admBdrDeleteMsg('+m.id+')" title="Delete"><i class="bi bi-trash"></i></button>' : '';
      var sender  = (!sent && m.sender_name) ? '<div class="bdr-sender-name">'+admEsc(m.sender_name)+'</div>' : '';
      var ticks   = '';
      if (sent && !m.is_deleted) ticks = m.is_read ? '<span class="bdr-ticks read"><i class="bi bi-check-all"></i></span>' : '<span class="bdr-ticks"><i class="bi bi-check-all"></i></span>';
      html += '<div class="bdr-bubble '+cls+(m.is_deleted?' deleted':'')+'" data-bdr-mid="'+m.id+'">'+delBtn+sender+'<div class="bdr-content">'+content+'</div><div class="bdr-footer"><span class="bdr-time">'+t+'</span>'+ticks+'</div></div>';
    });
    box.innerHTML = html;
    box.scrollTop = box.scrollHeight;
  }

  window.admBdrSend = function() {
    var inp = document.getElementById('admBdrInput'), txt = inp.value.trim();
    if (!txt || !admBdrConvId) return;
    inp.value = '';
    fetch('/bridge/conversations/'+admBdrConvId+'/messages', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({content:txt})})
      .then(function(){ fetch('/bridge/conversations/'+admBdrConvId+'/read',{method:'POST'}); })
      .catch(function(){});
  };

  window.admBdrSendFile = function() {
    var f = document.getElementById('admBdrFile').files[0];
    if (!f || !admBdrConvId) return;
    if (f.size > 10*1024*1024) { alert('File too large. Max 10 MB.'); return; }
    var fd = new FormData(); fd.append('file', f);
    fetch('/bridge/conversations/'+admBdrConvId+'/file', {method:'POST',body:fd})
      .then(function(){ admBdrLoadMessages(admBdrConvId); fetch('/bridge/conversations/'+admBdrConvId+'/read',{method:'POST'}); })
      .finally(function(){ document.getElementById('admBdrFile').value=''; });
  };

  window.admBdrDeleteMsg = function(msgId) {
    if (!confirm('Delete this message?')) return;
    fetch('/bridge/messages/'+msgId, {method:'DELETE'}).catch(function(){});
  };

  document.getElementById('admBdrInput').addEventListener('keydown', function(e) {
    if (e.key==='Enter' && !e.shiftKey) { e.preventDefault(); admBdrSend(); }
  });

  function admBdrUpdateBadge() {
    fetch('/bridge/unread-count').then(function(r){ return r.json(); }).then(function(res) {
      if (!res.success) return;
      var badge = document.getElementById('admBridgeBadge'), btn = document.getElementById('admBridgeBtn');
      if (res.data.total > 0) { badge.textContent = res.data.total; badge.style.display = ''; btn.classList.add('has-unread'); }
      else { badge.style.display = 'none'; btn.classList.remove('has-unread'); }
    }).catch(function(){});
  }

  function admEsc(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Group Channel Drawer ─────────────────────────────
  var admGcIsOpen  = false;
  var admGcUserId  = <%= user.id %>;
  var admGcLoaded  = false;
  var admGcUnread  = 0;
  var _admGcLastReadKey = 'gc-last-read-' + admGcUserId;

  function admGcSetBadge(n) {
    admGcUnread = n;
    var badge = document.getElementById('admGcBadge'), btn = document.getElementById('admGcBtn');
    if (!badge || !btn) return;
    if (n > 0) {
      badge.textContent = n > 99 ? '99+' : n;
      badge.style.display = '';
      btn.classList.add('has-unread');
    } else {
      badge.style.display = 'none';
      btn.classList.remove('has-unread');
    }
  }

  function toggleAdmGc() { admGcIsOpen ? closeAdmGc() : openAdmGc(); }

  function openAdmGc() {
    admGcIsOpen = true;
    document.getElementById('admGcOverlay').style.display = '';
    document.getElementById('admGcDrawer').classList.add('open');
    document.getElementById('admGcBtn').classList.add('active');
    admGcSetBadge(0);
    if (!admGcLoaded) admGcLoad();
  }

  function closeAdmGc() {
    admGcIsOpen = false;
    document.getElementById('admGcOverlay').style.display = 'none';
    document.getElementById('admGcDrawer').classList.remove('open');
    document.getElementById('admGcBtn').classList.remove('active');
  }

  function admGcLoad() {
    fetch('/channel/messages').then(function(r){ return r.json(); }).then(function(res) {
      if (!res.success) return;
      admGcLoaded = true;
      var msgs = res.data.messages.slice().reverse();
      admGcRenderMessages(msgs);
      if (msgs.length) {
        var latestId = msgs[msgs.length - 1].id;
        var lastRead = parseInt(localStorage.getItem(_admGcLastReadKey) || '0', 10);
        if (latestId > lastRead) localStorage.setItem(_admGcLastReadKey, String(latestId));
      }
    }).catch(function(){});
  }

  var GC_IMG_EXTS = ['jpg','jpeg','png','gif','webp'];
  function admGcRenderFile(att, msgId) {
    if (!att) return '<em style="opacity:0.5">File</em>';
    var url = att.drive_view_link || '#';
    var fn  = att.file_name || 'file';
    var ext = fn.split('.').pop().toLowerCase();
    if (GC_IMG_EXTS.indexOf(ext) !== -1) return '<a href="'+url+'" target="_blank"><img src="'+url+'" class="adm-gc-img" alt="'+admEsc(fn)+'"></a>';
    var icons = {pdf:'bi-file-earmark-pdf-fill',doc:'bi-file-earmark-word-fill',docx:'bi-file-earmark-word-fill',xls:'bi-file-earmark-excel-fill',xlsx:'bi-file-earmark-excel-fill',zip:'bi-file-earmark-zip-fill'};
    var ic = icons[ext] || 'bi-file-earmark-fill';
    return '<a class="adm-gc-file" href="'+url+'" target="_blank"><i class="bi '+ic+'" style="font-size:1.4rem"></i><span>'+admEsc(fn)+'</span></a>';
  }

  function admGcRenderMessages(messages) {
    var box = document.getElementById('admGcMessages');
    if (!messages.length) {
      box.innerHTML = '<div style="text-align:center;color:var(--adm-muted);padding:24px;font-size:0.82rem">No messages yet. Say hello!</div>';
      return;
    }
    var html = '', lastDate = '';
    messages.forEach(function(m) {
      var sent = m.sender_id === admGcUserId;
      var cls  = sent ? 'sent' : 'received';
      var t    = new Date(m.created_at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
      var dl   = new Date(m.created_at).toLocaleDateString([],{month:'short',day:'numeric'});
      if (dl !== lastDate) { html += '<div class="adm-gc-date-div"><span>'+dl+'</span></div>'; lastDate = dl; }
      var content = m.is_deleted ? '<em>This message was deleted</em>'
        : (m.type==='file' && m.attachment ? admGcRenderFile(m.attachment, m.id)
          : (function(){ var d=document.createElement('div'); d.textContent=m.content||''; return d.innerHTML; })());
      var sender = !sent ? '<div class="adm-gc-sender">'+admEsc(m.sender_name||'')+'</div>' : '';
      html += '<div class="adm-gc-bubble '+cls+(m.is_deleted?' deleted':'')+'" data-gc-mid="'+m.id+'">'
        +sender+'<div class="adm-gc-content">'+content+'</div>'
        +'<div class="adm-gc-footer"><span class="adm-gc-time">'+t+'</span></div></div>';
    });
    box.innerHTML = html;
    box.scrollTop = box.scrollHeight;
  }

  function admGcAppend(m) {
    var box  = document.getElementById('admGcMessages');
    var sent = m.sender_id === admGcUserId;
    var cls  = sent ? 'sent' : 'received';
    var t    = new Date(m.created_at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    var content = m.type==='file' && m.attachment ? admGcRenderFile(m.attachment, m.id)
      : (function(){ var d=document.createElement('div'); d.textContent=m.content||''; return d.innerHTML; })();
    var sender = !sent ? '<div class="adm-gc-sender">'+admEsc(m.sender_name||'')+'</div>' : '';
    var el = document.createElement('div');
    el.className = 'adm-gc-bubble '+cls;
    el.setAttribute('data-gc-mid', m.id);
    el.innerHTML = sender+'<div class="adm-gc-content">'+content+'</div>'
      +'<div class="adm-gc-footer"><span class="adm-gc-time">'+t+'</span></div>';
    var placeholder = box.querySelector('div[style*="No messages"]');
    if (placeholder) box.innerHTML = '';
    box.appendChild(el);
    box.scrollTop = box.scrollHeight;
  }

  window.admGcSend = function() {
    var inp = document.getElementById('admGcInput');
    var txt = inp ? inp.value.trim() : '';
    if (!txt) return;
    inp.value = '';
    fetch('/channel/messages', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({content:txt})})
      .catch(function(){});
  };

  window.admGcSendFile = function() {
    var f = document.getElementById('admGcFile').files[0];
    if (!f) return;
    if (f.size > 5*1024*1024) { alert('File too large. Max 5 MB.'); return; }
    var fd = new FormData(); fd.append('file', f);
    fetch('/channel/file', {method:'POST', body:fd}).catch(function(){});
    document.getElementById('admGcFile').value = '';
  };

  document.getElementById('admGcInput').addEventListener('keydown', function(e) {
    if (e.key==='Enter' && !e.shiftKey) { e.preventDefault(); admGcSend(); }
  });

  // ── Continuous queue bell + tab title blink ─────────────
  var _admBellCtx        = null;
  var _admBellInterval   = null;
  var _admBellActive     = false;
  var _admTitleInterval  = null;
  var _admOrigTitle      = document.title;
  var _admBellUnlocked   = false;
  var _admBellPending    = false; // ring as soon as user interacts

  // Create AudioContext and play a silent pulse to fully unlock it
  function _admUnlockAudio() {
    if (_admBellUnlocked) return;
    try {
      if (!_admBellCtx) _admBellCtx = new (window.AudioContext || window.webkitAudioContext)();
      var p = _admBellCtx.resume();
      if (p && p.then) {
        p.then(function() {
          // Play a truly silent buffer to satisfy autoplay policy
          var buf = _admBellCtx.createBuffer(1, 1, 22050);
          var src = _admBellCtx.createBufferSource();
          src.buffer = buf; src.connect(_admBellCtx.destination); src.start(0);
          _admBellUnlocked = true;
          // If a bell was pending while audio was locked, play it now
          if (_admBellPending) { _admBellPending = false; _admPlayBell(); }
        }).catch(function(){});
      }
    } catch(e) {}
  }

  // Unlock on first user interaction
  document.addEventListener('click',   _admUnlockAudio, { once: false });
  document.addEventListener('keydown', _admUnlockAudio, { once: false });

  function _admPlayBell() {
    if (!_admBellCtx || _admBellCtx.state !== 'running') {
      _admBellPending = true; // play as soon as ctx unlocks
      return;
    }
    try {
      var ctx = _admBellCtx, now = ctx.currentTime;
      [[659, 0.20], [1318, 0.10], [1975, 0.05]].forEach(function(p) {
        var osc = ctx.createOscillator(), g = ctx.createGain();
        osc.type = 'sine'; osc.frequency.value = p[0];
        osc.connect(g); g.connect(ctx.destination);
        g.gain.setValueAtTime(p[1], now);
        g.gain.exponentialRampToValueAtTime(0.001, now + 2.0);
        osc.start(now); osc.stop(now + 2.1);
      });
    } catch(e) {}
  }

  function _admStartTitleBlink() {
    if (_admTitleInterval) return;
    _admOrigTitle = document.title;
    var show = true;
    _admTitleInterval = setInterval(function() {
      document.title = show ? '(🔔) New Request' : _admOrigTitle;
      show = !show;
    }, 1000);
  }

  function _admStopTitleBlink() {
    if (_admTitleInterval) { clearInterval(_admTitleInterval); _admTitleInterval = null; }
    document.title = _admOrigTitle;
  }

  function _admStartBell() {
    if (_admBellActive) return;
    _admBellActive = true;
    _admUnlockAudio();
    _admStartTitleBlink();
    _admPlayBell();
    _admBellInterval = setInterval(function() {
      if (!_admBellActive) { clearInterval(_admBellInterval); _admBellInterval = null; return; }
      _admPlayBell();
    }, 4000);
  }

  function _admStopBell() {
    _admBellActive  = false;
    _admBellPending = false;
    if (_admBellInterval) { clearInterval(_admBellInterval); _admBellInterval = null; }
    _admStopTitleBlink();
  }

  // Stop when user returns to the tab that has the queue page open
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden && window.admqIsQueuePage) _admStopBell();
  });
  window.addEventListener('focus', function() {
    if (window.admqIsQueuePage) _admStopBell();
  });

  // ── Client Queue badge ───────────────────────────────────
  function admQueueUpdateBadge() {
    fetch('/queue/badge').then(function(r){ return r.json(); }).then(function(res) {
      if (!res.success) return;
      var count = res.data.count || 0;
      var btn   = document.getElementById('admQueueBtn');
      var badge = document.getElementById('admQueueCount');
      if (count > 0) {
        badge.textContent = count;
        btn.style.display = '';
        btn.classList.add('has-open');
      } else {
        btn.style.display = 'none';
        btn.classList.remove('has-open');
        _admStopBell();
      }
    }).catch(function(){});
  }
  admQueueUpdateBadge();

  // Socket.IO live updates
  if (typeof io !== 'undefined') {
    var admBdrSock = io('/', {withCredentials:true});

    admBdrSock.on('bridge:message', function(msg) {
      // If drawer is open on this conversation, append message
      if (admBdrIsOpen && msg.conversation_id === admBdrConvId) {
        var box = document.getElementById('admBdrMessages');
        if (box.querySelector('.text-center')) box.innerHTML = '';
        var sent = msg.sender_id === admBdrUserId, cls = sent?'sent':'received';
        var t = new Date(msg.created_at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
        var content = '';
        if (msg.type==='file'&&msg.attachment) content = admBdrRenderFile(msg.attachment, msg.id);
        else { var tmp2=document.createElement('div'); tmp2.textContent=msg.content||''; content=tmp2.innerHTML; }
        var sender = (!sent&&msg.sender_name)?'<div class="bdr-sender-name">'+admEsc(msg.sender_name)+'</div>':'';
        var delBtn = sent?'<button class="bdr-delete-btn" onclick="event.stopPropagation();admBdrDeleteMsg('+msg.id+')" title="Delete"><i class="bi bi-trash"></i></button>':'';
        box.insertAdjacentHTML('beforeend','<div class="bdr-bubble '+cls+'" data-bdr-mid="'+msg.id+'">'+delBtn+sender+'<div class="bdr-content">'+content+'</div><div class="bdr-footer"><span class="bdr-time">'+t+'</span></div></div>');
        box.scrollTop = box.scrollHeight;
        if (!sent) fetch('/bridge/conversations/'+admBdrConvId+'/read',{method:'POST'}).catch(function(){});
      }

      // Incoming message from client
      if (msg.sender_id !== admBdrUserId) {
        if (!admBdrIsOpen) {
          admBdrUpdateBadge();
          // Auto-open drawer and open the conversation
          openAdmBridge();
          admBdrOpenChat(msg.conversation_id, msg.sender_name || 'Client');
        } else if (msg.conversation_id !== admBdrConvId) {
          admBdrUpdateBadge();
        }
        // Play notification sound
        try {
          var ac = new (window.AudioContext||window.webkitAudioContext)();
          var o = ac.createOscillator(), g = ac.createGain();
          o.connect(g); g.connect(ac.destination);
          o.type='sine'; o.frequency.setValueAtTime(880,ac.currentTime); o.frequency.setValueAtTime(1046,ac.currentTime+0.1);
          g.gain.setValueAtTime(0.15,ac.currentTime); g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+0.3);
          o.start(ac.currentTime); o.stop(ac.currentTime+0.3);
        } catch(e) {}
      }

      // Refresh conv list if it's visible
      if (admBdrIsOpen && document.getElementById('admBdrConvList').style.display !== 'none') {
        admBdrLoadConvList();
      }
    });

    admBdrSock.on('bridge:message:delete', function(data) {
      if (data.conversation_id === admBdrConvId) {
        var bubble = document.querySelector('#admBdrMessages [data-bdr-mid="'+data.id+'"]');
        if (bubble) {
          bubble.classList.add('deleted');
          var ce = bubble.querySelector('.bdr-content');
          if (ce) ce.innerHTML = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
          var db = bubble.querySelector('.bdr-delete-btn');
          if (db) db.remove();
        }
      }
    });

    admBdrUpdateBadge();

    // Group Channel live events
    admBdrSock.on('channel:message', function(msg) {
      if (admGcLoaded) admGcAppend(msg);
      if (msg.sender_id !== admGcUserId && !admGcIsOpen) {
        admGcSetBadge(admGcUnread + 1);
        // Store latest msg id so page-load badge check works across sessions
        var lastRead = parseInt(localStorage.getItem(_admGcLastReadKey) || '0', 10);
        if (msg.id > lastRead) localStorage.setItem('gc-last-msg-' + admGcUserId, String(msg.id));
        // Play notification tone
        try {
          var _ac = new (window.AudioContext || window.webkitAudioContext)();
          var _now = _ac.currentTime;
          [784, 1046].forEach(function(freq, i) {
            var o = _ac.createOscillator(), g = _ac.createGain();
            o.type = 'sine'; o.frequency.value = freq; o.connect(g); g.connect(_ac.destination);
            var t = _now + i * 0.08;
            g.gain.setValueAtTime(0, t); g.gain.linearRampToValueAtTime(0.11, t + 0.02); g.gain.exponentialRampToValueAtTime(0.001, t + 0.22);
            o.start(t); o.stop(t + 0.25);
          });
        } catch(e) {}
      }
    });
    admBdrSock.on('channel:message:delete', function(data) {
      var bubble = document.querySelector('#admGcMessages [data-gc-mid="'+data.id+'"]');
      if (bubble) { bubble.classList.add('deleted'); var c=bubble.querySelector('.adm-gc-content'); if(c) c.innerHTML='<em>This message was deleted</em>'; }
    });

    // Initial unread count on page load (compare localStorage last-read vs last-received)
    (function() {
      var lastRead = parseInt(localStorage.getItem(_admGcLastReadKey) || '0', 10);
      var lastMsg  = parseInt(localStorage.getItem('gc-last-msg-' + admGcUserId) || '0', 10);
      if (lastMsg > lastRead) {
        // Do a quick fetch to count exact unreads
        fetch('/channel/messages').then(function(r){ return r.json(); }).then(function(res) {
          if (!res.success) return;
          var msgs = res.data.messages || [];
          var unread = msgs.filter(function(m){ return m.id > lastRead && m.sender_id !== admGcUserId; }).length;
          if (unread > 0) admGcSetBadge(unread);
          // Update last-msg to latest known
          if (msgs.length) localStorage.setItem('gc-last-msg-' + admGcUserId, String(Math.max.apply(null, msgs.map(function(m){return m.id;}))));
        }).catch(function(){});
      }
    })();

    // Queue live events
    admBdrSock.on('queue:new_request', function() {
      admQueueUpdateBadge();
      if (!window.admqIsQueuePage) _admStartBell();
      if (typeof window.admqSocketCallback === 'function') window.admqSocketCallback();
    });
    admBdrSock.on('queue:updated', function() {
      admQueueUpdateBadge();
      if (typeof window.admqSocketCallback === 'function') window.admqSocketCallback();
    });
    admBdrSock.on('request:comment', function(data) {
      var preview = data.body.length > 60 ? data.body.substring(0, 60) + '…' : data.body;
      _admShowToast(data.title, data.commenter_name + ': ' + preview, data.instance_id);
      _admPlayCommentSound();
      if (typeof window.admqOnComment === 'function') window.admqOnComment(data);
    });
  }

  var _typeAccent = { success: '#22c55e', error: '#ef4444', warning: '#f59e0b', info: 'var(--adm-accent)' };
  function showToast(message, type, duration) {
    var c = document.getElementById('_admToastContainer');
    if (!c) return;
    var accent = _typeAccent[type] || _typeAccent.info;
    var t = document.createElement('div');
    t.className = 'adm-toast';
    t.style.borderTopColor = accent;
    t.innerHTML = '<div class="adm-toast-body" style="flex:1"><div class="adm-toast-text" style="color:var(--adm-text);font-size:0.8rem">' + _admEsc(message) + '</div></div>'
      + '<button class="adm-toast-close" onclick="this.parentElement.remove()">&times;</button>';
    c.appendChild(t);
    setTimeout(function() { if (t.parentElement) t.remove(); }, duration || 4000);
  }

  function _admPlayCommentSound() {
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      [[880, 0, 0.13], [1108, 0.11, 0.16]].forEach(function(p) {
        var osc = ctx.createOscillator(), g = ctx.createGain();
        osc.type = 'sine'; osc.frequency.value = p[0];
        osc.connect(g); g.connect(ctx.destination);
        g.gain.setValueAtTime(0, ctx.currentTime + p[1]);
        g.gain.linearRampToValueAtTime(0.25, ctx.currentTime + p[1] + 0.01);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + p[1] + p[2]);
        osc.start(ctx.currentTime + p[1]);
        osc.stop(ctx.currentTime + p[1] + p[2] + 0.01);
      });
    } catch(e) {}
  }

  function _admShowToast(title, text, instanceId) {
    var c = document.getElementById('_admToastContainer');
    if (!c) return;
    var t = document.createElement('div');
    t.className = 'adm-toast';
    t.innerHTML = '<div class="adm-toast-icon"><i class="bi bi-chat-left-text-fill"></i></div>'
      + '<div class="adm-toast-body"><div class="adm-toast-title">' + _admEsc(title) + '</div>'
      + '<div class="adm-toast-text">' + _admEsc(text) + '</div></div>'
      + '<button class="adm-toast-close" onclick="this.parentElement.remove()">&times;</button>';
    if (instanceId) t.style.cursor = 'pointer';
    t.addEventListener('click', function(e) {
      if (e.target.classList.contains('adm-toast-close')) return;
      if (instanceId) window.location.href = '/admin/queue';
    });
    c.appendChild(t);
    setTimeout(function() { if (t.parentElement) t.remove(); }, 6000);
  }
  function _admEsc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
<!-- ── Notifications ──────────────────────────────────────────── -->
<script>
(function() {
  var _notifOpen = false;
  var _notifs    = [];

  function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function timeAgo(dateStr) {
    var diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
    if (diff < 60)   return 'just now';
    if (diff < 3600) return Math.floor(diff/60) + 'm ago';
    if (diff < 86400)return Math.floor(diff/3600) + 'h ago';
    return Math.floor(diff/86400) + 'd ago';
  }

  function iconClass(type) {
    if (type === 'task_assigned') return 'i-task bi-person-check-fill';
    if (type === 'leave_approved' || type === 'leave_granted') return 'i-leave bi-calendar-check-fill';
    return 'i-default bi-bell-fill';
  }

  function updateBadge(count) {
    var badge = document.getElementById('admNotifBadge');
    var btn   = document.getElementById('admNotifBtn');
    if (count > 0) {
      badge.textContent = count > 99 ? '99+' : count;
      badge.style.display = 'flex';
      btn.classList.add('has-unread');
    } else {
      badge.style.display = 'none';
      btn.classList.remove('has-unread');
    }
  }

  function renderList() {
    var list = document.getElementById('admNotifList');
    if (!_notifs.length) {
      list.innerHTML = '<div class="adm-notif-empty"><i class="bi bi-bell-slash" style="font-size:1.5rem;opacity:0.3;display:block;margin-bottom:8px"></i>No notifications yet</div>';
      return;
    }
    var html = '';
    _notifs.forEach(function(n) {
      var ic = iconClass(n.type).split(' ');
      var linkAttr = n.link ? 'href="' + esc(n.link) + '"' : 'href="#"';
      html += '<a ' + linkAttr + ' class="adm-notif-item' + (n.is_read ? '' : ' unread') + '" onclick="admNotifMarkRead(' + n.id + ',this,event)">' +
        '<div class="adm-notif-icon ' + esc(ic[0]) + '"><i class="bi ' + esc(ic[1]) + '"></i></div>' +
        '<div class="adm-notif-content">' +
          '<div class="adm-notif-item-title">' + esc(n.title) + '</div>' +
          '<div class="adm-notif-item-body">' + esc(n.body || '') + '</div>' +
          '<div class="adm-notif-item-time">' + timeAgo(n.created_at) + '</div>' +
        '</div>' +
        (n.is_read ? '' : '<div class="adm-notif-unread-dot"></div>') +
      '</a>';
    });
    list.innerHTML = html;
  }

  function loadNotifications() {
    fetch('/notifications', { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(res) {
        if (!res.success) return;
        _notifs = res.data.notifications;
        updateBadge(res.data.unreadCount);
        renderList();
      }).catch(function(){});
  }

  window.toggleAdmNotif = function() {
    var dd = document.getElementById('admNotifDropdown');
    _notifOpen = !_notifOpen;
    dd.classList.toggle('open', _notifOpen);
    if (_notifOpen) loadNotifications();
  };

  window.admNotifMarkRead = function(id, el, e) {
    if (!el.getAttribute('href') || el.getAttribute('href') === '#') e.preventDefault();
    var notif = _notifs.find(function(n){ return n.id === id; });
    if (notif && !notif.is_read) {
      notif.is_read = 1;
      fetch('/notifications/' + id + '/read', { method: 'POST', credentials: 'same-origin' }).catch(function(){});
      var unread = _notifs.filter(function(n){ return !n.is_read; }).length;
      updateBadge(unread);
      renderList();
    }
  };

  window.admNotifReadAll = function() {
    _notifs.forEach(function(n){ n.is_read = 1; });
    updateBadge(0);
    renderList();
    fetch('/notifications/read-all', { method: 'POST', credentials: 'same-origin' }).catch(function(){});
  };

  /* Close dropdown when clicking outside */
  document.addEventListener('click', function(e) {
    if (!_notifOpen) return;
    var btn = document.getElementById('admNotifBtn');
    var dd  = document.getElementById('admNotifDropdown');
    if (!btn.contains(e.target) && !dd.contains(e.target)) {
      _notifOpen = false;
      dd.classList.remove('open');
    }
  });

  /* Socket listener for real-time notifications */
  document.addEventListener('DOMContentLoaded', function() {
    loadNotifications();
    if (typeof io !== 'undefined') {
      var sock = typeof admBdrSock !== 'undefined' ? admBdrSock : io('/', { withCredentials: true });
      sock.on('notification:new', function(notif) {
        _notifs.unshift(notif);
        if (_notifs.length > 30) _notifs.pop();
        var unread = _notifs.filter(function(n){ return !n.is_read; }).length;
        updateBadge(unread);
        if (_notifOpen) renderList();
      });
    }
  });
})();
</script>

<!-- ── Change password modal ──────────────────────────────────── -->
<div class="adm-cpwd-overlay" id="admCpwdOverlay" onclick="if(event.target===this)closeAdmCpwd()">
  <div class="adm-cpwd-dialog">
    <p class="adm-cpwd-title"><i class="bi bi-key-fill"></i> Change Password</p>
    <div class="adm-cpwd-field">
      <label class="adm-cpwd-label">New Password</label>
      <input type="password" class="adm-cpwd-input" id="admCpwdNew" placeholder="Min. 6 characters" autocomplete="new-password">
    </div>
    <div class="adm-cpwd-field">
      <label class="adm-cpwd-label">Confirm Password</label>
      <input type="password" class="adm-cpwd-input" id="admCpwdConfirm" placeholder="Repeat new password" autocomplete="new-password">
    </div>
    <div class="adm-cpwd-msg" id="admCpwdMsg"></div>
    <div class="adm-cpwd-actions">
      <button class="adm-cpwd-cancel" onclick="closeAdmCpwd()">Cancel</button>
      <button class="adm-cpwd-submit" id="admCpwdSubmit" onclick="submitAdmCpwd()"><i class="bi bi-check-lg"></i> Update Password</button>
    </div>
  </div>
</div>
<script>
(function() {
  function msg(text, type) {
    var el = document.getElementById('admCpwdMsg');
    el.textContent = text; el.className = 'adm-cpwd-msg ' + (type || '');
  }
  window.openAdmCpwd = function() {
    document.getElementById('admCpwdNew').value = '';
    document.getElementById('admCpwdConfirm').value = '';
    msg('');
    document.getElementById('admCpwdSubmit').disabled = false;
    document.getElementById('admCpwdOverlay').classList.add('open');
    setTimeout(function(){ document.getElementById('admCpwdNew').focus(); }, 80);
  };
  window.closeAdmCpwd = function() {
    document.getElementById('admCpwdOverlay').classList.remove('open');
  };
  window.submitAdmCpwd = function() {
    var np = document.getElementById('admCpwdNew').value;
    var cp = document.getElementById('admCpwdConfirm').value;
    if (!np || !cp) { msg('Please fill in both fields.', 'err'); return; }
    if (np.length < 6)  { msg('Password must be at least 6 characters.', 'err'); return; }
    if (np !== cp)      { msg('Passwords do not match.', 'err'); return; }
    var btn = document.getElementById('admCpwdSubmit');
    btn.disabled = true; msg('Updating…');
    fetch('/change-password', {
      method: 'POST', credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ new_password: np, confirm_password: cp })
    })
    .then(function(r){ return r.json(); })
    .then(function(res) {
      if (res.success) {
        msg('Password updated successfully!', 'ok');
        setTimeout(closeAdmCpwd, 1400);
      } else {
        btn.disabled = false;
        msg(res.message || 'Failed to update password.', 'err');
      }
    })
    .catch(function() { btn.disabled = false; msg('Network error. Try again.', 'err'); });
  };
  /* Enter key in confirm field submits */
  document.getElementById('admCpwdConfirm').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') submitAdmCpwd();
  });
})();
</script>
