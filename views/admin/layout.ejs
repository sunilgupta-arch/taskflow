<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<script>(function(){var t=localStorage.getItem('tf-theme')||'dark';document.documentElement.setAttribute('data-bs-theme',t);})()</script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — TaskFlow' : 'TaskFlow Admin' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    /* ── Reset & base ─────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    * { scrollbar-width: thin; scrollbar-color: rgba(100,116,139,0.35) transparent; }
    *::-webkit-scrollbar { width: 4px; height: 4px; }
    *::-webkit-scrollbar-track { background: transparent; }
    *::-webkit-scrollbar-thumb { background: rgba(100,116,139,0.35); border-radius: 10px; }
    *::-webkit-scrollbar-thumb:hover { background: rgba(100,116,139,0.6); }

    /* ── Theme tokens ─────────────────────────────────── */
    :root {
      --adm-font: 'DM Sans', sans-serif;
      --adm-mono: 'Space Mono', monospace;
      --adm-sidebar-w: 240px;
    }

    [data-bs-theme="dark"] {
      --adm-bg:          #060d18;
      --adm-sidebar:     #0a1528;
      --adm-sidebar-2:   #0d1c35;
      --adm-surface:     #0e1d30;
      --adm-surface-2:   #132540;
      --adm-border:      #1a3050;
      --adm-border-2:    #1e3860;
      --adm-accent:      #00d4ff;
      --adm-text:        #dceaf8;
      --adm-text-2:      #a8c0d8;
      --adm-muted:       #445e78;
      --adm-topbar:      rgba(6,13,24,0.85);
    }

    [data-bs-theme="light"] {
      --adm-bg:          #f0f4f9;
      --adm-sidebar:     #ffffff;
      --adm-sidebar-2:   #f5f8fc;
      --adm-surface:     #ffffff;
      --adm-surface-2:   #f5f8fc;
      --adm-border:      #dde5ef;
      --adm-border-2:    #c8d6e8;
      --adm-accent:      #0284c7;
      --adm-text:        #1a2c3d;
      --adm-text-2:      #3d5568;
      --adm-muted:       #8ca8c0;
      --adm-topbar:      rgba(240,244,249,0.9);
    }

    body {
      font-family: var(--adm-font);
      background: var(--adm-bg);
      color: var(--adm-text);
      height: 100vh;
      overflow: hidden;
    }

    /* ── Shell ────────────────────────────────────────── */
    .adm-shell {
      display: flex;
      height: 100vh;
    }

    /* ── Sidebar ──────────────────────────────────────── */
    .adm-sidebar {
      width: var(--adm-sidebar-w);
      height: 100vh;
      background: var(--adm-sidebar);
      border-right: 1px solid var(--adm-border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      position: relative;
      z-index: 10;
    }

    /* Brand */
    .adm-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 20px 20px 18px;
      border-bottom: 1px solid var(--adm-border);
      flex-shrink: 0;
    }
    .adm-brand-mark {
      width: 38px; height: 38px;
      border-radius: 10px;
      background: linear-gradient(135deg, #0284c7, #00d4ff);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--adm-mono);
      font-size: 0.8rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -1px;
      flex-shrink: 0;
    }
    .adm-brand-text { min-width: 0; }
    .adm-brand-name {
      display: block;
      font-family: var(--adm-mono);
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--adm-accent);
      letter-spacing: 0.5px;
      white-space: nowrap;
    }
    .adm-brand-org {
      display: block;
      font-size: 0.7rem;
      color: var(--adm-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Nav */
    .adm-nav {
      flex: 1;
      overflow-y: auto;
      padding: 12px 0;
    }
    .adm-nav-label {
      font-size: 0.6rem;
      font-family: var(--adm-mono);
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: var(--adm-muted);
      padding: 10px 20px 4px;
    }
    .adm-nav-link {
      display: flex;
      align-items: center;
      gap: 11px;
      padding: 9px 14px;
      margin: 1px 8px;
      border-radius: 10px;
      border-left: 2px solid transparent;
      color: var(--adm-text-2);
      font-size: 0.875rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.15s ease;
      cursor: pointer;
    }
    .adm-nav-link:hover {
      background: var(--adm-sidebar-2);
      color: var(--adm-text);
      border-left-color: var(--adm-border-2);
    }
    .adm-nav-link.active {
      background: rgba(0,212,255,0.07);
      color: var(--adm-text);
      border-left-color: var(--adm-accent);
    }
    .adm-nav-icon {
      width: 32px; height: 32px;
      border-radius: 8px;
      background: rgba(255,255,255,0.04);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.95rem;
      flex-shrink: 0;
      transition: background 0.15s, color 0.15s;
      color: var(--adm-muted);
    }
    .adm-nav-link:hover .adm-nav-icon { background: rgba(255,255,255,0.07); color: var(--adm-text-2); }
    .adm-nav-link.active .adm-nav-icon { background: rgba(0,212,255,0.12); color: var(--adm-accent); }

    /* Per-section active colours */
    .adm-nav-link[data-s="work"].active    { background: rgba(59,130,246,0.07);  border-left-color: #3b82f6; }
    .adm-nav-link[data-s="work"].active .adm-nav-icon    { background: rgba(59,130,246,0.14);  color: #3b82f6; }
    .adm-nav-link[data-s="team"].active    { background: rgba(139,92,246,0.07);  border-left-color: #8b5cf6; }
    .adm-nav-link[data-s="team"].active .adm-nav-icon    { background: rgba(139,92,246,0.14);  color: #8b5cf6; }
    .adm-nav-link[data-s="reports"].active { background: rgba(249,115,22,0.07);  border-left-color: #f97316; }
    .adm-nav-link[data-s="reports"].active .adm-nav-icon { background: rgba(249,115,22,0.14);  color: #f97316; }
    .adm-nav-link[data-s="comms"].active   { background: rgba(16,185,129,0.07);  border-left-color: #10b981; }
    .adm-nav-link[data-s="comms"].active .adm-nav-icon   { background: rgba(16,185,129,0.14);  color: #10b981; }
    .adm-nav-link[data-s="tools"].active   { background: rgba(100,116,139,0.07); border-left-color: #64748b; }
    .adm-nav-link[data-s="tools"].active .adm-nav-icon   { background: rgba(100,116,139,0.14); color: #94a3b8; }

    .adm-nav-divider {
      height: 1px;
      background: var(--adm-border);
      margin: 8px 16px;
    }

    /* Sidebar footer */
    .adm-sidebar-footer {
      border-top: 1px solid var(--adm-border);
      padding: 14px 16px;
      flex-shrink: 0;
    }
    .adm-user-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .adm-user-avatar {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: linear-gradient(135deg, #0284c7, #7c3aed);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--adm-mono);
      font-size: 0.75rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }
    .adm-user-name {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--adm-text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .adm-user-role {
      display: block;
      font-size: 0.65rem;
      color: var(--adm-muted);
      font-family: var(--adm-mono);
    }
    .adm-footer-btns {
      display: flex;
      gap: 6px;
    }
    .adm-footer-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 8px;
      border: 1px solid var(--adm-border);
      background: transparent;
      color: var(--adm-muted);
      font-size: 0.75rem;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.15s;
    }
    .adm-footer-btn:hover { border-color: var(--adm-border-2); color: var(--adm-text); background: var(--adm-sidebar-2); }
    .adm-footer-btn i { font-size: 0.85rem; }

    /* ── Main ─────────────────────────────────────────── */
    .adm-main {
      flex: 1;
      min-width: 0;
      height: 100vh;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    /* Topbar */
    .adm-topbar {
      position: sticky;
      top: 0;
      z-index: 5;
      height: 52px;
      background: var(--adm-topbar);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--adm-border);
      display: flex;
      align-items: center;
      padding: 0 24px;
      gap: 16px;
      flex-shrink: 0;
    }
    .adm-topbar-title {
      font-family: var(--adm-mono);
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--adm-text-2);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      flex: 1;
    }
    .adm-clock {
      font-family: var(--adm-mono);
      font-size: 0.72rem;
      color: var(--adm-muted);
    }
    .adm-theme-btn {
      width: 30px; height: 30px;
      border-radius: 8px;
      background: transparent;
      border: 1px solid var(--adm-border);
      color: var(--adm-muted);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem;
      transition: all 0.15s;
    }
    .adm-theme-btn:hover { border-color: var(--adm-accent); color: var(--adm-accent); }

    /* Content */
    .adm-content {
      flex: 1;
      padding: 32px;
    }

    /* ── Hub page shared ──────────────────────────────── */
    .adm-hub-header {
      margin-bottom: 28px;
    }
    .adm-section-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
      font-family: var(--adm-mono);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }
    .adm-hub-title {
      font-family: var(--adm-mono);
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--adm-text);
      line-height: 1.2;
      margin-bottom: 6px;
    }
    .adm-hub-sub {
      font-size: 0.875rem;
      color: var(--adm-muted);
      line-height: 1.5;
    }

    /* ── Cards ────────────────────────────────────────── */
    .adm-cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 16px;
    }
    .adm-card {
      background: var(--adm-surface);
      border: 1px solid var(--adm-border);
      border-radius: 14px;
      padding: 22px;
      text-decoration: none;
      color: var(--adm-text);
      display: flex;
      flex-direction: column;
      gap: 14px;
      transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
      position: relative;
      overflow: hidden;
    }
    .adm-card::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 14px;
      border: 1px solid transparent;
      transition: border-color 0.18s;
      pointer-events: none;
    }
    .adm-card:hover {
      transform: translateY(-3px);
      border-color: var(--card-accent, var(--adm-accent));
      box-shadow: 0 12px 36px rgba(0,0,0,0.35), 0 0 0 1px color-mix(in srgb, var(--card-accent, #00d4ff) 30%, transparent);
      color: var(--adm-text);
      text-decoration: none;
    }
    .adm-card-icon {
      width: 50px; height: 50px;
      border-radius: 13px;
      background: rgba(var(--card-rgb, 0,212,255), 0.1);
      color: var(--card-accent, var(--adm-accent));
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }
    .adm-card-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--adm-text);
      margin-bottom: 5px;
    }
    .adm-card-desc {
      font-size: 0.78rem;
      color: var(--adm-muted);
      line-height: 1.55;
    }
    .adm-card-body { flex: 1; }
    .adm-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 12px;
      border-top: 1px solid var(--adm-border);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--card-accent, var(--adm-accent));
    }

    /* ── Dashboard section cards (larger) ─────────────── */
    .adm-section-cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 16px;
    }
    .adm-section-card {
      background: var(--adm-surface);
      border: 1px solid var(--adm-border);
      border-radius: 16px;
      padding: 28px;
      text-decoration: none;
      color: var(--adm-text);
      display: flex;
      align-items: flex-start;
      gap: 18px;
      transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    }
    .adm-section-card:hover {
      transform: translateY(-3px);
      border-color: var(--card-accent, var(--adm-accent));
      box-shadow: 0 12px 36px rgba(0,0,0,0.35);
      color: var(--adm-text);
      text-decoration: none;
    }
    .adm-section-card-icon {
      width: 54px; height: 54px;
      border-radius: 14px;
      background: rgba(var(--card-rgb, 0,212,255), 0.1);
      color: var(--card-accent, var(--adm-accent));
      display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem;
      flex-shrink: 0;
    }
    .adm-section-card-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--adm-text);
      margin-bottom: 5px;
    }
    .adm-section-card-desc {
      font-size: 0.78rem;
      color: var(--adm-muted);
      line-height: 1.5;
    }
    .adm-section-card-arrow {
      margin-left: auto;
      color: var(--adm-muted);
      font-size: 1rem;
      align-self: center;
      flex-shrink: 0;
      transition: color 0.15s, transform 0.15s;
    }
    .adm-section-card:hover .adm-section-card-arrow {
      color: var(--card-accent, var(--adm-accent));
      transform: translateX(4px);
    }

    /* ── Welcome strip (dashboard) ────────────────────── */
    .adm-welcome {
      background: linear-gradient(135deg, var(--adm-surface) 0%, var(--adm-surface-2) 100%);
      border: 1px solid var(--adm-border-2);
      border-radius: 16px;
      padding: 28px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 32px;
      position: relative;
      overflow: hidden;
    }
    .adm-welcome::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 180px; height: 180px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0,212,255,0.06) 0%, transparent 70%);
    }
    .adm-welcome-greeting {
      font-size: 0.8rem;
      color: var(--adm-muted);
      margin-bottom: 4px;
      font-family: var(--adm-mono);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .adm-welcome-name {
      font-family: var(--adm-mono);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--adm-text);
    }
    .adm-welcome-role {
      font-size: 0.75rem;
      color: var(--adm-accent);
      font-family: var(--adm-mono);
      margin-top: 4px;
    }
    .adm-welcome-date {
      text-align: right;
    }
    .adm-welcome-day {
      font-size: 2rem;
      font-weight: 700;
      font-family: var(--adm-mono);
      color: var(--adm-text);
      line-height: 1;
    }
    .adm-welcome-date-label {
      font-size: 0.72rem;
      color: var(--adm-muted);
      margin-top: 4px;
    }

    /* ── Responsive ───────────────────────────────────── */
    @media (max-width: 768px) {
      .adm-content { padding: 20px 16px; }
      .adm-cards { grid-template-columns: 1fr; }
      .adm-section-cards { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="adm-shell">

  <!-- ── Sidebar ──────────────────────────────────────── -->
  <aside class="adm-sidebar">
    <div class="adm-brand">
      <div class="adm-brand-mark">TF</div>
      <div class="adm-brand-text">
        <span class="adm-brand-name">TASKFLOW</span>
        <span class="adm-brand-org"><%= user.org_name %></span>
      </div>
    </div>

    <nav class="adm-nav">
      <a href="/admin" data-s="dashboard"
         class="adm-nav-link <%= section === 'dashboard' ? 'active' : '' %>">
        <div class="adm-nav-icon"><i class="bi bi-grid-1x2-fill"></i></div>
        <span>Dashboard</span>
      </a>

      <div class="adm-nav-divider"></div>
      <div class="adm-nav-label">Sections</div>

      <a href="/admin/work" data-s="work"
         class="adm-nav-link <%= section === 'work' ? 'active' : '' %>">
        <div class="adm-nav-icon"><i class="bi bi-kanban"></i></div>
        <span>Work</span>
      </a>

      <a href="/admin/team" data-s="team"
         class="adm-nav-link <%= section === 'team' ? 'active' : '' %>">
        <div class="adm-nav-icon"><i class="bi bi-people-fill"></i></div>
        <span>Team</span>
      </a>

      <a href="/admin/reports" data-s="reports"
         class="adm-nav-link <%= section === 'reports' ? 'active' : '' %>">
        <div class="adm-nav-icon"><i class="bi bi-bar-chart-fill"></i></div>
        <span>Reports</span>
      </a>

      <a href="/admin/comms" data-s="comms"
         class="adm-nav-link <%= section === 'comms' ? 'active' : '' %>">
        <div class="adm-nav-icon"><i class="bi bi-chat-dots-fill"></i></div>
        <span>Communications</span>
      </a>

      <a href="/admin/tools" data-s="tools"
         class="adm-nav-link <%= section === 'tools' ? 'active' : '' %>">
        <div class="adm-nav-icon"><i class="bi bi-tools"></i></div>
        <span>Tools</span>
      </a>
    </nav>

    <div class="adm-sidebar-footer">
      <div class="adm-user-row">
        <div class="adm-user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <div style="min-width:0">
          <span class="adm-user-name"><%= user.name %></span>
          <span class="adm-user-role"><%= user.role_name.replace('LOCAL_','') %></span>
        </div>
      </div>
      <div class="adm-footer-btns">
        <a href="/" class="adm-footer-btn" title="Back to classic UI">
          <i class="bi bi-grid"></i> Classic
        </a>
        <a href="/auth/logout" class="adm-footer-btn" title="Sign out">
          <i class="bi bi-box-arrow-right"></i> Sign out
        </a>
      </div>
    </div>
  </aside>

  <!-- ── Main ─────────────────────────────────────────── -->
  <main class="adm-main">
    <div class="adm-topbar">
      <div class="adm-topbar-title"><%= typeof title !== 'undefined' ? title : 'Admin' %></div>
      <span class="adm-clock" id="admClock"></span>
      <button class="adm-theme-btn" id="admThemeBtn" onclick="toggleAdmTheme()" title="Toggle theme"></button>
    </div>
    <div class="adm-content">
      <%- body %>
    </div>
  </main>

</div>
<script>
  // Clock
  (function() {
    var el = document.getElementById('admClock');
    function tick() {
      if (!el) return;
      el.textContent = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
    }
    tick(); setInterval(tick, 1000);
  })();

  // Theme
  var _admTheme = localStorage.getItem('tf-theme') || 'dark';
  function applyAdmTheme(t) {
    document.documentElement.setAttribute('data-bs-theme', t);
    var btn = document.getElementById('admThemeBtn');
    if (btn) btn.innerHTML = t === 'dark'
      ? '<i class="bi bi-sun-fill"></i>'
      : '<i class="bi bi-moon-stars-fill"></i>';
  }
  function toggleAdmTheme() {
    _admTheme = _admTheme === 'dark' ? 'light' : 'dark';
    localStorage.setItem('tf-theme', _admTheme);
    applyAdmTheme(_admTheme);
  }
  applyAdmTheme(_admTheme);
</script>
</body>
</html>
