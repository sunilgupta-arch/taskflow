<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h5 style="font-family:var(--tf-font-mono);font-weight:700;margin:0;">
    <i class="bi bi-megaphone me-2" style="color:#a855f7;"></i>Info Board
  </h5>
</div>

<% if (canPost) { %>
<!-- Create Post Form -->
<div class="tf-card mb-4">
  <div class="card-header"><i class="bi bi-pencil-square me-2"></i>NEW POST</div>
  <div class="p-3">
    <div class="row g-3">
      <div class="col-12">
        <input type="text" id="postTitle" class="tf-form-control" placeholder="Title — e.g., Team meeting at 2 PM today" style="font-size:0.85rem;font-weight:500;">
      </div>
      <div class="col-12">
        <textarea id="postBody" class="tf-form-control" rows="3" placeholder="Details (optional) — Add any context, instructions, or links..." style="font-size:0.8rem;resize:vertical;"></textarea>
      </div>
      <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-3">
          <label style="font-size:0.75rem;color:var(--tf-text-muted);cursor:pointer;display:flex;align-items:center;gap:6px;">
            <input type="checkbox" id="postPinned" style="accent-color:#a855f7;width:15px;height:15px;">
            <i class="bi bi-pin-angle" style="color:#a855f7;"></i> Pin to top
          </label>
          <% if (orgType === 'CLIENT') { %>
          <div style="display:flex;align-items:center;gap:6px;font-size:0.75rem;">
            <span style="color:var(--tf-text-muted);">Audience:</span>
            <select id="postAudience" class="tf-select" style="font-size:0.75rem;padding:3px 8px;min-width:auto;">
              <option value="client">Client Team Only</option>
              <option value="all">All Teams (inc. Local)</option>
            </select>
          </div>
          <% } %>
        </div>
        <button class="btn-tf btn-tf-primary" onclick="publishPost()" style="padding:6px 20px;font-size:0.8rem;">
          <i class="bi bi-send me-1"></i> Publish
        </button>
      </div>
    </div>
    <div id="postError" style="display:none;font-size:0.75rem;color:#ef4444;margin-top:0.5rem;"></div>
  </div>
</div>
<% } %>

<!-- Posts Feed -->
<%
  var localPosts = posts.filter(function(p) { return p.audience === 'local'; });
  var clientPosts = posts.filter(function(p) { return p.audience !== 'local'; });
%>
<% if (posts.length === 0) { %>
<div class="tf-card">
  <div class="p-4" style="text-align:center;color:var(--tf-text-muted);">
    <i class="bi bi-megaphone" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:0.5rem;"></i>
    <div style="font-size:0.85rem;">No announcements yet</div>
    <% if (canPost) { %>
    <div style="font-size:0.75rem;margin-top:0.25rem;">Use the form above to post your first update</div>
    <% } %>
  </div>
</div>
<% } else { %>
<div style="display:flex;gap:1rem;align-items:flex-start;">
  <!-- Local Team Column (left) -->
  <div style="flex:1;min-width:0;">
    <div style="font-size:0.75rem;font-weight:700;font-family:var(--tf-font-mono);color:#a855f7;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.75rem;padding-bottom:0.5rem;border-bottom:2px solid rgba(168,85,247,0.2);">
      <i class="bi bi-people me-1"></i>Local Team
    </div>
    <% if (localPosts.length === 0) { %>
    <div style="text-align:center;color:var(--tf-text-muted);padding:1.5rem;font-size:0.8rem;opacity:0.5;">No local updates</div>
    <% } %>
    <div style="display:flex;flex-direction:column;gap:0.75rem;">
    <% localPosts.forEach(function(p) { %>
      <div class="tf-card" style="<%= p.is_pinned ? 'border-left:3px solid #a855f7;' : '' %>">
        <div class="p-3">
          <div class="d-flex justify-content-between align-items-start gap-2">
            <div style="flex:1;min-width:0;">
              <div style="font-size:0.95rem;font-weight:600;color:var(--tf-text);margin-bottom:0.25rem;">
                <% if (p.is_pinned) { %><i class="bi bi-pin-angle-fill me-1" style="color:#a855f7;font-size:0.75rem;"></i><% } %>
                <%= p.title %>
              </div>
              <% if (p.body) { %>
              <div style="font-size:0.8rem;color:var(--tf-text-muted);line-height:1.5;white-space:pre-line;margin-bottom:0.5rem;"><%= p.body %></div>
              <% } %>
              <div style="font-size:0.7rem;color:var(--tf-text-muted);">
                <i class="bi bi-person me-1"></i><%= p.author_name %>
                <span style="margin:0 0.4rem;">&middot;</span>
                <i class="bi bi-clock me-1"></i><%= new Date(p.created_at).toLocaleString('en-US', { month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit', hour12:true }) %>
              </div>
            </div>
            <% if (canManage && p.author_org_id === userOrgId) { %>
            <div class="d-flex gap-1">
              <button onclick="togglePin(<%= p.id %>)" class="btn-tf" style="font-size:0.6rem;padding:3px 8px;background:transparent;color:<%= p.is_pinned ? '#a855f7' : 'var(--tf-text-muted)' %>;border:1px solid var(--tf-border);" title="<%= p.is_pinned ? 'Unpin' : 'Pin' %>"><i class="bi bi-pin-angle<%= p.is_pinned ? '-fill' : '' %>"></i></button>
              <button onclick="deletePost(<%= p.id %>)" class="btn-tf" style="font-size:0.6rem;padding:3px 8px;background:transparent;color:#ef4444;border:1px solid rgba(239,68,68,0.3);" title="Delete"><i class="bi bi-trash3"></i></button>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
    </div>
  </div>

  <!-- Client Column (right) -->
  <div style="flex:1;min-width:0;">
    <div style="font-size:0.75rem;font-weight:700;font-family:var(--tf-font-mono);color:#f59e0b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.75rem;padding-bottom:0.5rem;border-bottom:2px solid rgba(245,158,11,0.2);">
      <i class="bi bi-building me-1"></i>Client
    </div>
    <% if (clientPosts.length === 0) { %>
    <div style="text-align:center;color:var(--tf-text-muted);padding:1.5rem;font-size:0.8rem;opacity:0.5;">No client updates</div>
    <% } %>
    <div style="display:flex;flex-direction:column;gap:0.75rem;">
    <% clientPosts.forEach(function(p) { %>
      <div class="tf-card" style="background:rgba(245,158,11,0.03);border-color:rgba(245,158,11,0.2);<%= p.is_pinned ? 'border-left:3px solid #f59e0b;' : '' %>">
        <div class="p-3">
          <div class="d-flex justify-content-between align-items-start gap-2">
            <div style="flex:1;min-width:0;">
              <div style="font-size:0.95rem;font-weight:600;color:var(--tf-text);margin-bottom:0.25rem;">
                <% if (p.is_pinned) { %><i class="bi bi-pin-angle-fill me-1" style="color:#f59e0b;font-size:0.75rem;"></i><% } %>
                <%= p.title %>
                <% if (p.audience === 'all') { %>
                <span style="font-size:0.55rem;background:rgba(0,212,255,0.1);color:#00d4ff;padding:1px 6px;border-radius:3px;margin-left:6px;font-weight:500;vertical-align:middle;">ALL TEAMS</span>
                <% } %>
              </div>
              <% if (p.body) { %>
              <div style="font-size:0.8rem;color:var(--tf-text-muted);line-height:1.5;white-space:pre-line;margin-bottom:0.5rem;"><%= p.body %></div>
              <% } %>
              <div style="font-size:0.7rem;color:var(--tf-text-muted);">
                <i class="bi bi-person me-1"></i><%= p.author_name %> (<%= p.author_role.replace('_', ' ') %>)
                <span style="margin:0 0.4rem;">&middot;</span>
                <i class="bi bi-clock me-1"></i><%= new Date(p.created_at).toLocaleString('en-US', { month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit', hour12:true }) %>
              </div>
            </div>
            <% if (canManage && p.author_org_id === userOrgId) { %>
            <div class="d-flex gap-1">
              <button onclick="togglePin(<%= p.id %>)" class="btn-tf" style="font-size:0.6rem;padding:3px 8px;background:transparent;color:<%= p.is_pinned ? '#f59e0b' : 'var(--tf-text-muted)' %>;border:1px solid var(--tf-border);" title="<%= p.is_pinned ? 'Unpin' : 'Pin' %>"><i class="bi bi-pin-angle<%= p.is_pinned ? '-fill' : '' %>"></i></button>
              <button onclick="deletePost(<%= p.id %>)" class="btn-tf" style="font-size:0.6rem;padding:3px 8px;background:transparent;color:#ef4444;border:1px solid rgba(239,68,68,0.3);" title="Delete"><i class="bi bi-trash3"></i></button>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
    </div>
  </div>
</div>
<% } %>

<script>
function publishPost() {
  var title = document.getElementById('postTitle').value.trim();
  var body = document.getElementById('postBody').value.trim();
  var pinned = document.getElementById('postPinned').checked;
  var audienceEl = document.getElementById('postAudience');
  var audience = audienceEl ? audienceEl.value : 'local';
  var errEl = document.getElementById('postError');

  if (!title) {
    errEl.textContent = 'Title is required';
    errEl.style.display = 'block';
    return;
  }
  errEl.style.display = 'none';

  fetch('/announcements', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ title: title, body: body || null, is_pinned: pinned, audience: audience })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) {
      window.location.reload();
    } else {
      errEl.textContent = data.message || 'Failed';
      errEl.style.display = 'block';
    }
  });
}

function togglePin(id) {
  fetch('/announcements/' + id + '/pin', { method: 'PUT' })
    .then(function(r) { return r.json(); })
    .then(function(data) { if (data.success) window.location.reload(); });
}

function deletePost(id) {
  if (!confirm('Delete this post?')) return;
  fetch('/announcements/' + id, { method: 'DELETE' })
    .then(function(r) { return r.json(); })
    .then(function(data) { if (data.success) window.location.reload(); });
}
</script>
