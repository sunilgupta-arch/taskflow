<style>
  .chat-container {
    display: flex;
    height: calc(100vh - 120px);
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 12px;
    overflow: hidden;
  }

  /* --- Left Panel: Conversation List --- */
  .chat-sidebar {
    width: 320px;
    min-width: 320px;
    border-right: 1px solid var(--tf-border);
    display: flex;
    flex-direction: column;
    background: var(--tf-surface);
  }

  .chat-sidebar-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--tf-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .chat-sidebar-header h6 {
    font-family: var(--tf-font-mono);
    font-size: 0.75rem;
    letter-spacing: 1px;
    margin: 0;
    color: var(--tf-text-muted);
    text-transform: uppercase;
  }

  .chat-search {
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--tf-border);
  }

  .chat-search input {
    background: var(--tf-surface-2);
    border: 1px solid var(--tf-border);
    color: var(--tf-text);
    border-radius: 8px;
    padding: 0.45rem 0.75rem 0.45rem 2.25rem;
    font-size: 0.8rem;
    width: 100%;
    font-family: var(--tf-font);
  }
  .chat-search input:focus { outline: none; border-color: var(--tf-accent); }

  .chat-search-wrap {
    position: relative;
  }
  .chat-search-wrap i {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--tf-text-muted);
    font-size: 0.8rem;
  }

  .chat-list {
    flex: 1;
    overflow-y: auto;
  }

  .chat-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    cursor: pointer;
    border-bottom: 1px solid var(--tf-border);
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
  }
  .chat-list-item:hover { background: var(--tf-surface-2); }
  .chat-list-item.active { background: var(--tf-surface-2); border-left: 3px solid var(--tf-accent); }

  .chat-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--tf-font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: #000;
    flex-shrink: 0;
  }
  .chat-avatar.direct { background: linear-gradient(135deg, var(--tf-accent), var(--tf-accent-2)); }
  .chat-avatar.group { background: linear-gradient(135deg, var(--tf-accent-2), #ec4899); }

  .chat-list-info { flex: 1; min-width: 0; }

  .chat-list-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--tf-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chat-list-preview {
    font-size: 0.75rem;
    color: var(--tf-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
  }

  .chat-list-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
  }

  .chat-list-time {
    font-size: 0.6rem;
    color: var(--tf-text-muted);
    font-family: var(--tf-font-mono);
  }

  .chat-unread-badge {
    background: var(--tf-accent);
    color: #000;
    font-size: 0.6rem;
    font-weight: 700;
    font-family: var(--tf-font-mono);
    width: 20px; height: 20px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }

  .chat-org-tag {
    font-size: 0.55rem;
    padding: 1px 5px;
    border-radius: 4px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  .chat-org-tag.CLIENT { background: rgba(0,212,255,0.15); color: var(--tf-accent); }
  .chat-org-tag.LOCAL { background: rgba(124,58,237,0.15); color: #a78bfa; }

  /* --- Right Panel: Messages --- */
  .chat-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .chat-main-header {
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--tf-border);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--tf-surface);
  }

  .chat-main-header .chat-header-name {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .chat-main-header .chat-header-sub {
    font-size: 0.7rem;
    color: var(--tf-text-muted);
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .chat-empty {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tf-text-muted);
    font-size: 0.85rem;
    flex-direction: column;
    gap: 0.5rem;
  }
  .chat-empty i { font-size: 2.5rem; opacity: 0.3; }

  .msg-bubble {
    max-width: 70%;
    padding: 0.6rem 0.9rem;
    border-radius: 12px;
    font-size: 0.85rem;
    line-height: 1.45;
    position: relative;
    word-wrap: break-word;
  }

  .msg-row { display: flex; align-items: flex-end; gap: 0.5rem; }
  .msg-row.sent { justify-content: flex-end; }
  .msg-row.received { justify-content: flex-start; }

  .msg-row.sent .msg-bubble {
    background: rgba(180,190,200,0.18);
    border: 1px solid rgba(180,190,200,0.25);
    color: var(--tf-text);
    border-bottom-right-radius: 4px;
  }

  .msg-row.received .msg-bubble {
    background: var(--tf-surface-2);
    border: 1px solid var(--tf-border);
    color: var(--tf-text);
    border-bottom-left-radius: 4px;
  }

  .msg-sender {
    font-size: 0.65rem;
    font-weight: 700;
    margin-bottom: 2px;
    color: var(--tf-accent-2);
  }

  .msg-time {
    font-size: 0.55rem;
    margin-top: 4px;
    opacity: 0.7;
    text-align: right;
    font-family: var(--tf-font-mono);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
  }

  .msg-tick {
    font-size: 0.8rem;
    font-weight: 700;
    opacity: 1;
    display: inline-flex;
    align-items: center;
  }
  .msg-tick i { font-weight: 900; -webkit-text-stroke: 0.3px currentColor; }
  .msg-tick.sent { color: rgba(180,195,210,0.7); }
  .msg-tick.read { color: #00d4ff; }

  .msg-row.sent .msg-time { color: var(--tf-text-muted); }

  .msg-date-divider {
    text-align: center;
    margin: 0.75rem 0;
    font-size: 0.65rem;
    color: var(--tf-text-muted);
    font-family: var(--tf-font-mono);
    letter-spacing: 0.5px;
  }

  .msg-date-divider span {
    background: var(--tf-surface);
    padding: 0.2rem 0.75rem;
    border: 1px solid var(--tf-border);
    border-radius: 20px;
  }

  .load-more-btn {
    align-self: center;
    font-size: 0.7rem;
    color: var(--tf-accent);
    cursor: pointer;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--tf-border);
    border-radius: 20px;
    background: var(--tf-surface-2);
    margin-bottom: 0.5rem;
  }
  .load-more-btn:hover { border-color: var(--tf-accent); }

  /* --- Chat Input --- */
  .chat-input-area {
    padding: 0.85rem 1.25rem;
    border-top: 1px solid var(--tf-border);
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    background: var(--tf-surface);
  }

  .chat-input-area textarea {
    flex: 1;
    background: var(--tf-surface-2);
    border: 1px solid var(--tf-border);
    color: var(--tf-text);
    border-radius: 18px;
    padding: 0.55rem 1rem;
    font-size: 0.85rem;
    font-family: var(--tf-font);
    resize: none;
    overflow-y: auto;
    min-height: 38px;
    max-height: 120px;
    line-height: 1.4;
    rows: 1;
  }
  .chat-input-area textarea:focus { outline: none; border-color: var(--tf-accent); }

  .chat-send-btn {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: var(--tf-accent);
    color: #000;
    border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .chat-send-btn:hover { background: #00b8d9; }
  .chat-send-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Attachment button */
  .chat-attach-btn {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: var(--tf-surface-2);
    color: var(--tf-text-muted);
    border: 1px solid var(--tf-border);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.15s;
    flex-shrink: 0;
    position: relative;
  }
  .chat-attach-btn:hover { color: var(--tf-accent); border-color: var(--tf-accent); }

  /* Attach menu dropdown */
  .attach-menu {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 10px;
    padding: 0.35rem 0;
    min-width: 180px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    z-index: 50;
    display: none;
  }
  .attach-menu.show { display: block; }

  .attach-menu button {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.55rem 1rem;
    background: none;
    border: none;
    color: var(--tf-text);
    font-size: 0.8rem;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
  }
  .attach-menu button:hover { background: var(--tf-surface-2); }
  .attach-menu button i { font-size: 0.9rem; width: 18px; text-align: center; }

  /* Attachment preview bar (shown before sending) */
  .attach-preview {
    display: none;
    padding: 0.5rem 1.25rem;
    border-top: 1px solid var(--tf-border);
    background: var(--tf-surface-2);
    align-items: center;
    gap: 0.75rem;
  }
  .attach-preview.show { display: flex; }

  .attach-preview-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: rgba(0,212,255,0.1);
    color: var(--tf-accent);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .attach-preview-info { flex: 1; min-width: 0; }

  .attach-preview-name {
    font-size: 0.78rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .attach-preview-size {
    font-size: 0.6rem;
    color: var(--tf-text-muted);
    font-family: var(--tf-font-mono);
  }

  .attach-preview-remove {
    background: none; border: none;
    color: var(--tf-text-muted);
    cursor: pointer;
    font-size: 0.85rem;
    padding: 4px;
    border-radius: 4px;
  }
  .attach-preview-remove:hover { color: var(--tf-danger); background: rgba(239,68,68,0.1); }

  /* Upload progress bar */
  .chat-upload-bar {
    display: none;
    padding: 0.5rem 1.25rem;
    border-top: 1px solid var(--tf-border);
    background: var(--tf-surface-2);
    align-items: center;
    gap: 0.75rem;
  }
  .chat-upload-bar.show { display: flex; }

  .chat-upload-bar .upload-spinner {
    width: 20px; height: 20px;
    border: 2px solid var(--tf-border);
    border-top-color: var(--tf-accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    flex-shrink: 0;
  }

  .chat-upload-bar .upload-info {
    flex: 1; min-width: 0;
  }

  .chat-upload-bar .upload-name {
    font-size: 0.75rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chat-upload-bar .upload-status {
    font-size: 0.6rem;
    color: var(--tf-text-muted);
    font-family: var(--tf-font-mono);
  }

  .chat-upload-progress-track {
    height: 4px;
    background: var(--tf-border);
    border-radius: 2px;
    margin-top: 4px;
    overflow: hidden;
  }

  .chat-upload-progress-fill {
    height: 100%;
    background: var(--tf-accent);
    border-radius: 2px;
    width: 0%;
    transition: width 0.2s ease;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.7; }
  }

  /* Attachment in message bubble */
  .msg-attachment {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.65rem;
    border-radius: 8px;
    margin-bottom: 4px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    cursor: pointer;
  }

  .msg-row.sent .msg-attachment {
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 8px;
  }
  .msg-row.received .msg-attachment {
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 8px;
  }
  .msg-attachment:hover { opacity: 0.9; }

  /* Attachment context menu */
  #attachCtxMenu {
    display: none;
    position: fixed;
    z-index: 9999;
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
    min-width: 160px;
    padding: 0.3rem 0;
    font-size: 0.85rem;
  }
  #attachCtxMenu.show { display: block; }
  .attach-ctx-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    cursor: pointer;
    color: var(--tf-text);
    transition: background 0.15s;
  }
  .attach-ctx-item:hover { background: var(--tf-hover, rgba(99,102,241,0.08)); }

  .msg-attach-icon {
    width: 32px; height: 32px;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .msg-row.sent .msg-attach-icon { background: rgba(0,212,255,0.15); color: var(--tf-accent); }
  .msg-row.received .msg-attach-icon { background: rgba(0,212,255,0.15); color: var(--tf-accent); }

  .msg-attach-name {
    font-size: 0.75rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
  }

  .msg-attach-size {
    font-size: 0.55rem;
    opacity: 0.7;
    font-family: var(--tf-font-mono);
  }

  .msg-attach-dl {
    font-size: 0.75rem;
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* Drive picker modal */
  .drive-picker-modal {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.75);
    z-index: 210;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .drive-picker-modal.show { display: flex; }

  .drive-picker-body {
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 12px;
    width: 100%; max-width: 520px;
    max-height: 80vh;
    display: flex; flex-direction: column;
  }

  .drive-picker-list {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
  }

  .drive-picker-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .drive-picker-item:hover { background: var(--tf-surface-2); }
  .drive-picker-item.selected { background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.3); }

  .drive-picker-item .dp-icon {
    width: 32px; height: 32px;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .drive-picker-item .dp-icon.folder { background: rgba(245,158,11,0.15); color: #f59e0b; }
  .drive-picker-item .dp-icon.file { background: rgba(100,116,139,0.15); color: #94a3b8; }

  .drive-picker-item .dp-name {
    font-size: 0.8rem;
    font-weight: 500;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .drive-picker-item .dp-size {
    font-size: 0.6rem;
    color: var(--tf-text-muted);
    font-family: var(--tf-font-mono);
    flex-shrink: 0;
  }

  /* --- New Chat Modal --- */
  .new-chat-modal {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.75);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .new-chat-modal.show { display: flex; }

  .new-chat-body {
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 12px;
    width: 100%; max-width: 480px;
    max-height: 80vh;
    display: flex; flex-direction: column;
  }

  .new-chat-body .modal-header {
    padding: 1.25rem;
    border-bottom: 1px solid var(--tf-border);
    display: flex; align-items: center; justify-content: space-between;
  }

  .new-chat-body .modal-header h6 {
    font-family: var(--tf-font-mono);
    font-size: 0.8rem;
    letter-spacing: 1px;
    margin: 0;
  }

  .new-chat-body .modal-content-area {
    padding: 1.25rem;
    overflow-y: auto;
    flex: 1;
  }

  .user-select-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
    margin-bottom: 0.25rem;
  }
  .user-select-item:hover { background: var(--tf-surface-2); }
  .user-select-item.selected { background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.3); }

  .user-select-item input[type="checkbox"] { accent-color: var(--tf-accent); }

  .typing-indicator {
    font-size: 0.7rem;
    color: var(--tf-text-muted);
    font-style: italic;
    padding: 0 0.5rem;
    height: 18px;
  }

  /* Mobile: hide sidebar, show toggle */
  .chat-back-btn {
    display: none;
    background: none; border: none;
    color: var(--tf-text-muted);
    font-size: 1.1rem;
    cursor: pointer;
    padding: 0;
  }

  @media (max-width: 768px) {
    .chat-sidebar { width: 100%; min-width: 100%; }
    .chat-main { display: none; }
    .chat-container.conv-open .chat-sidebar { display: none; }
    .chat-container.conv-open .chat-main { display: flex; }
    .chat-back-btn { display: inline-flex; }
  }
</style>

<div class="chat-container" id="chatContainer">
  <!-- Left: Conversations -->
  <div class="chat-sidebar">
    <div class="chat-sidebar-header">
      <h6>Conversations</h6>
      <% if (canInitiate) { %>
      <button class="btn-tf btn-tf-primary" style="padding:0.3rem 0.6rem;font-size:0.7rem;" onclick="openNewChatModal()">
        <i class="bi bi-plus-lg me-1"></i>New
      </button>
      <% } %>
    </div>
    <div class="chat-search">
      <div class="chat-search-wrap">
        <i class="bi bi-search"></i>
        <input type="text" id="chatSearchInput" placeholder="Search conversations..." oninput="filterConversations()">
      </div>
    </div>
    <div class="chat-list" id="chatList">
      <% if (conversations.length === 0) { %>
        <div class="chat-empty" style="padding:2rem;">
          <i class="bi bi-chat-dots"></i>
          <span>No conversations yet</span>
        </div>
      <% } else { %>
        <% conversations.forEach(function(c) { %>
          <div class="chat-list-item <%= activeConversationId === c.id ? 'active' : '' %>"
               data-id="<%= c.id %>"
               data-search="<%= c.type === 'system' ? 'System' : (c.type === 'direct' ? (c.other_user ? c.other_user.name : '') : c.group_name) %>"
               onclick="openConversation(<%= c.id %>)">
            <div class="chat-avatar <%= c.type %>" <%= c.type === 'system' ? 'style="background:rgba(99,102,241,0.15);color:#6366f1;"' : '' %>>
              <% if (c.type === 'system') { %>
                <i class="bi bi-robot" style="font-size:0.9rem;"></i>
              <% } else if (c.type === 'direct' && c.other_user) { %>
                <%= c.other_user.name.charAt(0).toUpperCase() %>
              <% } else { %>
                <i class="bi bi-people-fill" style="font-size:0.9rem;"></i>
              <% } %>
            </div>
            <div class="chat-list-info">
              <div class="d-flex align-items-center gap-1">
                <span class="chat-list-name">
                  <%= c.type === 'system' ? 'System' : (c.type === 'direct' ? (c.other_user ? c.other_user.name : 'Unknown') : c.group_name) %>
                </span>
                <% if (c.type === 'system') { %>
                  <span class="chat-org-tag" style="background:rgba(99,102,241,0.15);color:#6366f1;">BOT</span>
                <% } else if (c.type === 'direct' && c.other_user) { %>
                  <span class="chat-org-tag <%= c.other_user.org_type %>"><%= c.other_user.org_type %></span>
                <% } %>
              </div>
              <div class="chat-list-preview">
                <% if (c.last_message) { %>
                  <% if (c.type === 'group' && c.last_message_sender) { %><strong><%= c.last_message_sender.split(' ')[0] %>:</strong> <% } %>
                  <%= c.last_message.length > 40 ? c.last_message.substring(0, 40) + '...' : c.last_message %>
                <% } else { %>
                  <em>No messages yet</em>
                <% } %>
              </div>
            </div>
            <div class="chat-list-meta">
              <% if (c.last_message_at) { %>
                <span class="chat-list-time"><%= formatChatTime(c.last_message_at) %></span>
              <% } %>
              <% if (c.unread_count > 0) { %>
                <span class="chat-unread-badge"><%= c.unread_count > 9 ? '9+' : c.unread_count %></span>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Right: Messages -->
  <div class="chat-main" id="chatMain">
    <div id="chatHeaderArea">
      <!-- Filled dynamically -->
    </div>
    <div class="chat-messages" id="chatMessages">
      <div class="chat-empty">
        <i class="bi bi-chat-square-text"></i>
        <span>Select a conversation to start chatting</span>
      </div>
    </div>
    <div id="chatInputArea" style="display:none;">
      <div class="typing-indicator" id="typingIndicator"></div>
      <div class="attach-preview" id="attachPreview">
        <div class="attach-preview-icon" id="attachPreviewIcon"><i class="bi bi-file-earmark"></i></div>
        <img class="attach-preview-thumb" id="attachPreviewThumb" style="display:none;width:48px;height:48px;object-fit:cover;border-radius:6px;" alt="">
        <div class="attach-preview-info">
          <div class="attach-preview-name" id="attachPreviewName"></div>
          <div class="attach-preview-size" id="attachPreviewSize"></div>
        </div>
        <button class="attach-preview-remove" onclick="clearAttachment()"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="chat-upload-bar" id="chatUploadBar">
        <div class="upload-spinner"></div>
        <div class="upload-info">
          <div class="upload-name" id="uploadBarName">Uploading...</div>
          <div class="upload-status" id="uploadBarStatus">0%</div>
          <div class="chat-upload-progress-track">
            <div class="chat-upload-progress-fill" id="uploadBarFill"></div>
          </div>
        </div>
      </div>
      <div class="chat-input-area">
        <div style="position:relative;">
          <button class="chat-attach-btn" onclick="toggleAttachMenu(event)" id="attachBtn">
            <i class="bi bi-paperclip"></i>
          </button>
          <div class="attach-menu" id="attachMenu">
            <button onclick="triggerLocalUpload()"><i class="bi bi-upload"></i> Upload File</button>
            <button onclick="openDrivePicker()"><i class="bi bi-cloud"></i> From Drive</button>
          </div>
          <input type="file" id="attachFileInput" style="display:none;" onchange="handleAttachFile(this)">
        </div>
        <textarea id="chatInput" placeholder="Type a message..." autocomplete="off" rows="1"
               onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMessage();}"
               oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px';"></textarea>
        <button class="chat-send-btn" onclick="sendMessage()" id="sendBtn">
          <i class="bi bi-send-fill"></i>
        </button>
      </div>
    </div>
  </div>
</div>

