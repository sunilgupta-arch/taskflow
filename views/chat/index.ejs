<%
  function formatChatTime(date) {
    if (!date) return '';
    var d = new Date(date);
    var now = new Date();
    var diff = now - d;
    if (diff < 86400000 && d.getDate() === now.getDate()) {
      return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
    }
    if (diff < 604800000) {
      return d.toLocaleDateString('en-US', { weekday: 'short' });
    }
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }
%>

<script>
var currentConversationId = <%= activeConversationId || 'null' %>;
var currentUserId = <%= user.id %>;
var chatType = 'direct';
var typingTimeout = null;
var maxAttachMB = <%= maxAttachMB %>;
var socket = io({ withCredentials: true });

// Attachment state
var pendingAttachment = null; // { type: 'local'|'drive', file, driveFileId, name, size, mime }

// ============ Conversation List ============

function filterConversations() {
  var term = document.getElementById('chatSearchInput').value.toLowerCase();
  document.querySelectorAll('.chat-list-item').forEach(function(el) {
    var name = (el.dataset.search || '').toLowerCase();
    el.style.display = name.includes(term) ? '' : 'none';
  });
}

function openConversation(id) {
  currentConversationId = id;

  // Update active state in list
  document.querySelectorAll('.chat-list-item').forEach(function(el) {
    el.classList.toggle('active', parseInt(el.dataset.id) === id);
  });

  // Mobile: show messages panel
  document.getElementById('chatContainer').classList.add('conv-open');

  // Remove unread badge
  var activeItem = document.querySelector('.chat-list-item[data-id="' + id + '"]');
  if (activeItem) {
    var badge = activeItem.querySelector('.chat-unread-badge');
    if (badge) badge.remove();
  }

  loadMessages(id);
}

function goBackToList() {
  document.getElementById('chatContainer').classList.remove('conv-open');
  currentConversationId = null;
}

// ============ Messages ============

async function loadMessages(conversationId, beforeId) {
  try {
    var url = '/chat/conversations/' + conversationId + '/messages';
    if (beforeId) url += '?before=' + beforeId;

    var res = await axios.get(url);
    var data = res.data.data;
    var messages = data.messages;
    var conversation = data.conversation;

    // Render header
    renderHeader(conversation);

    // Input area visibility is handled by renderHeader based on conversation type

    // Render messages
    var container = document.getElementById('chatMessages');

    if (beforeId) {
      // Prepend older messages
      var oldScrollHeight = container.scrollHeight;
      var html = buildMessagesHTML(messages, false);
      container.insertAdjacentHTML('afterbegin', html);
      container.scrollTop = container.scrollHeight - oldScrollHeight;
    } else {
      var html = '';
      if (messages.length >= 50) {
        html += '<div class="load-more-btn" onclick="loadOlderMessages()">Load older messages</div>';
      }
      html += buildMessagesHTML(messages, true);
      container.innerHTML = html;
      container.scrollTop = container.scrollHeight;
    }

    // Mark as read
    axios.post('/chat/conversations/' + conversationId + '/read');

    // Join socket room
    socket.emit('chat:join', conversationId);
  } catch (err) {
    console.error('Failed to load messages:', err);
  }
}

function loadOlderMessages() {
  var firstMsg = document.querySelector('.msg-row[data-mid]');
  if (firstMsg) {
    loadMessages(currentConversationId, firstMsg.dataset.mid);
  }
}

var currentCallPeerId = null;
var currentCallPeerName = null;

function renderHeader(conversation) {
  var name, sub, avatarClass, avatarContent;

  if (conversation.type === 'system') {
    currentCallPeerId = null;
    currentCallPeerName = null;
    name = 'System Notifications';
    sub = 'Automated task reminders';
    avatarClass = 'system';
    avatarContent = '<i class="bi bi-robot" style="font-size:0.9rem;"></i>';
  } else if (conversation.type === 'direct') {
    var other = conversation.participants.find(function(p) { return p.id !== currentUserId; }) || conversation.participants[0];
    name = other.name;
    sub = other.role_name + ' &middot; ' + other.org_type;
    avatarClass = 'direct';
    avatarContent = other.name.charAt(0).toUpperCase();
    currentCallPeerId = other.id;
    currentCallPeerName = other.name;
  } else {
    currentCallPeerId = null;
    currentCallPeerName = null;
    name = conversation.name || 'Group';
    sub = conversation.participants.map(function(p) { return p.name.split(' ')[0]; }).join(', ');
    avatarClass = 'group';
    avatarContent = '<i class="bi bi-people-fill" style="font-size:0.9rem;"></i>';
  }

  var actions = '';
  if (conversation.type !== 'system') {
    if (conversation.type === 'direct') {
      actions += '<button onclick="startCall(currentCallPeerId, currentCallPeerName, currentConversationId)" title="Voice call" style="background:none;border:none;color:var(--tf-text-muted);cursor:pointer;padding:4px 8px;border-radius:6px;font-size:0.95rem;display:flex;align-items:center;transition:color 0.15s;" onmouseover="this.style.color=\'#10b981\'" onmouseout="this.style.color=\'var(--tf-text-muted)\'"><i class="bi bi-telephone-fill"></i></button>';
    }
    actions += '<button onclick="confirmClearChat()" title="Clear chat" style="background:none;border:none;color:var(--tf-text-muted);cursor:pointer;padding:4px 8px;border-radius:6px;font-size:0.8rem;display:flex;align-items:center;gap:4px;transition:color 0.15s;" onmouseover="this.style.color=\'#ef4444\'" onmouseout="this.style.color=\'var(--tf-text-muted)\'"><i class="bi bi-trash3"></i></button>';
  }

  document.getElementById('chatHeaderArea').innerHTML =
    '<div class="chat-main-header">' +
      '<button class="chat-back-btn" onclick="goBackToList()"><i class="bi bi-arrow-left"></i></button>' +
      '<div class="chat-avatar ' + avatarClass + '" ' + (conversation.type === 'system' ? 'style="background:rgba(99,102,241,0.15);color:#6366f1;"' : '') + '>' + avatarContent + '</div>' +
      '<div style="flex:1;min-width:0;"><div class="chat-header-name">' + escapeHtml(name) + '</div>' +
      '<div class="chat-header-sub">' + sub + '</div></div>' +
      actions +
    '</div>';

  // Toggle input area based on conversation type
  var inputArea = document.getElementById('chatInputArea');
  var systemNotice = document.getElementById('systemChatNotice');
  if (conversation.type === 'system') {
    inputArea.style.display = 'none';
    if (!systemNotice) {
      var notice = document.createElement('div');
      notice.id = 'systemChatNotice';
      notice.style.cssText = 'padding:0.75rem 1.25rem;text-align:center;font-size:0.75rem;color:#6366f1;background:rgba(99,102,241,0.08);border-top:1px solid var(--tf-border);';
      notice.innerHTML = '<i class="bi bi-robot me-1"></i> System notifications — no reply allowed';
      inputArea.parentNode.appendChild(notice);
    } else {
      systemNotice.style.display = 'block';
    }
  } else {
    inputArea.style.display = 'block';
    if (systemNotice) systemNotice.style.display = 'none';
  }
}

function isViewableType(mime, name) {
  if (!mime) return false;
  // Documents, images, PDFs, text — viewable in browser / Google viewer
  if (mime.startsWith('image/')) return true;
  if (mime === 'application/pdf') return true;
  if (mime.startsWith('text/')) return true;
  if (mime.includes('word') || mime.includes('document')) return true;
  if (mime.includes('sheet') || mime.includes('excel') || mime.includes('csv')) return true;
  if (mime.includes('presentation') || mime.includes('powerpoint')) return true;
  if (mime.includes('google-apps')) return true;
  // Common viewable extensions
  var n = (name || '').toLowerCase();
  if (/\.(pdf|doc|docx|xls|xlsx|csv|ppt|pptx|txt|jpg|jpeg|png|gif|svg|webp)$/.test(n)) return true;
  return false;
}

function buildAttachmentHTML(m) {
  if (!m.attachment_drive_id) return '';
  var icon = getAttachIcon(m.attachment_mime);
  var size = m.attachment_size ? formatBytes(m.attachment_size) : '';
  var viewable = isViewableType(m.attachment_mime, m.attachment_name);
  var link = m.attachment_link || '#';
  var isSender = m.sender_id === currentUserId;
  var alreadySaved = m.saved_to_drive || isSender;

  var html = '<div class="msg-attachment" style="cursor:default;" data-msg-id="' + m.id + '" data-mime="' + (m.attachment_mime || '') + '" oncontextmenu="openAttachMenu(event,this)">';
  html += '<div class="msg-attach-icon"><i class="bi bi-' + icon + '"></i></div>';
  html += '<div style="flex:1;min-width:0;">';
  html += '<div class="msg-attach-name">' + escapeHtml(m.attachment_name) + '</div>';
  if (size) html += '<div class="msg-attach-size">' + size + '</div>';
  html += '</div>';

  if (viewable) {
    // Open via server proxy (works for all participants)
    html += '<a href="/chat/attachment/' + m.id + '?action=view" target="_blank" class="msg-attach-dl" title="Open" style="cursor:pointer;text-decoration:none;color:inherit;"><i class="bi bi-box-arrow-up-right"></i></a>';
  } else if (alreadySaved) {
    // Already saved — show checkmark, disabled
    html += '<span class="msg-attach-dl" title="Saved to Drive" style="color:var(--tf-success);font-size:0.85rem;"><i class="bi bi-check-lg"></i></span>';
  } else {
    // Save to Drive button
    var safeName = escapeHtml(m.attachment_name).replace(/'/g, "\\'");
    html += '<button onclick="event.stopPropagation();saveToDrive(\'' + m.attachment_drive_id + '\',\'' + safeName + '\',' + m.id + ',this)" class="msg-attach-dl" title="Save to your Drive" style="background:none;border:none;cursor:pointer;color:var(--tf-accent);font-size:0.85rem;padding:2px 4px;border-radius:4px;">';
    html += '<i class="bi bi-cloud-download"></i>';
    html += '</button>';
  }

  html += '</div>';
  return html;
}

function getAttachIcon(mime) {
  if (!mime) return 'file-earmark';
  if (mime.startsWith('image/')) return 'file-image';
  if (mime === 'application/pdf') return 'file-pdf';
  if (mime.includes('word') || mime.includes('document')) return 'file-word';
  if (mime.includes('sheet') || mime.includes('excel')) return 'file-spreadsheet';
  if (mime.startsWith('video/')) return 'file-play';
  if (mime.startsWith('audio/')) return 'file-music';
  if (mime.includes('zip') || mime.includes('rar') || mime.includes('tar')) return 'file-zip';
  return 'file-earmark';
}

function formatBytes(bytes) {
  if (!bytes) return '';
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / 1048576).toFixed(1) + ' MB';
}

function buildMessagesHTML(messages, isInitial) {
  var html = '';
  var lastDate = '';

  messages.forEach(function(m) {
    var msgDate = new Date(m.created_at).toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
    if (msgDate !== lastDate) {
      html += '<div class="msg-date-divider"><span>' + msgDate + '</span></div>';
      lastDate = msgDate;
    }

    var isSent = m.sender_id === currentUserId;
    var isSystem = m.sender_name === 'System';
    var time = new Date(m.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });

    if (m.message_type && m.message_type.startsWith('call_')) {
      // Call event message: centered with phone icon
      var isCallMissed = m.message_type === 'call_missed';
      var callIcon = isCallMissed ? 'bi-telephone-x-fill' : (m.message_type === 'call_outgoing' ? 'bi-telephone-outbound-fill' : 'bi-telephone-inbound-fill');
      var callColor = isCallMissed ? '#ef4444' : '#10b981';
      html += '<div class="msg-row" data-mid="' + m.id + '" style="justify-content:center;">';
      html += '<div style="display:inline-flex;align-items:center;gap:8px;background:rgba(' + (isCallMissed ? '239,68,68' : '16,185,129') + ',0.08);border:1px solid rgba(' + (isCallMissed ? '239,68,68' : '16,185,129') + ',0.2);border-radius:20px;padding:6px 16px;">';
      html += '<i class="bi ' + callIcon + '" style="color:' + callColor + ';font-size:0.85rem;"></i>';
      html += '<span style="font-size:0.8rem;color:' + callColor + ';font-weight:500;">' + escapeHtml(m.content) + '</span>';
      html += '<span style="font-size:0.65rem;color:var(--tf-text-muted);margin-left:4px;">' + time + '</span>';
      html += '</div></div>';
    } else if (isSystem) {
      // System message: centered notification style
      html += '<div class="msg-row" data-mid="' + m.id + '" style="justify-content:center;">';
      html += '<div style="max-width:85%;background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.2);border-radius:12px;padding:0.75rem 1rem;text-align:left;">';
      html += '<div style="font-size:0.65rem;color:#6366f1;font-weight:600;margin-bottom:4px;"><i class="bi bi-robot me-1"></i>System</div>';
      if (m.content) {
        html += '<div style="font-size:0.8rem;color:var(--tf-text);white-space:pre-wrap;">' + escapeHtml(m.content) + '</div>';
      }
      html += '<div class="msg-time" style="text-align:right;"><span>' + time + '</span></div>';
      html += '</div></div>';
    } else {
      html += '<div class="msg-row ' + (isSent ? 'sent' : 'received') + '" data-mid="' + m.id + '">';
      html += '<div class="msg-bubble">';

      if (!isSent && m.sender_name) {
        html += '<div class="msg-sender">' + escapeHtml(m.sender_name) + '</div>';
      }

      html += buildAttachmentHTML(m);

      if (m.content) {
        html += '<div>' + escapeHtml(m.content) + '</div>';
      }

      var tickHtml = isSent
        ? '<span class="msg-tick ' + (m.is_read ? 'read' : 'sent') + '" data-tick="' + m.id + '"><i class="bi bi-check2-all"></i></span>'
        : '';
      html += '<div class="msg-time"><span>' + time + '</span>' + tickHtml + '</div>';
      html += '</div></div>';
    }
  });

  return html;
}

// ============ Send Message ============

function showUploadBar(fileName) {
  document.getElementById('uploadBarName').textContent = 'Uploading ' + fileName;
  document.getElementById('uploadBarStatus').textContent = '0%';
  document.getElementById('uploadBarFill').style.width = '0%';
  document.getElementById('chatUploadBar').classList.add('show');
}

function updateUploadProgress(percent) {
  document.getElementById('uploadBarStatus').textContent = percent + '%';
  document.getElementById('uploadBarFill').style.width = percent + '%';
}

function hideUploadBar() {
  document.getElementById('chatUploadBar').classList.remove('show');
}

async function sendMessage() {
  var input = document.getElementById('chatInput');
  var content = input.value.trim();

  if (!currentConversationId) return;
  if (!content && !pendingAttachment) return;

  input.value = '';
  document.getElementById('sendBtn').disabled = true;
  document.getElementById('attachBtn').disabled = true;

  try {
    var res;
    var hasAttachment = !!pendingAttachment;

    if (pendingAttachment && pendingAttachment.type === 'local') {
      // Show upload progress
      showUploadBar(pendingAttachment.name);
      document.getElementById('attachPreview').classList.remove('show');

      var formData = new FormData();
      formData.append('file', pendingAttachment.file);
      if (content) formData.append('content', content);

      res = await axios.post('/chat/conversations/' + currentConversationId + '/attach-local', formData, {
        headers: { 'Content-Type': 'multipart/form-data' },
        onUploadProgress: function(e) {
          if (e.total) {
            var pct = Math.round((e.loaded / e.total) * 100);
            updateUploadProgress(pct);
          }
        }
      });
    } else if (pendingAttachment && pendingAttachment.type === 'drive') {
      document.getElementById('attachPreview').classList.remove('show');
      document.getElementById('uploadBarName').textContent = 'Linking from Drive...';
      document.getElementById('uploadBarStatus').textContent = pendingAttachment.name;
      document.getElementById('uploadBarFill').style.transition = 'none';
      document.getElementById('uploadBarFill').style.width = '100%';
      document.getElementById('uploadBarFill').style.opacity = '0.4';
      document.getElementById('uploadBarFill').style.animation = 'pulse 1.2s ease-in-out infinite';
      document.getElementById('chatUploadBar').classList.add('show');

      res = await axios.post('/chat/conversations/' + currentConversationId + '/attach-drive', {
        drive_file_id: pendingAttachment.driveFileId,
        content: content || null
      });

      document.getElementById('uploadBarFill').style.animation = '';
      document.getElementById('uploadBarFill').style.opacity = '1';
      document.getElementById('uploadBarFill').style.transition = '';
    } else {
      res = await axios.post('/chat/conversations/' + currentConversationId + '/messages', { content: content });
    }

    if (hasAttachment) hideUploadBar();

    var msg = res.data.data.message;
    clearAttachment();
    appendMessage(msg);
    updateConversationPreview(currentConversationId, msg);
  } catch (err) {
    hideUploadBar();
    showToast(err.response?.data?.message || 'Failed to send', 'error');
    input.value = content;
  } finally {
    document.getElementById('sendBtn').disabled = false;
    document.getElementById('attachBtn').disabled = false;
    input.focus();
  }
}

function appendMessage(msg) {
  var container = document.getElementById('chatMessages');
  var emptyEl = container.querySelector('.chat-empty');
  if (emptyEl) emptyEl.remove();

  var isSent = msg.sender_id === currentUserId;
  var time = new Date(msg.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });

  // Check if we need a date divider
  var lastRow = container.querySelector('.msg-row:last-child');
  var msgDate = new Date(msg.created_at).toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
  var needDate = true;
  if (lastRow) {
    var lastDividers = container.querySelectorAll('.msg-date-divider');
    if (lastDividers.length > 0) {
      var lastDivText = lastDividers[lastDividers.length - 1].textContent.trim();
      if (lastDivText === msgDate) needDate = false;
    }
  }

  var html = '';
  if (needDate && !lastRow) {
    html += '<div class="msg-date-divider"><span>' + msgDate + '</span></div>';
  }

  html += '<div class="msg-row ' + (isSent ? 'sent' : 'received') + '" data-mid="' + msg.id + '">';
  html += '<div class="msg-bubble">';
  if (!isSent && msg.sender_name) {
    html += '<div class="msg-sender">' + escapeHtml(msg.sender_name) + '</div>';
  }
  html += buildAttachmentHTML(msg);
  if (msg.content) {
    html += '<div>' + escapeHtml(msg.content) + '</div>';
  }
  var appendTickHtml = isSent
    ? '<span class="msg-tick ' + (msg.is_read ? 'read' : 'sent') + '" data-tick="' + msg.id + '"><i class="bi bi-check2-all"></i></span>'
    : '';
  html += '<div class="msg-time"><span>' + time + '</span>' + appendTickHtml + '</div>';
  html += '</div></div>';

  container.insertAdjacentHTML('beforeend', html);
  container.scrollTop = container.scrollHeight;
}

function updateConversationPreview(convId, msg) {
  var item = document.querySelector('.chat-list-item[data-id="' + convId + '"]');
  if (!item) return;

  var preview = item.querySelector('.chat-list-preview');
  if (preview) {
    var text = msg.content ? (msg.content.length > 40 ? msg.content.substring(0, 40) + '...' : msg.content) : '';
    if (msg.attachment_name) text = (text ? text : '') || '<i class="bi bi-paperclip"></i> ' + msg.attachment_name;
    preview.innerHTML = msg.sender_id === currentUserId ? '<strong>You:</strong> ' + text : text;
  }

  var timeEl = item.querySelector('.chat-list-time');
  if (timeEl) {
    timeEl.textContent = new Date(msg.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
  }

  // Move to top of list
  var list = document.getElementById('chatList');
  if (list.firstElementChild !== item) {
    list.insertBefore(item, list.firstElementChild);
  }
}

// ============ Socket.IO Events ============

socket.on('chat:message', function(data) {
  var msg = data.message;
  var convId = data.conversation_id;

  // If this conversation is currently open, append and mark read
  if (convId === currentConversationId) {
    appendMessage(msg);
    axios.post('/chat/conversations/' + convId + '/read');
  } else {
    // Increment unread badge
    var item = document.querySelector('.chat-list-item[data-id="' + convId + '"]');
    if (item) {
      var badge = item.querySelector('.chat-unread-badge');
      if (badge) {
        var count = parseInt(badge.textContent) || 0;
        badge.textContent = count + 1 > 9 ? '9+' : count + 1;
      } else {
        var meta = item.querySelector('.chat-list-meta');
        if (meta) meta.insertAdjacentHTML('beforeend', '<span class="chat-unread-badge">1</span>');
      }
    } else {
      // New conversation not in list — reload
      location.reload();
    }
  }

  updateConversationPreview(convId, msg);
  updateGlobalUnreadBadge();
});

socket.on('chat:typing', function(data) {
  if (data.conversation_id === currentConversationId && data.user_id !== currentUserId) {
    var el = document.getElementById('typingIndicator');
    el.textContent = data.user_name + ' is typing...';
    clearTimeout(typingTimeout);
    typingTimeout = setTimeout(function() { el.textContent = ''; }, 3000);
  }
});

// Update sent message ticks to blue when recipient reads
socket.on('chat:read', function(data) {
  if (data.conversation_id !== currentConversationId) return;
  document.querySelectorAll('.msg-tick.sent').forEach(function(tick) {
    if (parseInt(tick.dataset.tick) <= data.last_read_message_id) {
      tick.classList.remove('sent');
      tick.classList.add('read');
    }
  });
});

// ============ System Chat Notification ============
socket.on('chat:system', function(data) {
  // Reload conversation list to show system chat
  axios.get('/chat/conversations').then(function(res) {
    if (res.data.success) {
      // Find system conversation and open it or refresh current
      var convs = res.data.data.conversations;
      var sysConv = convs.find(function(c) { return c.type === 'system'; });
      if (sysConv && currentConversationId === sysConv.id) {
        loadMessages(sysConv.id);
      }
    }
  }).catch(function() {});
});

// ============ Clear Chat ============

function confirmClearChat() {
  if (!currentConversationId) return;
  var modal = document.getElementById('clearChatModal');
  modal.style.display = 'flex';
}

async function executeClearChat() {
  document.getElementById('clearChatModal').style.display = 'none';
  try {
    await axios.post('/chat/conversations/' + currentConversationId + '/clear');
    // Clear the message container
    var container = document.getElementById('chatMessages');
    container.innerHTML = '<div class="chat-empty"><i class="bi bi-chat-dots"></i><span>No messages yet</span></div>';
    showToast('Chat cleared', 'success');
  } catch (err) {
    showToast('Failed to clear chat', 'error');
  }
}

// Emit typing indicator
(function() {
  var input = document.getElementById('chatInput');
  var lastTypingEmit = 0;
  if (input) {
    input.addEventListener('input', function() {
      if (!currentConversationId) return;
      var now = Date.now();
      if (now - lastTypingEmit > 2000) {
        socket.emit('chat:typing', { conversation_id: currentConversationId });
        lastTypingEmit = now;
      }
    });
  }
})();

// ============ New Chat Modal ============

function openNewChatModal() {
  document.getElementById('newChatModal').classList.add('show');
  setChatType('direct');
  document.querySelectorAll('.user-select-item').forEach(function(el) {
    el.classList.remove('selected');
    el.querySelector('input[type="checkbox"]').checked = false;
  });
  document.getElementById('userSearchInput').value = '';
  filterUsers();
}

function closeNewChatModal() {
  document.getElementById('newChatModal').classList.remove('show');
}

// Attachment right-click context menu
var _ctxMsgId = null;

function openAttachMenu(e, el) {
  e.preventDefault();
  e.stopPropagation();
  _ctxMsgId = el.dataset.msgId;

  // Show/hide Open based on viewable type
  var mime = el.dataset.mime || '';
  var nameEl = el.querySelector('.msg-attach-name');
  var name = nameEl ? nameEl.textContent : '';
  var canView = isViewableType(mime, name);
  document.getElementById('attachCtxOpen').style.display = canView ? 'flex' : 'none';

  var menu = document.getElementById('attachCtxMenu');
  menu.classList.add('show');
  // Position near cursor, keep within viewport
  var x = e.clientX, y = e.clientY;
  if (x + 170 > window.innerWidth) x = window.innerWidth - 175;
  if (y + 90 > window.innerHeight) y = window.innerHeight - 95;
  menu.style.left = x + 'px';
  menu.style.top = y + 'px';
}

function closeAttachMenu() {
  document.getElementById('attachCtxMenu').classList.remove('show');
  _ctxMsgId = null;
}

document.getElementById('attachCtxOpen').addEventListener('click', function() {
  if (!_ctxMsgId) return;
  window.open('/chat/attachment/' + _ctxMsgId + '?action=view', '_blank');
  closeAttachMenu();
});

document.getElementById('attachCtxSave').addEventListener('click', function() {
  if (!_ctxMsgId) return;
  var a = document.createElement('a');
  a.href = '/chat/attachment/' + _ctxMsgId + '?action=download';
  a.download = '';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  closeAttachMenu();
});

document.addEventListener('click', function(e) {
  if (!document.getElementById('attachCtxMenu').contains(e.target)) closeAttachMenu();
});
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeAttachMenu(); });

function setChatType(type) {
  chatType = type;
  document.getElementById('btnTypeDirect').className = 'btn-tf ' + (type === 'direct' ? 'btn-tf-primary' : 'btn-tf-outline');
  document.getElementById('btnTypeGroup').className = 'btn-tf ' + (type === 'group' ? 'btn-tf-primary' : 'btn-tf-outline');
  document.getElementById('groupNameField').style.display = type === 'group' ? 'block' : 'none';
}

function filterUsers() {
  var term = document.getElementById('userSearchInput').value.toLowerCase();
  document.querySelectorAll('.user-select-item').forEach(function(el) {
    var name = el.dataset.name;
    el.style.display = name.includes(term) ? '' : 'none';
  });
}

function toggleUserSelect(el) {
  var checkbox = el.querySelector('input[type="checkbox"]');

  if (chatType === 'direct') {
    // Only allow one selection
    document.querySelectorAll('.user-select-item').forEach(function(item) {
      item.classList.remove('selected');
      item.querySelector('input[type="checkbox"]').checked = false;
    });
  }

  el.classList.toggle('selected');
  checkbox.checked = el.classList.contains('selected');
}

async function createConversation() {
  var selectedItems = document.querySelectorAll('.user-select-item.selected');
  var ids = [];
  selectedItems.forEach(function(el) {
    ids.push(parseInt(el.dataset.uid));
  });

  if (ids.length === 0) {
    showToast('Please select at least one user', 'error');
    return;
  }

  if (chatType === 'direct' && ids.length > 1) {
    showToast('Select only one user for direct chat', 'error');
    return;
  }

  var payload = {
    type: chatType,
    participant_ids: ids
  };

  if (chatType === 'group') {
    var groupName = document.getElementById('groupNameInput').value.trim();
    if (!groupName) {
      showToast('Please enter a group name', 'error');
      return;
    }
    payload.name = groupName;
  }

  document.getElementById('createChatBtn').disabled = true;

  try {
    var res = await axios.post('/chat/conversations', payload);
    var convId = res.data.data.conversation_id;
    closeNewChatModal();

    // Navigate to the new conversation
    window.location.href = '/chat?c=' + convId;
  } catch (err) {
    showToast(err.response?.data?.message || 'Failed to create chat', 'error');
  } finally {
    document.getElementById('createChatBtn').disabled = false;
  }
}

// ============ Global Unread Badge ============

async function updateGlobalUnreadBadge() {
  try {
    var res = await axios.get('/chat/unread-count');
    var count = res.data.data.count;
    var badge = document.getElementById('chatNavBadge');
    if (badge) {
      badge.textContent = count > 9 ? '9+' : count;
      badge.style.display = count > 0 ? 'inline-flex' : 'none';
    }
  } catch (e) {}
}

// Poll unread count every 30s
setInterval(updateGlobalUnreadBadge, 30000);

// ============ Utils ============

function escapeHtml(text) {
  if (!text) return '';
  var div = document.createElement('div');
  div.appendChild(document.createTextNode(text));
  return div.innerHTML;
}

// ============ Save to Drive ============

async function saveToDrive(driveFileId, fileName, messageId, btnEl) {
  var origHtml = btnEl.innerHTML;
  btnEl.innerHTML = '<i class="bi bi-hourglass-split"></i>';
  btnEl.disabled = true;

  try {
    var res = await axios.post('/chat/save-to-drive', {
      drive_file_id: driveFileId,
      file_name: fileName,
      message_id: messageId
    });
    showToast('Saved "' + fileName + '" to your Drive', 'success');
    btnEl.innerHTML = '<i class="bi bi-check-lg"></i>';
    btnEl.style.color = 'var(--tf-success)';
    btnEl.style.cursor = 'default';
    btnEl.title = 'Saved to Drive';
    btnEl.onclick = null;
  } catch (err) {
    if (err.response?.status === 409) {
      // Already saved
      btnEl.innerHTML = '<i class="bi bi-check-lg"></i>';
      btnEl.style.color = 'var(--tf-success)';
      btnEl.style.cursor = 'default';
      btnEl.title = 'Saved to Drive';
      btnEl.onclick = null;
      showToast('Already saved to your Drive', 'info');
    } else {
      showToast(err.response?.data?.message || 'Failed to save to Drive', 'error');
      btnEl.innerHTML = origHtml;
      btnEl.disabled = false;
    }
  }
}

// ============ Attachment Handling ============

function toggleAttachMenu(e) {
  e.stopPropagation();
  var menu = document.getElementById('attachMenu');
  menu.classList.toggle('show');
}

// Close attach menu on click outside
document.addEventListener('click', function(e) {
  var menu = document.getElementById('attachMenu');
  if (menu && !e.target.closest('.chat-attach-btn')) {
    menu.classList.remove('show');
  }
});

function triggerLocalUpload() {
  document.getElementById('attachMenu').classList.remove('show');
  document.getElementById('attachFileInput').click();
}

function handleAttachFile(input) {
  if (!input.files || !input.files[0]) return;
  attachPendingFile(input.files[0]);
  input.value = '';
}

function attachPendingFile(file) {
  if (file.size > maxAttachMB * 1024 * 1024) {
    showToast('File exceeds ' + maxAttachMB + 'MB limit', 'error');
    return;
  }
  pendingAttachment = {
    type: 'local',
    file: file,
    name: file.name || ('pasted-' + Date.now() + '.png'),
    size: file.size,
    mime: file.type
  };
  showAttachPreview(pendingAttachment.name, pendingAttachment.size, file);
}

// Paste screenshot into local chat input — attach directly
(function attachLocalChatPaste() {
  var el = document.getElementById('chatInput');
  if (!el) { setTimeout(attachLocalChatPaste, 300); return; }
  el.addEventListener('paste', function(e) {
    var items = (e.clipboardData || window.clipboardData)?.items;
    if (!items) return;
    for (var i = 0; i < items.length; i++) {
      if (items[i].kind === 'file') {
        var f = items[i].getAsFile();
        if (f) { e.preventDefault(); attachPendingFile(f); return; }
      }
    }
  });
})();

function showAttachPreview(name, size, file) {
  document.getElementById('attachPreviewName').textContent = name;
  document.getElementById('attachPreviewSize').textContent = formatBytes(size);
  var thumb = document.getElementById('attachPreviewThumb');
  var icon = document.getElementById('attachPreviewIcon');
  // If the attachment is an image File/Blob, show a thumbnail
  if (file && file.type && file.type.indexOf('image/') === 0) {
    try {
      if (thumb.dataset.blobUrl) URL.revokeObjectURL(thumb.dataset.blobUrl);
      var url = URL.createObjectURL(file);
      thumb.src = url;
      thumb.dataset.blobUrl = url;
      thumb.style.display = '';
      if (icon) icon.style.display = 'none';
    } catch (e) {}
  } else {
    thumb.style.display = 'none';
    if (icon) icon.style.display = '';
  }
  document.getElementById('attachPreview').classList.add('show');
}

function clearAttachment() {
  pendingAttachment = null;
  var thumb = document.getElementById('attachPreviewThumb');
  if (thumb.dataset.blobUrl) { URL.revokeObjectURL(thumb.dataset.blobUrl); delete thumb.dataset.blobUrl; }
  thumb.style.display = 'none';
  thumb.src = '';
  var icon = document.getElementById('attachPreviewIcon');
  if (icon) icon.style.display = '';
  document.getElementById('attachPreview').classList.remove('show');
  document.getElementById('attachPreviewName').textContent = '';
  document.getElementById('attachPreviewSize').textContent = '';
}

// ============ Drive Picker ============

var dpRootFolderId = null;
var dpCurrentFolderId = null;
var dpSelectedFileId = null;
var dpSelectedFileName = null;
var dpSelectedFileSize = null;
var dpSelectedFileMime = null;

function openDrivePicker() {
  document.getElementById('attachMenu').classList.remove('show');
  document.getElementById('drivePickerModal').classList.add('show');
  dpSelectedFileId = null;
  document.getElementById('dpSelectBtn').disabled = true;
  loadDrivePickerFiles();
}

function closeDrivePicker() {
  document.getElementById('drivePickerModal').classList.remove('show');
}

async function loadDrivePickerFiles(folderId) {
  var list = document.getElementById('drivePickerList');
  list.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--tf-text-muted);font-size:0.8rem;">Loading...</div>';

  try {
    var url = '/chat/drive-files';
    if (folderId) url += '?folder=' + folderId;

    var res = await axios.get(url);
    var data = res.data.data;
    var files = data.files;
    dpRootFolderId = data.rootFolderId;
    dpCurrentFolderId = data.currentFolderId;

    // Update breadcrumb
    var bc = document.getElementById('dpBreadcrumb');
    bc.innerHTML = '<a href="#" onclick="loadDrivePickerFiles();return false;">My Drive</a>';
    if (folderId && folderId !== dpRootFolderId) {
      bc.innerHTML += ' <span class="sep" style="color:var(--tf-text-muted);"><i class="bi bi-chevron-right"></i></span> <span style="color:var(--tf-text);">...</span>';
    }

    if (files.length === 0) {
      list.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--tf-text-muted);font-size:0.8rem;">This folder is empty</div>';
      return;
    }

    var html = '';
    files.forEach(function(f) {
      var iconClass = f.isFolder ? 'folder' : 'file';
      var icon = f.isFolder ? 'folder-fill' : getAttachIcon(f.mimeType);
      var size = !f.isFolder && f.size ? formatBytes(f.size) : '';

      html += '<div class="drive-picker-item" data-id="' + f.id + '" data-is-folder="' + f.isFolder + '" data-name="' + escapeHtml(f.name) + '" data-size="' + (f.size || 0) + '" data-mime="' + (f.mimeType || '') + '"';

      if (f.isFolder) {
        html += ' ondblclick="loadDrivePickerFiles(\'' + f.id + '\')"';
      }

      html += ' onclick="selectDrivePickerItem(this)">';
      html += '<div class="dp-icon ' + iconClass + '"><i class="bi bi-' + icon + '"></i></div>';
      html += '<div class="dp-name">' + escapeHtml(f.name) + '</div>';
      if (size) html += '<div class="dp-size">' + size + '</div>';
      html += '</div>';
    });

    list.innerHTML = html;
  } catch (err) {
    list.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--tf-danger);font-size:0.8rem;">Failed to load files</div>';
  }
}

function selectDrivePickerItem(el) {
  // Deselect all
  document.querySelectorAll('.drive-picker-item').forEach(function(item) {
    item.classList.remove('selected');
  });

  el.classList.add('selected');
  var isFolder = el.dataset.isFolder === 'true';

  if (isFolder) {
    dpSelectedFileId = null;
    document.getElementById('dpSelectBtn').disabled = true;
  } else {
    dpSelectedFileId = el.dataset.id;
    dpSelectedFileName = el.dataset.name;
    dpSelectedFileSize = parseInt(el.dataset.size) || 0;
    dpSelectedFileMime = el.dataset.mime;
    document.getElementById('dpSelectBtn').disabled = false;
  }
}

function selectDriveFile() {
  if (!dpSelectedFileId) return;

  pendingAttachment = {
    type: 'drive',
    driveFileId: dpSelectedFileId,
    name: dpSelectedFileName,
    size: dpSelectedFileSize,
    mime: dpSelectedFileMime
  };

  showAttachPreview(dpSelectedFileName, dpSelectedFileSize);
  closeDrivePicker();
}

// ============ Auto-open conversation ============

(function() {
  if (currentConversationId) {
    openConversation(currentConversationId);
  }
})();

// startCall(), endCall(), acceptCall(), rejectCall(), toggleMute()
// are all defined globally in main.ejs and work from any page.
</script>
