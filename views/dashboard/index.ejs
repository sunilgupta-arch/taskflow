<%
const isAdmin = ['CLIENT_ADMIN', 'LOCAL_ADMIN'].includes(user.role_name);
const isManager = ['CLIENT_MANAGER', 'LOCAL_MANAGER'].includes(user.role_name);
%>

<% if (isAdmin || isManager) { %>
<!-- Admin / Manager Dashboard -->

<!-- Task Stats Row -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <a href="/tasks" class="stat-card stat-card-link" style="--stat-color: #00d4ff;">
      <div class="stat-value"><%= taskStats.total || 0 %></div>
      <div class="stat-label">Total Tasks</div>
      <i class="bi bi-list-task stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/tasks?status=pending" class="stat-card stat-card-link" style="--stat-color: #f59e0b;">
      <div class="stat-value"><%= taskStats.pending || 0 %></div>
      <div class="stat-label">Pending</div>
      <i class="bi bi-hourglass stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/tasks?status=in_progress" class="stat-card stat-card-link" style="--stat-color: #00d4ff;">
      <div class="stat-value"><%= taskStats.in_progress || 0 %></div>
      <div class="stat-label">In Progress</div>
      <i class="bi bi-play-circle stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/tasks?status=completed" class="stat-card stat-card-link" style="--stat-color: #10b981;">
      <div class="stat-value"><%= taskStats.completed || 0 %></div>
      <div class="stat-label">Completed</div>
      <i class="bi bi-check-circle stat-icon"></i>
    </a>
  </div>
</div>

<!-- Completion Timeline -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <a href="/tasks?status=completed&completed_period=today" class="stat-card stat-card-link" style="--stat-color: #7c3aed;">
      <div class="stat-value"><%= taskStats.completed_today || 0 %></div>
      <div class="stat-label">Completed Today</div>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/tasks?status=completed&completed_period=week" class="stat-card stat-card-link" style="--stat-color: #7c3aed;">
      <div class="stat-value"><%= taskStats.completed_this_week || 0 %></div>
      <div class="stat-label">This Week</div>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/tasks?status=completed&completed_period=month" class="stat-card stat-card-link" style="--stat-color: #7c3aed;">
      <div class="stat-value"><%= taskStats.completed_this_month || 0 %></div>
      <div class="stat-label">This Month</div>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/tasks?status=completed&completed_period=year" class="stat-card stat-card-link" style="--stat-color: #7c3aed;">
      <div class="stat-value"><%= taskStats.completed_this_year || 0 %></div>
      <div class="stat-label">This Year</div>
    </a>
  </div>
</div>

<!-- Task Types -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-4">
    <a href="/tasks?type=daily" class="stat-card stat-card-link" style="--stat-color: #06b6d4;">
      <div class="stat-value"><%= taskStats.type_daily || 0 %></div>
      <div class="stat-label">Daily Tasks</div>
      <i class="bi bi-calendar-day stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-4">
    <a href="/tasks?type=weekly" class="stat-card stat-card-link" style="--stat-color: #8b5cf6;">
      <div class="stat-value"><%= taskStats.type_weekly || 0 %></div>
      <div class="stat-label">Weekly Tasks</div>
      <i class="bi bi-calendar-week stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-4">
    <a href="/tasks?type=adhoc" class="stat-card stat-card-link" style="--stat-color: #f97316;">
      <div class="stat-value"><%= taskStats.type_adhoc || 0 %></div>
      <div class="stat-label">One Time Tasks</div>
      <i class="bi bi-lightning stat-icon"></i>
    </a>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- Rewards Summary -->
  <div class="col-md-4">
    <div class="tf-card h-100">
      <div class="card-header">
        <i class="bi bi-coin me-2" style="color:#f59e0b;"></i>REWARDS OVERVIEW
      </div>
      <div class="p-3">
        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Total Earned</span>
          <span style="font-family:var(--tf-font-mono);color:#00d4ff;"><%= parseFloat(rewardSummary?.total || 0).toFixed(0) %> pts</span>
        </div>
        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Pending</span>
          <span style="font-family:var(--tf-font-mono);color:#f59e0b;"><%= parseFloat(rewardSummary?.pending || 0).toFixed(0) %> pts</span>
        </div>
        <div class="d-flex justify-content-between align-items-center py-2">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Paid Out</span>
          <span style="font-family:var(--tf-font-mono);color:#10b981;"><%= parseFloat(rewardSummary?.paid || 0).toFixed(0) %> pts</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Attendance Summary -->
  <div class="col-md-4">
    <div class="tf-card h-100">
      <div class="card-header">
        <i class="bi bi-people me-2" style="color:#00d4ff;"></i>ATTENDANCE TODAY
      </div>
      <div class="p-3">
        <% if (attendanceSummary) { %>
        <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Total Users</span>
          <span style="font-family:var(--tf-font-mono)"><%= attendanceSummary.total_users %></span>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Logged In</span>
          <span style="font-family:var(--tf-font-mono);color:#10b981;"><%= attendanceSummary.logged_in_today %></span>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">On Leave</span>
          <span style="font-family:var(--tf-font-mono);color:#f59e0b;"><%= attendanceSummary.on_leave %></span>
        </div>
        <div class="d-flex justify-content-between py-2">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">On Weekoff</span>
          <span style="font-family:var(--tf-font-mono);color:#64748b;"><%= attendanceSummary.on_weekoff %></span>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="col-md-4">
    <div class="tf-card h-100">
      <div class="card-header">
        <i class="bi bi-lightning me-2" style="color:#f59e0b;"></i>QUICK ACTIONS
      </div>
      <div class="p-3 d-flex flex-column gap-2">
        <a href="/tasks/create" class="btn-tf btn-tf-primary text-center text-decoration-none">
          <i class="bi bi-plus-circle me-1"></i> Create Task
        </a>
        <a href="/tasks" class="btn-tf btn-tf-outline text-center text-decoration-none">
          <i class="bi bi-list-task me-1"></i> View All Tasks
        </a>
        <a href="/rewards" class="btn-tf btn-tf-outline text-center text-decoration-none">
          <i class="bi bi-coin me-1"></i> Rewards Ledger
        </a>
        <% if (user.role_name === 'LOCAL_ADMIN') { %>
        <a href="/users" class="btn-tf btn-tf-outline text-center text-decoration-none">
          <i class="bi bi-people me-1"></i> Manage Users
        </a>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Per User Stats -->
<% if (perUserStats && perUserStats.length > 0) { %>
<div class="tf-card mb-4">
  <div class="card-header">
    <i class="bi bi-bar-chart me-2"></i>TEAM PERFORMANCE
  </div>
  <div style="overflow-x:auto;">
    <table class="tf-table">
      <thead>
        <tr>
          <th>User</th>
          <th>Total</th>
          <th>Done</th>
          <th>Active</th>
          <th>Pending</th>
          <th>Recurring</th>
          <th>Deactivated</th>
          <th>Progress</th>
          <th>Rewards</th>
        </tr>
      </thead>
      <tbody>
        <% perUserStats.forEach(u => {
           const progress = u.total_tasks > 0 ? Math.round((u.completed / u.total_tasks) * 100) : 0;
           const reward = perUserRewards?.find(r => r.id === u.id);
        %>
        <tr>
          <td>
            <a href="/users/<%= u.id %>/progress" style="text-decoration:none;color:inherit;">
              <div style="font-weight:600;font-size:0.875rem;"><%= u.name %></div>
              <div style="font-size:0.7rem;color:var(--tf-text-muted);"><%= u.email %></div>
            </a>
          </td>
          <td><span style="font-family:var(--tf-font-mono);"><%= u.total_tasks %></span></td>
          <td><span style="color:#10b981;font-family:var(--tf-font-mono);"><%= u.completed %></span></td>
          <td><span style="color:#00d4ff;font-family:var(--tf-font-mono);"><%= u.in_progress %></span></td>
          <td><span style="color:#f59e0b;font-family:var(--tf-font-mono);"><%= u.pending %></span></td>
          <td><span style="color:#8b5cf6;font-family:var(--tf-font-mono);"><%= u.active_recurring || 0 %></span></td>
          <td><span style="color:#64748b;font-family:var(--tf-font-mono);"><%= u.deactivated || 0 %></span></td>
          <td style="min-width:100px;">
            <div class="tf-progress">
              <div class="tf-progress-bar" style="width:<%= progress %>%"></div>
            </div>
            <div style="font-size:0.65rem;color:var(--tf-text-muted);margin-top:2px;"><%= progress %>%</div>
          </td>
          <td>
            <span style="font-family:var(--tf-font-mono);color:#f59e0b;">
              <%= parseFloat(reward?.total_earned || 0).toFixed(0) %> pts
            </span>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<% } else { %>
<!-- LOCAL_USER Dashboard -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <a href="/tasks?status=in_progress" class="stat-card stat-card-link" style="--stat-color:#00d4ff;">
      <div class="stat-value"><%= taskStats?.in_progress || 0 %></div>
      <div class="stat-label">Active Tasks</div>
      <i class="bi bi-play-circle stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/tasks?status=completed" class="stat-card stat-card-link" style="--stat-color:#10b981;">
      <div class="stat-value"><%= taskStats?.completed || 0 %></div>
      <div class="stat-label">Completed</div>
      <i class="bi bi-check-circle stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/rewards?status=pending" class="stat-card stat-card-link" style="--stat-color:#f59e0b;">
      <div class="stat-value"><%= parseFloat(rewardSummary?.pending_amount || 0).toFixed(0) %> pts</div>
      <div class="stat-label">Pending Reward</div>
      <i class="bi bi-hourglass stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-3">
    <a href="/rewards?status=paid" class="stat-card stat-card-link" style="--stat-color:#10b981;">
      <div class="stat-value"><%= parseFloat(rewardSummary?.paid_amount || 0).toFixed(0) %> pts</div>
      <div class="stat-label">Paid Out</div>
      <i class="bi bi-coin stat-icon"></i>
    </a>
  </div>
</div>

<!-- Task Types -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-4">
    <a href="/tasks/my?type=daily" class="stat-card stat-card-link" style="--stat-color: #06b6d4;">
      <div class="stat-value"><%= taskStats?.type_daily || 0 %></div>
      <div class="stat-label">Daily Tasks</div>
      <i class="bi bi-calendar-day stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-4">
    <a href="/tasks/my?type=weekly" class="stat-card stat-card-link" style="--stat-color: #8b5cf6;">
      <div class="stat-value"><%= taskStats?.type_weekly || 0 %></div>
      <div class="stat-label">Weekly Tasks</div>
      <i class="bi bi-calendar-week stat-icon"></i>
    </a>
  </div>
  <div class="col-6 col-md-4">
    <a href="/tasks/my?type=adhoc" class="stat-card stat-card-link" style="--stat-color: #f97316;">
      <div class="stat-value"><%= taskStats?.type_adhoc || 0 %></div>
      <div class="stat-label">One Time Tasks</div>
      <i class="bi bi-lightning stat-icon"></i>
    </a>
  </div>
</div>

<!-- Day Tasks with Date Navigation -->
<%
  const selDate = typeof selectedDate !== 'undefined' ? selectedDate : new Date().toISOString().split('T')[0];
  const dateObj = new Date(selDate + 'T00:00:00');
  const prevDate = new Date(dateObj); prevDate.setDate(prevDate.getDate() - 1);
  const nextDate = new Date(dateObj); nextDate.setDate(nextDate.getDate() + 1);
  const prevStr = prevDate.toISOString().split('T')[0];
  const nextStr = nextDate.toISOString().split('T')[0];
  const isTodayView = typeof isToday !== 'undefined' ? isToday : true;
  const todayStr = isTodayView ? selDate : '__not_today__';
  const displayDate = dateObj.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
%>
<div class="tf-card">
  <div class="card-header d-flex align-items-center justify-content-between">
    <span>
      <i class="bi bi-calendar-check me-2"></i>MY TASKS
      <% if (isTodayView) { %>
        <span style="font-size:0.7rem;padding:2px 8px;border-radius:4px;background:rgba(16,185,129,0.15);color:#10b981;margin-left:6px;">TODAY</span>
      <% } else if (typeof isPast !== 'undefined' && isPast) { %>
        <span style="font-size:0.7rem;padding:2px 8px;border-radius:4px;background:rgba(107,114,128,0.15);color:#6b7280;margin-left:6px;">PAST</span>
      <% } else if (typeof isFuture !== 'undefined' && isFuture) { %>
        <span style="font-size:0.7rem;padding:2px 8px;border-radius:4px;background:rgba(59,130,246,0.15);color:#3b82f6;margin-left:6px;">UPCOMING</span>
      <% } %>
    </span>
    <a href="/tasks/my" style="font-size:0.75rem;color:var(--tf-accent);text-decoration:none;">View All →</a>
  </div>

  <!-- Date Navigation -->
  <div class="d-flex align-items-center justify-content-between p-3" style="border-bottom:1px solid var(--tf-border);">
    <a href="/dashboard?date=<%= prevStr %>" class="btn-tf btn-tf-outline" style="font-size:0.75rem;padding:4px 12px;text-decoration:none;">
      <i class="bi bi-chevron-left"></i> Prev
    </a>
    <div class="text-center">
      <div style="font-size:0.9rem;font-weight:600;"><%= displayDate %></div>
      <% if (!isTodayView) { %>
      <a href="/dashboard" style="font-size:0.7rem;color:var(--tf-accent);text-decoration:none;">
        <i class="bi bi-arrow-return-left me-1"></i>Back to Today
      </a>
      <% } %>
    </div>
    <a href="/dashboard?date=<%= nextStr %>" class="btn-tf btn-tf-outline" style="font-size:0.75rem;padding:4px 12px;text-decoration:none;">
      Next <i class="bi bi-chevron-right"></i>
    </a>
  </div>

  <table class="tf-table">
    <thead>
      <tr><th>Task</th><th>Type</th><th>Priority</th><th>Status</th><th>Reward</th><th>Action</th></tr>
    </thead>
    <tbody>
      <% if (typeof dayTasks !== 'undefined' && dayTasks && dayTasks.length > 0) { %>
        <% const pColors = { urgent: { bg: 'rgba(239,68,68,0.15)', color: '#ef4444' }, high: { bg: 'rgba(245,158,11,0.15)', color: '#f59e0b' }, medium: { bg: 'rgba(59,130,246,0.15)', color: '#3b82f6' }, low: { bg: 'rgba(107,114,128,0.15)', color: '#6b7280' } }; %>
        <% dayTasks.forEach(t => { %>
        <% const isRecurring = t.is_recurring == 1; %>
        <% const isCompletedForDate = t.is_completed_for_date > 0; %>
        <tr>
          <td>
            <a href="/tasks/<%= t.id %>" style="color:var(--tf-text);text-decoration:none;font-weight:500;"><%= t.title %></a>
          </td>
          <td><span class="badge badge-<%= t.type %>" style="font-size:0.65rem;border-radius:4px;padding:2px 6px;"><%= t.type === 'adhoc' ? 'one time' : t.type %></span></td>
          <td>
            <% const pc = pColors[t.priority] || pColors.medium; %>
            <span class="badge" style="font-size:0.65rem;border-radius:4px;padding:2px 6px;background:<%= pc.bg %>;color:<%= pc.color %>;"><%= (t.priority || 'medium').toUpperCase() %></span>
          </td>
          <td>
            <% if (isRecurring) { %>
              <% if (isCompletedForDate) { %>
              <span class="badge" style="font-size:0.65rem;border-radius:4px;padding:3px 8px;background:rgba(16,185,129,0.15);color:#10b981;">
                <i class="bi bi-check-circle-fill"></i> Done
              </span>
              <% } else { %>
              <span class="badge" style="font-size:0.65rem;border-radius:4px;padding:3px 8px;background:rgba(245,158,11,0.15);color:#f59e0b;">
                <i class="bi bi-circle"></i> Pending
              </span>
              <% } %>
            <% } else { %>
            <span class="badge badge-<%= t.status %>" style="font-size:0.65rem;border-radius:4px;padding:2px 6px;"><%= t.status.replace('_',' ') %></span>
            <% } %>
          </td>
          <td style="font-family:var(--tf-font-mono);color:#f59e0b;font-size:0.8rem;">
            <%= t.reward_amount ? parseFloat(t.reward_amount).toFixed(0) + ' pts' : '—' %>
          </td>
          <td>
            <% if (isRecurring && isTodayView) { %>
              <% if (isCompletedForDate) { %>
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.3);"
                onclick="undoDayCompletion(<%= t.id %>)">Undo</button>
              <% } else { %>
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:rgba(16,185,129,0.1);color:#10b981;border:1px solid rgba(16,185,129,0.3);"
                onclick="logDayCompletion(<%= t.id %>)">Log</button>
              <% } %>
            <% } else if (!isRecurring && t.status === 'pending' && isTodayView) { %>
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:rgba(0,212,255,0.1);color:#00d4ff;border:1px solid rgba(0,212,255,0.3);"
                onclick="startDayTask(<%= t.id %>)">Start</button>
            <% } else if (!isRecurring && t.status === 'in_progress' && isTodayView) { %>
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:rgba(16,185,129,0.1);color:#10b981;border:1px solid rgba(16,185,129,0.3);"
                onclick="completeDayTask(<%= t.id %>)">Complete</button>
            <% } else { %>
              <a href="/tasks/<%= t.id %>" style="font-size:0.65rem;color:var(--tf-accent);text-decoration:none;">View</a>
            <% } %>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
      <tr><td colspan="6" style="text-align:center;color:var(--tf-text-muted);padding:2rem;">
        <i class="bi bi-check-all" style="font-size:1.5rem;display:block;margin-bottom:0.5rem;"></i>
        No tasks for this date
      </td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<script>
async function logDayCompletion(taskId) {
  if (!confirm('Log completion for this task?')) return;
  try {
    await axios.post('/tasks/' + taskId + '/log-completion');
    showToast('Completion logged!');
    setTimeout(() => location.reload(), 800);
  } catch (e) {
    showToast(e.response?.data?.message || 'Error', 'error');
  }
}
async function undoDayCompletion(taskId) {
  if (!confirm('Undo completion?')) return;
  try {
    await axios.post('/tasks/' + taskId + '/undo-completion');
    showToast('Completion undone');
    setTimeout(() => location.reload(), 800);
  } catch (e) {
    showToast(e.response?.data?.message || 'Error', 'error');
  }
}
async function startDayTask(taskId) {
  if (!confirm('Start this task?')) return;
  try {
    await axios.post('/tasks/start/' + taskId);
    showToast('Task started!');
    setTimeout(() => location.reload(), 800);
  } catch (e) {
    showToast(e.response?.data?.message || 'Error', 'error');
  }
}
async function completeDayTask(taskId) {
  if (!confirm('Mark as completed?')) return;
  try {
    await axios.post('/tasks/complete/' + taskId);
    showToast('Task completed!');
    setTimeout(() => location.reload(), 800);
  } catch (e) {
    showToast(e.response?.data?.message || 'Error', 'error');
  }
}
</script>
<% } %>
