<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<script>(function(){var t=localStorage.getItem('tf-theme')||'dark';document.documentElement.setAttribute('data-bs-theme',t);})()</script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error <%= code || 500 %> - TaskFlow</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  <style>
    [data-bs-theme="dark"] { --bg: #0a0e1a; --text: #e2e8f0; --accent: #00d4ff; --muted: #64748b; }
    [data-bs-theme="light"] { --bg: #f1f5f9; --text: #1e293b; --accent: #0284c7; --muted: #64748b; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
    .code { font-family: 'Space Mono', monospace; font-size: 6rem; font-weight: 700; color: var(--accent); line-height: 1; }
    .msg { font-size: 1.1rem; color: var(--muted); margin: 1rem 0 2rem; }
    a { color: var(--accent); text-decoration: none; font-family: 'Space Mono', monospace; font-size: 0.8rem; }
  </style>
</head>
<body>
  <div style="text-align:center;">
    <div class="code"><%= code || 500 %></div>
    <div class="msg"><%= message || 'Something went wrong' %></div>
    <a href="/dashboard">← Return to Dashboard</a>
  </div>
</body>
</html>
