<style>
  .help-container {
    display: flex;
    gap: 1.25rem;
    height: calc(100vh - 120px);
  }

  /* --- Sidebar --- */
  .help-sidebar {
    width: 280px;
    min-width: 280px;
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .help-sidebar-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--tf-border);
  }

  .help-sidebar-header h6 {
    font-family: var(--tf-font-mono);
    font-size: 0.7rem;
    letter-spacing: 1px;
    margin: 0 0 0.75rem;
    color: var(--tf-text-muted);
    text-transform: uppercase;
  }

  .help-search {
    position: relative;
  }
  .help-search i {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--tf-text-muted);
    font-size: 0.8rem;
  }
  .help-search input {
    width: 100%;
    background: var(--tf-surface-2);
    border: 1px solid var(--tf-border);
    color: var(--tf-text);
    border-radius: 8px;
    padding: 0.45rem 0.75rem 0.45rem 2.25rem;
    font-size: 0.8rem;
    font-family: var(--tf-font);
  }
  .help-search input:focus { outline: none; border-color: var(--tf-accent); }

  .help-nav {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 0;
  }

  .help-nav-section {
    padding: 0.5rem 1.25rem 0.2rem;
    font-family: var(--tf-font-mono);
    font-size: 0.55rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--tf-text-muted);
  }

  .help-nav-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1.25rem;
    font-size: 0.8rem;
    color: var(--tf-nav-link);
    cursor: pointer;
    transition: all 0.15s;
    border-left: 3px solid transparent;
    text-decoration: none;
  }
  .help-nav-item:hover { color: var(--tf-text); background: var(--tf-surface-2); }
  .help-nav-item.active { color: var(--tf-text); background: var(--tf-surface-2); border-left-color: var(--tf-accent); }
  .help-nav-item i { font-size: 0.85rem; width: 18px; text-align: center; }

  /* --- Content --- */
  .help-content {
    flex: 1;
    background: var(--tf-surface);
    border: 1px solid var(--tf-border);
    border-radius: 12px;
    overflow-y: auto;
    min-width: 0;
  }

  .help-topic {
    display: none;
    padding: 2rem 2.5rem;
  }
  .help-topic.active { display: block; }

  .help-topic h2 {
    font-family: var(--tf-font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--tf-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .help-topic h2 i { color: var(--tf-accent); }

  .help-topic .topic-desc {
    font-size: 0.85rem;
    color: var(--tf-text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .help-topic h3 {
    font-family: var(--tf-font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    margin: 1.75rem 0 0.75rem;
    color: var(--tf-accent);
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .help-topic h4 {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 1.25rem 0 0.5rem;
    color: var(--tf-text);
  }

  .help-topic p {
    font-size: 0.84rem;
    color: var(--tf-text);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .help-topic ul, .help-topic ol {
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .help-topic li {
    font-size: 0.84rem;
    color: var(--tf-text);
    line-height: 1.7;
    margin-bottom: 0.3rem;
  }

  .help-step {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    align-items: flex-start;
  }

  .help-step-num {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: rgba(0,212,255,0.15);
    color: var(--tf-accent);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--tf-font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .help-step-content {
    flex: 1;
  }
  .help-step-content strong {
    display: block;
    font-size: 0.84rem;
    margin-bottom: 2px;
  }
  .help-step-content p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--tf-text-muted);
    line-height: 1.5;
  }

  .help-tip {
    background: rgba(0,212,255,0.06);
    border: 1px solid rgba(0,212,255,0.15);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    font-size: 0.8rem;
    color: var(--tf-text);
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }
  .help-tip i { color: var(--tf-accent); font-size: 0.9rem; flex-shrink: 0; margin-top: 2px; }

  .help-warn {
    background: rgba(245,158,11,0.08);
    border: 1px solid rgba(245,158,11,0.2);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    font-size: 0.8rem;
    color: var(--tf-text);
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }
  .help-warn i { color: #f59e0b; font-size: 0.9rem; flex-shrink: 0; margin-top: 2px; }

  .help-role-badge {
    display: inline-block;
    font-size: 0.6rem;
    font-family: var(--tf-font-mono);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-right: 4px;
  }
  .help-role-badge.admin { background: rgba(239,68,68,0.15); color: #ef4444; }
  .help-role-badge.manager { background: rgba(124,58,237,0.15); color: #a78bfa; }
  .help-role-badge.user { background: rgba(16,185,129,0.15); color: #10b981; }
  .help-role-badge.all { background: rgba(0,212,255,0.15); color: var(--tf-accent); }

  /* Welcome / landing */
  .help-welcome {
    padding: 3rem 2.5rem;
    text-align: center;
  }
  .help-welcome i { font-size: 3rem; color: var(--tf-accent); opacity: 0.3; }
  .help-welcome h2 { justify-content: center; margin-top: 1rem; }
  .help-welcome p { color: var(--tf-text-muted); max-width: 500px; margin: 0 auto; }

  .help-quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-top: 1.5rem;
    text-align: left;
  }

  .help-quick-link {
    background: var(--tf-surface-2);
    border: 1px solid var(--tf-border);
    border-radius: 10px;
    padding: 1rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .help-quick-link:hover { border-color: var(--tf-accent); transform: translateY(-2px); }
  .help-quick-link i { font-size: 1.1rem; color: var(--tf-accent); }
  .help-quick-link .ql-title { font-size: 0.8rem; font-weight: 600; margin-top: 0.5rem; }
  .help-quick-link .ql-desc { font-size: 0.7rem; color: var(--tf-text-muted); margin-top: 0.2rem; }

  /* Mobile toggle */
  .help-sidebar-toggle {
    display: none;
    background: var(--tf-surface-2);
    border: 1px solid var(--tf-border);
    color: var(--tf-text);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    cursor: pointer;
    margin-bottom: 0.75rem;
    width: 100%;
    text-align: left;
  }

  @media (max-width: 768px) {
    .help-container { flex-direction: column; height: auto; }
    .help-sidebar { width: 100%; min-width: 100%; max-height: 50vh; }
    .help-sidebar-toggle { display: block; }
    .help-content { min-height: 60vh; }
  }
</style>

