      <button class="btn-tf btn-tf-danger" style="padding:0.6rem 1.5rem;font-size:0.85rem;" onclick="localStorage.removeItem('tf_login_at');localStorage.removeItem('tf_shift_extended');window.location.href='/auth/logout'">
