    <div id="lateReasonError" style="display:none;font-size:0.75rem;color:#ef4444;margin-bottom:0.75rem;"><i class="bi bi-exclamation-circle me-1"></i>Please select a reason</div>
    <div class="d-flex justify-content-end">
