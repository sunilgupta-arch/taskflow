<script>
// Late login check & modal logic
(function() {
  var role = '<%= user.role_name %>';
  // Skip for admins
  if (role === 'LOCAL_ADMIN' || role.startsWith('CLIENT_')) return;

  // Highlight selected radio
  document.querySelectorAll('.late-reason-opt input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
      document.querySelectorAll('.late-reason-opt').forEach(function(label) {
        label.style.borderColor = 'var(--tf-border)';
        label.style.background = 'transparent';
      });
      this.closest('.late-reason-opt').style.borderColor = 'var(--tf-accent)';
      this.closest('.late-reason-opt').style.background = 'rgba(0,212,255,0.05)';
      document.getElementById('lateReasonError').style.display = 'none';
      document.getElementById('lateCustomReasonWrap').style.display = document.getElementById('lateReasonOther').checked ? 'block' : 'none';
    });
  });

  // Check on page load
  fetch('/auth/check-late').then(function(r) { return r.json(); }).then(function(data) {
    if (data.success && data.data.needsReason) {
      var mins = data.data.lateByMinutes || 0;
      var lateText = mins >= 60 ? Math.floor(mins/60) + 'h ' + (mins%60) + 'm' : mins + ' minutes';
      document.getElementById('lateLoginSubtext').textContent = 'You logged in ' + lateText + ' after your shift started. Please provide a reason.';
      document.getElementById('lateLoginModal').style.display = 'flex';
    }
  }).catch(function() {});
})();

function submitLateReason() {
  var selected = document.querySelector('input[name="late_reason"]:checked');
  if (!selected) {
    document.getElementById('lateReasonError').style.display = 'block';
    return;
  }
  var reason = selected.value;
  if (reason === 'Other') {
    var custom = document.getElementById('lateCustomReason').value.trim();
    if (!custom) {
      document.getElementById('lateReasonError').textContent = 'Please specify your reason';
      document.getElementById('lateReasonError').style.display = 'block';
      return;
    }
    reason = 'Other: ' + custom;
  }

  fetch('/auth/late-reason', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ reason: reason })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) {
      document.getElementById('lateLoginModal').style.display = 'none';
    }
  }).catch(function() {
    document.getElementById('lateLoginModal').style.display = 'none';
  });
}
</script>

<script>
// Logout reason modal logic
(function() {
  // Highlight selected radio option
  document.querySelectorAll('.logout-reason-opt input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
      document.querySelectorAll('.logout-reason-opt').forEach(function(label) {
        label.style.borderColor = 'var(--tf-border)';
        label.style.background = 'transparent';
      });
      this.closest('.logout-reason-opt').style.borderColor = 'var(--tf-accent)';
      this.closest('.logout-reason-opt').style.background = 'rgba(0,212,255,0.05)';
      document.getElementById('logoutReasonError').style.display = 'none';
      // Show/hide custom reason textarea
      document.getElementById('logoutCustomReasonWrap').style.display = document.getElementById('logoutReasonOther').checked ? 'block' : 'none';
    });
  });
})();

function isMidShift() {
  var shiftStart = '<%= user.shift_start || "" %>';
  var shiftHours = parseFloat('<%= user.shift_hours || 0 %>');
  if (!shiftStart || !shiftHours) return false;

  var now = new Date();
  var parts = shiftStart.split(':');
  var startMin = parseInt(parts[0]) * 60 + parseInt(parts[1] || 0);
  var endMin = startMin + Math.round(shiftHours * 60);
  var nowMin = now.getHours() * 60 + now.getMinutes();

  // Handle overnight shifts
  if (endMin > 1440) {
    return nowMin >= startMin || nowMin < (endMin - 1440);
  }
  return nowMin >= startMin && nowMin < endMin;
}

function handleLogout() {
  var role = '<%= user.role_name %>';
  // Admins can logout without reason
  if (role === 'LOCAL_ADMIN' || role.startsWith('CLIENT_')) {
    window.location.href = '/auth/logout';
    return;
  }
  // If mid-shift, show reason modal
  if (isMidShift()) {
    document.getElementById('logoutReasonModal').style.display = 'flex';
    return;
  }
  // Shift not active — logout directly
  window.location.href = '/auth/logout';
}

function submitLogoutWithReason() {
  var selected = document.querySelector('input[name="logout_reason"]:checked');
  if (!selected) {
    document.getElementById('logoutReasonError').style.display = 'block';
    return;
  }
  var reason = selected.value;
  if (reason === 'Other') {
    var custom = document.getElementById('logoutCustomReason').value.trim();
    if (!custom) {
      document.getElementById('logoutReasonError').textContent = 'Please specify your reason';
      document.getElementById('logoutReasonError').style.display = 'block';
      return;
    }
    reason = 'Other: ' + custom;
  }

  fetch('/auth/logout', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ logout_reason: reason })
  }).then(function() {
    window.location.href = '/auth/login';
  }).catch(function() {
    window.location.href = '/auth/logout';
  });
}
</script>

