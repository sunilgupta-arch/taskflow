    mp3:{i:'bi-file-earmark-music-fill',c:'#a855f7'}, wav:{i:'bi-file-earmark-music-fill',c:'#a855f7'},
    mp4:{i:'bi-file-earmark-play-fill',c:'#ec4899'}, mov:{i:'bi-file-earmark-play-fill',c:'#ec4899'}, webm:{i:'bi-file-earmark-play-fill',c:'#ec4899'},
    js:{i:'bi-file-earmark-code-fill',c:'#f0db4f'}, json:{i:'bi-file-earmark-code-fill',c:'#f0db4f'}, html:{i:'bi-file-earmark-code-fill',c:'#e34c26'}, css:{i:'bi-file-earmark-code-fill',c:'#2965f1'}
  };
  return map[ext] || {i:'bi-file-earmark-fill',c:'#94a3b8'};
}
function bridgeRenderFile(attachment, msgId) {
  var fname = attachment.file_name;
  var ext = fname.split('.').pop().toLowerCase();
  var url = '/bridge/attachment/' + msgId;
  if (BRIDGE_IMAGE_EXTS.indexOf(ext) !== -1) {
    return '<a href="' + url + '" target="_blank" class="msg-image-link"><img src="' + url + '" class="msg-image-preview" alt="' + fname + '" loading="lazy"></a>';
  }
  var short = fname.length > 25 ? fname.substring(0, 22) + '...' : fname;
  var size = attachment.file_size ? (attachment.file_size < 1048576 ? (attachment.file_size/1024).toFixed(1)+' KB' : (attachment.file_size/1048576).toFixed(1)+' MB') : '';
  var meta = bridgeFileIconMeta(ext);
  return '<a class="msg-file" href="' + url + '" target="_blank"><i class="bi ' + meta.i + '" style="color:' + meta.c + ';font-size:1.4rem;"></i><div><span class="msg-file-name">' + short + '</span>' + (size ? '<span class="msg-file-size">' + size + '</span>' : '') + '</div></a>';
}

function bridgeDateLabel(dateStr) {
  var d = new Date(dateStr);
  var today = new Date();
  var yesterday = new Date(today);
  yesterday.setDate(yesterday.getDate() - 1);
  if (d.toDateString() === today.toDateString()) return 'Today';
  if (d.toDateString() === yesterday.toDateString()) return 'Yesterday';
  return d.toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric', year: 'numeric' });
}

function renderBridgeWidgetMessages(messages) {
  var container = document.getElementById('bridgeChatMessages');
  if (!messages.length) {
    container.innerHTML = '<div class="text-center text-muted py-3 small">No messages yet</div>';
    return;
  }
  var lastDate = '';
  container.innerHTML = messages.map(function(m) {
    var msgDate = bridgeDateLabel(m.created_at);
    var dateDivider = '';
    if (msgDate !== lastDate) {
      dateDivider = '<div class="msg-date-divider"><span>' + msgDate + '</span></div>';
      lastDate = msgDate;
    }
    var isSent = m.sender_id === bridgeWidgetUserId;
    var cls = isSent ? 'sent' : 'received';
    var time = new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    var content = '';
    if (m.is_deleted) {
      content = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
    } else if (m.type === 'file' && m.attachment) {
      content = bridgeRenderFile(m.attachment, m.id);
    } else {
      var div = document.createElement('div'); div.textContent = m.content; content = div.innerHTML;
    }
    var deleteBtn = isSent && !m.is_deleted ? '<span class="bridge-msg-delete" onclick="event.stopPropagation(); deleteBridgeWidgetMsg(' + m.id + ')" title="Delete"><i class="bi bi-trash"></i></span>' : '';
    var senderName = !isSent && m.sender_name ? '<div class="msg-sender-name">' + m.sender_name + '</div>' : '';
    var ticks = '';
    if (isSent && !m.is_deleted) {
      ticks = m.is_read
        ? '<span class="msg-ticks read"><i class="bi bi-check-all"></i></span>'
        : '<span class="msg-ticks"><i class="bi bi-check-all"></i></span>';
    }
    return dateDivider + '<div class="msg-bubble ' + cls + (m.is_deleted ? ' deleted' : '') + '" data-bridge-msg-id="' + m.id + '">' + deleteBtn + senderName + '<div class="msg-content">' + content + '</div><div class="msg-footer"><span class="msg-time">' + time + '</span>' + ticks + '</div></div>';
  }).join('');
  container.scrollTop = container.scrollHeight;
}

function deleteBridgeWidgetMsg(msgId) {
  if (!confirm('Delete this message?')) return;
  $.ajax({ url: '/bridge/messages/' + msgId, method: 'DELETE' });
}

function backToBridgeList() {
  bridgeWidgetConvId = null;
  loadBridgeConvList();
}

function sendBridgeWidgetMessage() {
  if (!bridgeWidgetConvId) return;
  var input = document.getElementById('bridgeWidgetInput');
  var content = input.value.trim();
  if (!content) return;

  $.ajax({
    url: '/bridge/conversations/' + bridgeWidgetConvId + '/messages',
    method: 'POST',
    contentType: 'application/json',
    data: JSON.stringify({ content: content }),
    success: function() {
      input.value = '';
      // Mark as read only when support staff replies
      $.post('/bridge/conversations/' + bridgeWidgetConvId + '/read');
    }
  });
}

function showBridgeWidgetUploadPlaceholder(filename) {
  var container = document.getElementById('bridgeChatMessages');
  if (!container) return null;
  var id = 'bridge-upload-' + Date.now();
  var html = '<div class="msg-bubble sent chat-uploading" id="' + id + '">' +
    '<div class="msg-content"><span class="gc-upload-spinner"></span><i class="bi bi-paperclip me-1"></i>' + (filename.replace(/[<>&"']/g, function(c){return {'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c];})) + '</div>' +
    '<div class="msg-footer"><span class="msg-time">Uploading…</span></div>' +
    '</div>';
  container.insertAdjacentHTML('beforeend', html);
  container.scrollTop = container.scrollHeight;
  return id;
}
function markBridgeWidgetUploadFailed(id, reason) {
  var el = document.getElementById(id);
  if (!el) return;
  el.classList.add('chat-upload-failed');
  var footer = el.querySelector('.msg-time');
  if (footer) footer.innerHTML = '<i class="bi bi-exclamation-circle me-1"></i>' + (reason || 'Upload failed');
  var spinner = el.querySelector('.gc-upload-spinner');
  if (spinner) spinner.remove();
}
function uploadBridgeWidgetFileDirect(file) {
  if (!bridgeWidgetConvId) return;
  if (file.size > 10 * 1024 * 1024) { alert('File too large. Max 10 MB.'); return; }
  var placeholderId = showBridgeWidgetUploadPlaceholder(file.name || 'pasted-image.png');
  var fd = new FormData();
  fd.append('file', file, file.name || ('pasted-' + Date.now() + '.png'));
  $.ajax({
    url: '/bridge/conversations/' + bridgeWidgetConvId + '/file',
    method: 'POST', data: fd, processData: false, contentType: false,
    success: function() {
      var el = document.getElementById(placeholderId);
      if (el) el.remove();
      $.post('/bridge/conversations/' + bridgeWidgetConvId + '/read');
    },
    error: function(xhr) {
      var msg = (xhr.responseJSON && xhr.responseJSON.message) || 'Upload failed';
      markBridgeWidgetUploadFailed(placeholderId, msg);
    }
  });
}

function sendBridgeWidgetFile() {
  var fileInput = document.getElementById('bridgeWidgetFile');
  if (!fileInput.files.length || !bridgeWidgetConvId) return;
  var file = fileInput.files[0];
  fileInput.value = '';
  uploadBridgeWidgetFileDirect(file);
}

// Enter to send in widget
$(document).on('keydown', '#bridgeWidgetInput', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendBridgeWidgetMessage();
  }
});

// Paste screenshot/image into bridge widget
$(document).on('paste', '#bridgeWidgetInput', function(e) {
  var items = (e.originalEvent.clipboardData || window.clipboardData)?.items;
  if (!items || !bridgeWidgetConvId) return;
  for (var i = 0; i < items.length; i++) {
    if (items[i].kind === 'file') {
      var f = items[i].getAsFile();
      if (f) { e.preventDefault(); uploadBridgeWidgetFileDirect(f); return; }
    }
  }
});

// Listen for bridge messages via main socket
if (typeof io !== 'undefined') {
  var bridgeSocket = io('/', { withCredentials: true });
  bridgeSocket.on('bridge:message', function(msg) {
    // If widget chat is open for this conversation, append the new message
    if (msg.conversation_id === bridgeWidgetConvId) {
      var container = document.getElementById('bridgeChatMessages');
      // Clear placeholder if present
      if (container.querySelector('.text-center')) container.innerHTML = '';
      var isSent = msg.sender_id === bridgeWidgetUserId;
      var cls = isSent ? 'sent' : 'received';
      var time = new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      var content = '';
      if (msg.is_deleted) {
        content = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
      } else if (msg.type === 'file' && msg.attachment) {
        content = bridgeRenderFile(msg.attachment, msg.id);
      } else {
        var div = document.createElement('div'); div.textContent = msg.content; content = div.innerHTML;
      }
      var senderLabel = !isSent && msg.sender_name ? '<div class="msg-sender-name">' + msg.sender_name + '</div>' : '';
      var deleteBtn = isSent && !msg.is_deleted ? '<span class="bridge-msg-delete" onclick="event.stopPropagation(); deleteBridgeWidgetMsg(' + msg.id + ')" title="Delete"><i class="bi bi-trash"></i></span>' : '';
      var ticks = isSent ? '<span class="msg-ticks"><i class="bi bi-check-all"></i></span>' : '';
      container.insertAdjacentHTML('beforeend', '<div class="msg-bubble ' + cls + '" data-bridge-msg-id="' + msg.id + '">' + deleteBtn + senderLabel + '<div class="msg-content">' + content + '</div><div class="msg-footer"><span class="msg-time">' + time + '</span>' + ticks + '</div></div>');
      container.scrollTop = container.scrollHeight;
    }

    // Play sound + auto-open chat for messages from others
    if (msg.sender_id !== bridgeWidgetUserId) {
      var panel = document.getElementById('bridgePanel');
      var chatIsOpen = panel.style.display !== 'none' && msg.conversation_id === bridgeWidgetConvId;

      if (!chatIsOpen) {
        updateBridgeFabBadge();

        // Auto-open the chat window for this conversation
        var senderName = msg.sender_name || (msg.conversation ? msg.conversation.client_user_name : 'Client');
        panel.style.display = 'flex';
        openBridgeChat(msg.conversation_id, senderName);
      }

      // Always play sound
      try {
        var ctx = new (window.AudioContext || window.webkitAudioContext)();
        var o = ctx.createOscillator(); var g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.type = 'sine'; o.frequency.setValueAtTime(880, ctx.currentTime);
        o.frequency.setValueAtTime(1046, ctx.currentTime + 0.1);
        g.gain.setValueAtTime(0.15, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
        o.start(ctx.currentTime); o.stop(ctx.currentTime + 0.3);
      } catch(e) {}
    }

    // Refresh conversation list if visible
    if (document.getElementById('bridgeConvList').style.display !== 'none') {
      loadBridgeConvList();
    }
  });

  // Update FAB badge on load
  function updateBridgeFabBadge() {
    $.get('/bridge/unread-count', function(res) {
      if (!res.success) return;
      var badge = document.getElementById('bridgeFabBadge');
      if (res.data.total > 0) {
        badge.textContent = res.data.total;
        badge.style.display = '';
      } else {
        badge.style.display = 'none';
      }
    });
  }

  // Bridge message delete
  bridgeSocket.on('bridge:message:delete', function(data) {
    if (data.conversation_id === bridgeWidgetConvId) {
      var bubble = document.querySelector('.bridge-chat-messages [data-bridge-msg-id="' + data.id + '"]');
      if (bubble) {
        bubble.classList.add('deleted');
        var contentEl = bubble.querySelector('.msg-content');
        if (contentEl) contentEl.innerHTML = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
        var delBtn = bubble.querySelector('.bridge-msg-delete');
        if (delBtn) delBtn.remove();
      }
    }
  });

  // Read receipt — turn ticks blue
  bridgeSocket.on('bridge:read', function(data) {
    if (data.conversation_id === bridgeWidgetConvId) {
      document.querySelectorAll('.bridge-chat-messages .msg-bubble.sent .msg-ticks:not(.read)').forEach(function(el) {
        el.classList.add('read');
      });
    }
  });

  // Typing indicator
  var _bwTypingTimer = null;
  bridgeSocket.on('bridge:typing', function(data) {
    if (data.conversation_id !== bridgeWidgetConvId) return;
    var el = document.getElementById('bridgeWidgetTypingStatus');
    if (el) el.innerHTML = '<span class="bridge-typing"><span class="typing-dots"><span></span><span></span><span></span></span></span>';
    clearTimeout(_bwTypingTimer);
    _bwTypingTimer = setTimeout(function() {
      if (el) el.textContent = '';
    }, 3000);
  });

  bridgeSocket.on('bridge:typing:stop', function(data) {
    if (data.conversation_id !== bridgeWidgetConvId) return;
    clearTimeout(_bwTypingTimer);
    var el = document.getElementById('bridgeWidgetTypingStatus');
    if (el) el.textContent = '';
  });

  // Emit typing when LOCAL user types
  (function() {
    var input = document.getElementById('bridgeWidgetInput');
    if (!input) return;
    var typingTimeout = null;
    input.addEventListener('keydown', function() {
      if (!bridgeWidgetConvId) return;
      bridgeSocket.emit('bridge:typing', { conversation_id: bridgeWidgetConvId });
      clearTimeout(typingTimeout);
      typingTimeout = setTimeout(function() {
        bridgeSocket.emit('bridge:typing:stop', { conversation_id: bridgeWidgetConvId });
      }, 2000);
    });
  })();

  // Append ticks on new sent messages in widget
  var _origAppendBridge = null;

  updateBridgeFabBadge();
  setInterval(updateBridgeFabBadge, 30000);
}
</script>
<% } %>

<% if (!(typeof gcFullPage !== 'undefined' && gcFullPage)) { %>
<!-- Group Channel Script -->
<script>
(function() {
  var _gcUserId = <%= typeof user !== 'undefined' ? user.id : 0 %>;
  var _gcUserName = '<%- typeof user !== "undefined" ? user.name.replace(/\x27/g, "\\x27") : "" %>';
  var _gcUserRole = '<%= typeof user !== "undefined" ? user.role_name : "" %>';
  var _gcIsAdmin = (_gcUserRole === 'LOCAL_ADMIN' || _gcUserRole === 'CLIENT_ADMIN');
  var _gcCollapsed = localStorage.getItem('gc-collapsed') === '1';
  var _gcUnread = 0;
  var _gcBaseUrl = '/channel';
  var _gcSocket = typeof io !== 'undefined' ? io('/', { withCredentials: true }) : null;

  // Apply initial collapsed state on load
  if (_gcCollapsed) {
    var panel0 = document.getElementById('gcPanel');
    var handle0 = document.getElementById('gcHandle');
    var main0 = document.getElementById('main-content');
    if (panel0) panel0.style.display = 'none';
    if (handle0) handle0.style.display = '';
    if (main0) main0.classList.add('gc-collapsed');
    document.body.classList.add('gc-is-collapsed');
  }

  window.toggleGroupChannel = function() {
    _gcCollapsed = !_gcCollapsed;
    localStorage.setItem('gc-collapsed', _gcCollapsed ? '1' : '0');
    document.getElementById('gcPanel').style.display = _gcCollapsed ? 'none' : '';
    document.getElementById('gcHandle').style.display = _gcCollapsed ? '' : 'none';
    document.getElementById('main-content').classList.toggle('gc-collapsed', _gcCollapsed);
    document.body.classList.toggle('gc-is-collapsed', _gcCollapsed);
    if (!_gcCollapsed) {
      _gcUnread = 0;
      var badge = document.getElementById('gcHandleBadge');
      badge.style.display = 'none';
      loadGcMessages();
    }
  };

  function _escHtmlGc(str) {
    var d = document.createElement('div'); d.textContent = str; return d.innerHTML;
  }

  // ── Unread tracking + scroll-to-bottom ──────────
  var _gcLastReadKey = 'gc-last-read-' + _gcUserId;
  function _gcGetLastRead() { return parseInt(localStorage.getItem(_gcLastReadKey) || '0', 10); }
  function _gcSetLastRead(id) {
    var cur = _gcGetLastRead();
    if (id > cur) localStorage.setItem(_gcLastReadKey, String(id));
  }
  function _gcIsAtBottom(c, threshold) {
    threshold = threshold || 60;
    return c.scrollHeight - (c.scrollTop + c.clientHeight) < threshold;
  }
  window.gcScrollToBottom = function() {
    var c = document.getElementById('gcMessages');
    if (!c) return;
    c.scrollTop = c.scrollHeight;
    _gcUpdateScrollBtn();
  };
  function _gcUpdateScrollBtn() {
    var c = document.getElementById('gcMessages');
    var btn = document.getElementById('gcScrollBtn');
    var badge = document.getElementById('gcScrollBtnBadge');
    if (!c || !btn) return;
    if (_gcIsAtBottom(c)) {
      btn.style.display = 'none';
      if (badge) { badge.style.display = 'none'; badge.textContent = '0'; }
      // Mark all visible as read
      var bubbles = c.querySelectorAll('[data-gc-msg-id]');
      if (bubbles.length) {
        var lastId = parseInt(bubbles[bubbles.length - 1].getAttribute('data-gc-msg-id'), 10);
        if (lastId) _gcSetLastRead(lastId);
      }
    } else {
      btn.style.display = '';
    }
  }
  function _gcBumpScrollBadge() {
    var badge = document.getElementById('gcScrollBtnBadge');
    if (!badge) return;
    var n = parseInt(badge.textContent || '0', 10) + 1;
    badge.textContent = n > 99 ? '99+' : n;
    badge.style.display = '';
  }
  function _gcUnreadDividerHtml() {
    return '<div class="gc-unread-divider" data-gc-unread-divider><span><i class="bi bi-arrow-down-circle me-1"></i>New messages</span></div>';
  }
  // ── @mentions ───────────────────────────────────
  // _gcAllUsers is populated by loadGcUsers later in the IIFE
  function _gcEscMention(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
  function gcRenderWithMentions(text) {
    var html = _gcEscMention(text || '');
    // Linkify URLs
    html = html.replace(/(https?:\/\/[^\s<]+)/g, function(m) {
      var clean = m.replace(/[.,;:!?)]+$/, '');
      var trailing = m.substring(clean.length);
      return '<a href="' + clean + '" target="_blank" rel="noopener" class="gc-link">' + clean + '</a>' + trailing;
    });
    return html.replace(/@\[([^\]]+)\]/g, function(_, name) {
      var cls = (name === _gcUserName) ? 'gc-mention gc-mention-self' : 'gc-mention';
      return '<span class="' + cls + '">@' + _gcEscMention(name) + '</span>';
    });
  }
  function _gcMentionsMe(text) {
    if (!text) return false;
    var re = /@\[([^\]]+)\]/g, m;
    while ((m = re.exec(text)) !== null) { if (m[1] === _gcUserName) return true; }
    return false;
  }
  // Mention popup state
  var _gcMentionActive = false;
  var _gcMentionQuery = '';
  var _gcMentionStart = -1;
  var _gcMentionIdx = 0;
  function _gcHideMention() {
    _gcMentionActive = false; _gcMentionStart = -1; _gcMentionQuery = '';
    var p = document.getElementById('gcMentionPopup'); if (p) p.style.display = 'none';
  }
  function _gcMentionCandidates() {
    var q = _gcMentionQuery.toLowerCase();
    return (typeof _gcAllUsers !== 'undefined' ? _gcAllUsers : []).filter(function(u) {
      return u.id !== _gcUserId && u.name.toLowerCase().indexOf(q) !== -1;
    }).slice(0, 8);
  }
  function _gcRenderMentionPopup() {
    var p = document.getElementById('gcMentionPopup');
    if (!p) return;
    var list = _gcMentionCandidates();
    if (!list.length) { _gcHideMention(); return; }
    if (_gcMentionIdx >= list.length) _gcMentionIdx = 0;
    p.innerHTML = list.map(function(u, i) {
      return '<div class="gc-mention-item' + (i === _gcMentionIdx ? ' active' : '') + '" data-mention-idx="' + i + '" onmousedown="_gcSelectMention(' + i + ')">' +
        '<div class="gc-mention-avatar">' + _gcEscMention(u.name.charAt(0).toUpperCase()) + '</div>' +
        '<div class="gc-mention-name">' + _gcEscMention(u.name) + '</div>' +
        '<div class="gc-mention-role">' + _gcEscMention((u.role_name || '').replace(/^LOCAL_|^CLIENT_/, '')) + '</div>' +
      '</div>';
    }).join('');
    p.style.display = '';
  }
  window._gcSelectMention = function(idx) {
    var list = _gcMentionCandidates();
    if (!list[idx]) return;
    var input = document.getElementById('gcInput');
    if (!input) return;
    var v = input.value, caret = input.selectionStart;
    var before = v.substring(0, _gcMentionStart);
    var after = v.substring(caret);
    var insert = '@[' + list[idx].name + '] ';
    input.value = before + insert + after;
    var newCaret = before.length + insert.length;
    input.setSelectionRange(newCaret, newCaret);
    input.focus();
    _gcHideMention();
  };
  function _gcMentionInputHandler() {
    var input = document.getElementById('gcInput');
    if (!input) return;
    var val = input.value, caret = input.selectionStart;
    // Find the @ before caret, bounded by whitespace/line-start
    var at = -1;
    for (var i = caret - 1; i >= 0; i--) {
      var c = val.charAt(i);
      if (c === '@') { at = i; break; }
      if (/\s/.test(c) || c === '[' || c === ']') break;
    }
    if (at === -1 || (at > 0 && !/\s/.test(val.charAt(at - 1)))) { _gcHideMention(); return; }
    _gcMentionActive = true;
    _gcMentionStart = at;
    _gcMentionQuery = val.substring(at + 1, caret);
    _gcMentionIdx = 0;
    _gcRenderMentionPopup();
  }
  function _gcMentionKeyHandler(e) {
    if (!_gcMentionActive) return false;
    var list = _gcMentionCandidates();
    if (!list.length) return false;
    if (e.key === 'ArrowDown') { e.preventDefault(); _gcMentionIdx = (_gcMentionIdx + 1) % list.length; _gcRenderMentionPopup(); return true; }
    if (e.key === 'ArrowUp') { e.preventDefault(); _gcMentionIdx = (_gcMentionIdx - 1 + list.length) % list.length; _gcRenderMentionPopup(); return true; }
    if (e.key === 'Enter' || e.key === 'Tab') { e.preventDefault(); _gcSelectMention(_gcMentionIdx); return true; }
    if (e.key === 'Escape') { e.preventDefault(); _gcHideMention(); return true; }
    return false;
  }

  // ── Link preview ────────────────────────────────
  var _gcLinkPreviewCache = {};
  function _gcExtractFirstUrl(text) {
    var m = (text || '').match(/(https?:\/\/[^\s<]+)/);
    if (!m) return null;
    return m[0].replace(/[.,;:!?)]+$/, '');
  }
  function _gcRenderLinkPreviewHtml(preview) {
    if (!preview) return '';
    var img = preview.image ? '<div class="gc-link-preview-image"><img src="' + _escHtmlGc(preview.image) + '" alt="" onerror="this.parentNode.style.display=\'none\'" /></div>' : '';
    var site = preview.site_name ? '<div class="gc-link-preview-site">' + _escHtmlGc(preview.site_name) + '</div>' : '';
    var title = preview.title ? '<div class="gc-link-preview-title">' + _escHtmlGc(preview.title) + '</div>' : '';
    var desc = preview.description ? '<div class="gc-link-preview-desc">' + _escHtmlGc(preview.description) + '</div>' : '';
    return '<a class="gc-link-preview" href="' + _escHtmlGc(preview.url) + '" target="_blank" rel="noopener">' + img + '<div class="gc-link-preview-body">' + site + title + desc + '</div></a>';
  }
  function _gcInsertPreview(bubble, preview) {
    if (!bubble || bubble.querySelector('.gc-link-preview')) return;
    var content = bubble.querySelector('.msg-content');
    if (!content) return;
    content.insertAdjacentHTML('afterend', _gcRenderLinkPreviewHtml(preview));
  }
  function _gcFetchAndRenderPreview(bubble, rawText) {
    if (!bubble || !rawText) return;
    var url = _gcExtractFirstUrl(rawText);
    if (!url) return;
    if (bubble.querySelector('.gc-link-preview')) return;
    if (_gcLinkPreviewCache[url] === null) return;
    if (_gcLinkPreviewCache[url]) { _gcInsertPreview(bubble, _gcLinkPreviewCache[url]); return; }
    $.get(_gcBaseUrl + '/unfurl?url=' + encodeURIComponent(url), function(res) {
      if (!res.success) return;
      var preview = res.data.preview;
