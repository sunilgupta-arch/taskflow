  // ── Reply-to-message state + helpers ────────────
  var _gcReplyingTo = null; // { id, sender_name, preview }
  window.replyToGcMsg = function(msgId) {
    var bubble = document.querySelector('[data-gc-msg-id="' + msgId + '"]');
    if (!bubble) return;
    var senderEl = bubble.querySelector('.gc-msg-sender');
    var senderName = senderEl ? senderEl.textContent : 'You';
    var contentEl = bubble.querySelector('.msg-content');
    var preview = contentEl ? (contentEl.textContent || '').trim() : '';
    if (!preview) preview = '📎 attachment';
    if (preview.length > 120) preview = preview.substring(0, 120) + '…';
