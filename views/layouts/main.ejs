    <div class="bridge-chat-view" id="bridgeChatView" style="display:none">
      <div class="bridge-chat-header">
        <button class="btn btn-sm btn-link p-0 me-2" onclick="backToBridgeList()"><i class="bi bi-arrow-left"></i></button>
        <div>
          <span class="fw-bold" style="font-size:0.85rem" id="bridgeChatName"></span>
          <div class="small text-muted" id="bridgeWidgetTypingStatus" style="font-size:0.65rem;min-height:14px"></div>
        </div>
      </div>
      <div class="bridge-chat-messages" id="bridgeChatMessages"></div>
      <div class="bridge-chat-input">
        <input type="file" id="bridgeWidgetFile" style="display:none" onchange="sendBridgeWidgetFile()">
        <div class="d-flex gap-2 align-items-stretch">
          <textarea class="form-control" id="bridgeWidgetInput" placeholder="Type a message..." rows="2"></textarea>
          <div class="bridge-chat-input-btns">
            <button class="btn btn-outline-secondary" onclick="document.getElementById('bridgeWidgetFile').click()" title="Attach"><i class="bi bi-paperclip"></i></button>
            <button class="btn btn-primary" onclick="sendBridgeWidgetMessage()"><i class="bi bi-send"></i></button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Urgent Chat Widget (LOCAL users) -->
<% if (typeof user !== 'undefined' && user.role_name && user.role_name.startsWith('LOCAL_')) { %>
<div class="urgent-local-widget" id="urgentLocalWidget" style="display:none">
  <div class="urgent-local-header">
    <div class="d-flex align-items-center gap-2">
      <div class="urgent-local-pulse"></div>
      <span class="fw-bold" style="font-size:0.85rem;color:#fff">Urgent</span>
      <span class="urgent-local-status" id="urgentLocalStatus"></span>
    </div>
    <div class="d-flex align-items-center gap-1">
      <button class="btn btn-sm btn-link p-0 text-white" onclick="toggleUrgentLocal()" title="Minimize"><i class="bi bi-dash-lg"></i></button>
      <button class="btn btn-sm btn-outline-light" onclick="resolveUrgentLocal()" style="font-size:0.65rem;padding:2px 8px">Resolve</button>
    </div>
  </div>
  <div class="urgent-local-messages" id="urgentLocalMessages"></div>
  <div class="urgent-typing-bar" id="urgentLocalTypingBar" style="display:none;padding:2px 12px;font-size:0.75rem;color:#bbf7d0;"></div>
  <div class="urgent-local-input">
    <input type="file" id="urgentLocalFile" style="display:none" onchange="sendUrgentLocalFile()">
    <div class="d-flex gap-1">
      <textarea class="form-control" id="urgentLocalInput" placeholder="Type a message..." rows="2"></textarea>
      <div style="display:grid;grid-template-columns:1fr;gap:3px;">
        <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('urgentLocalFile').click()" style="width:34px;height:34px;padding:0" title="Attach"><i class="bi bi-paperclip"></i></button>
        <button class="btn btn-danger btn-sm" onclick="sendUrgentLocalMessage()" style="width:34px;height:34px;padding:0" title="Send"><i class="bi bi-send"></i></button>
      </div>
    </div>
  </div>
</div>
<button class="urgent-local-fab" id="urgentLocalFab" style="display:none" onclick="toggleUrgentLocal()">
  <i class="bi bi-exclamation-triangle-fill"></i>
</button>
<% } %>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.2/axios.min.js"></script>
<script src="https://cdn.socket.io/4.7.4/socket.io.min.js"></script>

<script>
// Toast utility
function showToast(message, type = 'success', duration) {
  const icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', info: 'bi-chat-dots-fill' };
  const titles = { success: 'Success', error: 'Error', info: 'New Message' };

  var ms = duration || (type === 'info' ? 60000 : 4000);

  const toast = $(`
    <div class="tf-toast">
      <div class="tf-toast-inner">
        <div class="tf-toast-icon ${type}">
          <i class="bi ${icons[type]}"></i>
        </div>
        <div class="tf-toast-body">
          <div class="tf-toast-title ${type}">${titles[type]}</div>
          <div class="tf-toast-msg">${message}</div>
        </div>
      </div>
      <button class="tf-toast-close" onclick="$(this).closest('.tf-toast').fadeOut(200,function(){$(this).remove()})">
        <i class="bi bi-x-lg"></i>
      </button>
      <div class="tf-toast-progress">
        <div class="tf-toast-progress-bar ${type}" style="width:100%;"></div>
      </div>
    </div>
  `);

  $('#toast-container').append(toast);

  // Animate progress bar countdown
  var bar = toast.find('.tf-toast-progress-bar');
  requestAnimationFrame(function() {
    bar.css('transition-duration', ms + 'ms');
    bar.css('width', '0%');
  });

  // Pause countdown on hover
  var timer;
  var remaining = ms;
  var startTime = Date.now();

  function startTimer() {
    startTime = Date.now();
    timer = setTimeout(function() {
      toast.fadeOut(300, function() { toast.remove(); });
    }, remaining);
  }

  toast.on('mouseenter', function() {
    clearTimeout(timer);
    remaining -= (Date.now() - startTime);
    bar.css('transition-duration', '0ms');
    bar.css('width', bar[0].getBoundingClientRect().width + 'px');
  });

  toast.on('mouseleave', function() {
    bar.css('transition-duration', remaining + 'ms');
    bar.css('width', '0%');
    startTimer();
  });

  startTimer();

  // Scroll to newest
  var container = document.getElementById('toast-container');
  container.scrollTop = container.scrollHeight;
}

// Mobile sidebar toggle
(function() {
  const menuBtn = document.getElementById('menuBtn');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');

  if (menuBtn && sidebar) {
    menuBtn.addEventListener('click', function() {
      sidebar.classList.toggle('show');
      overlay.classList.toggle('show');
    });

    overlay.addEventListener('click', function() {
      sidebar.classList.remove('show');
      overlay.classList.remove('show');
    });
  }
})();

// Theme toggle
(function() {
  var toggle = document.getElementById('themeToggle');
  var iconLight = document.getElementById('themeIconLight');
  var iconDark = document.getElementById('themeIconDark');

  function applyIcons() {
    var current = document.documentElement.getAttribute('data-bs-theme');
    iconLight.style.display = current === 'dark' ? 'none' : 'inline';
    iconDark.style.display = current === 'dark' ? 'inline' : 'none';
  }
  applyIcons();

  toggle.addEventListener('click', function() {
    var current = document.documentElement.getAttribute('data-bs-theme');
    var next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-bs-theme', next);
    localStorage.setItem('tf-theme', next);
    applyIcons();
  });
})();

// User's timezone
var USER_TIMEZONE = '<%= typeof user !== "undefined" && user.org_timezone ? user.org_timezone : "America/New_York" %>';

// Topbar clocks — Client time, Team time, Shift remaining
(function() {
  var isClient = '<%= user.org_type %>' === 'CLIENT';
  var clientTz = isClient
    ? '<%= user.org_timezone %>'
    : '<%= typeof otherOrgTimezone !== "undefined" ? otherOrgTimezone : "UTC" %>';
  var teamTz = 'Asia/Kolkata';
  var shiftStart = '<%= user.shift_start || "10:00:00" %>';
  var shiftHours = parseFloat('<%= user.shift_hours || 8.5 %>');

  var elClient = document.getElementById('clockClient');
  var elTeam = document.getElementById('clockTeam');
  var elShift = document.getElementById('shiftRemaining');

  function fmtTime(tz) {
    return new Date().toLocaleTimeString('en-GB', { timeZone: tz, hour12: false, hour:'2-digit', minute:'2-digit', second:'2-digit' });
  }

  function updateClocks() {
    if (elClient) elClient.textContent = fmtTime(clientTz);
    if (elTeam) elTeam.textContent = fmtTime(teamTz);

    // Shift remaining — based on user's own org timezone
    if (elShift) {
      var userTz = USER_TIMEZONE;
      var str = new Date().toLocaleTimeString('en-GB', { timeZone: userTz, hour12: false });
      var p = str.split(':');
      var nowMin = parseInt(p[0]) * 60 + parseInt(p[1]);
      var sp = shiftStart.split(':');
      var startMin = parseInt(sp[0]) * 60 + parseInt(sp[1]);
      var endMin = startMin + Math.round(shiftHours * 60);

      var remaining;
      if (endMin > 1440) {
        // Night shift crosses midnight
        if (nowMin >= startMin) {
          remaining = endMin - nowMin;
        } else if (nowMin < (endMin - 1440)) {
          remaining = (endMin - 1440) - nowMin;
        } else {
          remaining = -1;
        }
      } else {
        remaining = endMin - nowMin;
      }

      if (remaining > 0) {
        var h = Math.floor(remaining / 60);
        var m = remaining % 60;
        elShift.textContent = h + 'h ' + (m < 10 ? '0' : '') + m + 'm left';
        elShift.closest('.badge').style.display = '';
      } else {
        elShift.textContent = 'Shift over';
        elShift.closest('.badge').style.background = 'var(--tf-surface-2)';
        elShift.closest('.badge').style.color = 'var(--tf-text-muted)';
      }
    }
  }

  updateClocks();
  setInterval(updateClocks, 1000);
})();

// Global Axios defaults
axios.defaults.headers.common['X-Requested-With'] = 'XMLHttpRequest';

// Handle Axios errors globally
axios.interceptors.response.use(
  res => res,
  err => {
    if (err.response?.status === 401) window.location.href = '/auth/login';
    return Promise.reject(err);
  }
);

// Auto-logout helper — posts reason before redirecting
function autoLogoutWithReason(reason) {
  fetch('/auth/logout', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ logout_reason: reason })
  }).finally(function() {
    window.location.href = '/auth/login';
  });
}

// Shift-end warning & auto-logout (skip for admins)
(function() {
  var userRole = '<%= user.role_name %>';
  if (userRole === 'LOCAL_ADMIN' || userRole.startsWith('CLIENT_')) return;

  var SHIFT_START = '<%= user.shift_start || "10:00:00" %>';
  var SHIFT_HOURS = parseFloat('<%= user.shift_hours || 8.5 %>');
  var WARNING_AFTER_MS = 15 * 60 * 1000; // Show warning 15 min after shift end
  var EXTENSION_MS = 2 * 60 * 60 * 1000; // 2 hour extension

  function getTzTime() {
    var str = new Date().toLocaleTimeString('en-GB', { timeZone: USER_TIMEZONE, hour12: false });
    var p = str.split(':');
    return { h: parseInt(p[0]), m: parseInt(p[1]), s: parseInt(p[2] || 0) };
  }

  function getMsUntilShiftEnd() {
    var parts = SHIFT_START.split(':');
    var startMin = parseInt(parts[0]) * 60 + parseInt(parts[1]);
    var endMin = startMin + Math.round(SHIFT_HOURS * 60);
    var tz = getTzTime();
    var nowMin = tz.h * 60 + tz.m;
    if (endMin > 1440) {
      if (nowMin < (endMin - 1440)) {
        var diffMin = (endMin - 1440) - nowMin;
        return (diffMin * 60 - tz.s) * 1000;
      } else if (nowMin >= parseInt(parts[0]) * 60 + parseInt(parts[1])) {
        var diffMin = endMin - nowMin;
        return (diffMin * 60 - tz.s) * 1000;
      }
    }
    var diffMin = endMin - nowMin;
    return (diffMin * 60 - tz.s) * 1000;
  }

  var msUntilShiftEnd = getMsUntilShiftEnd();

  // Check if user already extended this session
  var extended = localStorage.getItem('tf_shift_extended');

  if (extended) {
    // User clicked Continue — auto-logout 2 hours after shift end
    var msUntilExtendedLogout = msUntilShiftEnd + EXTENSION_MS;
    if (msUntilExtendedLogout <= 0) {
      localStorage.removeItem('tf_login_at');
      localStorage.removeItem('tf_shift_extended');
      autoLogoutWithReason('Auto Logout');
    } else {
      setTimeout(function() {
        localStorage.removeItem('tf_login_at');
        localStorage.removeItem('tf_shift_extended');
        autoLogoutWithReason('Auto Logout');
      }, msUntilExtendedLogout);
    }
    return;
  }

  if (msUntilShiftEnd <= -(WARNING_AFTER_MS + WARNING_AFTER_MS)) {
    // More than 30 min past shift end and user never extended — logout now
    localStorage.removeItem('tf_login_at');
    autoLogoutWithReason('Auto Logout');
    return;
  }

  // Schedule the warning modal 15 minutes after shift end
  var msUntilWarning = msUntilShiftEnd + WARNING_AFTER_MS;

  function showShiftWarning() {
    var modal = document.getElementById('shiftEndModal');
    if (!modal) return;
    modal.style.display = 'flex';

    // Countdown for 15 minutes before auto-logout
    var remaining = Math.floor(WARNING_AFTER_MS / 1000);
    var countdownEl = document.getElementById('shiftEndCountdown');
    var countdownInterval = setInterval(function() {
      remaining--;
      if (remaining <= 0) {
        clearInterval(countdownInterval);
        modal.style.display = 'none';
        localStorage.removeItem('tf_login_at');
        autoLogoutWithReason('Auto Logout');
        return;
      }
      var m = Math.floor(remaining / 60);
      var s = Math.floor(remaining % 60);
      if (countdownEl) countdownEl.textContent = m + ':' + String(s).padStart(2, '0');
    }, 1000);

    // "Logout Now" button
    window.shiftEndLogoutNow = function() {
      clearInterval(countdownInterval);
      modal.style.display = 'none';
      localStorage.removeItem('tf_login_at');
      localStorage.removeItem('tf_shift_extended');
      autoLogoutWithReason('Shift Ended');
    };

    // "Continue (2 hrs)" button
    window.shiftEndContinue = function() {
      clearInterval(countdownInterval);
      modal.style.display = 'none';
      localStorage.setItem('tf_shift_extended', '1');
      // Schedule auto-logout 2 hours after shift end
      setTimeout(function() {
        localStorage.removeItem('tf_login_at');
        localStorage.removeItem('tf_shift_extended');
        autoLogoutWithReason('Auto Logout');
      }, remaining * 1000 + EXTENSION_MS);
    };

    // Play alert sound
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      [0, 0.3, 0.6].forEach(function(delay) {
        var osc = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.frequency.value = 880;
        osc.type = 'sine';
        gain.gain.setValueAtTime(0.2, ctx.currentTime + delay);
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + delay + 0.25);
        osc.start(ctx.currentTime + delay);
        osc.stop(ctx.currentTime + delay + 0.25);
      });
    } catch (e) {}
  }

  if (msUntilWarning <= 0) {
    // Already past 15 min after shift end — show warning immediately
    showShiftWarning();
  } else {
    setTimeout(showShiftWarning, msUntilWarning);
  }
})();

// Pending tasks reminder — 1 hour before shift ends
(function() {
  var userRole = '<%= user.role_name %>';
  if (userRole === 'LOCAL_ADMIN' || userRole.startsWith('CLIENT_')) return;

  var SHIFT_START = '<%= user.shift_start || "10:00:00" %>';
  var SHIFT_HOURS = parseFloat('<%= user.shift_hours || 8.5 %>');
  var REMIND_BEFORE_MIN = 60; // 1 hour before shift ends

  function getTzTime2() {
    var str = new Date().toLocaleTimeString('en-GB', { timeZone: USER_TIMEZONE, hour12: false });
    var p = str.split(':');
    return { h: parseInt(p[0]), m: parseInt(p[1]), s: parseInt(p[2] || 0) };
  }

  var parts = SHIFT_START.split(':');
  var startMin = parseInt(parts[0]) * 60 + parseInt(parts[1]);
  var endMin = startMin + Math.round(SHIFT_HOURS * 60);
  var reminderMin = endMin - REMIND_BEFORE_MIN;
  var tz = getTzTime2();
  var nowMin = tz.h * 60 + tz.m;
  var msUntilReminder = ((reminderMin - nowMin) * 60 - tz.s) * 1000;

  if (msUntilReminder < 0) return; // Already past reminder time
  if (localStorage.getItem('tf_pending_reminder_' + new Date().toISOString().split('T')[0])) return; // Already shown today

  setTimeout(function() {
    localStorage.setItem('tf_pending_reminder_' + new Date().toISOString().split('T')[0], '1');
    // Fetch pending tasks
    axios.get('/tasks/pending-today').then(function(res) {
      var data = res.data.data;
      if (!data || !data.tasks || data.tasks.length === 0) return;

      var tasks = data.tasks;
      var modal = document.getElementById('pendingTasksModal');
      var list = document.getElementById('pendingTasksList');
      var count = document.getElementById('pendingTasksCount');
      if (!modal || !list) return;

      count.textContent = tasks.length;
      list.innerHTML = '';
      tasks.forEach(function(t) {
        var priorityColors = { urgent: '#ef4444', high: '#f59e0b', medium: '#3b82f6', low: '#6b7280' };
        var clr = priorityColors[t.priority] || '#6b7280';
        var typeLabel = t.type === 'recurring' ? '<span style="font-size:0.55rem;background:rgba(124,58,237,0.15);color:#a78bfa;padding:1px 5px;border-radius:4px;margin-left:4px;">Recurring</span>' : '';
        list.innerHTML +=
          '<a href="/tasks/' + t.id + '" style="display:block;padding:0.6rem 0.75rem;border-bottom:1px solid var(--tf-border);text-decoration:none;color:var(--tf-text);transition:background 0.15s;" onmouseover="this.style.background=\'rgba(0,212,255,0.05)\'" onmouseout="this.style.background=\'transparent\'">' +
            '<div style="display:flex;align-items:center;gap:0.5rem;">' +
              '<span style="width:8px;height:8px;border-radius:50%;background:' + clr + ';flex-shrink:0;"></span>' +
              '<span style="font-size:0.8rem;font-weight:500;">' + t.title + '</span>' +
              typeLabel +
            '</div>' +
            (t.due_date ? '<div style="font-size:0.65rem;color:var(--tf-text-muted);margin-top:2px;margin-left:18px;">Due: ' + t.due_date + '</div>' : '') +
          '</a>';
      });

      modal.style.display = 'flex';

      // Play alert sound
      try {
        var ctx = new (window.AudioContext || window.webkitAudioContext)();
        [0, 0.25, 0.5, 0.75].forEach(function(delay) {
          var osc = ctx.createOscillator();
          var gain = ctx.createGain();
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.frequency.value = delay < 0.5 ? 660 : 880;
          osc.type = 'sine';
          gain.gain.setValueAtTime(0.25, ctx.currentTime + delay);
          gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + delay + 0.2);
          osc.start(ctx.currentTime + delay);
          osc.stop(ctx.currentTime + delay + 0.2);
        });
      } catch (e) {}
    });
  }, msUntilReminder);

  window.closePendingModal = function() {
    var modal = document.getElementById('pendingTasksModal');
    if (modal) modal.style.display = 'none';
  };
})();

// Socket.IO - Real-time notifications
(function() {
  if (typeof io === 'undefined') return;

  var socket = io({ withCredentials: true });

  socket.on('connect', function() {
    console.log('[Socket] Connected:', socket.id);
  });

  socket.on('task:assigned', function(data) {
    showToast(data.message, 'info');
  });

  socket.on('task:completed', function(data) {
    showToast(data.message, 'info');
  });

  socket.on('leave:new', function(data) {
    showToast(data.message, 'info');
  });
  socket.on('leave:approved', function(data) {
    showToast(data.message, 'success');
  });
  socket.on('leave:rejected', function(data) {
    showToast(data.message, 'error');
  });

  // Chat: update sidebar unread badge on new message
  socket.on('chat:message', function(data) {
    var badge = document.getElementById('chatNavBadge');
    if (badge) {
      var current = parseInt(badge.textContent) || 0;
      badge.textContent = current + 1 > 9 ? '9+' : current + 1;
      badge.style.display = 'inline-flex';
    }
  });

  // Load initial unread count
  axios.get('/chat/unread-count').then(function(res) {
    var count = res.data.data.count;
    var badge = document.getElementById('chatNavBadge');
    if (badge && count > 0) {
      badge.textContent = count > 9 ? '9+' : count;
      badge.style.display = 'inline-flex';
    }
  }).catch(function() {});
})();

// Chat alert: toast + sound for incoming messages (global, works on every page)
(function() {
  if (typeof io === 'undefined') return;

  var chatAlertSocket = io({ withCredentials: true });

  chatAlertSocket.on('chat:message', function(data) {
    var msg = data.message;
    if (!msg) return;

    // Skip toast and sound if user is already on the chat page
    if (window.location.pathname.startsWith('/chat')) return;

    // Show toast
    var sender = msg.sender_name || 'Someone';
    var preview = msg.content || '';
    if (preview.length > 50) preview = preview.substring(0, 50) + '...';
    showToast(sender + ': ' + preview, 'info', 3000);

    // Play two-tone chime
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      var o1 = ctx.createOscillator();
      var g1 = ctx.createGain();
      o1.connect(g1); g1.connect(ctx.destination);
      o1.frequency.value = 880; o1.type = 'sine';
      g1.gain.setValueAtTime(0.2, ctx.currentTime);
      g1.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
      o1.start(ctx.currentTime); o1.stop(ctx.currentTime + 0.3);

      var o2 = ctx.createOscillator();
      var g2 = ctx.createGain();
      o2.connect(g2); g2.connect(ctx.destination);
      o2.frequency.value = 1100; o2.type = 'sine';
      g2.gain.setValueAtTime(0.2, ctx.currentTime + 0.15);
      g2.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.45);
      o2.start(ctx.currentTime + 0.15); o2.stop(ctx.currentTime + 0.45);
    } catch (e) {}
  });
})();
</script>

<!-- Change Password Modal -->
<div id="changePasswordModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:200;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:var(--tf-surface);border:1px solid var(--tf-border);border-radius:12px;padding:1.5rem;width:100%;max-width:420px;">
    <h6 style="font-family:var(--tf-font-mono);margin-bottom:1.25rem;"><i class="bi bi-key me-2"></i>RESET PASSWORD</h6>
    <div id="cpError" class="tf-alert" style="display:none;border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.1);color:#fca5a5;margin-bottom:1rem;font-size:0.85rem;"></div>
    <div class="mb-3">
      <label style="font-size:0.7rem;color:var(--tf-text-muted);display:block;margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">NEW PASSWORD</label>
      <input type="password" id="cpNew" class="tf-form-control" placeholder="Min 6 characters">
    </div>
    <div class="mb-3">
      <label style="font-size:0.7rem;color:var(--tf-text-muted);display:block;margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">CONFIRM NEW PASSWORD</label>
      <input type="password" id="cpConfirm" class="tf-form-control" placeholder="Re-enter new password">
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button class="btn-tf btn-tf-outline" onclick="closeChangePasswordModal()">Cancel</button>
      <button class="btn-tf btn-tf-primary" id="cpSubmitBtn" onclick="submitChangePassword()">RESET</button>
    </div>
  </div>
</div>

<script>
function openChangePasswordModal() {
  document.getElementById('cpNew').value = '';
  document.getElementById('cpConfirm').value = '';
  document.getElementById('cpError').style.display = 'none';
  document.getElementById('cpSubmitBtn').disabled = false;
  document.getElementById('cpSubmitBtn').textContent = 'RESET';
  document.getElementById('changePasswordModal').style.display = 'flex';
}
function closeChangePasswordModal() {
  document.getElementById('changePasswordModal').style.display = 'none';
}
async function submitChangePassword() {
  var errDiv = document.getElementById('cpError');
  var btn = document.getElementById('cpSubmitBtn');
  var newPw = document.getElementById('cpNew').value;
  var confirm = document.getElementById('cpConfirm').value;

  errDiv.style.display = 'none';

  if (!newPw || !confirm) {
    errDiv.textContent = 'Both fields are required';
    errDiv.style.display = 'block';
    return;
  }
  if (newPw.length < 6) {
    errDiv.textContent = 'Password must be at least 6 characters';
    errDiv.style.display = 'block';
    return;
  }
  if (newPw !== confirm) {
    errDiv.textContent = 'Passwords do not match';
    errDiv.style.display = 'block';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'RESETTING...';

  try {
    var res = await axios.post('/change-password', {
      new_password: newPw,
      confirm_password: confirm
    });
    if (res.data.success) {
      closeChangePasswordModal();
      showToast('Password reset successfully');
    }
  } catch (e) {
    errDiv.textContent = e.response?.data?.message || 'Failed to reset password';
    errDiv.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'RESET';
  }
}
</script>

<!-- Shift End Warning Modal -->
<div id="shiftEndModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:350;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:var(--tf-surface);border:1px solid var(--tf-border);border-radius:16px;padding:2rem;width:100%;max-width:440px;text-align:center;">
    <div style="width:64px;height:64px;border-radius:50%;background:rgba(239,68,68,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
      <i class="bi bi-clock-history" style="font-size:1.75rem;color:#ef4444;"></i>
