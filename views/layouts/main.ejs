</aside>

<!-- Main Content -->
<div id="main-content"<%= (typeof gcFullPage !== 'undefined' && gcFullPage) ? ' class="gc-collapsed"' : '' %>>
  <div id="topbar">
    <button id="menuBtn" class="btn-menu d-md-none" aria-label="Toggle menu">
      <i class="bi bi-list"></i>
    </button>
    <div class="page-title"><%= typeof title !== 'undefined' ? title.split(' - ')[0] : 'TaskFlow' %></div>
    <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
      <% var isClient = user.org_type === 'CLIENT'; %>
      <span class="badge d-flex align-items-center gap-1" style="background:var(--tf-surface-2);color:var(--tf-text-muted);font-family:var(--tf-font-mono);font-size:0.65rem;" title="<%= isClient ? 'Your' : 'Client' %> Time (<%= isClient ? user.org_timezone : (typeof otherOrgTimezone !== 'undefined' ? otherOrgTimezone : 'America/New_York') %>)">
        <i class="bi bi-building" style="font-size:0.6rem;"></i>
        <span>Client</span>
        <span id="clockClient" style="min-width:52px;">--:--:--</span>
      </span>
      <span class="badge d-flex align-items-center gap-1" style="background:var(--tf-surface-2);color:var(--tf-text-muted);font-family:var(--tf-font-mono);font-size:0.65rem;" title="Team Time (Asia/Kolkata)">
        <i class="bi bi-people" style="font-size:0.6rem;"></i>
        <span>Team</span>
        <span id="clockTeam" style="min-width:52px;">--:--:--</span>
      </span>
      <% if (!isClient && (user.role_name === 'LOCAL_USER' || user.role_name === 'LOCAL_MANAGER')) { %>
      <span class="badge d-flex align-items-center gap-1" style="background:var(--tf-primary-alpha);color:var(--tf-primary);font-family:var(--tf-font-mono);font-size:0.65rem;" title="Time remaining in shift">
        <i class="bi bi-hourglass-split" style="font-size:0.6rem;"></i>
        <span id="shiftRemaining">--:--</span>
      </span>
      <% } %>
      <span class="badge" style="background:var(--tf-surface-2);color:var(--tf-text-muted);font-family:var(--tf-font-mono);font-size:0.65rem;">
        <%= new Date().toLocaleDateString('en-US', {weekday:'short',month:'short',day:'numeric'}) %>
      </span>
      <% if (!isClient) { %>
      <a href="/admin" class="btn-theme-toggle" title="Switch to new UI" style="text-decoration:none;font-size:0.65rem;font-family:var(--tf-font-mono);font-weight:700;gap:4px;padding:0 10px;">
        <i class="bi bi-stars"></i> New UI
      </a>
      <% } %>
      <button id="themeToggle" class="btn-theme-toggle" aria-label="Toggle theme">
        <i class="bi bi-sun-fill" id="themeIconLight" style="display:none;"></i>
        <i class="bi bi-moon-stars-fill" id="themeIconDark"></i>
      </button>
    </div>
  </div>

  <!-- Urgent Alert Banner (for local team) -->
  <% if (typeof user !== 'undefined' && user.role_name && user.role_name.startsWith('LOCAL_')) { %>
  <div class="urgent-banner" id="urgentBanner" style="display:none">
    <div class="urgent-banner-inner">
      <div class="urgent-banner-pulse"></div>
      <div class="urgent-banner-body">
        <span class="urgent-banner-label">URGENT</span>
        <span class="urgent-banner-from" id="urgentBannerFrom"></span>
        <span class="urgent-banner-msg" id="urgentBannerMsg"></span>
      </div>
      <div class="urgent-banner-actions">
        <span class="urgent-banner-accepted" id="urgentBannerAccepted" style="display:none"></span>
        <button class="btn btn-sm btn-light fw-bold urgent-banner-accept" id="urgentBannerAcceptBtn" onclick="acceptUrgent()">Accept</button>
        <button class="btn btn-sm btn-outline-light urgent-banner-view" id="urgentBannerViewBtn" style="display:none" onclick="viewUrgent()">View</button>
        <button class="btn btn-sm btn-outline-light urgent-banner-dismiss" id="urgentBannerDismissBtn" style="display:none" onclick="dismissUrgentBanner()"><i class="bi bi-x"></i></button>
      </div>
    </div>
  </div>
  <% } %>

  <div class="content-area">
    <% if (typeof announcements !== 'undefined' && announcements.length > 0 && typeof title !== 'undefined' && title !== 'Info Board') { %>
    <div id="announceBanner" style="margin-bottom:0.75rem;background:linear-gradient(135deg, rgba(168,85,247,0.08), rgba(0,212,255,0.05));border:1px solid rgba(168,85,247,0.2);border-radius:10px;padding:0.6rem 1rem;position:relative;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.4rem;">
        <span style="font-size:0.7rem;font-weight:700;font-family:var(--tf-font-mono);color:#a855f7;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-megaphone me-1"></i>Info Board</span>
        <div style="display:flex;gap:0.5rem;align-items:center;">
          <a href="/announcements" style="font-size:0.6rem;color:var(--tf-accent);text-decoration:none;">View All</a>
          <button onclick="document.getElementById('announceBanner').style.display='none'" style="background:none;border:none;color:var(--tf-text-muted);cursor:pointer;font-size:0.8rem;padding:0;line-height:1;" title="Dismiss"><i class="bi bi-x"></i></button>
        </div>
      </div>
      <%
        var localPosts = announcements.filter(function(a) { return a.audience === 'local'; });
        var clientPosts = announcements.filter(function(a) { return a.audience !== 'local'; });
      %>
      <div style="display:flex;gap:0.75rem;">
        <!-- Local posts (left) -->
        <div style="flex:1;min-width:0;">
          <div style="font-size:0.6rem;color:#a855f7;font-weight:600;font-family:var(--tf-font-mono);margin-bottom:0.35rem;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-people me-1"></i>Local Team</div>
          <div style="display:flex;flex-direction:column;gap:0.4rem;">
            <% if (localPosts.length === 0) { %>
            <div style="font-size:0.65rem;color:var(--tf-text-muted);padding:0.4rem;opacity:0.5;">No updates</div>
            <% } %>
            <% localPosts.forEach(function(a) { %>
            <div style="background:var(--tf-surface);border:1px solid var(--tf-border);border-radius:8px;padding:0.5rem 0.75rem;<%= a.is_pinned ? 'border-left:3px solid #a855f7;' : '' %>">
              <div style="font-size:0.75rem;font-weight:600;color:var(--tf-text);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                <% if (a.is_pinned) { %><i class="bi bi-pin-angle-fill me-1" style="color:#a855f7;font-size:0.6rem;"></i><% } %><%= a.title %>
              </div>
              <% if (a.body) { %>
              <div style="font-size:0.65rem;color:var(--tf-text-muted);line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= a.body %></div>
              <% } %>
              <div style="font-size:0.55rem;color:var(--tf-text-muted);margin-top:3px;"><%= a.author_name %> &middot; <%= new Date(a.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric' }) %></div>
            </div>
            <% }) %>
          </div>
        </div>
        <!-- Client posts (right) -->
        <div style="flex:1;min-width:0;">
          <div style="font-size:0.6rem;color:#f59e0b;font-weight:600;font-family:var(--tf-font-mono);margin-bottom:0.35rem;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-building me-1"></i>Client</div>
          <div style="display:flex;flex-direction:column;gap:0.4rem;">
            <% if (clientPosts.length === 0) { %>
            <div style="font-size:0.65rem;color:var(--tf-text-muted);padding:0.4rem;opacity:0.5;">No updates</div>
            <% } %>
            <% clientPosts.forEach(function(a) { %>
            <div style="background:rgba(245,158,11,0.04);border:1px solid rgba(245,158,11,0.2);border-radius:8px;padding:0.5rem 0.75rem;<%= a.is_pinned ? 'border-left:3px solid #f59e0b;' : '' %>">
              <div style="font-size:0.75rem;font-weight:600;color:var(--tf-text);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                <% if (a.is_pinned) { %><i class="bi bi-pin-angle-fill me-1" style="color:#f59e0b;font-size:0.6rem;"></i><% } %><%= a.title %>
              </div>
              <% if (a.body) { %>
              <div style="font-size:0.65rem;color:var(--tf-text-muted);line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= a.body %></div>
              <% } %>
              <div style="font-size:0.55rem;color:var(--tf-text-muted);margin-top:3px;"><%= a.author_name %> &middot; <%= new Date(a.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric' }) %></div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
    <% } %>
    <%- body %>
  </div>
</div>

<% if (!(typeof gcFullPage !== 'undefined' && gcFullPage)) { %>
<!-- Group Channel — right-side persistent panel -->
<div class="gc-panel" id="gcPanel">
  <div class="gc-panel-header">
    <div class="d-flex align-items-center gap-2">
      <i class="bi bi-broadcast" style="font-size:0.9rem"></i>
      <span class="fw-bold" style="font-size:0.8rem">Group Channel</span>
    </div>
    <div class="d-flex align-items-center gc-header-actions">
      <button class="gc-header-btn" onclick="toggleGcSearch()" title="Search"><i class="bi bi-search"></i></button>
      <button class="gc-header-btn" onclick="openGcHelp()" title="Help"><i class="bi bi-question-circle"></i></button>
      <a href="/channel" class="gc-header-btn" title="Maximize"><i class="bi bi-arrows-fullscreen"></i></a>
      <button class="gc-header-btn" onclick="toggleGroupChannel()" title="Collapse"><i class="bi bi-chevron-right" id="gcCollapseIcon"></i></button>
    </div>
  </div>
  <div class="gc-panel-body" id="gcPanelBody">
    <div class="gc-search-bar" id="gcSearchBar" style="display:none">
      <input type="text" class="form-control form-control-sm" id="gcSearchInput" placeholder="Search messages...">
      <i class="bi bi-x-lg gc-search-close" onclick="toggleGcSearch()" title="Close"></i>
      <div class="gc-search-results" id="gcSearchResults"></div>
    </div>
    <div class="gc-presence-strip" id="gcPresenceStrip"></div>
    <div class="gc-pinned-bar" id="gcPinnedBar" style="display:none">
      <div class="gc-pinned-bar-header" onclick="toggleGcPinnedList()">
        <i class="bi bi-pin-angle-fill"></i>
        <span id="gcPinnedBarTitle">0 pinned</span>
        <i class="bi bi-chevron-down gc-pinned-bar-chev" id="gcPinnedBarChev"></i>
      </div>
      <div class="gc-pinned-bar-list" id="gcPinnedBarList" style="display:none"></div>
    </div>
    <div class="gc-messages" id="gcMessages">
      <div class="text-center text-muted py-3 small">Loading...</div>
    </div>
    <button class="gc-scroll-btn" id="gcScrollBtn" onclick="gcScrollToBottom()" style="display:none" title="Jump to latest"><i class="bi bi-chevron-double-down"></i><span class="gc-scroll-btn-badge" id="gcScrollBtnBadge" style="display:none">0</span></button>
    <div class="gc-typing-bar" id="gcTypingBar" style="display:none"></div>
    <div class="gc-reply-compose-bar" id="gcReplyBar" style="display:none">
      <i class="bi bi-reply-fill" style="color:#2563eb;font-size:0.75rem"></i>
      <div class="gc-reply-compose-text">
        <span class="gc-reply-compose-sender" id="gcReplyBarSender"></span>
        <span class="gc-reply-compose-content" id="gcReplyBarContent"></span>
      </div>
      <i class="bi bi-x-lg gc-reply-compose-close" onclick="cancelGcReply()" title="Cancel reply"></i>
    </div>
    <div class="gc-input" style="position:relative">
      <div class="gc-mention-popup" id="gcMentionPopup" style="display:none"></div>
      <input type="file" id="gcFileInput" style="display:none" onchange="sendGcFile()">
      <div class="d-flex gap-1 align-items-stretch">
        <textarea class="form-control" id="gcInput" placeholder="Message..." rows="2" oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,100)+'px'"></textarea>
        <div class="gc-input-btns">
          <button class="btn btn-outline-secondary btn-sm gc-input-btn" onclick="document.getElementById('gcFileInput').click()" title="Attach"><i class="bi bi-paperclip"></i></button>
          <button class="btn btn-primary btn-sm gc-input-btn" onclick="sendGcMessage()" title="Send"><i class="bi bi-send"></i></button>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- Group Channel collapsed handle -->
<div class="gc-handle" id="gcHandle" style="display:none" onclick="toggleGroupChannel()" title="Open Group Channel">
  <i class="bi bi-broadcast"></i>
  <span class="gc-handle-badge" id="gcHandleBadge" style="display:none"></span>
</div>
<% } %>

<!-- Group Channel Help Modal -->
<div class="gc-help-backdrop" id="gcHelpBackdrop" style="display:none" onclick="if(event.target===this) closeGcHelp()">
  <div class="gc-help-modal" role="dialog" aria-label="Group Channel help">
    <div class="gc-help-header">
      <div class="gc-help-title"><i class="bi bi-broadcast"></i>Group Channel — Guide</div>
      <button class="gc-help-close" onclick="closeGcHelp()" title="Close"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="gc-help-body">
      <div class="gc-help-intro">The Group Channel is a shared chat visible to everyone except client sales. Here's everything you can do.</div>

      <div class="gc-help-section-title">Sending</div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-chat-dots-fill"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Send messages & files</div>
          <div class="gc-help-desc">Type and press <code>Enter</code>. <code>Shift+Enter</code> adds a new line. Click the paperclip for attachments (up to 5 MB). You can also <b>paste screenshots</b> directly into the compose box.</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-at"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Mention someone with @</div>
          <div class="gc-help-desc">Type <code>@</code> and start typing a name — a list pops up. Use <code>↑/↓</code> to move, <code>Enter</code> to pick. The mentioned person gets a red highlight on the message and a louder desktop notification (even if their chat is open).</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-reply-fill"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Reply to a specific message</div>
          <div class="gc-help-desc">Hover any message and click the <i class="bi bi-reply-fill"></i> icon. Your reply shows a quote of the original — click the quote later to jump to it.</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-emoji-smile-fill"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">React with emoji</div>
          <div class="gc-help-desc">Hover a message and click the smile icon to pick from 48 emojis. Click existing reaction chips to toggle yours on/off. Hover a chip to see who reacted.</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-pencil-fill"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Edit your own message</div>
          <div class="gc-help-desc">Within <b>15 minutes</b> of sending, hover your text message and click the pencil to edit inline. <code>Enter</code> saves, <code>Esc</code> cancels. Edited messages show <i>"(edited)"</i> in the footer.</div>
        </div>
      </div>

      <div class="gc-help-section-title">Reading</div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-chevron-double-down"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Stay caught up</div>
          <div class="gc-help-desc">When messages arrive while you're scrolled up, a blue jump-button appears with a red unread count. A <b>"New messages"</b> divider marks where you last left off. Scroll to the top to auto-load older history.</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-bell-fill"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Browser notifications</div>
          <div class="gc-help-desc">If the panel is collapsed or the tab is in the background, a desktop notification fires for new messages. Grant notification permission the first time you open the chat. Mentions always notify.</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-search"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Search older messages</div>
          <div class="gc-help-desc">Click the search icon, type 2+ characters. Matches are highlighted. Click a result to jump to it (scroll up first if it's not loaded yet).</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-link-45deg"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Automatic link previews</div>
          <div class="gc-help-desc">Any URL you paste becomes clickable and gets a preview card showing site title, description, and image.</div>
        </div>
      </div>

      <div class="gc-help-section-title">Organizing (admin)</div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-pin-angle-fill"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Pin important messages</div>
          <div class="gc-help-desc">Admins (<code>LOCAL_ADMIN</code>, <code>CLIENT_ADMIN</code>) can pin any message via the yellow pin icon on hover. A "N pinned" bar shows at the top — click to expand the list, click any pin to jump to it.</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-trash-fill"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">Delete your own message</div>
          <div class="gc-help-desc">Hover your message and click the red trash icon. Deleted messages show as "deleted" with the original replaced.</div>
        </div>
      </div>
      <div class="gc-help-item">
        <div class="gc-help-icon"><i class="bi bi-people-fill"></i></div>
        <div class="gc-help-content">
          <div class="gc-help-feature">See who's online</div>
          <div class="gc-help-desc">The top strip shows online users with a green dot, plus a count of offline local teammates.</div>
        </div>
      </div>

      <div class="gc-help-section-title">Tips</div>
      <ul class="gc-help-tips">
        <li>The chat panel stays collapsed/expanded across pages — your choice persists.</li>
        <li>Click <i class="bi bi-arrows-fullscreen"></i> Maximize to open a full-page channel view with more space.</li>
        <li>Messages with deleted reply-targets still work — the quote just shows "deleted message".</li>
        <li>Hover any reaction chip to see the full list of users who reacted.</li>
      </ul>
    </div>
  </div>
</div>

<script>
(function() {
  window.openGcHelp = function() {
    var bd = document.getElementById('gcHelpBackdrop');
    if (bd) bd.style.display = 'flex';
  };
  window.closeGcHelp = function() {
    var bd = document.getElementById('gcHelpBackdrop');
    if (bd) bd.style.display = 'none';
  };
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var bd = document.getElementById('gcHelpBackdrop');
      if (bd && bd.style.display !== 'none') closeGcHelp();
    }
  });
})();
</script>

<!-- Sidebar Overlay (mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Toast Container -->
<div id="toast-container"></div>

<!-- Bridge Chat Floating Widget (LOCAL_ADMIN and LOCAL_MANAGER only) -->
<% if (typeof user !== 'undefined' && user.role_name && ['LOCAL_ADMIN', 'LOCAL_MANAGER'].includes(user.role_name)) { %>
<div id="bridgeWidget" class="bridge-widget">
