    <div id="_callTimerEl" style="font-size:0.7rem;color:#10b981;font-family:monospace;">00:00</div>
  </div>
  <button id="_muteBtn" onclick="toggleMute()" title="Mute" style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:0.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;"><i class="bi bi-mic-fill"></i></button>
  <button onclick="endCall(true)" title="End call" style="width:36px;height:36px;border-radius:50%;background:#ef4444;border:none;color:#fff;font-size:0.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(239,68,68,0.4);"><i class="bi bi-telephone-x-fill"></i></button>
</div>

<style>
@keyframes _callPulse {
  0%,100% { box-shadow:0 0 0 0 rgba(16,185,129,0.5); }
  50%      { box-shadow:0 0 0 16px rgba(16,185,129,0); }
}
</style>

<script>
// ── Global Voice Call (WebRTC, works on every page) ──────────────────────────
var callSocket = io({ withCredentials: true, forceNew: true, reconnection: true, reconnectionAttempts: Infinity, reconnectionDelay: 1000 });

var _callSocketReady = false;
callSocket.on('connect', function() {
  _callSocketReady = true;
  console.log('[Call] Socket connected, id:', callSocket.id);
});
callSocket.on('connect_error', function(err) {
  _callSocketReady = false;
  console.error('[Call] Socket connection error:', err.message);
});
callSocket.on('disconnect', function(reason) {
  _callSocketReady = false;
  console.warn('[Call] Socket disconnected:', reason);
  // If in a call, clean up
  if (_callState === 'calling' || _callState === 'active') {
    window.endCall(false);
    showToast('Call disconnected — connection lost', 'error');
  }
  if (_callState === 'incoming') {
    _stopRingtone();
    if (window._titleFlashIv) { clearInterval(window._titleFlashIv); document.title = window._origTitle || 'TaskFlow'; }
    document.getElementById('_incomingOverlay').style.display = 'none';
    _callState = 'idle';
  }
});

var _callState = 'idle';   // idle | calling | incoming | active
var _pc        = null;
var _localStream = null;
var _pendingOffer   = null;
var _pendingFromId  = null;
var _callPeerId   = null;
var _callPeerName = null;
var _callConvId   = null;
var _callTimerIv  = null;
var _callSecs     = 0;

var _ICE = { iceServers: [
  { urls: 'stun:stun.l.google.com:19302' },
  { urls: 'stun:stun1.l.google.com:19302' }
]};

// Called from chat page button: startCall(peerId, peerName, convId)
window.startCall = function(peerId, peerName, convId) {
  if (_callState !== 'idle') { showToast('Already in a call', 'error'); return; }
  if (!callSocket.connected) { showToast('Not connected to server — please refresh the page', 'error'); return; }
  _callPeerId = peerId; _callPeerName = peerName; _callConvId = convId;
  _callState = 'calling';
  document.getElementById('_callOverlayName').textContent = peerName;
  document.getElementById('_callOverlay').style.display = 'flex';

  navigator.mediaDevices.getUserMedia({ audio: true, video: false })
    .then(function(stream) {
      _localStream = stream;
      _pc = new RTCPeerConnection(_ICE);
      stream.getTracks().forEach(function(t) { _pc.addTrack(t, stream); });
      _pc.ontrack = function(e) { _attachAudio(e.streams[0]); };
      _pc.onicecandidate = function(e) {
        if (e.candidate) callSocket.emit('call:ice-candidate', { to_user_id: _callPeerId, candidate: e.candidate });
      };
      _pc.oniceconnectionstatechange = function() {
        if (_pc && (_pc.iceConnectionState === 'disconnected' || _pc.iceConnectionState === 'failed')) window.endCall(false);
      };
      return _pc.createOffer();
    })
    .then(function(offer) { return _pc.setLocalDescription(offer).then(function() { return offer; }); })
    .then(function(offer) {
      callSocket.emit('call:offer', { to_user_id: _callPeerId, conversation_id: _callConvId, offer: offer });
    })
    .catch(function(err) {
      _callState = 'idle';
      document.getElementById('_callOverlay').style.display = 'none';
      showToast(err.name === 'NotAllowedError' ? 'Microphone access denied' : 'Could not start call', 'error');
      _callCleanup();
    });
};

window.endCall = function(notifyPeer) {
  if (notifyPeer !== false && _callPeerId) callSocket.emit('call:end', { to_user_id: _callPeerId });
  _callCleanup();
  document.getElementById('_callOverlay').style.display = 'none';
  document.getElementById('_activePanel').style.display = 'none';
  _callState = 'idle';
};

window.acceptCall = function() {
  document.getElementById('_incomingOverlay').style.display = 'none';
  _stopRingtone();
  if (window._titleFlashIv) { clearInterval(window._titleFlashIv); document.title = window._origTitle || 'TaskFlow'; }
  if (!_pendingOffer || !_pendingFromId) return;
  _callState = 'active';

  navigator.mediaDevices.getUserMedia({ audio: true, video: false })
    .then(function(stream) {
      _localStream = stream;
      _pc = new RTCPeerConnection(_ICE);
      stream.getTracks().forEach(function(t) { _pc.addTrack(t, stream); });
      _pc.ontrack = function(e) { _attachAudio(e.streams[0]); };
      _pc.onicecandidate = function(e) {
        if (e.candidate) callSocket.emit('call:ice-candidate', { to_user_id: _pendingFromId, candidate: e.candidate });
      };
      _pc.oniceconnectionstatechange = function() {
        if (_pc && (_pc.iceConnectionState === 'disconnected' || _pc.iceConnectionState === 'failed')) window.endCall(false);
      };
      return _pc.setRemoteDescription(new RTCSessionDescription(_pendingOffer));
    })
    .then(function() { return _pc.createAnswer(); })
    .then(function(answer) { return _pc.setLocalDescription(answer).then(function() { return answer; }); })
    .then(function(answer) {
      callSocket.emit('call:answer', { to_user_id: _pendingFromId, conversation_id: _callConvId, answer: answer });
      _callPeerId = _pendingFromId;
      _callPeerName = document.getElementById('_incomingName').textContent;
      _pendingOffer = null; _pendingFromId = null;
      _showActivePanel(_callPeerName);
    })
    .catch(function(err) {
      _callState = 'idle';
      showToast(err.name === 'NotAllowedError' ? 'Microphone access denied' : 'Could not answer call', 'error');
      _callCleanup();
    });
};

window.rejectCall = function() {
  document.getElementById('_incomingOverlay').style.display = 'none';
  _stopRingtone();
  if (window._titleFlashIv) { clearInterval(window._titleFlashIv); document.title = window._origTitle || 'TaskFlow'; }
  if (_pendingFromId) callSocket.emit('call:reject', { to_user_id: _pendingFromId, conversation_id: _callConvId });
  _pendingOffer = null; _pendingFromId = null;
  _callState = 'idle';
};

window.toggleMute = function() {
  if (!_localStream) return;
  var t = _localStream.getAudioTracks()[0]; if (!t) return;
  t.enabled = !t.enabled;
  var btn = document.getElementById('_muteBtn');
  btn.innerHTML = t.enabled ? '<i class="bi bi-mic-fill"></i>' : '<i class="bi bi-mic-mute-fill"></i>';
  btn.style.background = t.enabled ? 'rgba(255,255,255,0.15)' : 'rgba(239,68,68,0.4)';
};

function _attachAudio(stream) {
  var a = document.getElementById('_callAudio');
  a.srcObject = stream; a.play().catch(function() {});
}

function _showActivePanel(name) {
  document.getElementById('_activeName').textContent = name;
  document.getElementById('_activePanel').style.display = 'flex';
  _callSecs = 0;
  _callTimerIv = setInterval(function() {
    _callSecs++;
    var m = Math.floor(_callSecs / 60), s = _callSecs % 60;
    document.getElementById('_callTimerEl').textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
  }, 1000);
}

function _callCleanup() {
  if (_localStream) { _localStream.getTracks().forEach(function(t) { t.stop(); }); _localStream = null; }
  if (_pc) { _pc.close(); _pc = null; }
  if (_callTimerIv) { clearInterval(_callTimerIv); _callTimerIv = null; }
  var a = document.getElementById('_callAudio'); if (a) a.srcObject = null;
}

// ── Ringtone generator (no external audio file needed) ──
var _ringtoneCtx = null;
var _ringtoneIv = null;
function _startRingtone() {
  try {
    _ringtoneCtx = new (window.AudioContext || window.webkitAudioContext)();
    var playBeep = function() {
      var osc = _ringtoneCtx.createOscillator();
      var gain = _ringtoneCtx.createGain();
      osc.connect(gain);
      gain.connect(_ringtoneCtx.destination);
      osc.type = 'sine';
      osc.frequency.value = 440;
      gain.gain.value = 0.3;
      osc.start();
      gain.gain.exponentialRampToValueAtTime(0.001, _ringtoneCtx.currentTime + 0.3);
      osc.stop(_ringtoneCtx.currentTime + 0.3);
      // Second beep after short gap
      setTimeout(function() {
        if (!_ringtoneCtx) return;
        var osc2 = _ringtoneCtx.createOscillator();
        var gain2 = _ringtoneCtx.createGain();
        osc2.connect(gain2);
        gain2.connect(_ringtoneCtx.destination);
        osc2.type = 'sine';
        osc2.frequency.value = 523;
        gain2.gain.value = 0.3;
        osc2.start();
        gain2.gain.exponentialRampToValueAtTime(0.001, _ringtoneCtx.currentTime + 0.3);
        osc2.stop(_ringtoneCtx.currentTime + 0.3);
      }, 350);
    };
    playBeep();
    _ringtoneIv = setInterval(playBeep, 2000);
  } catch (e) {}
}
function _stopRingtone() {
  if (_ringtoneIv) { clearInterval(_ringtoneIv); _ringtoneIv = null; }
  if (_ringtoneCtx) { _ringtoneCtx.close().catch(function(){}); _ringtoneCtx = null; }
}

// ── Browser notification for incoming calls ──
function _notifyIncomingCall(callerName) {
  if (!('Notification' in window)) return;
  if (Notification.permission === 'granted') {
    var n = new Notification('Incoming Call', { body: callerName + ' is calling you', icon: '/favicon.ico', requireInteraction: true, tag: 'incoming-call' });
    n.onclick = function() { window.focus(); n.close(); };
  } else if (Notification.permission !== 'denied') {
    Notification.requestPermission();
  }
}
function _clearCallNotification() {
  // Close the notification if still showing
  try { if ('Notification' in window) { /* tag-based auto-replaces */ } } catch(e) {}
}

// Request notification permission on page load (silent, no prompt until needed)
if ('Notification' in window && Notification.permission === 'default') {
  // Will prompt on first incoming call
}

// Socket events
callSocket.on('call:incoming', function(data) {
  if (_callState !== 'idle') {
    callSocket.emit('call:reject', { to_user_id: data.from_user_id, conversation_id: data.conversation_id });
    return;
  }
  _callState = 'incoming';
  _callConvId = data.conversation_id;
  _pendingOffer = data.offer;
  _pendingFromId = data.from_user_id;
  document.getElementById('_incomingName').textContent = data.from_user_name;
  document.getElementById('_incomingOverlay').style.display = 'flex';
  _startRingtone();
  _notifyIncomingCall(data.from_user_name);
  // Flash the page title to draw attention
  var _origTitle = document.title;
  var _titleFlash = setInterval(function() {
    document.title = document.title === _origTitle ? '📞 ' + data.from_user_name + ' calling...' : _origTitle;
  }, 1000);
  // Store flash interval to clear on accept/reject
  window._titleFlashIv = _titleFlash;
  window._origTitle = _origTitle;
});

callSocket.on('call:answered', function(data) {
  console.log('[Call] Received call:answered', !!_pc, !!data.answer);
  if (!_pc) return;
  _pc.setRemoteDescription(new RTCSessionDescription(data.answer))
    .then(function() {
      _callState = 'active';
      document.getElementById('_callOverlay').style.display = 'none';
      _showActivePanel(_callPeerName);
    })
    .catch(function(err) { console.error('[Call] setRemoteDescription error:', err); window.endCall(true); });
});

callSocket.on('call:ice-candidate', function(data) {
  if (_pc && data.candidate) _pc.addIceCandidate(new RTCIceCandidate(data.candidate)).catch(function() {});
});

callSocket.on('call:rejected', function() {
  _callState = 'idle';
  document.getElementById('_callOverlay').style.display = 'none';
  showToast('Call was declined', 'error');
  _callCleanup();
});

callSocket.on('call:ended', function() {
  var wasIncoming = _callState === 'incoming';
  _stopRingtone();
  if (window._titleFlashIv) { clearInterval(window._titleFlashIv); document.title = window._origTitle || 'TaskFlow'; }
  document.getElementById('_incomingOverlay').style.display = 'none';
  window.endCall(false);
  if (wasIncoming) showToast('Missed call', 'error');
  else if (_callState !== 'idle') showToast('Call ended', 'success');
});

callSocket.on('call:busy', function() {
  _callState = 'idle';
  document.getElementById('_callOverlay').style.display = 'none';
  showToast('User is busy on another call', 'error');
  _callCleanup();
});
</script>

</body>
</html>
