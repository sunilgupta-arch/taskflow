  window._gcToggleReaction = function(msgId, emoji, mine) {
    $.ajax({
      url: _gcBaseUrl + '/messages/' + msgId + '/reactions',
      method: 'POST',
      contentType: 'application/json',
      data: JSON.stringify({ emoji: emoji, action: mine ? 'remove' : 'add' })
    });
  };
  window.showGcEmojiPicker = function(evt, msgId) {
    var existing = document.getElementById('gcEmojiPicker');
    if (existing) existing.remove();
    var picker = document.createElement('div');
    picker.id = 'gcEmojiPicker';
    picker.className = 'gc-emoji-picker';
    picker.innerHTML = GC_EMOJI_LIST.map(function(e) {
      return '<span class="gc-emoji-pick" onclick="_gcPickEmoji(' + msgId + ',\'' + e.replace(/'/g, "\\'") + '\')">' + e + '</span>';
    }).join('');
    document.body.appendChild(picker);
    var rect = evt.currentTarget.getBoundingClientRect();
    var pw = picker.offsetWidth;
    var ph = picker.offsetHeight;
    var top = rect.top - ph - 8;
    if (top < 8) top = Math.min(rect.bottom + 8, window.innerHeight - ph - 8);
    picker.style.top = top + 'px';
    picker.style.left = Math.max(10, Math.min(window.innerWidth - pw - 10, rect.right - pw)) + 'px';
    setTimeout(function() {
      document.addEventListener('click', function close(e) {
        if (!picker.contains(e.target)) { picker.remove(); document.removeEventListener('click', close); }
      });
    }, 10);
  };
  window._gcPickEmoji = function(msgId, emoji) {
    _gcToggleReaction(msgId, emoji, false);
    var p = document.getElementById('gcEmojiPicker');
    if (p) p.remove();
