<!-- Pending Tasks Reminder Modal -->
<div id="pendingTasksModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:290;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:var(--tf-surface);border:1px solid var(--tf-border);border-radius:16px;width:100%;max-width:500px;overflow:hidden;">
    <div style="padding:1.5rem 1.5rem 1rem;text-align:center;">
      <div style="width:56px;height:56px;border-radius:50%;background:rgba(245,158,11,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
        <i class="bi bi-list-check" style="font-size:1.5rem;color:#f59e0b;"></i>
      </div>
      <h5 style="font-family:var(--tf-font-mono);margin-bottom:0.3rem;font-weight:700;">PENDING TASKS</h5>
      <p style="font-size:0.8rem;color:var(--tf-text-muted);margin-bottom:0;">Your shift ends in 1 hour. You have <strong id="pendingTasksCount" style="color:#f59e0b;">0</strong> pending task(s).</p>
