  function _gcDoSearch(q) {
    var results = document.getElementById('gcSearchResults');
    if (!results) return;
    if (!q || q.length < 2) { results.innerHTML = ''; return; }
    $.get(_gcBaseUrl + '/search?q=' + encodeURIComponent(q), function(res) {
      if (!res.success) return;
      var msgs = res.data.messages || [];
      if (!msgs.length) { results.innerHTML = '<div class="gc-search-empty">No matches</div>'; return; }
      var re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
      results.innerHTML = msgs.map(function(m) {
        var text = _escHtmlGc((m.content || '').substring(0, 140));
        text = text.replace(re, '<mark>$1</mark>');
        return '<div class="gc-search-item" onclick="_gcSearchJump(' + m.id + ')">' +
          '<div class="gc-search-item-sender">' + _escHtmlGc(m.sender_name) + '</div>' +
          '<div class="gc-search-item-content">' + text + '</div>' +
        '</div>';
      }).join('');
    });
  }
  window._gcSearchJump = function(msgId) {
