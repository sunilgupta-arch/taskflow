    document.getElementById('gcReplyBar').style.display = 'none';
  };
  window.gcJumpToMsg = function(msgId) {
    var bubble = document.querySelector('[data-gc-msg-id="' + msgId + '"]');
    if (!bubble) return;
    bubble.scrollIntoView({ block: 'center', behavior: 'smooth' });
    bubble.classList.add('gc-msg-jump-highlight');
