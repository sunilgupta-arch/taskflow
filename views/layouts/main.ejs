<% if (typeof user !== 'undefined' && user.role_name && ['LOCAL_ADMIN', 'LOCAL_MANAGER'].includes(user.role_name)) { %>
<script>
// ── Bridge Chat Floating Widget ────────────────────────────
var bridgeWidgetConvId = null;
var bridgeWidgetUserId = <%= user.id %>;

// ── Draggable FAB ──────────────────────────────────────────
(function() {
  var widget = document.getElementById('bridgeWidget');
  var fab    = document.getElementById('bridgeFab');
  if (!widget || !fab) return;

  function updatePanelQuadrant() {
    var panel = document.getElementById('bridgePanel');
    if (!panel) return;
    var rect = widget.getBoundingClientRect();
    panel.classList.toggle('panel-top',  rect.top  < window.innerHeight / 2);
    panel.classList.toggle('panel-left', rect.left < window.innerWidth  / 2);
  }

  function applyPos(left, top) {
    widget.style.left   = left + 'px';
    widget.style.top    = top  + 'px';
    widget.style.right  = 'auto';
    widget.style.bottom = 'auto';
    updatePanelQuadrant();
  }

  function savePos() {
    var rect = widget.getBoundingClientRect();
    localStorage.setItem('bridge-fab-pos', JSON.stringify({ left: rect.left, top: rect.top }));
  }

  // Restore saved position
  var saved = localStorage.getItem('bridge-fab-pos');
  if (saved) {
    try { var p = JSON.parse(saved); applyPos(p.left, p.top); } catch(e) {}
  }

  var dragging = false, dragMoved = false;
  var startX, startY, startLeft, startTop;

  function dragStart(cx, cy) {
    var rect  = widget.getBoundingClientRect();
    dragging  = true;
    dragMoved = false;
    startX    = cx; startY    = cy;
    startLeft = rect.left; startTop = rect.top;
    widget.style.right  = 'auto';
    widget.style.bottom = 'auto';
    widget.classList.add('is-dragging');
  }

  function dragMove(cx, cy) {
    if (!dragging) return;
    var dx = cx - startX, dy = cy - startY;
    if (Math.abs(dx) > 4 || Math.abs(dy) > 4) dragMoved = true;
    widget.style.left = Math.max(0, Math.min(startLeft + dx, window.innerWidth  - 40)) + 'px';
    widget.style.top  = Math.max(0, Math.min(startTop  + dy, window.innerHeight - 40)) + 'px';
  }

  function dragEnd() {
    if (!dragging) return;
    dragging = false;
    widget.classList.remove('is-dragging');
    if (dragMoved) savePos();
  }

  fab.addEventListener('mousedown', function(e) { if (e.button === 0) { dragStart(e.clientX, e.clientY); e.preventDefault(); } });
  document.addEventListener('mousemove', function(e) { dragMove(e.clientX, e.clientY); });
  document.addEventListener('mouseup',   function()  { dragEnd(); });

  fab.addEventListener('touchstart', function(e) { dragStart(e.touches[0].clientX, e.touches[0].clientY); }, { passive: true });
  document.addEventListener('touchmove',  function(e) { if (dragging) dragMove(e.touches[0].clientX, e.touches[0].clientY); }, { passive: true });
  document.addEventListener('touchend',   function()  { dragEnd(); });

  fab.addEventListener('click', function() { if (!dragMoved) toggleBridgeWidget(); });

  // Keep FAB on-screen if window is resized
  window.addEventListener('resize', function() {
    var rect = widget.getBoundingClientRect();
    var newLeft = Math.min(rect.left, window.innerWidth  - 40);
    var newTop  = Math.min(rect.top,  window.innerHeight - 40);
    if (newLeft !== rect.left || newTop !== rect.top) applyPos(newLeft, newTop);
    updatePanelQuadrant();
  });
})();

function toggleBridgeWidget() {
  var panel = document.getElementById('bridgePanel');
  if (panel.style.display === 'none') {
    panel.style.display = 'flex';
    // Flip panel direction based on which corner the FAB is in
    var widget = document.getElementById('bridgeWidget');
    var rect   = widget.getBoundingClientRect();
    panel.classList.toggle('panel-top',  rect.top  < window.innerHeight / 2);
    panel.classList.toggle('panel-left', rect.left < window.innerWidth  / 2);
    loadBridgeConvList();
  } else {
    panel.style.display = 'none';
  }
}

function loadBridgeConvList() {
  document.getElementById('bridgeConvList').style.display = '';
  document.getElementById('bridgeChatView').style.display = 'none';
  document.getElementById('bridgePanelTitle').textContent = 'Client Messages';

  $.get('/bridge/conversations', function(res) {
    if (!res.success) return;
    var list = document.getElementById('bridgeConvList');
    var convs = res.data.conversations;
    if (!convs.length) {
      list.innerHTML = '<div class="text-center text-muted py-3 small">No messages yet</div>';
      return;
    }
    list.innerHTML = convs.map(function(c) {
      var unread = c.unread_count > 0 ? '<span class="bridge-conv-unread">' + c.unread_count + '</span>' : '';
      return '<div class="bridge-conv-item" onclick="openBridgeChat(' + c.id + ', \'' + c.client_user_name.replace(/'/g, "\\'") + '\')">' +
        '<div class="bridge-conv-avatar">' + c.client_user_name.charAt(0).toUpperCase() + '</div>' +
        '<div class="bridge-conv-info"><span class="bridge-conv-name">' + c.client_user_name + '</span>' +
        '<span class="bridge-conv-last">' + (c.last_message || '') + '</span></div>' +
        unread + '</div>';
    }).join('');
  });
}

function openBridgeChat(convId, name) {
  bridgeWidgetConvId = convId;
  document.getElementById('bridgeConvList').style.display = 'none';
  document.getElementById('bridgeChatView').style.display = 'flex';
  document.getElementById('bridgeChatName').textContent = name;

  $.get('/bridge/conversations/' + convId + '/messages', function(res) {
    if (!res.success) return;
    renderBridgeWidgetMessages(res.data.messages);
  });
}

