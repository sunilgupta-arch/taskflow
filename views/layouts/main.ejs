  }
  function _gcDeleteBtnHtmlShifted(m) {
    if (m.is_deleted) return '';
    var right = _gcCanEdit(m) ? 100 : 68;
    return '<span class="gc-msg-delete" style="right:' + right + 'px" onclick="event.stopPropagation(); deleteGcMsg(' + m.id + ')" title="Delete"><i class="bi bi-trash"></i></span>';
  }
  window.editGcMsg = function(msgId) {
    var bubble = document.querySelector('[data-gc-msg-id="' + msgId + '"]');
    if (!bubble) return;
    var contentEl = bubble.querySelector('.msg-content');
    if (!contentEl) return;
    if (contentEl.querySelector('.gc-editor')) return; // already editing
    var originalHtml = contentEl.innerHTML;
    var originalRaw = _gcMsgRaw[msgId] || contentEl.textContent || '';
    contentEl.innerHTML = '<div class="gc-editor">' +
      '<textarea class="form-control form-control-sm" rows="2">' + _escHtmlGc(originalRaw) + '</textarea>' +
      '<div class="gc-editor-actions">' +
        '<button class="btn btn-sm btn-outline-light" data-action="cancel">Cancel</button>' +
        '<button class="btn btn-sm btn-primary" data-action="save">Save</button>' +
      '</div></div>';
    var ta = contentEl.querySelector('textarea');
    var cancelBtn = contentEl.querySelector('[data-action="cancel"]');
    var saveBtn = contentEl.querySelector('[data-action="save"]');
    ta.focus(); ta.setSelectionRange(ta.value.length, ta.value.length);
    function cancel() { contentEl.innerHTML = originalHtml; }
    function save() {
      var v = ta.value.trim();
      if (!v) return;
      if (v === originalRaw) { cancel(); return; }
      $.ajax({
        url: _gcBaseUrl + '/messages/' + msgId,
        method: 'PUT',
        contentType: 'application/json',
        data: JSON.stringify({ content: v }),
        error: function(xhr) {
          var m = (xhr.responseJSON && xhr.responseJSON.message) || 'Edit failed';
          alert(m); cancel();
        }
      });
    }
    cancelBtn.addEventListener('click', cancel);
    saveBtn.addEventListener('click', save);
    ta.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { e.preventDefault(); cancel(); }
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); save(); }
    });
  };

  // ── Reactions ───────────────────────────────────
  var GC_EMOJI_LIST = ['😀','😂','😊','😍','🥰','😎','🤔','🤩','😐','😢','😭','😤','😡','🤯','😱','🥳','👍','👎','👌','✌️','🤞','🙏','👏','🙌','❤️','🧡','💛','💚','💙','💜','🖤','💔','🎉','🔥','✨','💯','✅','❌','⚠️','💡','👀','💪','🚀','⚡','🌟','🎯','📌','📎'];
  function _gcRenderReactions(m) {
    if (!m.reactions || !m.reactions.length) return '';
    var html = m.reactions.map(function(r) {
      var mine = r.users && r.users.some(function(u) { return u.id === _gcUserId; });
      var tooltip = (r.users || []).map(function(u) { return u.name; }).join(', ');
      return '<span class="gc-reaction-chip' + (mine ? ' mine' : '') + '" title="' + _escHtmlGc(tooltip) + '" onclick="event.stopPropagation(); _gcToggleReaction(' + m.id + ',\'' + r.emoji.replace(/'/g, "\\'") + '\',' + (mine ? 'true' : 'false') + ')">' + r.emoji + ' <span>' + r.count + '</span></span>';
    }).join('');
    return '<div class="gc-reactions">' + html + '</div>';
