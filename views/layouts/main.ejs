  // ── Edit own message ────────────────────────────
  var _gcMsgRaw = {}; // cache: msgId → raw text content
  var GC_EDIT_WINDOW_MS = 15 * 60 * 1000;
  function _gcCanEdit(m) {
    if (!m || m.is_deleted) return false;
    if (m.sender_id !== _gcUserId) return false;
    if (m.type !== 'text') return false;
    return (Date.now() - new Date(m.created_at).getTime()) < GC_EDIT_WINDOW_MS;
  }
  function _gcEditBtnHtml(m) {
    if (!_gcCanEdit(m)) return '';
