        <input type="radio" name="late_reason" value="Family Emergency" style="accent-color:var(--tf-accent);"> Family Emergency
      </label>
      <label class="late-reason-opt" style="display:flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid var(--tf-border);border-radius:8px;cursor:pointer;font-size:0.8rem;transition:all 0.15s;">
        <input type="radio" name="late_reason" value="Power / Internet Outage" style="accent-color:var(--tf-accent);"> Power / Internet Outage
      </label>
