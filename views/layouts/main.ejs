<% if (typeof user !== 'undefined' && user.role_name && user.role_name.startsWith('LOCAL_')) { %>
<script>
// ── Bridge Chat Floating Widget ────────────────────────────
var bridgeWidgetConvId = null;
var bridgeWidgetUserId = <%= user.id %>;

function toggleBridgeWidget() {
  var panel = document.getElementById('bridgePanel');
  if (panel.style.display === 'none') {
    panel.style.display = 'flex';
    loadBridgeConvList();
  } else {
    panel.style.display = 'none';
  }
}

function loadBridgeConvList() {
  document.getElementById('bridgeConvList').style.display = '';
  document.getElementById('bridgeChatView').style.display = 'none';
  document.getElementById('bridgePanelTitle').textContent = 'Client Messages';

  $.get('/bridge/conversations', function(res) {
    if (!res.success) return;
    var list = document.getElementById('bridgeConvList');
    var convs = res.data.conversations;
    if (!convs.length) {
      list.innerHTML = '<div class="text-center text-muted py-3 small">No messages yet</div>';
      return;
    }
    list.innerHTML = convs.map(function(c) {
      var unread = c.unread_count > 0 ? '<span class="bridge-conv-unread">' + c.unread_count + '</span>' : '';
      return '<div class="bridge-conv-item" onclick="openBridgeChat(' + c.id + ', \'' + c.client_user_name.replace(/'/g, "\\'") + '\')">' +
        '<div class="bridge-conv-avatar">' + c.client_user_name.charAt(0).toUpperCase() + '</div>' +
        '<div class="bridge-conv-info"><span class="bridge-conv-name">' + c.client_user_name + '</span>' +
        '<span class="bridge-conv-last">' + (c.last_message || '') + '</span></div>' +
        unread + '</div>';
    }).join('');
  });
}

function openBridgeChat(convId, name) {
  bridgeWidgetConvId = convId;
  document.getElementById('bridgeConvList').style.display = 'none';
  document.getElementById('bridgeChatView').style.display = 'flex';
  document.getElementById('bridgeChatName').textContent = name;

  $.get('/bridge/conversations/' + convId + '/messages', function(res) {
    if (!res.success) return;
    renderBridgeWidgetMessages(res.data.messages);
  });

  $.post('/bridge/conversations/' + convId + '/read');
}

function renderBridgeWidgetMessages(messages) {
  var container = document.getElementById('bridgeChatMessages');
  if (!messages.length) {
    container.innerHTML = '<div class="text-center text-muted py-3 small">No messages yet</div>';
    return;
  }
  container.innerHTML = messages.map(function(m) {
    var isSent = m.sender_id === bridgeWidgetUserId;
    var cls = isSent ? 'sent' : 'received';
    var time = new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    var content = '';
    if (m.is_deleted) {
      content = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
    } else if (m.type === 'file' && m.attachment) {
      content = '<a class="msg-file" href="/bridge/attachment/' + m.id + '" target="_blank" style="color:inherit;text-decoration:none;font-size:0.75rem"><i class="bi bi-file-earmark me-1"></i>' + m.attachment.file_name + '</a>';
    } else {
      var div = document.createElement('div'); div.textContent = m.content; content = div.innerHTML;
    }
    var deleteBtn = isSent && !m.is_deleted ? '<span class="bridge-msg-delete" onclick="event.stopPropagation(); deleteBridgeWidgetMsg(' + m.id + ')" title="Delete"><i class="bi bi-trash"></i></span>' : '';
    var senderName = !isSent && m.sender_name ? '<div class="msg-sender-name">' + m.sender_name + '</div>' : '';
    return '<div class="msg-bubble ' + cls + (m.is_deleted ? ' deleted' : '') + '" data-bridge-msg-id="' + m.id + '">' + deleteBtn + senderName + '<div class="msg-content">' + content + '</div><div class="msg-footer"><span class="msg-time">' + time + '</span></div></div>';
  }).join('');
  container.scrollTop = container.scrollHeight;
}

function deleteBridgeWidgetMsg(msgId) {
  if (!confirm('Delete this message?')) return;
  $.ajax({ url: '/bridge/messages/' + msgId, method: 'DELETE' });
}

function backToBridgeList() {
  bridgeWidgetConvId = null;
  loadBridgeConvList();
}

function sendBridgeWidgetMessage() {
  if (!bridgeWidgetConvId) return;
  var input = document.getElementById('bridgeWidgetInput');
  var content = input.value.trim();
  if (!content) return;

  $.ajax({
    url: '/bridge/conversations/' + bridgeWidgetConvId + '/messages',
    method: 'POST',
    contentType: 'application/json',
    data: JSON.stringify({ content: content }),
    success: function() { input.value = ''; }
  });
}

function sendBridgeWidgetFile() {
  if (!bridgeWidgetConvId) return;
  var fileInput = document.getElementById('bridgeWidgetFile');
  if (!fileInput.files.length) return;
  var fd = new FormData();
  fd.append('file', fileInput.files[0]);
  $.ajax({
    url: '/bridge/conversations/' + bridgeWidgetConvId + '/file',
    method: 'POST',
    data: fd,
    processData: false,
    contentType: false,
    success: function() { fileInput.value = ''; }
  });
}

// Enter to send in widget
$(document).on('keydown', '#bridgeWidgetInput', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendBridgeWidgetMessage();
  }
});

// Listen for bridge messages via main socket
if (typeof io !== 'undefined') {
  var bridgeSocket = io('/', { withCredentials: true });
  bridgeSocket.on('bridge:message', function(msg) {
    // If widget chat is open for this conversation, append the new message
    if (msg.conversation_id === bridgeWidgetConvId) {
      var container = document.getElementById('bridgeChatMessages');
      // Clear placeholder if present
      if (container.querySelector('.text-center')) container.innerHTML = '';
      var isSent = msg.sender_id === bridgeWidgetUserId;
      var cls = isSent ? 'sent' : 'received';
      var time = new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      var content = '';
      if (msg.is_deleted) {
        content = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
      } else if (msg.type === 'file' && msg.attachment) {
        content = '<a class="msg-file" href="/bridge/attachment/' + msg.id + '" target="_blank" style="color:inherit;text-decoration:none;font-size:0.75rem"><i class="bi bi-file-earmark me-1"></i>' + msg.attachment.file_name + '</a>';
      } else {
        var div = document.createElement('div'); div.textContent = msg.content; content = div.innerHTML;
      }
      var senderLabel = !isSent && msg.sender_name ? '<div class="msg-sender-name">' + msg.sender_name + '</div>' : '';
      var deleteBtn = isSent && !msg.is_deleted ? '<span class="bridge-msg-delete" onclick="event.stopPropagation(); deleteBridgeWidgetMsg(' + msg.id + ')" title="Delete"><i class="bi bi-trash"></i></span>' : '';
      container.insertAdjacentHTML('beforeend', '<div class="msg-bubble ' + cls + '" data-bridge-msg-id="' + msg.id + '">' + deleteBtn + senderLabel + '<div class="msg-content">' + content + '</div><div class="msg-footer"><span class="msg-time">' + time + '</span></div></div>');
      container.scrollTop = container.scrollHeight;

      $.post('/bridge/conversations/' + bridgeWidgetConvId + '/read');
    }

    // Play sound + update badge for messages from others
    if (msg.sender_id !== bridgeWidgetUserId) {
      var panel = document.getElementById('bridgePanel');
      var chatIsOpen = panel.style.display !== 'none' && msg.conversation_id === bridgeWidgetConvId;

      if (!chatIsOpen) {
        updateBridgeFabBadge();

        // Show toast only when chat is not open
        var senderName = msg.sender_name || (msg.conversation ? msg.conversation.client_user_name : 'Client');
        showToast('Message from <strong>' + senderName + '</strong>: ' + (msg.content || 'File').substring(0, 50), 'info');
      }

      // Always play sound
      try {
        var ctx = new (window.AudioContext || window.webkitAudioContext)();
        var o = ctx.createOscillator(); var g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.type = 'sine'; o.frequency.setValueAtTime(880, ctx.currentTime);
        o.frequency.setValueAtTime(1046, ctx.currentTime + 0.1);
        g.gain.setValueAtTime(0.15, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
        o.start(ctx.currentTime); o.stop(ctx.currentTime + 0.3);
      } catch(e) {}
    }

    // Refresh conversation list if visible
    if (document.getElementById('bridgeConvList').style.display !== 'none') {
      loadBridgeConvList();
    }
  });

  // Update FAB badge on load
  function updateBridgeFabBadge() {
    $.get('/bridge/unread-count', function(res) {
      if (!res.success) return;
      var badge = document.getElementById('bridgeFabBadge');
      if (res.data.total > 0) {
        badge.textContent = res.data.total;
        badge.style.display = '';
      } else {
        badge.style.display = 'none';
      }
    });
  }

  // Bridge message delete
  bridgeSocket.on('bridge:message:delete', function(data) {
    if (data.conversation_id === bridgeWidgetConvId) {
      var bubble = document.querySelector('.bridge-chat-messages [data-bridge-msg-id="' + data.id + '"]');
      if (bubble) {
        bubble.classList.add('deleted');
        var contentEl = bubble.querySelector('.msg-content');
        if (contentEl) contentEl.innerHTML = '<i class="bi bi-ban me-1"></i><em>This message was deleted</em>';
        var delBtn = bubble.querySelector('.bridge-msg-delete');
        if (delBtn) delBtn.remove();
      }
    }
  });

  updateBridgeFabBadge();
  setInterval(updateBridgeFabBadge, 30000);
}
</script>
<% } %>

