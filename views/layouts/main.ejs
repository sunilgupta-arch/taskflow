    var bar = document.getElementById('gcSearchBar');
    if (!bar) return;
    var open = bar.style.display !== 'none';
    bar.style.display = open ? 'none' : '';
    if (!open) {
      var input = document.getElementById('gcSearchInput');
      if (input) input.focus();
    } else {
      var results = document.getElementById('gcSearchResults');
      if (results) results.innerHTML = '';
      var input = document.getElementById('gcSearchInput');
      if (input) input.value = '';
