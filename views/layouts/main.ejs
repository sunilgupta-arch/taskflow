  };
  function _gcReplyQuoteHtml(m) {
    if (!m.reply_to_id) return '';
    var sender = _escHtmlGc(m.reply_to_sender_name || '');
    var preview = '';
    if (m.reply_to_is_deleted) preview = '<em>deleted message</em>';
    else if (m.reply_to_type === 'file') preview = '📎 attachment';
    else preview = _escHtmlGc((m.reply_to_content || '').substring(0, 120));
    return '<div class="gc-reply-quote" onclick="event.stopPropagation(); gcJumpToMsg(' + m.reply_to_id + ')"><div class="gc-reply-quote-sender">' + sender + '</div><div class="gc-reply-quote-content">' + preview + '</div></div>';
  }
  function _gcReplyBtnHtml(m, isSent) {
