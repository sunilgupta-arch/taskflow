      <span class="fw-bold" style="font-size:0.85rem" id="bridgePanelTitle">Client Messages</span>
      <button class="btn btn-sm btn-link p-0" onclick="toggleBridgeWidget()"><i class="bi bi-x-lg"></i></button>
    </div>
    <!-- Conversation list view -->
    <div class="bridge-conv-list" id="bridgeConvList">
      <div class="text-center text-muted py-3 small">No messages yet</div>
    </div>
