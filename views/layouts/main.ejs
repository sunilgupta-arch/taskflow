  }

  // ── Browser notifications ────────────────────────
  var _gcNotifAsked = false;
  function _gcRequestNotifPerm() {
    if (_gcNotifAsked) return;
    if (!('Notification' in window)) return;
    if (Notification.permission === 'default') {
      try { Notification.requestPermission(); } catch (e) {}
    }
    _gcNotifAsked = true;
  }
  function _gcShowNotif(msg) {
    if (!('Notification' in window)) return;
    if (Notification.permission !== 'granted') return;
    if (msg.sender_id === _gcUserId) return;
    var mentionsMe = _gcMentionsMe(msg.content);
    if (!document.hidden && !_gcCollapsed && !mentionsMe) return;
    var body = '';
    if (msg.type === 'file' && msg.attachment) body = '📎 ' + (msg.attachment.file_name || 'Sent a file');
    else body = (msg.content || '').replace(/@\[([^\]]+)\]/g, '@$1');
    var title = mentionsMe ? ('@ ' + msg.sender_name + ' mentioned you') : ('Group Channel — ' + msg.sender_name);
    try {
      var n = new Notification(title, { body: body, tag: 'gc-channel', renotify: true, requireInteraction: mentionsMe });
      n.onclick = function() { window.focus(); n.close(); };
      setTimeout(function() { try { n.close(); } catch (e) {} }, mentionsMe ? 15000 : 8000);
    } catch (e) {}
  }
  // Ask for notification permission on any user interaction with the panel
  document.addEventListener('click', function _gcAsk(e) {
    var t = e.target;
    if (t.closest && (t.closest('#gcPanel') || t.closest('#gcHandle'))) {
      _gcRequestNotifPerm();
      document.removeEventListener('click', _gcAsk);
    }
  });

  var _gcLoadingMore = false;
  var _gcHasMore = true;
  window.loadGcMessages = function(beforeId) {
    var url = _gcBaseUrl + '/messages' + (beforeId ? '?before=' + beforeId : '');
    $.get(url, function(res) {
      if (!res.success) return;
      if (!beforeId) { _gcHasMore = true; }
      renderGcMessages(res.data.messages, !!beforeId);
    });
  };
  function _gcLoadMore() {
    if (_gcLoadingMore || !_gcHasMore) return;
    var container = document.getElementById('gcMessages');
    if (!container) return;
    var first = container.querySelector('[data-gc-msg-id]');
    if (!first) return;
    var oldestId = parseInt(first.getAttribute('data-gc-msg-id'), 10);
    if (!oldestId) return;
    _gcLoadingMore = true;
    var prevHeight = container.scrollHeight;
    var loader = document.createElement('div');
    loader.className = 'text-center text-muted py-2 small gc-loading-more';
    loader.innerHTML = '<span class="gc-upload-spinner"></span> Loading...';
    container.insertAdjacentElement('afterbegin', loader);
    $.get(_gcBaseUrl + '/messages?before=' + oldestId, function(res) {
      loader.remove();
      if (!res.success) { _gcLoadingMore = false; return; }
      var msgs = res.data.messages || [];
      if (!msgs.length) { _gcHasMore = false; _gcLoadingMore = false; return; }
      renderGcMessages(msgs, true);
      container.scrollTop = container.scrollHeight - prevHeight;
      _gcLoadingMore = false;
    }).fail(function() { loader.remove(); _gcLoadingMore = false; });
  }

  var GC_IMAGE_EXTS = ['jpg','jpeg','png','gif','webp','bmp','svg'];
  function gcFileIconMeta(ext) {
    var map = {
      pdf:{i:'bi-file-earmark-pdf-fill',c:'#ef4444'},
      doc:{i:'bi-file-earmark-word-fill',c:'#2b7bf0'}, docx:{i:'bi-file-earmark-word-fill',c:'#2b7bf0'},
      xls:{i:'bi-file-earmark-excel-fill',c:'#16a34a'}, xlsx:{i:'bi-file-earmark-excel-fill',c:'#16a34a'}, csv:{i:'bi-file-earmark-spreadsheet-fill',c:'#16a34a'},
      ppt:{i:'bi-file-earmark-ppt-fill',c:'#f97316'}, pptx:{i:'bi-file-earmark-ppt-fill',c:'#f97316'},
      zip:{i:'bi-file-earmark-zip-fill',c:'#eab308'}, rar:{i:'bi-file-earmark-zip-fill',c:'#eab308'}, '7z':{i:'bi-file-earmark-zip-fill',c:'#eab308'},
      txt:{i:'bi-file-earmark-text-fill',c:'#9ca3af'},
      mp3:{i:'bi-file-earmark-music-fill',c:'#a855f7'}, wav:{i:'bi-file-earmark-music-fill',c:'#a855f7'},
      mp4:{i:'bi-file-earmark-play-fill',c:'#ec4899'}, mov:{i:'bi-file-earmark-play-fill',c:'#ec4899'}, webm:{i:'bi-file-earmark-play-fill',c:'#ec4899'},
      js:{i:'bi-file-earmark-code-fill',c:'#f0db4f'}, json:{i:'bi-file-earmark-code-fill',c:'#f0db4f'}, html:{i:'bi-file-earmark-code-fill',c:'#e34c26'}, css:{i:'bi-file-earmark-code-fill',c:'#2965f1'}
    };
    return map[ext] || {i:'bi-file-earmark-fill',c:'#94a3b8'};
  }
  function gcRenderFile(attachment, msgId) {
    var fname = attachment.file_name;
    var ext = fname.split('.').pop().toLowerCase();
    var url = _gcBaseUrl + '/attachment/' + msgId;
    if (GC_IMAGE_EXTS.indexOf(ext) !== -1) {
      return '<a href="' + url + '" target="_blank" class="msg-image-link"><img src="' + url + '" class="msg-image-preview" alt="' + fname + '" loading="lazy" style="max-width:180px;border-radius:6px;"></a>';
    }
    var short = fname.length > 20 ? fname.substring(0, 17) + '...' : fname;
    var size = attachment.file_size ? (attachment.file_size < 1048576 ? (attachment.file_size/1024).toFixed(1)+' KB' : (attachment.file_size/1048576).toFixed(1)+' MB') : '';
    var meta = gcFileIconMeta(ext);
    return '<a class="msg-file" href="' + url + '" target="_blank"><i class="bi ' + meta.i + '" style="color:' + meta.c + ';font-size:1.4rem;"></i><div><span class="msg-file-name">' + short + '</span>' + (size ? '<span class="msg-file-size">' + size + '</span>' : '') + '</div></a>';
  }

  function gcDateLabel(dateStr) {
    var d = new Date(dateStr);
    var today = new Date();
    var yesterday = new Date(today);
    yesterday.setDate(yesterday.getDate() - 1);
    if (d.toDateString() === today.toDateString()) return 'Today';
    if (d.toDateString() === yesterday.toDateString()) return 'Yesterday';
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function renderGcMessages(messages, prepend) {
    var container = document.getElementById('gcMessages');
    if (!messages.length && !prepend) {
      container.innerHTML = '<div class="text-center text-muted py-3 small">No messages yet. Start the conversation!</div>';
      return;
    }
    var lastDate = '';
    var lastReadId = _gcGetLastRead();
    var unreadInserted = false;
    var html = messages.map(function(m) {
      var msgDate = gcDateLabel(m.created_at);
      var dateDivider = '';
      if (msgDate !== lastDate) {
        dateDivider = '<div class="msg-date-divider"><span>' + msgDate + '</span></div>';
        lastDate = msgDate;
      }
      var isSent = m.sender_id === _gcUserId;
      var unreadDivider = '';
      if (!unreadInserted && !isSent && m.id > lastReadId && lastReadId > 0) {
        unreadDivider = _gcUnreadDividerHtml();
        unreadInserted = true;
      }
      var cls = isSent ? 'sent' : 'received';
      var time = new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      var content = '';
      if (m.is_deleted) {
        content = '<em class="text-muted" style="font-size:0.75rem"><i class="bi bi-ban me-1"></i>deleted</em>';
      } else if (m.type === 'file' && m.attachment) {
        content = gcRenderFile(m.attachment, m.id);
      } else {
        content = gcRenderWithMentions(m.content);
      }
      _gcMsgRaw[m.id] = m.content;
      var deleteBtn = isSent && !m.is_deleted ? _gcDeleteBtnHtmlShifted(m) : '';
      var editBtn = _gcEditBtnHtml(m);
      var replyBtn = _gcReplyBtnHtml(m, isSent);
      var reactBtn = _gcReactBtnHtml(m);
      var pinBtn = _gcPinBtnHtml(m);
      var pinInd = _gcPinIndicatorHtml(m);
      var replyQuote = _gcReplyQuoteHtml(m);
      var reactions = _gcRenderReactions(m);
      var senderName = !isSent ? '<div class="gc-msg-sender">' + _escHtmlGc(m.sender_name) + '</div>' : '';
      var editedLabel = m.edited_at ? '<span class="gc-edited-label">(edited)</span>' : '';
      return dateDivider + unreadDivider + '<div class="msg-bubble ' + cls + (m.is_deleted ? ' deleted' : '') + (m.is_pinned ? ' pinned' : '') + '" data-gc-msg-id="' + m.id + '">' + pinInd + deleteBtn + editBtn + pinBtn + replyBtn + reactBtn + senderName + replyQuote + '<div class="msg-content">' + content + '</div>' + reactions + '<div class="msg-footer"><span class="msg-time">' + time + '</span>' + editedLabel + '</div></div>';
    }).join('');
    if (prepend) {
      container.insertAdjacentHTML('afterbegin', html);
    } else {
      container.innerHTML = html;
      // If unread divider is present, scroll to it; else scroll to bottom
      var div = container.querySelector('[data-gc-unread-divider]');
      if (div) { div.scrollIntoView({ block: 'center' }); }
      else { container.scrollTop = container.scrollHeight; }
      _gcUpdateScrollBtn();
    }
    // Fetch link previews for text messages
    messages.forEach(function(m) {
      if (m.type === 'text' && m.content && !m.is_deleted) {
        var b = container.querySelector('[data-gc-msg-id="' + m.id + '"]');
        if (b) _gcFetchAndRenderPreview(b, m.content);
      }
    });
  }

  window.sendGcMessage = function() {
    var input = document.getElementById('gcInput');
    var content = input.value.trim();
    if (!content) return;
    var payload = { content: content };
    if (_gcReplyingTo) payload.reply_to_id = _gcReplyingTo.id;
    $.ajax({
      url: _gcBaseUrl + '/messages',
      method: 'POST',
      contentType: 'application/json',
      data: JSON.stringify(payload),
      success: function() { input.value = ''; input.style.height = 'auto'; cancelGcReply(); }
    });
  };

  function showGcUploadPlaceholderLocal(filename) {
    var container = document.getElementById('gcMessages');
    if (!container) return null;
    if (container.querySelector('.text-center')) container.innerHTML = '';
    var id = 'gc-upload-' + Date.now();
    var html = '<div class="msg-bubble sent gc-uploading" id="' + id + '">' +
      '<div class="msg-content"><span class="gc-upload-spinner"></span><i class="bi bi-paperclip me-1"></i><span class="gc-upload-name">' + _escHtmlGc(filename) + '</span></div>' +
      '<div class="msg-footer"><span class="msg-time">Uploading…</span></div>' +
      '</div>';
    container.insertAdjacentHTML('beforeend', html);
    container.scrollTop = container.scrollHeight;
    return id;
  }
  function markGcUploadFailedLocal(id, reason) {
    var el = document.getElementById(id);
    if (!el) return;
    el.classList.add('gc-upload-failed');
    var footer = el.querySelector('.msg-time');
    if (footer) footer.innerHTML = '<i class="bi bi-exclamation-circle me-1"></i>' + _escHtmlGc(reason || 'Upload failed');
    var spinner = el.querySelector('.gc-upload-spinner');
    if (spinner) spinner.remove();
  }

  window.sendGcFile = function() {
    var fileInput = document.getElementById('gcFileInput');
    if (!fileInput.files.length) return;
    var file = fileInput.files[0];
    if (file.size > 5 * 1024 * 1024) {
      alert('File too large. Max 5 MB.');
      fileInput.value = '';
      return;
    }
    var placeholderId = showGcUploadPlaceholderLocal(file.name);
    var fd = new FormData();
    fd.append('file', file);
    if (_gcReplyingTo) fd.append('reply_to_id', _gcReplyingTo.id);
    fileInput.value = '';
    $.ajax({
      url: _gcBaseUrl + '/file',
      method: 'POST',
      data: fd,
      processData: false,
      contentType: false,
      success: function() {
        var el = document.getElementById(placeholderId);
        if (el) el.remove();
        cancelGcReply();
      },
      error: function(xhr) {
        var msg = (xhr.responseJSON && xhr.responseJSON.message) || 'Upload failed';
        markGcUploadFailedLocal(placeholderId, msg);
      }
    });
  };

  window.deleteGcMsg = function(msgId) {
    if (!confirm('Delete this message?')) return;
    $.ajax({ url: _gcBaseUrl + '/messages/' + msgId, method: 'DELETE' });
  };

  // Enter to send (and mention-navigation takes precedence)
  document.getElementById('gcInput')?.addEventListener('keydown', function(e) {
    if (_gcMentionKeyHandler(e)) return;
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendGcMessage(); }
  });
  document.getElementById('gcInput')?.addEventListener('input', _gcMentionInputHandler);
  document.getElementById('gcInput')?.addEventListener('blur', function() { setTimeout(_gcHideMention, 150); });

  // Paste screenshot/image directly
  function uploadGcFileDirectLocal(file) {
    if (file.size > 5 * 1024 * 1024) { alert('File too large. Max 5 MB.'); return; }
    var placeholderId = showGcUploadPlaceholderLocal(file.name || 'pasted-image.png');
    var fd = new FormData();
    fd.append('file', file, file.name || ('pasted-' + Date.now() + '.png'));
    if (_gcReplyingTo) fd.append('reply_to_id', _gcReplyingTo.id);
    $.ajax({
      url: _gcBaseUrl + '/file', method: 'POST', data: fd, processData: false, contentType: false,
      success: function() { var el = document.getElementById(placeholderId); if (el) el.remove(); cancelGcReply(); },
      error: function(xhr) {
        var msg = (xhr.responseJSON && xhr.responseJSON.message) || 'Upload failed';
        markGcUploadFailedLocal(placeholderId, msg);
      }
    });
  }
  document.getElementById('gcInput')?.addEventListener('paste', function(e) {
    var items = (e.clipboardData || window.clipboardData)?.items;
    if (!items) return;
    for (var i = 0; i < items.length; i++) {
      if (items[i].kind === 'file') {
        var file = items[i].getAsFile();
        if (file) { e.preventDefault(); uploadGcFileDirectLocal(file); return; }
      }
    }
  });

  function playGcAlert() {
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      var now = ctx.currentTime;
      [784, 1046].forEach(function(freq, i) {
        var o = ctx.createOscillator(); var g = ctx.createGain();
        o.type = 'sine'; o.frequency.value = freq;
        o.connect(g); g.connect(ctx.destination);
        var t = now + i * 0.08;
        g.gain.setValueAtTime(0, t);
        g.gain.linearRampToValueAtTime(0.12, t + 0.02);
        g.gain.exponentialRampToValueAtTime(0.001, t + 0.22);
        o.start(t); o.stop(t + 0.25);
      });
    } catch (e) {}
  }

  if (_gcSocket) {
    // Socket: real-time messages
    _gcSocket.on('channel:message', function(msg) {
      var isFromOther = msg.sender_id !== _gcUserId;
      if (isFromOther) playGcAlert();
      // Browser notification (collapsed or background tab)
      _gcShowNotif(msg);
      if (_gcCollapsed) {
        if (isFromOther) {
          _gcUnread++;
          var badge = document.getElementById('gcHandleBadge');
          badge.textContent = _gcUnread;
          badge.style.display = '';
        }
      } else {
        var container = document.getElementById('gcMessages');
        if (container.querySelector('.text-center')) container.innerHTML = '';
        var wasAtBottom = _gcIsAtBottom(container);
        var isSent = msg.sender_id === _gcUserId;
        var cls = isSent ? 'sent' : 'received';
        var time = new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        var content = '';
        if (msg.type === 'file' && msg.attachment) {
          content = gcRenderFile(msg.attachment, msg.id);
        } else {
          content = gcRenderWithMentions(msg.content);
        }
        _gcMsgRaw[msg.id] = msg.content;
        var deleteBtn = isSent ? _gcDeleteBtnHtmlShifted(msg) : '';
        var editBtn = _gcEditBtnHtml(msg);
        var replyBtn = _gcReplyBtnHtml(msg, isSent);
        var reactBtn = _gcReactBtnHtml(msg);
        var replyQuote = _gcReplyQuoteHtml(msg);
        var senderName = !isSent ? '<div class="gc-msg-sender">' + _escHtmlGc(msg.sender_name) + '</div>' : '';
        // Insert unread divider before this msg if not already present, scrolled-up, and from someone else
        if (isFromOther && !wasAtBottom && !container.querySelector('[data-gc-unread-divider]')) {
          container.insertAdjacentHTML('beforeend', _gcUnreadDividerHtml());
        }
        container.insertAdjacentHTML('beforeend', '<div class="msg-bubble ' + cls + '" data-gc-msg-id="' + msg.id + '">' + deleteBtn + editBtn + replyBtn + reactBtn + senderName + replyQuote + '<div class="msg-content">' + content + '</div><div class="msg-footer"><span class="msg-time">' + time + '</span></div></div>');
        if (msg.type === 'text' && msg.content) {
          var newBubble = container.querySelector('[data-gc-msg-id="' + msg.id + '"]');
          if (newBubble) _gcFetchAndRenderPreview(newBubble, msg.content);
        }
        if (isFromOther && _gcMentionsMe(msg.content)) {
          var bubble = container.querySelector('[data-gc-msg-id="' + msg.id + '"]');
          if (bubble) bubble.classList.add('gc-msg-mention-me');
        }
        if (wasAtBottom && !document.hidden) {
          container.scrollTop = container.scrollHeight;
          _gcSetLastRead(msg.id);
        } else if (isFromOther) {
          _gcBumpScrollBadge();
        }
        _gcUpdateScrollBtn();
      }
    });

    _gcSocket.on('channel:message:pin', function(data) {
      // Update bubble's pinned state
      var bubble = document.querySelector('[data-gc-msg-id="' + data.message.id + '"]');
      if (bubble) {
        bubble.classList.toggle('pinned', !!data.pinned);
        var existingInd = bubble.querySelector('.gc-pin-indicator');
        if (data.pinned && !existingInd) {
          bubble.insertAdjacentHTML('afterbegin', '<span class="gc-pin-indicator" title="Pinned"><i class="bi bi-pin-angle-fill"></i></span>');
        } else if (!data.pinned && existingInd) {
          existingInd.remove();
        }
        var pinBtn = bubble.querySelector('.gc-msg-pin');
        if (pinBtn) {
          pinBtn.classList.toggle('pinned', !!data.pinned);
          pinBtn.title = data.pinned ? 'Unpin' : 'Pin';
        }
      }
      // Refresh pinned bar
      loadGcPinned();
    });

    _gcSocket.on('channel:message:edit', function(msg) {
      var bubble = document.querySelector('[data-gc-msg-id="' + msg.id + '"]');
      if (!bubble) return;
      _gcMsgRaw[msg.id] = msg.content;
      var contentEl = bubble.querySelector('.msg-content');
      if (contentEl) contentEl.innerHTML = gcRenderWithMentions(msg.content);
      var footer = bubble.querySelector('.msg-footer');
      if (footer && !footer.querySelector('.gc-edited-label')) {
        footer.insertAdjacentHTML('beforeend', '<span class="gc-edited-label">(edited)</span>');
      }
    });

    _gcSocket.on('channel:reaction', function(data) {
      var bubble = document.querySelector('[data-gc-msg-id="' + data.message_id + '"]');
      if (!bubble) return;
      var block = bubble.querySelector('.gc-reactions');
      if (block) block.remove();
      var fakeMsg = { id: data.message_id, reactions: data.reactions || [] };
      var newHtml = _gcRenderReactions(fakeMsg);
      if (newHtml) {
        var content = bubble.querySelector('.msg-content');
        if (content) content.insertAdjacentHTML('afterend', newHtml);
      }
    });

    _gcSocket.on('channel:message:delete', function(data) {
      var bubble = document.querySelector('[data-gc-msg-id="' + data.id + '"]');
      if (bubble) {
        bubble.classList.add('deleted');
        var c = bubble.querySelector('.msg-content');
        if (c) c.innerHTML = '<em class="text-muted" style="font-size:0.75rem"><i class="bi bi-ban me-1"></i>deleted</em>';
        var d = bubble.querySelector('.gc-msg-delete');
        if (d) d.remove();
      }
    });

    // Typing indicators
    var _gcTypingTimer = null;
    var _gcRemoteTypingTimer = null;
    document.getElementById('gcInput')?.addEventListener('input', function() {
      _gcSocket.emit('channel:typing');
      clearTimeout(_gcTypingTimer);
      _gcTypingTimer = setTimeout(function() {
        _gcSocket.emit('channel:typing:stop');
      }, 2000);
    });
    _gcSocket.on('channel:typing', function(data) {
      if (data.user_id === _gcUserId) return;
      var bar = document.getElementById('gcTypingBar');
      if (bar) { bar.innerHTML = '<span class="bridge-typing"><span class="typing-dots"><span></span><span></span><span></span></span></span>'; bar.style.display = ''; }
      clearTimeout(_gcRemoteTypingTimer);
      _gcRemoteTypingTimer = setTimeout(function() {
        if (bar) { bar.style.display = 'none'; bar.innerHTML = ''; }
      }, 3000);
    });
    _gcSocket.on('channel:typing:stop', function(data) {
      if (data.user_id === _gcUserId) return;
      clearTimeout(_gcRemoteTypingTimer);
      var bar = document.getElementById('gcTypingBar');
      if (bar) { bar.style.display = 'none'; bar.innerHTML = ''; }
    });
  }

  // ── Presence strip ──────────────────────────────
  var _gcAllUsers = [];
  function loadGcUsers() {
    $.get(_gcBaseUrl + '/users', function(res) {
      if (!res.success) return;
      _gcAllUsers = res.data.users;
      renderGcPresence();
    });
  }

  function renderGcPresence() {
    var strip = document.getElementById('gcPresenceStrip');
    if (!strip) return;
    var online = _gcAllUsers.filter(function(u) { return u.online; });
    var offlineCount = _gcAllUsers.filter(function(u) {
      return !u.online && u.role_name && u.role_name.indexOf('LOCAL_') === 0;
    }).length;
    var html = online.map(function(u) {
      var initial = u.name.charAt(0).toUpperCase();
      return '<div class="gc-presence-avatar online" title="' + _escHtmlGc(u.name) + '" data-gc-uid="' + u.id + '">' + initial + '<span class="gc-presence-dot"></span></div>';
    }).join('');
    if (offlineCount > 0) html += '<span class="gc-presence-offline">' + offlineCount + ' offline</span>';
    strip.innerHTML = html;
  }

  if (_gcSocket) {
    _gcSocket.on('channel:presence', function(data) {
      _gcAllUsers.forEach(function(u) { if (u.id === data.user_id) u.online = data.online; });
      renderGcPresence();
    });
  }

  // Scroll listener for scroll-to-bottom button + auto-mark-read + load-more
  document.getElementById('gcMessages')?.addEventListener('scroll', function() {
    _gcUpdateScrollBtn();
    if (this.scrollTop < 60) _gcLoadMore();
  });
  // When tab becomes visible while at bottom, mark read
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden && !_gcCollapsed) _gcUpdateScrollBtn();
  });

  // Load on page load
  loadGcMessages();
  loadGcUsers();
  loadGcPinned();
})();
</script>
<% } %>

<%- script %>

<!-- ═══════════════════════════════════════════════════════════
     GLOBAL VOICE CALL SYSTEM  (works on every page)
     ═══════════════════════════════════════════════════════════ -->
<audio id="_callAudio" autoplay playsinline style="display:none;"></audio>

<!-- Outgoing / Calling overlay -->
<div id="_callOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:9000;align-items:center;justify-content:center;flex-direction:column;gap:1.5rem;">
  <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;font-size:1.8rem;animation:_callPulse 1.4s ease-in-out infinite;">
    <i class="bi bi-telephone-fill" style="color:#fff;"></i>
  </div>
  <div style="text-align:center;">
    <div style="font-size:0.75rem;color:rgba(255,255,255,0.5);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;">Calling...</div>
    <div id="_callOverlayName" style="font-size:1.4rem;font-weight:700;color:#fff;"></div>
  </div>
  <button onclick="endCall(true)" style="margin-top:0.5rem;width:60px;height:60px;border-radius:50%;background:#ef4444;border:none;color:#fff;font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(239,68,68,0.5);">
    <i class="bi bi-telephone-x-fill"></i>
  </button>
</div>

<!-- Incoming call overlay -->
<div id="_incomingOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:9000;align-items:center;justify-content:center;flex-direction:column;gap:1.5rem;">
  <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;font-size:1.8rem;animation:_callPulse 1.4s ease-in-out infinite;">
    <i class="bi bi-telephone-inbound-fill" style="color:#fff;"></i>
  </div>
  <div style="text-align:center;">
    <div style="font-size:0.75rem;color:rgba(255,255,255,0.5);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;">Incoming Call</div>
    <div id="_incomingName" style="font-size:1.4rem;font-weight:700;color:#fff;"></div>
  </div>
  <div style="display:flex;gap:2rem;margin-top:0.5rem;">
    <div style="display:flex;flex-direction:column;align-items:center;gap:8px;">
      <button onclick="rejectCall()" style="width:60px;height:60px;border-radius:50%;background:#ef4444;border:none;color:#fff;font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(239,68,68,0.5);"><i class="bi bi-telephone-x-fill"></i></button>
      <span style="font-size:0.65rem;color:rgba(255,255,255,0.5);">Decline</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:8px;">
      <button onclick="acceptCall()" style="width:60px;height:60px;border-radius:50%;background:#10b981;border:none;color:#fff;font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(16,185,129,0.5);"><i class="bi bi-telephone-fill"></i></button>
      <span style="font-size:0.65rem;color:rgba(255,255,255,0.5);">Accept</span>
    </div>
  </div>
</div>

<!-- Active call floating panel -->
<div id="_activePanel" style="display:none;position:fixed;bottom:1.5rem;right:1.5rem;z-index:8900;background:var(--tf-surface);border:1px solid rgba(16,185,129,0.4);border-radius:16px;padding:1rem 1.25rem;min-width:220px;box-shadow:0 8px 32px rgba(0,0,0,0.4);align-items:center;gap:1rem;">
  <div style="width:36px;height:36px;border-radius:50%;background:rgba(16,185,129,0.15);display:flex;align-items:center;justify-content:center;color:#10b981;font-size:1rem;flex-shrink:0;">
    <i class="bi bi-telephone-fill"></i>
  </div>
  <div style="flex:1;min-width:0;">
    <div id="_activeName" style="font-size:0.8rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
    <div id="_callTimerEl" style="font-size:0.7rem;color:#10b981;font-family:monospace;">00:00</div>
  </div>
  <button id="_muteBtn" onclick="toggleMute()" title="Mute" style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:0.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;"><i class="bi bi-mic-fill"></i></button>
  <button onclick="endCall(true)" title="End call" style="width:36px;height:36px;border-radius:50%;background:#ef4444;border:none;color:#fff;font-size:0.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(239,68,68,0.4);"><i class="bi bi-telephone-x-fill"></i></button>
</div>

<style>
@keyframes _callPulse {
  0%,100% { box-shadow:0 0 0 0 rgba(16,185,129,0.5); }
  50%      { box-shadow:0 0 0 16px rgba(16,185,129,0); }
}
</style>

<script>
// ── Urgent Chat (Local team side) ──────────────────────────────────────────────
<% if (typeof user !== 'undefined' && user.role_name && user.role_name.startsWith('LOCAL_')) { %>
(function() {
  var _urgentId = null;
  var _urgentOpen = false;
  var _urgentAccepted = false; // whether current user accepted it
  var _urgentSound = null;

  function playUrgentSound() {
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      var osc = ctx.createOscillator();
      var gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.value = 880; osc.type = 'square';
      gain.gain.value = 0.15;
      osc.start(); osc.stop(ctx.currentTime + 0.15);
      setTimeout(function() {
        var osc2 = ctx.createOscillator();
        var gain2 = ctx.createGain();
        osc2.connect(gain2); gain2.connect(ctx.destination);
        osc2.frequency.value = 1100; osc2.type = 'square';
        gain2.gain.value = 0.15;
        osc2.start(); osc2.stop(ctx.currentTime + 0.15);
      }, 200);
    } catch (_) {}
  }

  function showUrgentBanner(data) {
    _urgentId = data.id;
    var banner = document.getElementById('urgentBanner');
    document.getElementById('urgentBannerFrom').textContent = data.created_by_name;
    document.getElementById('urgentBannerMsg').textContent = data.message.length > 100 ? data.message.substring(0, 100) + '...' : data.message;
    document.getElementById('urgentBannerAcceptBtn').style.display = 'inline-block';
    document.getElementById('urgentBannerAccepted').style.display = 'none';
    document.getElementById('urgentBannerViewBtn').style.display = 'none';
    document.getElementById('urgentBannerDismissBtn').style.display = 'none';
    banner.style.display = 'block';
    banner.className = 'urgent-banner active';
    playUrgentSound();
  }

  window.acceptUrgent = async function() {
    if (!_urgentId) return;
    try {
      var res = await fetch('/urgent/' + _urgentId + '/accept', { method: 'POST' });
      var data = await res.json();
      if (data.success) {
        _urgentAccepted = true;
        showUrgentLocalWidget();
      } else {
        alert(data.message || 'Failed to accept');
      }
    } catch (e) { alert('Network error'); }
  };

  window.viewUrgent = function() {
    showUrgentLocalWidget();
  };

  window.dismissUrgentBanner = function() {
    document.getElementById('urgentBanner').style.display = 'none';
  };

  function showUrgentLocalWidget() {
    _urgentOpen = true;
    document.getElementById('urgentLocalWidget').style.display = 'flex';
    document.getElementById('urgentLocalFab').style.display = 'none';
    document.getElementById('urgentBanner').style.display = 'none';
    loadUrgentLocalMessages();
  }

  window.toggleUrgentLocal = function() {
    if (_urgentOpen) {
      document.getElementById('urgentLocalWidget').style.display = 'none';
      document.getElementById('urgentLocalFab').style.display = 'flex';
      _urgentOpen = false;
    } else {
      document.getElementById('urgentLocalWidget').style.display = 'flex';
      document.getElementById('urgentLocalFab').style.display = 'none';
      _urgentOpen = true;
      loadUrgentLocalMessages();
    }
  };

  function loadUrgentLocalMessages() {
    if (!_urgentId) return;
    fetch('/urgent/' + _urgentId + '/messages').then(function(r) { return r.json(); }).then(function(res) {
      if (!res.success) return;
      var container = document.getElementById('urgentLocalMessages');
      var messages = res.data.messages;
      if (!messages.length) { container.innerHTML = '<div class="text-center text-muted py-3 small">No messages yet</div>'; return; }
      var userId = <%= typeof user !== 'undefined' ? user.id : 0 %>;
      container.innerHTML = messages.map(function(m) {
        if (m.type === 'system') return '<div class="urgent-msg-system">' + _escHtml(m.content) + '</div>';
        var isMine = m.sender_id === userId;
        var cls = isMine ? 'sent' : 'received';
        var time = new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        var content = '';
        if (m.type === 'file' && m.attachment) {
          var _uext = m.attachment.file_name.split('.').pop().toLowerCase();
          var _uImgExts = ['jpg','jpeg','png','gif','webp','bmp','svg'];
          var _uurl = '/urgent/attachment/' + m.id;
          if (_uImgExts.indexOf(_uext) !== -1) {
            content = '<a href="' + _uurl + '" target="_blank" class="msg-image-link"><img src="' + _uurl + '" alt="' + _escHtml(m.attachment.file_name) + '" style="max-width:200px;border-radius:6px;" loading="lazy"></a>';
          } else {
            var _uMap = {pdf:['bi-file-earmark-pdf-fill','#ef4444'],doc:['bi-file-earmark-word-fill','#2b7bf0'],docx:['bi-file-earmark-word-fill','#2b7bf0'],xls:['bi-file-earmark-excel-fill','#16a34a'],xlsx:['bi-file-earmark-excel-fill','#16a34a'],csv:['bi-file-earmark-spreadsheet-fill','#16a34a'],ppt:['bi-file-earmark-ppt-fill','#f97316'],pptx:['bi-file-earmark-ppt-fill','#f97316'],zip:['bi-file-earmark-zip-fill','#eab308'],rar:['bi-file-earmark-zip-fill','#eab308'],'7z':['bi-file-earmark-zip-fill','#eab308'],txt:['bi-file-earmark-text-fill','#9ca3af'],mp3:['bi-file-earmark-music-fill','#a855f7'],mp4:['bi-file-earmark-play-fill','#ec4899']};
            var _uInfo = _uMap[_uext] || ['bi-file-earmark-fill','#94a3b8'];
            content = '<a href="' + _uurl + '" target="_blank" class="urgent-file-link"><i class="bi ' + _uInfo[0] + '" style="color:' + _uInfo[1] + ';font-size:1.3rem;"></i> ' + _escHtml(m.attachment.file_name) + '</a>';
          }
        } else {
          content = _escHtml(m.content);
        }
        return '<div class="urgent-msg ' + cls + '">' +
          (!isMine ? '<div class="urgent-msg-sender">' + _escHtml(m.sender_name) + '</div>' : '') +
          '<div class="urgent-msg-content">' + content + '</div>' +
          '<div class="urgent-msg-time">' + time + '</div></div>';
      }).join('');
      container.scrollTop = container.scrollHeight;
    });
  }

  window.sendUrgentLocalMessage = async function() {
    if (!_urgentId) return;
    var input = document.getElementById('urgentLocalInput');
    var content = input.value.trim();
    if (!content) return;
    input.value = '';
    await fetch('/urgent/' + _urgentId + '/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content: content })
    });
  };

  function showUrgentLocalUploadPlaceholder(filename) {
    var container = document.getElementById('urgentLocalMessages');
    if (!container) return null;
    var id = 'urgent-upload-' + Date.now();
    var html = '<div class="urgent-msg sent" id="' + id + '" style="opacity:0.7">' +
      '<div class="urgent-msg-content"><span class="gc-upload-spinner"></span><i class="bi bi-paperclip me-1"></i>' + _escHtml(filename) + '</div>' +
      '<div class="urgent-msg-time">Uploading…</div></div>';
    container.insertAdjacentHTML('beforeend', html);
    container.scrollTop = container.scrollHeight;
    return id;
  }
  function uploadUrgentLocalFileDirect(file) {
    if (!_urgentId) return;
    if (file.size > 10 * 1024 * 1024) { alert('File too large. Max 10 MB.'); return; }
    var placeholderId = showUrgentLocalUploadPlaceholder(file.name || 'pasted-image.png');
    var fd = new FormData();
    fd.append('file', file, file.name || ('pasted-' + Date.now() + '.png'));
    fetch('/urgent/' + _urgentId + '/file', { method: 'POST', body: fd })
      .then(function(r) {
        var el = document.getElementById(placeholderId);
        if (el) el.remove();
        if (!r.ok) alert('Upload failed');
      })
      .catch(function() {
        var el = document.getElementById(placeholderId);
        if (el) { el.style.opacity = '1'; el.style.background = 'rgba(220,38,38,0.15)'; var t = el.querySelector('.urgent-msg-time'); if (t) t.textContent = 'Upload failed'; }
      });
  }

  window.sendUrgentLocalFile = async function() {
    var fileInput = document.getElementById('urgentLocalFile');
    if (!fileInput.files.length || !_urgentId) return;
    var file = fileInput.files[0];
    fileInput.value = '';
    uploadUrgentLocalFileDirect(file);
  };

  // Paste screenshot in urgent local — attach directly
  (function attachUrgentLocalPaste() {
    var el = document.getElementById('urgentLocalInput');
    if (!el) { setTimeout(attachUrgentLocalPaste, 300); return; }
    el.addEventListener('paste', function(e) {
      var items = (e.clipboardData || window.clipboardData)?.items;
      if (!items || !_urgentId) return;
      for (var i = 0; i < items.length; i++) {
        if (items[i].kind === 'file') {
          var f = items[i].getAsFile();
          if (f) { e.preventDefault(); uploadUrgentLocalFileDirect(f); return; }
        }
      }
    });
  })();

  window.resolveUrgentLocal = async function() {
    if (!_urgentId) return;
    if (!confirm('Resolve this urgent chat?')) return;
    await fetch('/urgent/' + _urgentId + '/resolve', { method: 'POST' });
  };

  var _urgentLocalTypingTimeout = null;
  document.getElementById('urgentLocalInput')?.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendUrgentLocalMessage(); return; }
    if (_urgentId) {
      fetch('/urgent/' + _urgentId + '/typing', { method: 'POST' });
      clearTimeout(_urgentLocalTypingTimeout);
      _urgentLocalTypingTimeout = setTimeout(function() {
        if (_urgentId) fetch('/urgent/' + _urgentId + '/stop-typing', { method: 'POST' });
      }, 2000);
    }
  });

  function _escHtml(s) {
    if (!s) return '';
    var d = document.createElement('div'); d.textContent = s; return d.innerHTML;
  }

  // Socket listeners — own connection for urgent events
  var urgentSocket = io({ withCredentials: true });

  urgentSocket.on('urgent:new', function(data) {
    showUrgentBanner(data);
  });

  urgentSocket.on('urgent:accepted', function(data) {
    if (data.id !== _urgentId) return;
    var userId = <%= typeof user !== 'undefined' ? user.id : 0 %>;
    var banner = document.getElementById('urgentBanner');
    if (data.accepted_by === userId) {
      _urgentAccepted = true;
    } else {
      document.getElementById('urgentBannerAcceptBtn').style.display = 'none';
      document.getElementById('urgentBannerAccepted').style.display = 'inline';
      document.getElementById('urgentBannerAccepted').textContent = 'Accepted by ' + data.accepted_by_name;
      document.getElementById('urgentBannerViewBtn').style.display = 'inline-block';
      document.getElementById('urgentBannerDismissBtn').style.display = 'inline-block';
      banner.className = 'urgent-banner accepted';
    }
    document.getElementById('urgentLocalStatus').textContent = 'Accepted by ' + data.accepted_by_name;
    loadUrgentLocalMessages();
  });

  urgentSocket.on('urgent:message', function(data) {
    if (data.urgent_chat_id === _urgentId) {
      loadUrgentLocalMessages();
      // Play alert sound for messages from client side
      var userId = <%= typeof user !== 'undefined' ? user.id : 0 %>;
      if (data.sender_id !== userId) {
        playUrgentMsgSound();
      }
    }
  });

  urgentSocket.on('urgent:resolved', function(data) {
    if (data.id === _urgentId) {
      _urgentId = null;
      _urgentAccepted = false;
      document.getElementById('urgentBanner').style.display = 'none';
      document.getElementById('urgentLocalWidget').style.display = 'none';
      document.getElementById('urgentLocalFab').style.display = 'none';
      _urgentOpen = false;
      showToast('Urgent chat resolved', 'success');
    }
  });

  // Buzzer — loud alarm + force open chat widget
  // Typing indicators
  var _urgentRemoteTypingTimer = null;
  urgentSocket.on('urgent:typing', function(data) {
    if (data.id !== _urgentId) return;
    var userId = <%= typeof user !== 'undefined' ? user.id : 0 %>;
    if (data.user_id === userId) return;
    var bar = document.getElementById('urgentLocalTypingBar');
    if (!bar) return;
    bar.innerHTML = '<span class="bridge-typing"><span class="typing-dots"><span></span><span></span><span></span></span></span>';
    bar.style.display = '';
    clearTimeout(_urgentRemoteTypingTimer);
    _urgentRemoteTypingTimer = setTimeout(function() {
      bar.style.display = 'none';
      bar.innerHTML = '';
    }, 3000);
  });
  urgentSocket.on('urgent:stop-typing', function(data) {
    if (data.id !== _urgentId) return;
    var userId = <%= typeof user !== 'undefined' ? user.id : 0 %>;
    if (data.user_id === userId) return;
    clearTimeout(_urgentRemoteTypingTimer);
    var bar = document.getElementById('urgentLocalTypingBar');
    if (bar) { bar.style.display = 'none'; bar.innerHTML = ''; }
  });

  urgentSocket.on('urgent:buzz', function(data) {
    if (data.id !== _urgentId) return;
    playBuzzerAlarm();
    // Force open the chat widget if minimized or hidden
    if (!_urgentOpen) {
      if (_urgentAccepted || document.getElementById('urgentLocalFab').style.display !== 'none') {
        // Accepted user or has fab visible — open the widget
        document.getElementById('urgentLocalWidget').style.display = 'flex';
        document.getElementById('urgentLocalFab').style.display = 'none';
        _urgentOpen = true;
        loadUrgentLocalMessages();
      } else {
        // Not accepted yet — show the banner
        showUrgentBanner({ id: _urgentId, created_by_name: data.from, message: 'BUZZER — Needs immediate attention!' });
      }
    }
    // Flash the widget header
    var header = document.getElementById('urgentLocalWidget')?.querySelector('.urgent-local-header');
    if (header) {
      header.classList.add('buzzer-flash');
      setTimeout(function() { header.classList.remove('buzzer-flash'); }, 2000);
    }
    // Also flash the banner if visible
    var banner = document.getElementById('urgentBanner');
    if (banner && banner.style.display !== 'none') {
      banner.classList.add('buzzer-flash');
      setTimeout(function() { banner.classList.remove('buzzer-flash'); }, 2000);
    }
  });

  function playUrgentMsgSound() {
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      var osc = ctx.createOscillator();
      var gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.value = 660;
      osc.type = 'sine';
      gain.gain.setValueAtTime(0.2, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
      osc.start(); osc.stop(ctx.currentTime + 0.3);
    } catch (_) {}
  }

  function playBuzzerAlarm() {
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      // Three loud ascending beeps
      [0, 0.25, 0.5].forEach(function(delay, i) {
        var osc = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.frequency.value = 800 + (i * 200);
        osc.type = 'square';
        gain.gain.setValueAtTime(0.3, ctx.currentTime + delay);
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + delay + 0.2);
        osc.start(ctx.currentTime + delay);
        osc.stop(ctx.currentTime + delay + 0.2);
      });
      // Follow up with a longer alarm tone
      setTimeout(function() {
        var osc2 = ctx.createOscillator();
        var gain2 = ctx.createGain();
        osc2.connect(gain2); gain2.connect(ctx.destination);
        osc2.frequency.value = 1200;
        osc2.type = 'sawtooth';
        gain2.gain.setValueAtTime(0.25, ctx.currentTime);
        gain2.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.8);
        osc2.start(); osc2.stop(ctx.currentTime + 0.8);
      }, 800);
    } catch (_) {}
  }

  // On page load — check for active urgent chat
  fetch('/urgent/active').then(function(r) { return r.json(); }).then(function(res) {
    if (res.success && res.data.chat) {
      var chat = res.data.chat;
      _urgentId = chat.id;
      var userId = <%= typeof user !== 'undefined' ? user.id : 0 %>;
      if (chat.status === 'waiting') {
        showUrgentBanner(chat);
      } else if (chat.status === 'accepted') {
        if (chat.accepted_by === userId) {
          _urgentAccepted = true;
          document.getElementById('urgentLocalFab').style.display = 'flex';
          document.getElementById('urgentLocalStatus').textContent = 'You accepted';
        } else {
          // Show calmer banner
          document.getElementById('urgentBannerFrom').textContent = chat.created_by_name;
          document.getElementById('urgentBannerMsg').textContent = chat.message.length > 100 ? chat.message.substring(0, 100) + '...' : chat.message;
          document.getElementById('urgentBannerAcceptBtn').style.display = 'none';
          document.getElementById('urgentBannerAccepted').style.display = 'inline';
          document.getElementById('urgentBannerAccepted').textContent = 'Accepted by ' + chat.accepted_by_name;
          document.getElementById('urgentBannerViewBtn').style.display = 'inline-block';
          document.getElementById('urgentBannerDismissBtn').style.display = 'inline-block';
          document.getElementById('urgentBanner').style.display = 'block';
          document.getElementById('urgentBanner').className = 'urgent-banner accepted';
          document.getElementById('urgentLocalStatus').textContent = 'Accepted by ' + chat.accepted_by_name;
        }
      }
    }
  }).catch(function(){});
})();
<% } %>
</script>

<script>
// ── Global Voice Call (WebRTC, works on every page) ──────────────────────────
var callSocket = io({ withCredentials: true, forceNew: true, reconnection: true, reconnectionAttempts: Infinity, reconnectionDelay: 1000 });

var _callSocketReady = false;
callSocket.on('connect', function() {
  _callSocketReady = true;
  console.log('[Call] Socket connected, id:', callSocket.id);
});
callSocket.on('connect_error', function(err) {
  _callSocketReady = false;
  console.error('[Call] Socket connection error:', err.message);
});
callSocket.on('disconnect', function(reason) {
  _callSocketReady = false;
  console.warn('[Call] Socket disconnected:', reason);
  // If in a call, clean up
  if (_callState === 'calling' || _callState === 'active') {
    window.endCall(false);
    showToast('Call disconnected — connection lost', 'error');
  }
  if (_callState === 'incoming') {
    _stopRingtone();
    if (window._titleFlashIv) { clearInterval(window._titleFlashIv); document.title = window._origTitle || 'TaskFlow'; }
    document.getElementById('_incomingOverlay').style.display = 'none';
    _callState = 'idle';
  }
});

var _callState = 'idle';   // idle | calling | incoming | active
var _pc        = null;
var _localStream = null;
var _pendingOffer   = null;
var _pendingFromId  = null;
var _callPeerId   = null;
var _callPeerName = null;
var _callConvId   = null;
var _callTimerIv  = null;
var _callSecs     = 0;

var _ICE = { iceServers: [
  { urls: 'stun:stun.l.google.com:19302' },
  { urls: 'stun:stun1.l.google.com:19302' }
]};

// Called from chat page button: startCall(peerId, peerName, convId)
window.startCall = function(peerId, peerName, convId) {
  if (_callState !== 'idle') { showToast('Already in a call', 'error'); return; }
  if (!callSocket.connected) { showToast('Not connected to server — please refresh the page', 'error'); return; }
  _callPeerId = peerId; _callPeerName = peerName; _callConvId = convId;
  _callState = 'calling';
  document.getElementById('_callOverlayName').textContent = peerName;
  document.getElementById('_callOverlay').style.display = 'flex';

  navigator.mediaDevices.getUserMedia({ audio: true, video: false })
    .then(function(stream) {
      _localStream = stream;
      _pc = new RTCPeerConnection(_ICE);
      stream.getTracks().forEach(function(t) { _pc.addTrack(t, stream); });
      _pc.ontrack = function(e) { _attachAudio(e.streams[0]); };
      _pc.onicecandidate = function(e) {
        if (e.candidate) callSocket.emit('call:ice-candidate', { to_user_id: _callPeerId, candidate: e.candidate });
      };
      _pc.oniceconnectionstatechange = function() {
        if (_pc && (_pc.iceConnectionState === 'disconnected' || _pc.iceConnectionState === 'failed')) window.endCall(false);
      };
      return _pc.createOffer();
    })
    .then(function(offer) { return _pc.setLocalDescription(offer).then(function() { return offer; }); })
    .then(function(offer) {
      callSocket.emit('call:offer', { to_user_id: _callPeerId, conversation_id: _callConvId, offer: offer });
    })
    .catch(function(err) {
      _callState = 'idle';
      document.getElementById('_callOverlay').style.display = 'none';
      showToast(err.name === 'NotAllowedError' ? 'Microphone access denied' : 'Could not start call', 'error');
      _callCleanup();
    });
};

window.endCall = function(notifyPeer) {
  if (notifyPeer !== false && _callPeerId) callSocket.emit('call:end', { to_user_id: _callPeerId });
  _callCleanup();
  document.getElementById('_callOverlay').style.display = 'none';
  document.getElementById('_activePanel').style.display = 'none';
  _callState = 'idle';
};

window.acceptCall = function() {
  document.getElementById('_incomingOverlay').style.display = 'none';
  _stopRingtone();
  if (window._titleFlashIv) { clearInterval(window._titleFlashIv); document.title = window._origTitle || 'TaskFlow'; }
  if (!_pendingOffer || !_pendingFromId) return;
  _callState = 'active';

  navigator.mediaDevices.getUserMedia({ audio: true, video: false })
    .then(function(stream) {
      _localStream = stream;
      _pc = new RTCPeerConnection(_ICE);
      stream.getTracks().forEach(function(t) { _pc.addTrack(t, stream); });
      _pc.ontrack = function(e) { _attachAudio(e.streams[0]); };
      _pc.onicecandidate = function(e) {
        if (e.candidate) callSocket.emit('call:ice-candidate', { to_user_id: _pendingFromId, candidate: e.candidate });
      };
      _pc.oniceconnectionstatechange = function() {
        if (_pc && (_pc.iceConnectionState === 'disconnected' || _pc.iceConnectionState === 'failed')) window.endCall(false);
      };
      return _pc.setRemoteDescription(new RTCSessionDescription(_pendingOffer));
    })
    .then(function() { return _pc.createAnswer(); })
    .then(function(answer) { return _pc.setLocalDescription(answer).then(function() { return answer; }); })
    .then(function(answer) {
      callSocket.emit('call:answer', { to_user_id: _pendingFromId, conversation_id: _callConvId, answer: answer });
      _callPeerId = _pendingFromId;
      _callPeerName = document.getElementById('_incomingName').textContent;
      _pendingOffer = null; _pendingFromId = null;
      _showActivePanel(_callPeerName);
    })
    .catch(function(err) {
      _callState = 'idle';
      showToast(err.name === 'NotAllowedError' ? 'Microphone access denied' : 'Could not answer call', 'error');
      _callCleanup();
    });
};

window.rejectCall = function() {
  document.getElementById('_incomingOverlay').style.display = 'none';
  _stopRingtone();
  if (window._titleFlashIv) { clearInterval(window._titleFlashIv); document.title = window._origTitle || 'TaskFlow'; }
  if (_pendingFromId) callSocket.emit('call:reject', { to_user_id: _pendingFromId, conversation_id: _callConvId });
  _pendingOffer = null; _pendingFromId = null;
  _callState = 'idle';
};

window.toggleMute = function() {
  if (!_localStream) return;
  var t = _localStream.getAudioTracks()[0]; if (!t) return;
  t.enabled = !t.enabled;
  var btn = document.getElementById('_muteBtn');
  btn.innerHTML = t.enabled ? '<i class="bi bi-mic-fill"></i>' : '<i class="bi bi-mic-mute-fill"></i>';
  btn.style.background = t.enabled ? 'rgba(255,255,255,0.15)' : 'rgba(239,68,68,0.4)';
};

function _attachAudio(stream) {
  var a = document.getElementById('_callAudio');
  a.srcObject = stream; a.play().catch(function() {});
}

function _showActivePanel(name) {
  document.getElementById('_activeName').textContent = name;
  document.getElementById('_activePanel').style.display = 'flex';
  _callSecs = 0;
  _callTimerIv = setInterval(function() {
    _callSecs++;
    var m = Math.floor(_callSecs / 60), s = _callSecs % 60;
    document.getElementById('_callTimerEl').textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
  }, 1000);
}

function _callCleanup() {
  if (_localStream) { _localStream.getTracks().forEach(function(t) { t.stop(); }); _localStream = null; }
  if (_pc) { _pc.close(); _pc = null; }
  if (_callTimerIv) { clearInterval(_callTimerIv); _callTimerIv = null; }
  var a = document.getElementById('_callAudio'); if (a) a.srcObject = null;
}

// ── Ringtone generator (no external audio file needed) ──
var _ringtoneCtx = null;
var _ringtoneIv = null;
function _startRingtone() {
  try {
    _ringtoneCtx = new (window.AudioContext || window.webkitAudioContext)();
    var playBeep = function() {
      var osc = _ringtoneCtx.createOscillator();
      var gain = _ringtoneCtx.createGain();
      osc.connect(gain);
      gain.connect(_ringtoneCtx.destination);
      osc.type = 'sine';
      osc.frequency.value = 440;
      gain.gain.value = 0.3;
      osc.start();
      gain.gain.exponentialRampToValueAtTime(0.001, _ringtoneCtx.currentTime + 0.3);
      osc.stop(_ringtoneCtx.currentTime + 0.3);
      // Second beep after short gap
      setTimeout(function() {
        if (!_ringtoneCtx) return;
        var osc2 = _ringtoneCtx.createOscillator();
        var gain2 = _ringtoneCtx.createGain();
        osc2.connect(gain2);
        gain2.connect(_ringtoneCtx.destination);
        osc2.type = 'sine';
        osc2.frequency.value = 523;
        gain2.gain.value = 0.3;
        osc2.start();
        gain2.gain.exponentialRampToValueAtTime(0.001, _ringtoneCtx.currentTime + 0.3);
        osc2.stop(_ringtoneCtx.currentTime + 0.3);
      }, 350);
    };
    playBeep();
    _ringtoneIv = setInterval(playBeep, 2000);
  } catch (e) {}
}
function _stopRingtone() {
  if (_ringtoneIv) { clearInterval(_ringtoneIv); _ringtoneIv = null; }
  if (_ringtoneCtx) { _ringtoneCtx.close().catch(function(){}); _ringtoneCtx = null; }
}

// ── Browser notification for incoming calls ──
function _notifyIncomingCall(callerName) {
  if (!('Notification' in window)) return;
  if (Notification.permission === 'granted') {
    var n = new Notification('Incoming Call', { body: callerName + ' is calling you', icon: '/favicon.ico', requireInteraction: true, tag: 'incoming-call' });
    n.onclick = function() { window.focus(); n.close(); };
  } else if (Notification.permission !== 'denied') {
    Notification.requestPermission();
  }
}
function _clearCallNotification() {
  // Close the notification if still showing
  try { if ('Notification' in window) { /* tag-based auto-replaces */ } } catch(e) {}
}

// Request notification permission on page load (silent, no prompt until needed)
if ('Notification' in window && Notification.permission === 'default') {
  // Will prompt on first incoming call
}

// Socket events
callSocket.on('call:incoming', function(data) {
  if (_callState !== 'idle') {
    callSocket.emit('call:reject', { to_user_id: data.from_user_id, conversation_id: data.conversation_id });
    return;
  }
  _callState = 'incoming';
  _callConvId = data.conversation_id;
  _pendingOffer = data.offer;
  _pendingFromId = data.from_user_id;
  document.getElementById('_incomingName').textContent = data.from_user_name;
  document.getElementById('_incomingOverlay').style.display = 'flex';
  _startRingtone();
  _notifyIncomingCall(data.from_user_name);
  // Flash the page title to draw attention
  var _origTitle = document.title;
  var _titleFlash = setInterval(function() {
    document.title = document.title === _origTitle ? '📞 ' + data.from_user_name + ' calling...' : _origTitle;
  }, 1000);
  // Store flash interval to clear on accept/reject
  window._titleFlashIv = _titleFlash;
  window._origTitle = _origTitle;
});

callSocket.on('call:answered', function(data) {
  console.log('[Call] Received call:answered', !!_pc, !!data.answer);
  if (!_pc) return;
  _pc.setRemoteDescription(new RTCSessionDescription(data.answer))
    .then(function() {
      _callState = 'active';
      document.getElementById('_callOverlay').style.display = 'none';
      _showActivePanel(_callPeerName);
    })
    .catch(function(err) { console.error('[Call] setRemoteDescription error:', err); window.endCall(true); });
});

callSocket.on('call:ice-candidate', function(data) {
  if (_pc && data.candidate) _pc.addIceCandidate(new RTCIceCandidate(data.candidate)).catch(function() {});
});

callSocket.on('call:rejected', function() {
  _callState = 'idle';
  document.getElementById('_callOverlay').style.display = 'none';
  showToast('Call was declined', 'error');
  _callCleanup();
});

callSocket.on('call:ended', function() {
  var wasIncoming = _callState === 'incoming';
  _stopRingtone();
  if (window._titleFlashIv) { clearInterval(window._titleFlashIv); document.title = window._origTitle || 'TaskFlow'; }
  document.getElementById('_incomingOverlay').style.display = 'none';
  window.endCall(false);
  if (wasIncoming) showToast('Missed call', 'error');
  else if (_callState !== 'idle') showToast('Call ended', 'success');
});

callSocket.on('call:busy', function() {
  _callState = 'idle';
  document.getElementById('_callOverlay').style.display = 'none';
  showToast('User is busy on another call', 'error');
  _callCleanup();
});
</script>

<% if (typeof user !== 'undefined' && ['LOCAL_ADMIN', 'LOCAL_MANAGER', 'LOCAL_USER'].includes(user.role_name)) { %>
<script>
(function() {
  var _onQueuePage = <%= typeof section !== 'undefined' && section === 'queue' ? 'true' : 'false' %>;
  var _badge = document.getElementById('queueNavBadge');
  var _link  = document.getElementById('queueNavLink');

  function setQueueBadge(n) {
    if (!_badge) return;
    if (n > 0 && !_onQueuePage) {
      var prev = parseInt(_badge.textContent || '0', 10);
      _badge.textContent = n > 99 ? '99+' : String(n);
      _badge.style.display = 'flex';
      if (n > prev) {
        _badge.classList.remove('pop');
        void _badge.offsetWidth;
        _badge.classList.add('pop');
      }
      if (_link) _link.classList.add('nav-queue-alert');
    } else {
      _badge.style.display = 'none';
      if (_link) _link.classList.remove('nav-queue-alert');
    }
  }

  function fetchQueueBadge() {
    $.get('/queue/badge', function(res) {
      if (res && res.success) {
        var n = res.data.count || 0;
        setQueueBadge(n);
        if (n === 0) stopBell();
      }
    });
  }

  // ── persistent AudioContext bell ──────────────────────────────────────────
  var _ctx          = null;
  var _unlocked     = false;
  var _pending      = false;
  var _bellActive   = false;
  var _bellInterval = null;
  var _titleInterval = null;
  var _origTitle    = document.title;

  function unlockAudio() {
    if (_unlocked) return;
    try {
      if (!_ctx) _ctx = new (window.AudioContext || window.webkitAudioContext)();
      var p = _ctx.resume();
      if (p && p.then) {
        p.then(function() {
          var buf = _ctx.createBuffer(1, 1, 22050);
          var src = _ctx.createBufferSource();
          src.buffer = buf; src.connect(_ctx.destination); src.start(0);
          _unlocked = true;
          if (_pending) { _pending = false; playBell(); }
        }).catch(function(){});
      }
    } catch(e) {}
  }

  document.addEventListener('click',   unlockAudio, { once: false });
  document.addEventListener('keydown', unlockAudio, { once: false });

  function playBell() {
    if (!_ctx || _ctx.state !== 'running') { _pending = true; return; }
    try {
      var now = _ctx.currentTime;
      [[659, 0.20], [1318, 0.10], [1975, 0.05]].forEach(function(p) {
        var osc = _ctx.createOscillator(), g = _ctx.createGain();
        osc.type = 'sine'; osc.frequency.value = p[0];
        osc.connect(g); g.connect(_ctx.destination);
        g.gain.setValueAtTime(p[1], now);
        g.gain.exponentialRampToValueAtTime(0.001, now + 2.0);
        osc.start(now); osc.stop(now + 2.1);
      });
    } catch(e) {}
  }

  function startTitleBlink() {
    if (_titleInterval) return;
    _origTitle = document.title;
    var show = true;
    _titleInterval = setInterval(function() {
      document.title = show ? '(!) New Request' : _origTitle;
      show = !show;
    }, 1000);
  }

  function stopTitleBlink() {
    if (_titleInterval) { clearInterval(_titleInterval); _titleInterval = null; }
    document.title = _origTitle;
  }

  function startBell() {
    if (_bellActive) return;
    _bellActive = true;
    unlockAudio();
    startTitleBlink();
    playBell();
    _bellInterval = setInterval(function() {
      if (!_bellActive) { clearInterval(_bellInterval); _bellInterval = null; return; }
      playBell();
    }, 4000);
  }

  function stopBell() {
    _bellActive = false;
    _pending    = false;
    if (_bellInterval) { clearInterval(_bellInterval); _bellInterval = null; }
    stopTitleBlink();
  }

  document.addEventListener('visibilitychange', function() {
    if (!document.hidden && _onQueuePage) stopBell();
  });
  window.addEventListener('focus', function() {
    if (_onQueuePage) stopBell();
  });

  if (_onQueuePage) stopBell();
  // ─────────────────────────────────────────────────────────────────────────

  fetchQueueBadge();

  var _qSock = typeof io !== 'undefined' ? io('/', { withCredentials: true }) : null;
  if (_qSock) {
    _qSock.on('queue:new_request', function() {
      fetchQueueBadge();
      if (!_onQueuePage) startBell();
    });
    _qSock.on('queue:updated', function() { fetchQueueBadge(); });
  }
})();
</script>
<% } %>

</body>
</html>
