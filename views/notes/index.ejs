<!-- Header Actions -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <form method="GET" action="/notes" class="d-flex gap-2">
    <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search notes..." class="tf-form-control" style="max-width:250px;">
    <button type="submit" class="btn-tf btn-tf-outline">Search</button>
    <% if (filters.search) { %>
    <a href="/notes" class="btn-tf btn-tf-outline" style="color:var(--tf-text-muted);border-color:var(--tf-border);">Clear</a>
    <% } %>
  </form>
  <button class="btn-tf btn-tf-primary" onclick="openCreateModal()">
    <i class="bi bi-plus-circle me-1"></i> New Note
  </button>
</div>

<!-- Notes List -->
<div class="tf-card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-journal-text me-2"></i>MY NOTES (<%= pagination.total %>)</span>
    <% if (notes.length > 0) { %>
    <div class="d-flex gap-1">
      <button id="btnCardView" onclick="setView('card')" class="btn-tf" style="font-size:0.7rem;padding:3px 8px;background:transparent;border:1px solid var(--tf-border);color:var(--tf-text-muted);" title="Card view">
        <i class="bi bi-grid-3x2-gap"></i>
      </button>
      <button id="btnTableView" onclick="setView('table')" class="btn-tf" style="font-size:0.7rem;padding:3px 8px;background:transparent;border:1px solid var(--tf-border);color:var(--tf-text-muted);" title="Table view">
        <i class="bi bi-list-ul"></i>
      </button>
    </div>
    <% } %>
  </div>

  <% if (notes.length > 0) { %>
  <!-- Card View -->
  <div id="notesCardView" style="padding:1rem;">
    <div class="row g-3">
      <% notes.forEach(note => { %>
      <div class="col-md-6 col-lg-4">
        <div style="background:var(--tf-surface-2);border:1px solid var(--tf-border);border-radius:8px;padding:1rem;height:100%;display:flex;flex-direction:column;">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 style="font-size:0.9rem;font-weight:600;margin:0;color:var(--tf-text);word-break:break-word;flex:1;"><%= note.title %></h6>
            <div class="d-flex gap-1 ms-2" style="flex-shrink:0;">
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:#a78bfa;border:1px solid rgba(167,139,250,0.3);"
                onclick="readNote(<%= note.id %>)" title="Read aloud"><i class="bi bi-volume-up"></i></button>
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:#00d4ff;border:1px solid rgba(0,212,255,0.3);"
                onclick="openEditModal(<%= note.id %>)">Edit</button>
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:#ef4444;border:1px solid rgba(239,68,68,0.3);"
                onclick="deleteNote(<%= note.id %>)">Delete</button>
            </div>
          </div>
          <% if (note.content) { %>
          <p style="font-size:0.8rem;color:var(--tf-text-muted);margin:0 0 0.75rem 0;flex:1;word-break:break-word;white-space:pre-line;overflow:hidden;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;"><%= note.content %></p>
          <% } else { %>
          <p style="font-size:0.8rem;color:var(--tf-text-muted);font-style:italic;margin:0 0 0.75rem 0;flex:1;">No content</p>
          <% } %>
          <div style="font-size:0.65rem;color:var(--tf-text-muted);font-family:var(--tf-font-mono);margin-top:auto;">
            <% if (new Date(note.updated_at).getTime() !== new Date(note.created_at).getTime()) { %>
              Updated <%= new Date(note.updated_at).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
            <% } else { %>
              Created <%= new Date(note.created_at).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Table View -->
  <div id="notesTableView" style="display:none;overflow-x:auto;">
    <table class="tf-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Title</th>
          <th>Content</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% notes.forEach(note => { %>
        <tr>
          <td style="font-family:var(--tf-font-mono);font-size:0.75rem;color:var(--tf-text-muted);">#<%= note.id %></td>
          <td style="font-weight:500;"><%= note.title %></td>
          <td style="font-size:0.8rem;color:var(--tf-text-muted);max-width:300px;">
            <% if (note.content) { %>
            <span style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;"><%= note.content %></span>
            <% } else { %>
            <span style="font-style:italic;">No content</span>
            <% } %>
          </td>
          <td style="font-size:0.75rem;color:var(--tf-text-muted);white-space:nowrap;">
            <% if (new Date(note.updated_at).getTime() !== new Date(note.created_at).getTime()) { %>
              Updated <%= new Date(note.updated_at).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
            <% } else { %>
              <%= new Date(note.created_at).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
            <% } %>
          </td>
          <td>
            <div class="d-flex gap-1">
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:#a78bfa;border:1px solid rgba(167,139,250,0.3);"
                onclick="readNote(<%= note.id %>)" title="Read aloud"><i class="bi bi-volume-up"></i></button>
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:#00d4ff;border:1px solid rgba(0,212,255,0.3);"
                onclick="openEditModal(<%= note.id %>)">Edit</button>
              <button class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:#ef4444;border:1px solid rgba(239,68,68,0.3);"
                onclick="deleteNote(<%= note.id %>)">Delete</button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div style="text-align:center;padding:3rem;color:var(--tf-text-muted);">
    <i class="bi bi-journal-text" style="font-size:2.5rem;opacity:0.3;display:block;margin-bottom:0.75rem;"></i>
    <p style="font-size:0.9rem;margin:0;">No notes yet. Click "New Note" to create your first one.</p>
  </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (pagination.totalPages > 1) { %>
<div class="d-flex justify-content-center mt-3 gap-2">
  <% if (pagination.hasPrev) { %>
  <a href="/notes?page=<%= pagination.page - 1 %><%= filters.search ? '&search=' + encodeURIComponent(filters.search) : '' %>" class="btn-tf btn-tf-outline" style="font-size:0.75rem;">← Prev</a>
  <% } %>
  <span style="font-family:var(--tf-font-mono);font-size:0.75rem;color:var(--tf-text-muted);align-self:center;">
    Page <%= pagination.page %> of <%= pagination.totalPages %>
  </span>
  <% if (pagination.hasNext) { %>
  <a href="/notes?page=<%= pagination.page + 1 %><%= filters.search ? '&search=' + encodeURIComponent(filters.search) : '' %>" class="btn-tf btn-tf-outline" style="font-size:0.75rem;">Next →</a>
  <% } %>
</div>
<% } %>

<!-- Create/Edit Modal -->
<div id="noteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:200;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:var(--tf-surface);border:1px solid var(--tf-border);border-radius:12px;padding:1.5rem;width:100%;max-width:550px;max-height:90vh;overflow-y:auto;">
    <h6 style="font-family:var(--tf-font-mono);margin-bottom:1.25rem;" id="noteModalTitle">NEW NOTE</h6>

    <input type="hidden" id="editNoteId">

    <div class="row g-3">
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center" style="margin-bottom:0.3rem;">
          <label style="font-size:0.7rem;color:var(--tf-text-muted);">TITLE *</label>
          <button type="button" id="voiceTitleBtn" onclick="toggleVoiceInput('title')" class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:var(--tf-text-muted);border:1px solid var(--tf-border);" title="Voice input for title">
            <i class="bi bi-mic" id="voiceTitleIcon"></i> <span id="voiceTitleLabel">Dictate</span>
          </button>
        </div>
        <input type="text" id="nTitle" class="tf-form-control" placeholder="Note title">
      </div>
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center" style="margin-bottom:0.3rem;">
          <label style="font-size:0.7rem;color:var(--tf-text-muted);">CONTENT</label>
          <button type="button" id="voiceContentBtn" onclick="toggleVoiceInput('content')" class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:var(--tf-text-muted);border:1px solid var(--tf-border);" title="Voice input for content">
            <i class="bi bi-mic" id="voiceContentIcon"></i> <span id="voiceContentLabel">Dictate</span>
          </button>
        </div>
        <textarea id="nContent" class="tf-form-control" rows="8" placeholder="Write your note here or use voice input..." style="resize:vertical;min-height:120px;"></textarea>
      </div>
    </div>

    <div class="d-flex gap-2 mt-4 justify-content-end">
      <button class="btn-tf btn-tf-outline" onclick="closeNoteModal()">Cancel</button>
      <button class="btn-tf btn-tf-primary" onclick="submitNote()" id="noteModalSubmitBtn">CREATE</button>
    </div>
  </div>
</div>

<script>
function setView(mode) {
  var card = document.getElementById('notesCardView');
  var table = document.getElementById('notesTableView');
  var btnCard = document.getElementById('btnCardView');
  var btnTable = document.getElementById('btnTableView');
  if (!card || !table) return;
  if (mode === 'table') {
    card.style.display = 'none';
    table.style.display = 'block';
    btnCard.style.color = 'var(--tf-text-muted)';
    btnCard.style.borderColor = 'var(--tf-border)';
    btnTable.style.color = '#00d4ff';
    btnTable.style.borderColor = '#00d4ff';
  } else {
    card.style.display = 'block';
    table.style.display = 'none';
    btnCard.style.color = '#00d4ff';
    btnCard.style.borderColor = '#00d4ff';
    btnTable.style.color = 'var(--tf-text-muted)';
    btnTable.style.borderColor = 'var(--tf-border)';
  }
  localStorage.setItem('tf-notes-view', mode);
}
// Restore saved preference
(function() {
  var saved = localStorage.getItem('tf-notes-view');
  if (saved) setView(saved); else setView('card');
})();

var notesData = {};
<% notes.forEach(note => { %>
notesData[<%= note.id %>] = { id: <%= note.id %>, title: <%- JSON.stringify(note.title) %>, content: <%- JSON.stringify(note.content || '') %> };
<% }) %>

function openCreateModal() {
  document.getElementById('noteModalTitle').textContent = 'NEW NOTE';
  document.getElementById('editNoteId').value = '';
  document.getElementById('nTitle').value = '';
  document.getElementById('nContent').value = '';
  document.getElementById('noteModalSubmitBtn').textContent = 'CREATE';
  document.getElementById('noteModal').style.display = 'flex';
}
function openEditModal(id) {
  var note = notesData[id];
  if (!note) return;
  document.getElementById('noteModalTitle').textContent = 'EDIT NOTE';
  document.getElementById('editNoteId').value = note.id;
  document.getElementById('nTitle').value = note.title;
  document.getElementById('nContent').value = note.content || '';
  document.getElementById('noteModalSubmitBtn').textContent = 'UPDATE';
  document.getElementById('noteModal').style.display = 'flex';
}
function closeNoteModal() {
  document.getElementById('noteModal').style.display = 'none';
}
async function submitNote() {
  const id = document.getElementById('editNoteId').value;
  const data = {
    title: document.getElementById('nTitle').value,
    content: document.getElementById('nContent').value
  };
  if (!data.title.trim()) {
    return showToast('Title is required', 'error');
  }
  try {
    if (id) {
      await axios.put('/notes/' + id, data);
      showToast('Note updated');
    } else {
      await axios.post('/notes', data);
      showToast('Note created');
    }
    closeNoteModal();
    setTimeout(() => location.reload(), 800);
  } catch (e) {
    showToast(e.response?.data?.message || 'Error saving note', 'error');
  }
}
async function deleteNote(id) {
  if (!confirm('Delete this note? This cannot be undone.')) return;
  try {
    await axios.delete('/notes/' + id);
    showToast('Note deleted');
    setTimeout(() => location.reload(), 800);
  } catch (e) {
    showToast(e.response?.data?.message || 'Error deleting note', 'error');
  }
}

// Voice Input (Speech-to-Text)
var recognition = null;
var activeVoiceField = null; // 'title' or 'content'

function toggleVoiceInput(field) {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    return showToast('Voice input is not supported in this browser', 'error');
  }

  // If already recording this field, stop it
  if (recognition && activeVoiceField === field) {
    stopVoice();
    return;
  }

  // If recording a different field, stop that first
  if (recognition) stopVoice();

  var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SpeechRecognition();
  recognition.continuous = field === 'content';
  recognition.interimResults = true;
  recognition.lang = 'en-US';
  activeVoiceField = field;

  var input = document.getElementById(field === 'title' ? 'nTitle' : 'nContent');
  var existingText = input.value;

  recognition.onresult = function(e) {
    var interim = '';
    var final = '';
    for (var i = e.resultIndex; i < e.results.length; i++) {
      if (e.results[i].isFinal) {
        final += e.results[i][0].transcript;
      } else {
        interim += e.results[i][0].transcript;
      }
    }
    if (final) {
      existingText += (existingText ? ' ' : '') + final;
      input.value = existingText;
    }
    if (interim) {
      input.value = existingText + (existingText ? ' ' : '') + interim;
    }
  };

  recognition.onerror = function(e) {
    if (e.error !== 'aborted') showToast('Voice error: ' + e.error, 'error');
    stopVoice();
  };

  recognition.onend = function() {
    if (recognition && activeVoiceField === field) {
      if (field === 'content') {
        try { recognition.start(); } catch(e) { stopVoice(); }
      } else {
        stopVoice();
      }
    }
  };

  recognition.start();
  setVoiceBtnState(field, true);
  showToast('Listening... speak now', 'info');
}

function stopVoice() {
  var field = activeVoiceField;
  if (recognition) {
    activeVoiceField = null;
    try { recognition.stop(); } catch(e) {}
    recognition = null;
  }
  if (field) setVoiceBtnState(field, false);
}

function setVoiceBtnState(field, active) {
  var prefix = field === 'title' ? 'voiceTitle' : 'voiceContent';
  var icon = document.getElementById(prefix + 'Icon');
  var label = document.getElementById(prefix + 'Label');
  var btn = document.getElementById(prefix + 'Btn');
  if (!icon || !btn) return;
  if (active) {
    icon.className = 'bi bi-mic-fill';
    label.textContent = 'Stop';
    btn.style.color = '#ef4444';
    btn.style.borderColor = '#ef4444';
  } else {
    icon.className = 'bi bi-mic';
    label.textContent = 'Dictate';
    btn.style.color = 'var(--tf-text-muted)';
    btn.style.borderColor = 'var(--tf-border)';
  }
}

// Read Aloud (Text-to-Speech)
var currentReadingId = null;

function readNote(id) {
  if (!('speechSynthesis' in window)) {
    return showToast('Text-to-speech is not supported in this browser', 'error');
  }

  // If already reading this note, stop it
  if (window.speechSynthesis.speaking && currentReadingId === id) {
    window.speechSynthesis.cancel();
    currentReadingId = null;
    showToast('Stopped reading', 'info');
    return;
  }

  // Stop any other speech and start this one
  window.speechSynthesis.cancel();

  var note = notesData[id];
  if (!note) return;

  var text = note.title + '. ' + (note.content || 'No content');
  var utterance = new SpeechSynthesisUtterance(text);
  utterance.rate = 1;
  utterance.pitch = 1;
  currentReadingId = id;

  utterance.onend = function() { currentReadingId = null; };
  utterance.onerror = function() { currentReadingId = null; };

  showToast('Reading note... click speaker again to stop', 'info');
  window.speechSynthesis.speak(utterance);
}
</script>
