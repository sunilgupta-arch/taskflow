<!-- Reports Hub -->
<div class="tf-card mb-4">
  <div class="card-header"><i class="bi bi-speedometer2 me-2"></i>REPORTS CENTER</div>
  <div class="p-3">
    <p style="font-size:0.85rem;color:var(--tf-text-muted);margin-bottom:0;">Monitor team performance, attendance, and productivity from a single place.</p>
  </div>
</div>

<div class="row g-3">
  <!-- Task Completion Calendar -->
  <div class="col-md-6 col-lg-4">
    <a href="/reports/task-completion" class="text-decoration-none">
      <div class="tf-card h-100" style="transition:border-color 0.2s;cursor:pointer;" onmouseover="this.style.borderColor='var(--tf-accent)'" onmouseout="this.style.borderColor='var(--tf-border)'">
        <div class="p-3 text-center">
          <div style="width:48px;height:48px;border-radius:12px;background:rgba(16,185,129,0.12);display:inline-flex;align-items:center;justify-content:center;margin-bottom:0.75rem;">
            <i class="bi bi-clipboard-data" style="font-size:1.3rem;color:#10b981;"></i>
          </div>
          <h6 style="font-family:var(--tf-font-mono);font-size:0.8rem;font-weight:700;color:var(--tf-text);margin-bottom:0.4rem;">Task Completion</h6>
          <p style="font-size:0.7rem;color:var(--tf-text-muted);margin:0;">Daily task completion grid per employee with monthly calendar view</p>
        </div>
      </div>
    </a>
  </div>

  <!-- Completion Stats -->
  <div class="col-md-6 col-lg-4">
    <a href="/reports/completion" class="text-decoration-none">
      <div class="tf-card h-100" style="transition:border-color 0.2s;cursor:pointer;" onmouseover="this.style.borderColor='var(--tf-accent)'" onmouseout="this.style.borderColor='var(--tf-border)'">
        <div class="p-3 text-center">
          <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,212,255,0.12);display:inline-flex;align-items:center;justify-content:center;margin-bottom:0.75rem;">
            <i class="bi bi-graph-up" style="font-size:1.3rem;color:#00d4ff;"></i>
          </div>
          <h6 style="font-family:var(--tf-font-mono);font-size:0.8rem;font-weight:700;color:var(--tf-text);margin-bottom:0.4rem;">Completion Stats</h6>
          <p style="font-size:0.7rem;color:var(--tf-text-muted);margin:0;">Overall completion rates, monthly trends, and per-user breakdown</p>
        </div>
      </div>
    </a>
  </div>

  <!-- Rewards -->
  <div class="col-md-6 col-lg-4">
    <a href="/reports/rewards" class="text-decoration-none">
