          <p style="font-size:0.7rem;color:var(--tf-text-muted);margin:0;">Late one-time tasks and missed recurring tasks by employee</p>
        </div>
      </div>
    </a>
  </div>

  <!-- Punctuality (NEW) -->
  <div class="col-md-6 col-lg-4">
    <a href="/reports/punctuality" class="text-decoration-none">
      <div class="tf-card h-100" style="transition:border-color 0.2s;cursor:pointer;" onmouseover="this.style.borderColor='var(--tf-accent)'" onmouseout="this.style.borderColor='var(--tf-border)'">
        <div class="p-3 text-center">
          <div style="width:48px;height:48px;border-radius:12px;background:rgba(59,130,246,0.12);display:inline-flex;align-items:center;justify-content:center;margin-bottom:0.75rem;">
