  <div class="col-md-6 col-lg-4">
    <a href="/reports/workload" class="text-decoration-none">
      <div class="tf-card h-100" style="transition:border-color 0.2s;cursor:pointer;" onmouseover="this.style.borderColor='var(--tf-accent)'" onmouseout="this.style.borderColor='var(--tf-border)'">
        <div class="p-3 text-center">
          <div style="width:48px;height:48px;border-radius:12px;background:rgba(249,115,22,0.12);display:inline-flex;align-items:center;justify-content:center;margin-bottom:0.75rem;">
            <i class="bi bi-pie-chart" style="font-size:1.3rem;color:#f97316;"></i>
