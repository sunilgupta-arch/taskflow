<script>
(function() {
  var topbar = document.getElementById('topbar');
  if (topbar) {
    document.documentElement.style.setProperty('--topbar-h', topbar.offsetHeight + 'px');
  }
})();
</script>
<!-- Tab Navigation -->
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div class="d-flex align-items-center gap-3">
    <h5 style="font-family:var(--tf-font-mono);font-weight:700;margin:0;display:flex;align-items:center;gap:0.75rem;">
      <span><i class="bi bi-kanban me-2" style="color:var(--tf-accent);"></i>Task Board</span>
      <a href="/dashboard/overview" style="font-size:0.6rem;color:var(--tf-text-muted);text-decoration:none;border:1px solid var(--tf-border);padding:2px 8px;border-radius:4px;font-weight:500;" title="View Dashboard"><i class="bi bi-grid-1x2 me-1"></i>Dashboard</a>
    </h5>
    <div class="d-flex" style="border:1px solid var(--tf-border);border-radius:8px;overflow:hidden;">
      <a href="/tasks/board?tab=today&date=<%= selectedDate %>"
         style="padding:6px 16px;font-size:0.75rem;font-family:var(--tf-font-mono);font-weight:700;text-decoration:none;letter-spacing:0.5px;
                <%= tab === 'today' ? 'background:var(--tf-accent);color:#000;' : 'background:transparent;color:var(--tf-text-muted);' %>">
        TODAY
      </a>
      <a href="/tasks/board?tab=all"
         style="padding:6px 16px;font-size:0.75rem;font-family:var(--tf-font-mono);font-weight:700;text-decoration:none;letter-spacing:0.5px;
                <%= tab === 'all' ? 'background:var(--tf-accent);color:#000;' : 'background:transparent;color:var(--tf-text-muted);' %>">
        ALL TASKS
      </a>
    </div>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <% if (tab === 'today') { %>
    <form method="GET" action="/tasks/board" class="d-flex gap-2 align-items-center" style="margin:0;">
      <input type="hidden" name="tab" value="today">
      <input type="date" name="date" value="<%= selectedDate %>" class="tf-form-control" style="max-width:160px;" onchange="this.form.submit()">
    </form>
    <% } %>
    <% if (['CLIENT_ADMIN','CLIENT_MANAGER','LOCAL_ADMIN','LOCAL_MANAGER'].includes(user.role_name)) { %>
    <a href="/tasks/create" class="btn-tf btn-tf-primary text-decoration-none" style="font-size:0.75rem;padding:6px 14px;white-space:nowrap;">
      <i class="bi bi-plus-lg me-1"></i>New Task
    </a>
    <% } %>
  </div>
</div>

<% if (tab === 'today') { %>
<%
  var _today = new Date(); _today.setHours(12,0,0,0);
  var _sel = new Date(selectedDate + 'T12:00:00');
  var _isPast = _sel < _today;
  var _notDoneLabel = _isPast ? 'Not Done' : 'Not Started';
  var _notDoneBg = _isPast ? 'rgba(239,68,68,0.15)' : 'rgba(245,158,11,0.15)';
  var _notDoneColor = _isPast ? '#ef4444' : '#f59e0b';
%>
<!-- ═══════════════════════════════════════════════
