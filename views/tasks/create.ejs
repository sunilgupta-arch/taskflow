<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="tf-card">
      <div class="card-header"><i class="bi bi-plus-circle me-2"></i>CREATE NEW TASK</div>
      <div class="p-4">
        <div id="formError" class="tf-alert" style="display:none;border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.1);color:#fca5a5;margin-bottom:1rem;"></div>

        <form id="createTaskForm">
          <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom:0.4rem;">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">TITLE *</label>
              <button type="button" id="voiceTitleBtn" onclick="toggleVoiceInput('title')" class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:var(--tf-text-muted);border:1px solid var(--tf-border);" title="Voice input for title">
                <i class="bi bi-mic" id="voiceTitleIcon"></i> <span id="voiceTitleLabel">Dictate</span>
              </button>
            </div>
            <input type="text" id="taskTitle" name="title" class="tf-form-control" placeholder="Task title" required maxlength="255">
          </div>

          <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom:0.4rem;">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">DESCRIPTION</label>
              <button type="button" id="voiceDescBtn" onclick="toggleVoiceInput('desc')" class="btn-tf" style="font-size:0.65rem;padding:2px 8px;background:transparent;color:var(--tf-text-muted);border:1px solid var(--tf-border);" title="Voice input for description">
                <i class="bi bi-mic" id="voiceDescIcon"></i> <span id="voiceDescLabel">Dictate</span>
              </button>
            </div>
            <textarea id="taskDesc" name="description" class="tf-form-control" rows="4" placeholder="Task description or use voice input..." style="resize:vertical;"></textarea>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">TYPE *</label>
              <select name="type" id="taskType" class="tf-select" required>
                <option value="once">One Time</option>
                <option value="recurring">Recurring</option>
              </select>
            </div>
            <div class="col-md-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">PRIORITY *</label>
              <select name="priority" class="tf-select" required>
                <option value="low">Low</option>
                <option value="medium" selected>Medium</option>
                <option value="high">High</option>
                <option value="urgent">Urgent</option>
              </select>
            </div>
            <div class="col-md-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">DUE DATE</label>
              <input type="date" name="due_date" class="tf-form-control">
            </div>
            <% if (role !== 'LOCAL_USER') { %>
            <div class="col-md-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">REWARD (PTS)</label>
              <input type="number" name="reward_amount" class="tf-form-control" placeholder="0" min="0" step="1">
            </div>
            <% } %>
          </div>

          <!-- Recurrence Options (shown only when type=recurring) -->
          <div id="recurrenceOptions" style="display:none;" class="mb-3">
            <div class="row g-3">
              <div class="col-md-4">
                <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">PATTERN *</label>
                <select name="recurrence_pattern" id="recurrencePattern" class="tf-select">
                  <option value="daily">Every Day</option>
                  <option value="weekly" selected>Specific Days of Week</option>
                  <option value="monthly">Specific Dates of Month</option>
                </select>
              </div>
              <div class="col-md-4">
                <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">DEADLINE TIME</label>
                <input type="time" name="deadline_time" class="tf-form-control">
              </div>
              <div class="col-md-4">
                <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">END DATE (OPTIONAL)</label>
                <input type="date" name="recurrence_end_date" class="tf-form-control">
              </div>
            </div>

            <!-- Weekly: Day of week checkboxes -->
            <div id="weeklyDays" class="mt-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">SELECT DAYS *</label>
              <div class="d-flex flex-wrap gap-2">
                <% const days = [{v:0,l:'Sun'},{v:1,l:'Mon'},{v:2,l:'Tue'},{v:3,l:'Wed'},{v:4,l:'Thu'},{v:5,l:'Fri'},{v:6,l:'Sat'}]; %>
                <% days.forEach(d => { %>
                <label style="cursor:pointer;padding:6px 14px;border:1px solid var(--tf-border);border-radius:6px;font-size:0.8rem;color:var(--tf-text);transition:all 0.2s;" class="day-check-label">
                  <input type="checkbox" class="weekday-cb" value="<%= d.v %>" style="display:none;">
                  <%= d.l %>
                </label>
                <% }) %>
              </div>
            </div>

            <!-- Monthly: Date picker -->
            <div id="monthlyDates" style="display:none;" class="mt-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">SELECT DATES *</label>
              <div class="d-flex flex-wrap gap-1">
                <% for (let i = 1; i <= 31; i++) { %>
                <label style="cursor:pointer;width:36px;height:36px;display:flex;align-items:center;justify-content:center;border:1px solid var(--tf-border);border-radius:6px;font-size:0.75rem;color:var(--tf-text);transition:all 0.2s;" class="date-check-label">
                  <input type="checkbox" class="monthdate-cb" value="<%= i %>" style="display:none;">
                  <%= i %>
                </label>
                <% } %>
              </div>
            </div>

            <input type="hidden" name="recurrence_days" id="recurrenceDaysInput">
          </div>

          <% if (role !== 'LOCAL_USER') { %>
          <div class="mb-4">
            <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">ASSIGN TO (OPTIONAL)</label>
            <select name="assigned_to" id="assignToSelect" class="tf-select" multiple size="4" style="min-height:80px;">
              <% ourUsers.forEach(u => { %>
              <option value="<%= u.id %>" <%= String(u.id) === String(assignTo) ? 'selected' : '' %>><%= u.name %></option>
              <% }) %>
            </select>
            <div style="font-size:0.7rem;color:var(--tf-text-muted);margin-top:4px;">
              Hold Ctrl/Cmd to select multiple. Leave empty for unassigned (team can pick)
            </div>
          </div>

          <!-- Fallback Assignees (mutually exclusive with multi-assign) -->
          <div id="fallbackSection" class="mb-4">
            <div style="font-size:0.7rem;color:var(--tf-text-muted);margin-bottom:0.5rem;padding:6px 10px;background:rgba(0,212,255,0.05);border-radius:6px;border:1px solid rgba(0,212,255,0.15);">
              <i class="bi bi-info-circle me-1" style="color:var(--tf-accent);"></i>
              Fallback assignees take over if the primary is on leave. <strong>Not available with multi-assign.</strong>
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">SECONDARY (BACKUP 1)</label>
                <select name="secondary_assignee" id="secondaryAssignee" class="tf-select">
                  <option value="">— None —</option>
                  <% ourUsers.forEach(u => { %>
                  <option value="<%= u.id %>"><%= u.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">TERTIARY (BACKUP 2)</label>
                <select name="tertiary_assignee" id="tertiaryAssignee" class="tf-select">
                  <option value="">— None —</option>
                  <% ourUsers.forEach(u => { %>
                  <option value="<%= u.id %>"><%= u.name %></option>
                  <% }) %>
                </select>
              </div>
            </div>
          </div>
          <% } else { %>
          <div class="mb-4">
            <div class="tf-alert" style="border-color:rgba(124,58,237,0.3);background:rgba(124,58,237,0.1);color:#a78bfa;">
              <i class="bi bi-info-circle me-1"></i> This task will be auto-assigned to you.
            </div>
          </div>
          <% } %>

          <% if (['LOCAL_ADMIN', 'LOCAL_MANAGER'].includes(role)) { %>
          <div class="mb-4">
            <label class="d-flex align-items-center gap-2" style="cursor:pointer;">
              <input type="checkbox" name="client_visible" value="1" style="accent-color:var(--tf-accent);width:16px;height:16px;">
              <span style="font-size:0.8rem;color:var(--tf-text);">
                <i class="bi bi-eye me-1" style="color:#00d4ff;"></i> Visible to Client Team
              </span>
            </label>
            <div style="font-size:0.7rem;color:var(--tf-text-muted);margin-top:4px;margin-left:24px;">
              When enabled, this task will also appear in the client admin/manager dashboard
            </div>
          </div>
          <% } %>

          <div class="d-flex gap-2">
            <a href="/tasks" class="btn-tf btn-tf-outline text-decoration-none">Cancel</a>
            <button type="submit" class="btn-tf btn-tf-primary flex-grow-1" id="submitBtn">
              CREATE TASK
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
const typeSelect = document.getElementById('taskType');
const dueDateInput = document.querySelector('input[name="due_date"]');
const recurrenceOptions = document.getElementById('recurrenceOptions');
const recurrencePattern = document.getElementById('recurrencePattern');
const weeklyDays = document.getElementById('weeklyDays');
const monthlyDates = document.getElementById('monthlyDates');
const recurrenceDaysInput = document.getElementById('recurrenceDaysInput');

function handleTypeChange() {
  const isRecurring = typeSelect.value === 'recurring';
  recurrenceOptions.style.display = isRecurring ? 'block' : 'none';
  if (!isRecurring) {
    dueDateInput.readOnly = false;
    dueDateInput.style.opacity = '1';
  }
  handlePatternChange();
}

function handlePatternChange() {
  const pattern = recurrencePattern.value;
  weeklyDays.style.display = pattern === 'weekly' ? 'block' : 'none';
  monthlyDates.style.display = pattern === 'monthly' ? 'block' : 'none';
}

function updateRecurrenceDays() {
  const pattern = recurrencePattern.value;
  let selected = [];
  if (pattern === 'weekly') {
    selected = [...document.querySelectorAll('.weekday-cb:checked')].map(cb => cb.value);
  } else if (pattern === 'monthly') {
    selected = [...document.querySelectorAll('.monthdate-cb:checked')].map(cb => cb.value);
  }
  recurrenceDaysInput.value = selected.join(',');
}

// Toggle visual state for day/date checkboxes
document.querySelectorAll('.day-check-label, .date-check-label').forEach(label => {
  const cb = label.querySelector('input[type="checkbox"]');
  cb.addEventListener('change', () => {
    if (cb.checked) {
      label.style.background = 'rgba(0,212,255,0.15)';
      label.style.borderColor = '#00d4ff';
      label.style.color = '#00d4ff';
    } else {
      label.style.background = 'transparent';
      label.style.borderColor = 'var(--tf-border)';
      label.style.color = 'var(--tf-text)';
    }
    updateRecurrenceDays();
  });
  label.addEventListener('click', (e) => {
    if (e.target !== cb) { cb.checked = !cb.checked; cb.dispatchEvent(new Event('change')); e.preventDefault(); }
  });
});

typeSelect.addEventListener('change', handleTypeChange);
recurrencePattern.addEventListener('change', () => { handlePatternChange(); updateRecurrenceDays(); });
handleTypeChange();

// Mutual exclusion: multi-assign vs fallback assignees
var assignToSelect = document.getElementById('assignToSelect');
var fallbackSection = document.getElementById('fallbackSection');
var secondaryAssignee = document.getElementById('secondaryAssignee');
var tertiaryAssignee = document.getElementById('tertiaryAssignee');

if (assignToSelect && fallbackSection) {
  function updateFallbackState() {
    var selectedCount = assignToSelect.selectedOptions.length;
    var hasFallback = (secondaryAssignee && secondaryAssignee.value) || (tertiaryAssignee && tertiaryAssignee.value);
    if (selectedCount > 1) {
      // Multi-assign active: disable fallback
      fallbackSection.style.opacity = '0.4';
      fallbackSection.style.pointerEvents = 'none';
      secondaryAssignee.value = '';
      tertiaryAssignee.value = '';
    } else {
      fallbackSection.style.opacity = '1';
      fallbackSection.style.pointerEvents = 'auto';
    }
    // If fallback selected, limit multi-select to 1
    if (hasFallback && selectedCount > 1) {
      // Keep only the first selection
      Array.from(assignToSelect.options).forEach((opt, i) => { if (i > 0 || !opt.selected) opt.selected = false; });
    }
  }

  function updateMultiAssignState() {
    var hasFallback = (secondaryAssignee && secondaryAssignee.value) || (tertiaryAssignee && tertiaryAssignee.value);
    if (hasFallback) {
      // Disable multi-select (allow only single)
      assignToSelect.size = 4;
      // Deselect all but the first selected
      var foundFirst = false;
      Array.from(assignToSelect.options).forEach(opt => {
        if (opt.selected && !foundFirst) { foundFirst = true; }
        else if (opt.selected) { opt.selected = false; }
      });
    }
  }

  assignToSelect.addEventListener('change', updateFallbackState);
  if (secondaryAssignee) secondaryAssignee.addEventListener('change', function() { updateMultiAssignState(); updateFallbackState(); });
  if (tertiaryAssignee) tertiaryAssignee.addEventListener('change', function() { updateMultiAssignState(); updateFallbackState(); });
  updateFallbackState();
}

document.getElementById('createTaskForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('submitBtn');
  const errDiv = document.getElementById('formError');

  // Validate recurrence days if recurring
  if (typeSelect.value === 'recurring' && recurrencePattern.value !== 'daily') {
    updateRecurrenceDays();
    if (!recurrenceDaysInput.value) {
      errDiv.textContent = recurrencePattern.value === 'weekly' ? 'Please select at least one day of the week' : 'Please select at least one date of the month';
      errDiv.style.display = 'block';
      return;
    }
  }

  btn.disabled = true;
  btn.textContent = 'CREATING...';
  errDiv.style.display = 'none';

  const formData = {};
  new FormData(e.target).forEach((v, k) => {
    if (!v) return;
    if (k === 'assigned_to') {
      if (!formData.assigned_to) formData.assigned_to = [];
      formData.assigned_to.push(v);
    } else {
      formData[k] = v;
    }
  });

  // Clean up: don't send recurrence fields for one-time tasks
  if (formData.type === 'once') {
    delete formData.recurrence_pattern;
    delete formData.recurrence_days;
    delete formData.deadline_time;
    delete formData.recurrence_end_date;
  }

  try {
    const res = await axios.post('/tasks/create', formData);
    if (res.data.success) {
      showToast('Task created successfully!');
      setTimeout(() => window.location.href = '/tasks', 800);
    }
  } catch (err) {
    errDiv.textContent = err.response?.data?.message || 'Failed to create task';
    errDiv.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'CREATE TASK';
  }
});

// Voice Input (Speech-to-Text)
var recognition = null;
var activeVoiceField = null; // 'title' or 'desc'

function toggleVoiceInput(field) {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    return showToast('Voice input is not supported in this browser', 'error');
  }

  // If already recording this field, stop it
  if (recognition && activeVoiceField === field) {
    stopVoice();
    return;
  }

  // If recording a different field, stop that first
  if (recognition) stopVoice();

  var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SpeechRecognition();
  recognition.continuous = field === 'desc';
  recognition.interimResults = true;
  recognition.lang = 'en-US';
  activeVoiceField = field;

  var input = document.getElementById(field === 'title' ? 'taskTitle' : 'taskDesc');
  var existingText = input.value;

  recognition.onresult = function(e) {
    var interim = '';
    var final = '';
    for (var i = e.resultIndex; i < e.results.length; i++) {
      if (e.results[i].isFinal) {
        final += e.results[i][0].transcript;
      } else {
        interim += e.results[i][0].transcript;
      }
    }
    if (final) {
      existingText += (existingText ? ' ' : '') + final;
      input.value = existingText;
    }
    if (interim) {
      input.value = existingText + (existingText ? ' ' : '') + interim;
    }
  };

  recognition.onerror = function(e) {
    if (e.error !== 'aborted') showToast('Voice error: ' + e.error, 'error');
    stopVoice();
  };

  recognition.onend = function() {
    if (recognition && activeVoiceField === field) {
      if (field === 'desc') {
        try { recognition.start(); } catch(e) { stopVoice(); }
      } else {
        stopVoice();
      }
    }
  };

  recognition.start();
  setVoiceBtnState(field, true);
  showToast('Listening... speak now', 'info');
}

function stopVoice() {
  var field = activeVoiceField;
  if (recognition) {
    activeVoiceField = null;
    try { recognition.stop(); } catch(e) {}
    recognition = null;
  }
  if (field) setVoiceBtnState(field, false);
}

function setVoiceBtnState(field, active) {
  var prefix = field === 'title' ? 'voiceTitle' : 'voiceDesc';
  var icon = document.getElementById(prefix + 'Icon');
  var label = document.getElementById(prefix + 'Label');
  var btn = document.getElementById(prefix + 'Btn');
  if (!icon || !btn) return;
  if (active) {
    icon.className = 'bi bi-mic-fill';
    label.textContent = 'Stop';
    btn.style.color = '#ef4444';
    btn.style.borderColor = '#ef4444';
  } else {
    icon.className = 'bi bi-mic';
    label.textContent = 'Dictate';
    btn.style.color = 'var(--tf-text-muted)';
    btn.style.borderColor = 'var(--tf-border)';
  }
}
</script>
