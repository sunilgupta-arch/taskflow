<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="tf-card">
      <div class="card-header"><i class="bi bi-pencil-square me-2"></i>EDIT TASK #<%= task.id %></div>
      <div class="p-4">
        <div id="formError" class="tf-alert" style="display:none;border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.1);color:#fca5a5;margin-bottom:1rem;"></div>

        <form id="editTaskForm">
          <div class="mb-3">
            <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">TITLE *</label>
            <input type="text" id="taskTitle" name="title" class="tf-form-control" value="<%= task.title %>" required maxlength="255">
          </div>

          <div class="mb-3">
            <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">DESCRIPTION</label>
            <textarea id="taskDesc" name="description" class="tf-form-control" rows="4" style="resize:vertical;"><%= task.description || '' %></textarea>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">TYPE *</label>
              <select name="type" id="taskType" class="tf-select" required>
                <option value="once" <%= task.type === 'once' ? 'selected' : '' %>>One Time</option>
                <option value="recurring" <%= task.type === 'recurring' ? 'selected' : '' %>>Recurring</option>
              </select>
            </div>
            <div class="col-md-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">PRIORITY *</label>
              <select name="priority" class="tf-select" required>
                <option value="low" <%= task.priority === 'low' ? 'selected' : '' %>>Low</option>
                <option value="medium" <%= (task.priority === 'medium' || !task.priority) ? 'selected' : '' %>>Medium</option>
                <option value="high" <%= task.priority === 'high' ? 'selected' : '' %>>High</option>
                <option value="urgent" <%= task.priority === 'urgent' ? 'selected' : '' %>>Urgent</option>
              </select>
            </div>
            <div class="col-md-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">DUE DATE</label>
              <input type="date" name="due_date" class="tf-form-control" value="<%= task.due_date ? new Date(new Date(task.due_date).toISOString().split('T')[0] + 'T12:00:00').toISOString().split('T')[0] : '' %>">
            </div>
            <div class="col-md-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">REWARD (PTS)</label>
              <input type="number" name="reward_amount" class="tf-form-control" value="<%= task.reward_amount ? parseFloat(task.reward_amount) : '' %>" placeholder="0" min="0" step="1">
            </div>
          </div>

          <!-- Recurrence Options -->
          <div id="recurrenceOptions" style="display:<%= task.type === 'recurring' ? 'block' : 'none' %>;" class="mb-3">
            <div class="row g-3">
              <div class="col-md-4">
                <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">PATTERN *</label>
                <select name="recurrence_pattern" id="recurrencePattern" class="tf-select">
                  <option value="daily" <%= task.recurrence_pattern === 'daily' ? 'selected' : '' %>>Every Day</option>
                  <option value="weekly" <%= (task.recurrence_pattern === 'weekly' || !task.recurrence_pattern) ? 'selected' : '' %>>Specific Days of Week</option>
                  <option value="monthly" <%= task.recurrence_pattern === 'monthly' ? 'selected' : '' %>>Specific Dates of Month</option>
                </select>
              </div>
              <div class="col-md-4">
                <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">DEADLINE TIME</label>
                <input type="time" name="deadline_time" class="tf-form-control" value="<%= task.deadline_time || '' %>">
              </div>
              <div class="col-md-4">
                <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">END DATE (OPTIONAL)</label>
                <input type="date" name="recurrence_end_date" class="tf-form-control" value="<%= task.recurrence_end_date ? new Date(new Date(task.recurrence_end_date).toISOString().split('T')[0] + 'T12:00:00').toISOString().split('T')[0] : '' %>">
              </div>
            </div>

            <!-- Weekly: Day of week checkboxes -->
            <% const currentDays = (task.recurrence_days || '').split(',').map(d => d.trim()); %>
            <div id="weeklyDays" class="mt-3" style="display:<%= task.recurrence_pattern === 'weekly' || (!task.recurrence_pattern && task.type === 'recurring') ? 'block' : 'none' %>;">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">SELECT DAYS *</label>
              <div class="d-flex flex-wrap gap-2">
                <% const days = [{v:0,l:'Sun'},{v:1,l:'Mon'},{v:2,l:'Tue'},{v:3,l:'Wed'},{v:4,l:'Thu'},{v:5,l:'Fri'},{v:6,l:'Sat'}]; %>
                <% days.forEach(d => { const isChecked = task.recurrence_pattern === 'weekly' && currentDays.includes(String(d.v)); %>
                <label style="cursor:pointer;padding:6px 14px;border:1px solid <%= isChecked ? '#00d4ff' : 'var(--tf-border)' %>;border-radius:6px;font-size:0.8rem;color:<%= isChecked ? '#00d4ff' : 'var(--tf-text)' %>;background:<%= isChecked ? 'rgba(0,212,255,0.15)' : 'transparent' %>;transition:all 0.2s;" class="day-check-label">
                  <input type="checkbox" class="weekday-cb" value="<%= d.v %>" <%= isChecked ? 'checked' : '' %> style="display:none;">
                  <%= d.l %>
                </label>
                <% }) %>
              </div>
            </div>

            <!-- Monthly: Date picker -->
            <div id="monthlyDates" style="display:<%= task.recurrence_pattern === 'monthly' ? 'block' : 'none' %>;" class="mt-3">
              <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">SELECT DATES *</label>
              <div class="d-flex flex-wrap gap-1">
                <% for (let i = 1; i <= 31; i++) { const isDateChecked = task.recurrence_pattern === 'monthly' && currentDays.includes(String(i)); %>
                <label style="cursor:pointer;width:36px;height:36px;display:flex;align-items:center;justify-content:center;border:1px solid <%= isDateChecked ? '#00d4ff' : 'var(--tf-border)' %>;border-radius:6px;font-size:0.75rem;color:<%= isDateChecked ? '#00d4ff' : 'var(--tf-text)' %>;background:<%= isDateChecked ? 'rgba(0,212,255,0.15)' : 'transparent' %>;transition:all 0.2s;" class="date-check-label">
                  <input type="checkbox" class="monthdate-cb" value="<%= i %>" <%= isDateChecked ? 'checked' : '' %> style="display:none;">
                  <%= i %>
                </label>
                <% } %>
              </div>
            </div>

            <input type="hidden" name="recurrence_days" id="recurrenceDaysInput" value="<%= task.recurrence_days || '' %>">
          </div>

          <div class="mb-3">
            <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">STATUS</label>
            <div style="font-size:0.85rem;padding:8px 12px;background:var(--tf-surface-2);border-radius:6px;color:var(--tf-text);">
              <span class="badge badge-<%= task.status %>" style="font-size:0.65rem;border-radius:4px;padding:3px 8px;"><%= task.status.replace('_', ' ') %></span>
              <span style="font-size:0.7rem;color:var(--tf-text-muted);margin-left:8px;">Status is managed via task actions (Start, Complete, Deactivate)</span>
            </div>
          </div>

          <div class="mb-3">
            <label style="font-size:0.75rem;color:var(--tf-text-muted);display:block;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.5px;">ASSIGNED TO</label>
            <div style="font-size:0.85rem;padding:8px 12px;background:var(--tf-surface-2);border-radius:6px;color:var(--tf-text);">
              <%= task.assigned_to_name || 'Unassigned' %>
              <span style="font-size:0.7rem;color:var(--tf-text-muted);margin-left:8px;">Use the Assign button on the task list to change assignees</span>
            </div>
          </div>

          <% if (['LOCAL_ADMIN', 'LOCAL_MANAGER'].includes(role)) { %>
          <div class="mb-4">
            <label class="d-flex align-items-center gap-2" style="cursor:pointer;">
              <input type="checkbox" name="client_visible" value="1" <%= task.created_by_org === 'CLIENT' ? 'checked' : '' %> style="accent-color:var(--tf-accent);width:16px;height:16px;">
              <span style="font-size:0.8rem;color:var(--tf-text);">
                <i class="bi bi-eye me-1" style="color:#00d4ff;"></i> Visible to Client Team
              </span>
            </label>
            <div style="font-size:0.7rem;color:var(--tf-text-muted);margin-top:4px;margin-left:24px;">
              When enabled, this task will also appear in the client admin/manager dashboard
            </div>
          </div>
          <% } %>

          <div class="d-flex gap-2">
            <a href="/tasks/<%= task.id %>" class="btn-tf btn-tf-outline text-decoration-none">Cancel</a>
            <button type="submit" class="btn-tf btn-tf-primary flex-grow-1" id="submitBtn">
              SAVE CHANGES
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
const typeSelect = document.getElementById('taskType');
const recurrenceOptions = document.getElementById('recurrenceOptions');
const recurrencePattern = document.getElementById('recurrencePattern');
const weeklyDays = document.getElementById('weeklyDays');
const monthlyDates = document.getElementById('monthlyDates');
const recurrenceDaysInput = document.getElementById('recurrenceDaysInput');

function handleTypeChange() {
  recurrenceOptions.style.display = typeSelect.value === 'recurring' ? 'block' : 'none';
  handlePatternChange();
}

function handlePatternChange() {
  const pattern = recurrencePattern.value;
  weeklyDays.style.display = pattern === 'weekly' ? 'block' : 'none';
  monthlyDates.style.display = pattern === 'monthly' ? 'block' : 'none';
}

function updateRecurrenceDays() {
  const pattern = recurrencePattern.value;
  let selected = [];
  if (pattern === 'weekly') {
    selected = [...document.querySelectorAll('.weekday-cb:checked')].map(cb => cb.value);
  } else if (pattern === 'monthly') {
    selected = [...document.querySelectorAll('.monthdate-cb:checked')].map(cb => cb.value);
  }
  recurrenceDaysInput.value = selected.join(',');
}

document.querySelectorAll('.day-check-label, .date-check-label').forEach(label => {
  const cb = label.querySelector('input[type="checkbox"]');
  cb.addEventListener('change', () => {
    if (cb.checked) {
      label.style.background = 'rgba(0,212,255,0.15)';
      label.style.borderColor = '#00d4ff';
      label.style.color = '#00d4ff';
    } else {
      label.style.background = 'transparent';
      label.style.borderColor = 'var(--tf-border)';
      label.style.color = 'var(--tf-text)';
    }
    updateRecurrenceDays();
  });
  label.addEventListener('click', (e) => {
    if (e.target !== cb) { cb.checked = !cb.checked; cb.dispatchEvent(new Event('change')); e.preventDefault(); }
  });
});

typeSelect.addEventListener('change', handleTypeChange);
recurrencePattern.addEventListener('change', () => { handlePatternChange(); updateRecurrenceDays(); });

document.getElementById('editTaskForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('submitBtn');
  const errDiv = document.getElementById('formError');

  if (typeSelect.value === 'recurring' && recurrencePattern.value !== 'daily') {
    updateRecurrenceDays();
    if (!recurrenceDaysInput.value) {
      errDiv.textContent = recurrencePattern.value === 'weekly' ? 'Please select at least one day of the week' : 'Please select at least one date of the month';
      errDiv.style.display = 'block';
      return;
    }
  }

  btn.disabled = true;
  btn.textContent = 'SAVING...';
  errDiv.style.display = 'none';

  const formData = {};
  new FormData(e.target).forEach((v, k) => {
    formData[k] = v;
  });

  if (formData.type === 'once') {
    delete formData.recurrence_pattern;
    delete formData.recurrence_days;
    delete formData.deadline_time;
    delete formData.recurrence_end_date;
  }

  try {
    const res = await axios.put('/tasks/<%= task.id %>', formData);
    if (res.data.success) {
      showToast('Task updated successfully!');
      setTimeout(() => window.location.href = '/tasks/<%= task.id %>', 800);
    }
  } catch (err) {
    errDiv.textContent = err.response?.data?.message || 'Failed to update task';
    errDiv.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'SAVE CHANGES';
  }
});
</script>
