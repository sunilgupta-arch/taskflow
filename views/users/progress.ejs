<%
const selfView = typeof isSelf !== 'undefined' && isSelf;
const progressUrl = selfView ? '/my-progress' : '/users/' + targetUser.id + '/progress';
const reportUrl = selfView ? '/my-monthly-report' : '/users/' + targetUser.id + '/monthly-report';
const _isPast = typeof isPast !== 'undefined' && isPast;
const _isViewingToday = typeof isViewingToday !== 'undefined' ? isViewingToday : true;
const _dateLabel = _isViewingToday ? 'Today' : new Date(selectedDate + 'T12:00:00Z').toLocaleDateString('en-US', { timeZone: 'UTC', month: 'short', day: 'numeric' });
%>
<!-- User Header -->
<div class="tf-card mb-3">
  <div class="p-3 d-flex align-items-center gap-3 flex-wrap">
    <div class="user-avatar" style="width:48px;height:48px;font-size:1.2rem;"><%= targetUser.name.charAt(0) %></div>
    <div class="flex-grow-1">
      <h5 style="margin:0;font-weight:600;"><%= targetUser.name %></h5>
      <div style="font-size:0.8rem;color:var(--tf-text-muted);"><%= targetUser.email %></div>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <span class="badge" style="font-size:0.65rem;padding:3px 8px;border-radius:4px;
        background:<%= targetUser.org_type === 'CLIENT' ? 'rgba(0,212,255,0.1)' : 'rgba(124,58,237,0.1)' %>;
        color:<%= targetUser.org_type === 'CLIENT' ? '#00d4ff' : '#a78bfa' %>;"><%= targetUser.org_name %></span>
      <span class="badge" style="font-size:0.65rem;padding:3px 8px;border-radius:4px;background:rgba(0,212,255,0.05);color:var(--tf-text-muted);">
        <%= targetUser.role_name %>
      </span>
    </div>
    <% if (!selfView) { %>
    <a href="/tasks/create?assign_to=<%= targetUser.id %>" class="btn-tf text-decoration-none" style="font-size:0.75rem;padding:4px 12px;background:rgba(0,212,255,0.1);color:#00d4ff;border:1px solid rgba(0,212,255,0.3);">
      <i class="bi bi-plus-circle me-1"></i> Create Task
    </a>
    <% } %>
    <button class="btn-tf" style="font-size:0.75rem;padding:4px 12px;background:rgba(124,58,237,0.1);color:#a78bfa;border:1px solid rgba(124,58,237,0.3);"
      onclick="openMonthlyReport()">
      <i class="bi bi-calendar-month me-1"></i> Monthly Report
    </button>
    <a href="/dashboard" class="btn-tf btn-tf-outline text-decoration-none" style="font-size:0.75rem;">
      <i class="bi bi-arrow-left me-1"></i> Back
    </a>
  </div>
</div>

<!-- Date Picker -->
<div class="tf-card mb-3">
  <div class="p-3 d-flex align-items-center gap-3">
    <i class="bi bi-calendar3" style="color:var(--tf-accent);font-size:1.1rem;"></i>
    <span style="font-size:0.8rem;color:var(--tf-text-muted);font-family:var(--tf-font-mono);">DAY REPORT</span>
    <input type="date" id="dateSelect" value="<%= selectedDate %>" class="tf-form-control" style="max-width:180px;font-size:0.85rem;"
      onchange="window.location.href='<%= progressUrl %>?date=' + this.value">
    <% if (selectedDate !== new Date().toISOString().split('T')[0]) { %>
    <a href="<%= progressUrl %>" class="btn-tf btn-tf-outline" style="font-size:0.7rem;padding:3px 10px;">Today</a>
    <% } %>
  </div>
</div>

<!-- Day Tasks -->
<div class="tf-card mb-3">
  <div class="card-header">
    <i class="bi bi-calendar-event me-2" style="color:#06b6d4;"></i>TASKS FOR <%= new Date(selectedDate + 'T12:00:00Z').toLocaleDateString('en-US', { timeZone: 'UTC', weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
    <% if (isWeekOff) { %>
    <span style="font-size:0.7rem;background:rgba(100,116,139,0.15);color:#94a3b8;padding:2px 8px;border-radius:4px;margin-left:8px;">WEEK OFF</span>
    <% } else { %>
    (<%= dayTasks.length %>)
    <% } %>
  </div>
  <% if (isWeekOff) { %>
  <div style="text-align:center;padding:3rem 1rem;">
    <div style="width:80px;height:80px;border-radius:50%;background:rgba(100,116,139,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
      <i class="bi bi-moon-stars" style="font-size:2rem;color:#64748b;"></i>
    </div>
    <h4 style="font-family:var(--tf-font-mono);color:#64748b;font-weight:700;margin-bottom:0.5rem;">WEEK OFF</h4>
    <p style="font-size:0.85rem;color:var(--tf-text-muted);margin:0;">
      <%= targetUser.name %>'s weekly off is on <strong><%= targetUser.weekly_off_day %></strong>
    </p>
  </div>
  <% } else { %>
  <div style="overflow-x:auto;">
    <table class="tf-table">
      <thead>
        <tr><th>Task</th><th>Type</th><th>Status</th><th>Created By</th><th>Time</th></tr>
      </thead>
      <tbody>
        <% if (dayTasks.length > 0) { %>
          <% dayTasks.forEach(t => { %>
          <tr>
            <td>
              <a href="/tasks/<%= t.id %>" style="color:var(--tf-text);text-decoration:none;font-weight:500;font-size:0.85rem;">
                <span style="color:var(--tf-text-muted);font-family:var(--tf-font-mono);font-size:0.75rem;">#<%= t.id %></span> <%= t.title %>
              </a>
            </td>
            <td><span class="badge badge-<%= t.type %>" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;"><%= t.type === 'once' ? 'one time' : t.type %></span></td>
            <td>
              <% if (t.is_recurring) { %>
                <% if (t.is_completed) { %>
                <span class="badge" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;background:rgba(16,185,129,0.15);color:#10b981;">
                  <i class="bi bi-check-circle-fill"></i> done
                </span>
                <% } else if (_isPast) { %>
                <span class="badge" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;background:rgba(239,68,68,0.15);color:#ef4444;">
                  <i class="bi bi-x-circle"></i> not done
                </span>
                <% } else { %>
                <span class="badge" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;background:rgba(245,158,11,0.15);color:#f59e0b;">
                  <i class="bi bi-circle"></i> pending
                </span>
                <% } %>
              <% } else if (_isPast && t.status !== 'completed') { %>
              <span class="badge" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;background:rgba(239,68,68,0.15);color:#ef4444;">
                <i class="bi bi-x-circle"></i> not done
              </span>
              <% } else { %>
              <span class="badge badge-<%= t.status %>" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;"><%= t.status.replace('_', ' ') %></span>
              <% } %>
            </td>
            <td style="font-size:0.8rem;color:var(--tf-text-muted);"><%= t.created_by_name || '—' %></td>
            <td style="font-size:0.75rem;color:var(--tf-text-muted);">
              <%
                var _tz = typeof orgTimezone !== 'undefined' ? orgTimezone : 'UTC';
                var _fmt = { hour:'2-digit', minute:'2-digit', hour12:true, timeZone: _tz };
                var _fmtSec = { hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:true, timeZone: _tz };
              %>
              <% if (t.started_at) { %>
                <div><i class="bi bi-play-fill" style="color:#10b981;"></i> Started: <%= new Date(t.started_at).toLocaleTimeString('en-IN', _fmtSec) %></div>
              <% } %>
              <% if ((t.is_recurring && t.is_completed) || (t.status === 'completed' && t.completed_at)) { %>
                <div><i class="bi bi-check-circle-fill" style="color:#10b981;"></i> Completed: <%= new Date(t.completed_at).toLocaleTimeString('en-IN', _fmtSec) %></div>
              <% } else if (!t.started_at && !t.is_recurring) { %>
                <div>Created: <%= new Date(t.created_at).toLocaleTimeString('en-IN', _fmt) %></div>
              <% } else if (!t.started_at && t.is_recurring) { %>
                <div style="color:var(--tf-text-muted);">—</div>
              <% } %>
              <% if (t.duration_minutes) { %>
                <div style="font-size:0.65rem;color:#3b82f6;"><i class="bi bi-clock"></i> Duration: <%= t.duration_minutes >= 60 ? Math.floor(t.duration_minutes / 60) + 'h ' + (t.duration_minutes % 60) + 'm' : t.duration_minutes + ' min' %></div>
              <% } else if (t.started_at && t.completed_at) { %>
                <% var _dur = Math.round((new Date(t.completed_at) - new Date(t.started_at)) / 60000); %>
                <div style="font-size:0.65rem;color:#3b82f6;"><i class="bi bi-clock"></i> Duration: <%= _dur >= 60 ? Math.floor(_dur / 60) + 'h ' + (_dur % 60) + 'm' : _dur + ' min' %></div>
              <% } %>
            </td>
          </tr>
          <% }) %>
        <% } else { %>
        <tr><td colspan="5" style="text-align:center;color:var(--tf-text-muted);padding:1.5rem;">No task activity on this day</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%
const total = parseInt(taskStats.total) || 0;
const completed = parseInt(taskStats.completed) || 0;
const progress = total > 0 ? Math.round((completed / total) * 100) : 0;

// Count day's pending/done
var pendingCount = 0;
var doneCount = 0;
dayTasks.forEach(function(t) {
  if (t.is_recurring) {
    if (t.is_completed) doneCount++;
    else pendingCount++;
  } else {
    if (t.status === 'completed') doneCount++;
    else pendingCount++;
  }
});
%>

<!-- Status Stats -->
<div class="row g-3 mb-3">
  <div class="col-6 col-md-3">
    <div class="stat-card" style="--stat-color: #00d4ff;">
      <div class="stat-value"><%= taskStats.total || 0 %></div>
      <div class="stat-label">Total Tasks</div>
      <i class="bi bi-list-task stat-icon"></i>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card" style="--stat-color: <%= _isPast ? '#ef4444' : '#f59e0b' %>;">
      <div class="stat-value"><%= pendingCount %></div>
      <div class="stat-label"><%= _isPast ? 'Not Done' : 'Pending' %> — <%= _dateLabel %></div>
      <i class="bi bi-<%= _isPast ? 'x-circle' : 'hourglass' %> stat-icon"></i>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card" style="--stat-color: #10b981;">
      <div class="stat-value"><%= doneCount %></div>
      <div class="stat-label">Done — <%= _dateLabel %></div>
      <i class="bi bi-check-circle stat-icon"></i>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card" style="--stat-color: #00d4ff;">
      <div class="stat-value"><%= taskStats.in_progress || 0 %></div>
      <div class="stat-label">In Progress</div>
      <i class="bi bi-play-circle stat-icon"></i>
    </div>
  </div>
</div>

<!-- Type Stats + Overall Progress -->
<div class="row g-3 mb-3">
  <div class="col-6 col-md-3">
    <div class="stat-card" style="--stat-color: #06b6d4;">
      <div class="stat-value"><%= (taskStats.type_daily || 0) + (taskStats.type_weekly || 0) + (taskStats.type_monthly || 0) %></div>
      <div class="stat-label">Recurring Tasks</div>
      <i class="bi bi-arrow-repeat stat-icon"></i>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card" style="--stat-color: #f97316;">
      <div class="stat-value"><%= taskStats.type_once || 0 %></div>
      <div class="stat-label">One Time Tasks</div>
      <i class="bi bi-lightning stat-icon"></i>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card" style="--stat-color: #8b5cf6;">
      <div class="stat-value"><%= (taskStats.type_daily || 0) %>/<%= (taskStats.type_weekly || 0) %>/<%= (taskStats.type_monthly || 0) %></div>
      <div class="stat-label">Daily / Weekly / Monthly</div>
      <i class="bi bi-calendar-week stat-icon"></i>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card" style="--stat-color: #10b981;">
      <div class="stat-value"><%= progress %>%</div>
      <div class="stat-label">Completion Rate</div>
      <div class="tf-progress mt-2" style="height:6px;">
        <div class="tf-progress-bar" style="width:<%= progress %>%"></div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-3">
  <!-- Currently Working On (only for today) -->
  <% if (_isViewingToday) { %>
  <div class="col-md-6">
    <div class="tf-card h-100">
      <div class="card-header">
        <i class="bi bi-play-circle me-2" style="color:#00d4ff;"></i>CURRENTLY WORKING ON (<%= activeTasks.length %>)
      </div>
      <div class="p-3">
        <% if (activeTasks.length > 0) { %>
          <% activeTasks.forEach(t => { %>
          <div class="d-flex align-items-center gap-2 mb-2 p-2" style="background:var(--tf-surface-2);border-radius:6px;border-left:3px solid #00d4ff;">
            <div class="flex-grow-1">
              <a href="/tasks/<%= t.id %>" style="color:var(--tf-text);text-decoration:none;font-weight:500;font-size:0.85rem;">
                <span style="color:var(--tf-text-muted);font-family:var(--tf-font-mono);font-size:0.75rem;">#<%= t.id %></span> <%= t.title %>
              </a>
              <div style="font-size:0.7rem;color:var(--tf-text-muted);margin-top:2px;">
                <span class="badge badge-<%= t.type %>" style="font-size:0.6rem;padding:1px 5px;border-radius:3px;"><%= t.type === 'once' ? 'one time' : t.type %></span>
                <% if (t.due_date) { %>
                <span style="margin-left:6px;color:<%= new Date(String(t.due_date).split('T')[0] + 'T12:00:00') < new Date() ? '#ef4444' : 'var(--tf-text-muted)' %>;">
                  Due: <%= new Date(String(t.due_date).split('T')[0] + 'T12:00:00').toLocaleDateString() %>
                </span>
                <% } %>
                <span style="margin-left:6px;"><i class="bi bi-person" style="font-size:0.6rem;"></i> <%= t.created_by_name || '—' %></span>
              </div>
            </div>
            <span class="badge badge-in_progress" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;">in progress</span>
          </div>
          <% }) %>
        <% } else { %>
        <p style="color:var(--tf-text-muted);font-size:0.85rem;text-align:center;padding:1rem;">No active tasks right now</p>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Pending / Not Done for selected date -->
  <div class="<%= _isViewingToday ? 'col-md-6' : 'col-md-12' %>">
    <div class="tf-card h-100">
      <div class="card-header">
        <% if (_isPast) { %>
        <i class="bi bi-x-circle me-2" style="color:#ef4444;"></i>NOT DONE — <%= _dateLabel %> (<%= pendingCount %>)
        <% } else { %>
        <i class="bi bi-hourglass me-2" style="color:#f59e0b;"></i>PENDING — <%= _dateLabel %> (<%= pendingCount %>)
        <% } %>
      </div>
      <div class="p-3">
        <% var pendingDayTasks = dayTasks.filter(function(t) { return t.is_recurring ? !t.is_completed : t.status !== 'completed'; }); %>
        <% if (pendingDayTasks.length > 0) { %>
          <% pendingDayTasks.forEach(function(t) { %>
          <div class="d-flex align-items-center gap-2 mb-2 p-2" style="background:var(--tf-surface-2);border-radius:6px;border-left:3px solid <%= _isPast ? '#ef4444' : '#f59e0b' %>;">
            <div class="flex-grow-1">
              <a href="/tasks/<%= t.id %>" style="color:var(--tf-text);text-decoration:none;font-weight:500;font-size:0.85rem;">
                <span style="color:var(--tf-text-muted);font-family:var(--tf-font-mono);font-size:0.75rem;">#<%= t.id %></span> <%= t.title %>
              </a>
              <div style="font-size:0.7rem;color:var(--tf-text-muted);margin-top:2px;">
                <span class="badge badge-<%= t.type %>" style="font-size:0.6rem;padding:1px 5px;border-radius:3px;"><%= t.type === 'once' ? 'one time' : t.type %></span>
                <span style="margin-left:6px;"><i class="bi bi-person" style="font-size:0.6rem;"></i> <%= t.created_by_name || '—' %></span>
              </div>
            </div>
            <% if (_isPast) { %>
            <span class="badge" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;background:rgba(239,68,68,0.15);color:#ef4444;">not done</span>
            <% } else { %>
            <span class="badge" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;background:rgba(245,158,11,0.15);color:#f59e0b;">pending</span>
            <% } %>
          </div>
          <% }) %>
        <% } else { %>
        <p style="color:var(--tf-text-muted);font-size:0.85rem;text-align:center;padding:1rem;"><%= _isPast ? 'All tasks were completed!' : 'All tasks done for today!' %></p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <!-- Recently Completed -->
  <div class="col-md-8">
    <div class="tf-card">
      <div class="card-header">
        <i class="bi bi-check-circle me-2" style="color:#10b981;"></i>RECENTLY COMPLETED
      </div>
      <div style="overflow-x:auto;">
        <table class="tf-table">
          <thead>
            <tr><th>Task</th><th>Type</th><th>Created By</th><th>Completed</th></tr>
          </thead>
          <tbody>
            <% if (recentCompleted.length > 0) { %>
              <% recentCompleted.forEach(t => { %>
              <tr>
                <td>
                  <a href="/tasks/<%= t.id %>" style="color:var(--tf-text);text-decoration:none;font-weight:500;font-size:0.85rem;">
                    <span style="color:var(--tf-text-muted);font-family:var(--tf-font-mono);font-size:0.75rem;">#<%= t.id %></span> <%= t.title %>
                  </a>
                </td>
                <td><span class="badge badge-<%= t.type %>" style="font-size:0.6rem;padding:2px 6px;border-radius:3px;"><%= t.type === 'once' ? 'one time' : t.type %></span></td>
                <td style="font-size:0.8rem;color:var(--tf-text-muted);"><%= t.created_by_name || '—' %></td>
                <td style="font-size:0.8rem;color:#10b981;"><%= t.completed_at ? new Date(t.completed_at).toLocaleString('en-IN', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit', hour12:true, timeZone: typeof orgTimezone !== 'undefined' ? orgTimezone : 'UTC' }) : '—' %></td>
              </tr>
              <% }) %>
            <% } else { %>
            <tr><td colspan="4" style="text-align:center;color:var(--tf-text-muted);padding:1.5rem;">No completed tasks yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Rewards Summary -->
  <div class="col-md-4">
    <div class="tf-card h-100">
      <div class="card-header">
        <i class="bi bi-coin me-2" style="color:#f59e0b;"></i>REWARDS
      </div>
      <div class="p-3">
        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Total Earned</span>
          <span style="font-family:var(--tf-font-mono);color:#00d4ff;"><%= parseFloat(rewardSummary?.total_earned || 0).toFixed(0) %> pts</span>
        </div>
        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Pending</span>
          <span style="font-family:var(--tf-font-mono);color:#f59e0b;"><%= parseFloat(rewardSummary?.pending_amount || 0).toFixed(0) %> pts</span>
        </div>
        <div class="d-flex justify-content-between align-items-center py-2">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Paid Out</span>
          <span style="font-family:var(--tf-font-mono);color:#10b981;"><%= parseFloat(rewardSummary?.paid_amount || 0).toFixed(0) %> pts</span>
        </div>
      </div>
    </div>

    <!-- Completion Timeline -->
    <div class="tf-card mt-3">
      <div class="card-header">
        <i class="bi bi-graph-up me-2" style="color:#7c3aed;"></i>COMPLETED
      </div>
      <div class="p-3">
        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">Today</span>
          <span style="font-family:var(--tf-font-mono);color:#7c3aed;"><%= taskStats.completed_today || 0 %></span>
        </div>
        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">This Week</span>
          <span style="font-family:var(--tf-font-mono);color:#7c3aed;"><%= taskStats.completed_this_week || 0 %></span>
        </div>
        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color:var(--tf-border)!important;">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">This Month</span>
          <span style="font-family:var(--tf-font-mono);color:#7c3aed;"><%= taskStats.completed_this_month || 0 %></span>
        </div>
        <div class="d-flex justify-content-between align-items-center py-2">
          <span style="font-size:0.8rem;color:var(--tf-text-muted);">This Year</span>
          <span style="font-family:var(--tf-font-mono);color:#7c3aed;"><%= taskStats.completed_this_year || 0 %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Monthly Report Modal -->
<div id="monthlyModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:200;align-items:center;justify-content:center;">
  <div style="background:var(--tf-surface);border:1px solid var(--tf-border);border-radius:12px;padding:1.5rem;width:100%;max-width:600px;margin:1rem;max-height:85vh;display:flex;flex-direction:column;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h6 style="font-family:var(--tf-font-mono);margin:0;">MONTHLY REPORT — <%= targetUser.name %></h6>
      <button class="btn-tf" style="background:transparent;border:none;color:var(--tf-text-muted);font-size:1.2rem;" onclick="closeMonthlyReport()">&times;</button>
    </div>
    <div class="d-flex gap-2 mb-3">
      <input type="month" id="monthSelect" class="tf-form-control" style="max-width:180px;font-size:0.85rem;">
      <button class="btn-tf btn-tf-primary" style="font-size:0.8rem;" onclick="loadMonthlyReport()">Load</button>
    </div>
    <div id="monthlyContent" style="flex:1;overflow-y:auto;">
      <div style="text-align:center;padding:2rem;color:var(--tf-text-muted);">Select a month and click Load</div>
    </div>
  </div>
</div>

<script>
function openMonthlyReport() {
  const now = new Date();
  document.getElementById('monthSelect').value = now.toISOString().slice(0, 7);
  document.getElementById('monthlyModal').style.display = 'flex';
  loadMonthlyReport();
}
function closeMonthlyReport() {
  document.getElementById('monthlyModal').style.display = 'none';
}
async function loadMonthlyReport() {
  const month = document.getElementById('monthSelect').value;
  if (!month) return;
  const container = document.getElementById('monthlyContent');
  container.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--tf-text-muted);">Loading...</div>';

  try {
    const res = await axios.get('<%= reportUrl %>?month=' + month);
    const { stats, dailyBreakdown } = res.data.data;
    const [year, mon] = month.split('-');
    const monthName = new Date(year, mon - 1).toLocaleString('default', { month: 'long', year: 'numeric' });

    const total = parseInt(stats.total) || 0;
    const completed = parseInt(stats.completed) || 0;
    const rate = total > 0 ? Math.round((completed / total) * 100) : 0;

    let html = `
      <div style="margin-bottom:1rem;">
        <h6 style="font-family:var(--tf-font-mono);font-size:0.8rem;color:var(--tf-text-muted);margin-bottom:0.75rem;">${monthName.toUpperCase()}</h6>
        <div class="row g-2 mb-3">
          <div class="col-4">
            <div style="text-align:center;padding:0.75rem;background:var(--tf-surface-2);border-radius:8px;">
              <div style="font-size:1.5rem;font-weight:700;font-family:var(--tf-font-mono);color:#00d4ff;">${stats.total || 0}</div>
              <div style="font-size:0.65rem;color:var(--tf-text-muted);">TOTAL</div>
            </div>
          </div>
          <div class="col-4">
            <div style="text-align:center;padding:0.75rem;background:var(--tf-surface-2);border-radius:8px;">
              <div style="font-size:1.5rem;font-weight:700;font-family:var(--tf-font-mono);color:#10b981;">${stats.completed || 0}</div>
              <div style="font-size:0.65rem;color:var(--tf-text-muted);">COMPLETED</div>
            </div>
          </div>
          <div class="col-4">
            <div style="text-align:center;padding:0.75rem;background:var(--tf-surface-2);border-radius:8px;">
              <div style="font-size:1.5rem;font-weight:700;font-family:var(--tf-font-mono);color:#10b981;">${rate}%</div>
              <div style="font-size:0.65rem;color:var(--tf-text-muted);">RATE</div>
            </div>
          </div>
        </div>

        <div style="font-size:0.75rem;margin-bottom:0.75rem;font-family:var(--tf-font-mono);color:var(--tf-text-muted);">BY TYPE</div>
        <div class="row g-2 mb-3">
          <div class="col-6">
            <div style="padding:0.5rem;background:var(--tf-surface-2);border-radius:6px;border-left:3px solid #06b6d4;">
              <div style="font-size:0.7rem;color:var(--tf-text-muted);">Recurring</div>
              <div style="font-family:var(--tf-font-mono);font-size:0.9rem;">${(stats.daily_completed || 0) + (stats.weekly_completed || 0)} / ${(stats.type_daily || 0) + (stats.type_weekly || 0) + (stats.type_monthly || 0)}</div>
            </div>
          </div>
          <div class="col-6">
            <div style="padding:0.5rem;background:var(--tf-surface-2);border-radius:6px;border-left:3px solid #f97316;">
              <div style="font-size:0.7rem;color:var(--tf-text-muted);">One Time</div>
              <div style="font-family:var(--tf-font-mono);font-size:0.9rem;">${stats.once_completed || stats.adhoc_completed || 0} / ${stats.type_once || stats.type_adhoc || 0}</div>
            </div>
          </div>
        </div>`;

    if (dailyBreakdown.length > 0) {
      html += '<div style="font-size:0.75rem;margin-bottom:0.5rem;font-family:var(--tf-font-mono);color:var(--tf-text-muted);">DAILY BREAKDOWN</div>';
      html += '<table class="tf-table" style="font-size:0.8rem;"><thead><tr><th>Date</th><th>Total</th><th>Completed</th><th>Rate</th></tr></thead><tbody>';
      dailyBreakdown.forEach(function(d) {
        const dayRate = d.total > 0 ? Math.round((d.completed / d.total) * 100) : 0;
        const dateObj = new Date(d.date);
        const dateStr = dateObj.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
        const dateVal = d.date.split('T')[0];
        html += '<tr>';
        html += '<td><a href="<%= progressUrl %>?date=' + dateVal + '" style="color:var(--tf-accent);text-decoration:none;" onclick="closeMonthlyReport()">' + dateStr + '</a></td>';
        html += '<td style="font-family:var(--tf-font-mono);">' + d.total + '</td>';
        html += '<td style="font-family:var(--tf-font-mono);color:#10b981;">' + d.completed + '</td>';
        html += '<td><div class="d-flex align-items-center gap-2"><div class="tf-progress" style="flex:1;height:4px;"><div class="tf-progress-bar" style="width:' + dayRate + '%"></div></div><span style="font-size:0.7rem;font-family:var(--tf-font-mono);color:var(--tf-text-muted);min-width:30px;">' + dayRate + '%</span></div></td>';
        html += '</tr>';
      });
      html += '</tbody></table>';
    } else {
      html += '<p style="color:var(--tf-text-muted);font-size:0.85rem;text-align:center;padding:1rem;">No tasks in this month</p>';
    }

    html += '</div>';
    container.innerHTML = html;
  } catch (e) {
    container.innerHTML = '<div style="text-align:center;padding:2rem;color:#ef4444;">Failed to load report</div>';
  }
}
</script>
